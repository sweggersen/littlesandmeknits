---
// Native-app-style bottom tab bar. Renders only when the site is
// running as an installed PWA (`display-mode: standalone`); on the web
// the existing top StudioNav stays in place.
//
// Four fixed primary tabs + "Mer" → opens a sheet with the rest. The
// content area gets bottom padding equal to the tab bar height plus the
// iOS safe area so nothing hides behind it.
---

<nav data-studio-tabbar class="hidden">
  <a href="/studio" data-tab="/studio" data-tab-match="^/studio/?$">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 11 12 4l9 7" />
      <path d="M5 10v10h14V10" />
    </svg>
    <span>Hjem</span>
  </a>
  <a href="/studio/prosjekter" data-tab="/studio/prosjekter" data-tab-match="^/studio/prosjekter">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="4" y="5" width="16" height="14" rx="2" />
      <path d="M8 9h8M8 13h8M8 17h5" />
    </svg>
    <span>Prosjekter</span>
  </a>
  <a href="/studio/garn" data-tab="/studio/garn" data-tab-match="^/studio/garn">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="8" />
      <path d="M5 9c4 4 10 4 14 0M5 15c4 4 10 4 14 0M9 5c4 4 4 10 0 14M15 5c4 4 4 10 0 14" />
    </svg>
    <span>Garn</span>
  </a>
  <a href="/studio/verktoy" data-tab="/studio/verktoy" data-tab-match="^/studio/verktoy">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 19 19 3l2 2L5 21z" />
      <path d="M6 8l2 2M9 5l2 2M12 14l2 2M15 11l2 2" />
    </svg>
    <span>Verktøy</span>
  </a>
  <button type="button" data-tab-more data-tab-match="^/studio/(pinner|mine-oppskrifter|kjop|profil)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="6" cy="12" r="1.4" fill="currentColor" />
      <circle cx="12" cy="12" r="1.4" fill="currentColor" />
      <circle cx="18" cy="12" r="1.4" fill="currentColor" />
    </svg>
    <span>Mer</span>
  </button>
</nav>

<!-- More-sheet, slides up over the tab bar. -->
<div data-tab-sheet class="hidden">
  <div data-tab-sheet-backdrop></div>
  <div data-tab-sheet-card>
    <div data-tab-sheet-handle></div>
    <ul>
      <li><a href="/studio/pinner" data-tab-match="^/studio/pinner">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <path d="M3 21 21 3" />
          <circle cx="20" cy="4" r="1.5" />
        </svg>
        Pinner
      </a></li>
      <li><a href="/studio/mine-oppskrifter" data-tab-match="^/studio/mine-oppskrifter">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
        </svg>
        Bibliotek
      </a></li>
      <li><a href="/studio/kjop" data-tab-match="^/studio/kjop">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
          <path d="M3 6h18M16 10a4 4 0 0 1-8 0" />
        </svg>
        Kjøp
      </a></li>
      <li><a href="/studio/profil" data-tab-match="^/studio/profil">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="8" r="4" />
          <path d="M4 21v-1a6 6 0 0 1 6-6h4a6 6 0 0 1 6 6v1" />
        </svg>
        Profil
      </a></li>
    </ul>
  </div>
</div>

<style>
  /* Bottom tab bar — only visible when running as installed PWA. */
  [data-studio-tabbar] {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 60;
    display: none;
    background: rgb(from var(--color-linen) r g b / 0.96);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-top: 1px solid rgb(from var(--color-charcoal) r g b / 0.08);
    padding-bottom: env(safe-area-inset-bottom);
  }
  [data-studio-tabbar] > * {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    padding: 8px 4px 6px;
    background: transparent;
    border: 0;
    color: rgb(from var(--color-charcoal) r g b / 0.55);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    cursor: pointer;
  }
  [data-studio-tabbar] > * svg {
    width: 24px;
    height: 24px;
  }
  [data-studio-tabbar] > *.is-active {
    color: var(--color-terracotta-500);
  }

  /* More sheet. */
  [data-tab-sheet] {
    position: fixed;
    inset: 0;
    z-index: 70;
    display: none;
  }
  [data-tab-sheet][data-open] {
    display: block;
  }
  [data-tab-sheet-backdrop] {
    position: absolute;
    inset: 0;
    background: rgb(from var(--color-charcoal) r g b / 0.35);
    opacity: 0;
    transition: opacity 200ms ease;
  }
  [data-tab-sheet][data-open] [data-tab-sheet-backdrop] {
    opacity: 1;
  }
  [data-tab-sheet-card] {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-linen);
    border-top-left-radius: 24px;
    border-top-right-radius: 24px;
    padding: 12px 16px calc(env(safe-area-inset-bottom) + 16px);
    transform: translateY(100%);
    transition: transform 220ms cubic-bezier(0.32, 0.72, 0, 1);
    box-shadow: 0 -10px 40px rgb(from var(--color-charcoal) r g b / 0.1);
  }
  [data-tab-sheet][data-open] [data-tab-sheet-card] {
    transform: translateY(0);
  }
  [data-tab-sheet-handle] {
    width: 36px;
    height: 4px;
    border-radius: 999px;
    background: rgb(from var(--color-charcoal) r g b / 0.2);
    margin: 0 auto 12px;
  }
  [data-tab-sheet-card] ul {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  [data-tab-sheet-card] a {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 12px;
    border-radius: 14px;
    color: var(--color-charcoal);
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
  }
  [data-tab-sheet-card] a.is-active {
    background: rgb(from var(--color-sage-100) r g b / 1);
    color: var(--color-sage-900);
  }
  [data-tab-sheet-card] a svg {
    width: 22px;
    height: 22px;
  }

  @media all and (display-mode: standalone) {
    [data-studio-tabbar] {
      display: flex;
    }
    /* Reserve space at the bottom of the studio scroll area for the tab bar
       + iOS home indicator so content doesn't slip behind. */
    body {
      padding-bottom: calc(64px + env(safe-area-inset-bottom));
    }
    /* Suppress the existing top studio nav in standalone — bottom tabs replace it. */
    [data-studio-topnav] {
      display: none;
    }
    /* And hide the marketing site nav at the very top — apps shouldn't show
       a brand bar pointing to /, /oppskrifter, etc. */
    body > nav:first-of-type {
      display: none;
    }
  }

  /* Preview mirror: `?pwa=1` (or sessionStorage flag) sets html.pwa-preview
     so the same chrome shows up in any browser without installing. */
  html.pwa-preview [data-studio-tabbar] {
    display: flex;
  }
  html.pwa-preview body {
    padding-bottom: calc(64px + env(safe-area-inset-bottom));
  }
  html.pwa-preview [data-studio-topnav] {
    display: none;
  }
  html.pwa-preview body > nav:first-of-type {
    display: none;
  }
</style>

<script>
  function syncActive() {
    const path = window.location.pathname.replace(/\/$/, '') || '/studio';
    document
      .querySelectorAll<HTMLElement>('[data-studio-tabbar] [data-tab-match], [data-tab-sheet-card] [data-tab-match]')
      .forEach((el) => {
        const re = el.getAttribute('data-tab-match');
        if (!re) return;
        const isActive = new RegExp(re).test(path);
        el.classList.toggle('is-active', isActive);
      });
  }

  const sheet = document.querySelector<HTMLElement>('[data-tab-sheet]');
  const moreBtn = document.querySelector<HTMLButtonElement>('[data-tab-more]');
  const backdrop = document.querySelector<HTMLElement>('[data-tab-sheet-backdrop]');

  function openSheet() {
    sheet?.setAttribute('data-open', '');
    document.documentElement.style.overflow = 'hidden';
  }
  function closeSheet() {
    sheet?.removeAttribute('data-open');
    document.documentElement.style.overflow = '';
  }

  moreBtn?.addEventListener('click', () => {
    if (sheet?.hasAttribute('data-open')) closeSheet();
    else openSheet();
  });
  backdrop?.addEventListener('click', closeSheet);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSheet();
  });
  // Sheet links should close it on click (the navigation will replace the page,
  // but in case the link is the same page we should still tidy up).
  document.querySelectorAll('[data-tab-sheet-card] a').forEach((a) => {
    a.addEventListener('click', closeSheet);
  });

  syncActive();
</script>
