---
import { Image } from 'astro:assets';
import { useTranslations, localizedPath, type Lang } from '../lib/i18n';
import { formatNok } from '../lib/format';
import type { CollectionEntry } from 'astro:content';

interface Props {
  pattern: CollectionEntry<'patterns'>;
  lang: Lang;
  stashMatch?: boolean;
}

const { pattern, lang, stashMatch = false } = Astro.props;
const t = useTranslations(lang);
const data = pattern.data;
const href = localizedPath(lang, `/oppskrifter/${pattern.id}`);
---

<a
  href={href}
  class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-300"
>
  <div class="relative aspect-[4/5] overflow-hidden bg-oatmeal">
    <Image
      src={data.cover}
      alt={data.title[lang]}
      widths={[400, 600, 800]}
      sizes="(min-width: 1280px) 25vw, (min-width: 640px) 50vw, 100vw"
      loading="lazy"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
    />
    <div class="absolute top-3 left-3 flex flex-col gap-2">
      <span class="bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider text-charcoal shadow-sm">
        {t(`difficulty.${data.difficulty}` as const)}
      </span>
      {stashMatch && (
        <span class="bg-sage-500/95 backdrop-blur-sm px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider text-white shadow-sm">
          ✓ Stash match
        </span>
      )}
    </div>
  </div>
  <div class="p-5">
    <h3 class="text-lg font-serif leading-tight mb-1 group-hover:text-terracotta-500 transition-colors">
      {data.title[lang]}
    </h3>
    <div class="flex justify-between items-end mt-2">
      <span class="text-xs text-charcoal/50 font-medium uppercase tracking-wide">
        {t(`weight.${data.yarnWeight}` as const)}
      </span>
      <span class="text-base font-semibold text-terracotta-500">
        {formatNok(data.price, lang)}
      </span>
    </div>
  </div>
</a>
