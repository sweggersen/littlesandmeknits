---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { useTranslations, localizedPath, type Lang } from '../lib/i18n';
import { formatNok } from '../lib/format';
import PatternCard from './PatternCard.astro';

interface Props {
  pattern: CollectionEntry<'patterns'>;
  lang: Lang;
}

const { pattern, lang } = Astro.props;
const t = useTranslations(lang);
const data = pattern.data;
const { Content } = await render(pattern);

const allPatterns = await getCollection('patterns', (p) => !p.data.draft);
const related = allPatterns
  .filter((p) => p.id !== pattern.id && p.data.category === data.category)
  .slice(0, 3);

const heroImage = data.gallery[0] ?? data.cover;
const otherImages = data.gallery.slice(1);
---

<article class="max-w-7xl mx-auto px-6 py-10">
  <nav class="text-xs text-charcoal/50 mb-6">
    <a href={localizedPath(lang, '/oppskrifter')} class="hover:text-charcoal transition-colors">
      {t('shop.title')}
    </a>
    <span class="mx-2">/</span>
    <span>{data.title[lang]}</span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
    <!-- Gallery -->
    <div class="lg:col-span-7">
      <div class="aspect-[4/5] rounded-3xl overflow-hidden bg-oatmeal mb-3">
        <Image
          src={heroImage}
          alt={data.title[lang]}
          widths={[800, 1200, 1600]}
          sizes="(min-width: 1024px) 56vw, 100vw"
          class="w-full h-full object-cover"
        />
      </div>
      {otherImages.length > 0 && (
        <div class="grid grid-cols-3 gap-3">
          {otherImages.map((img) => (
            <div class="aspect-square rounded-2xl overflow-hidden bg-oatmeal">
              <Image
                src={img}
                alt=""
                widths={[200, 400]}
                sizes="(min-width: 1024px) 18vw, 33vw"
                class="w-full h-full object-cover"
              />
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Info rail -->
    <aside class="lg:col-span-5 lg:sticky lg:top-24 self-start">
      <div class="flex items-center gap-2 mb-4">
        <span class="bg-sage-100 text-sage-900 text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full">
          {t(`difficulty.${data.difficulty}` as const)}
        </span>
        <span class="bg-oatmeal text-charcoal/70 text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full">
          {t(`weight.${data.yarnWeight}` as const)}
        </span>
      </div>

      <h1 class="font-serif text-4xl sm:text-5xl leading-tight mb-3">
        {data.title[lang]}
      </h1>
      <p class="text-charcoal/70 mb-7 leading-relaxed">{data.summary[lang]}</p>

      <div class="flex items-baseline gap-3 mb-7">
        <span class="text-3xl font-semibold text-terracotta-500">
          {formatNok(data.price, lang)}
        </span>
      </div>

      <form method="post" action="/api/checkout" class="mb-8">
        <input type="hidden" name="pattern" value={pattern.id} />
        <input type="hidden" name="lang" value={lang} />
        <button
          type="submit"
          class="w-full bg-charcoal text-linen py-4 rounded-full font-medium hover:bg-terracotta-500 transition-colors"
        >
          {t('pattern.buy')}
        </button>
        <p class="text-[11px] text-charcoal/40 text-center mt-3">
          {lang === 'nb'
            ? 'Sikker betaling via Stripe. Du får oppskriften med en gang.'
            : 'Secure checkout via Stripe. PDF delivered instantly.'}
        </p>
      </form>

      <dl class="grid grid-cols-2 gap-x-4 gap-y-3 text-sm border-t border-sage-500/15 pt-6">
        <dt class="text-charcoal/50">{t('pattern.sizes')}</dt>
        <dd>{data.sizes.join(', ')}</dd>

        <dt class="text-charcoal/50">{t('pattern.gauge')}</dt>
        <dd>{data.gauge}</dd>

        <dt class="text-charcoal/50">{t('pattern.needles')}</dt>
        <dd>{data.needles}</dd>

        <dt class="text-charcoal/50">Garn</dt>
        <dd>{data.yarn}</dd>

        {data.yardage && (
          <>
            <dt class="text-charcoal/50">Forbruk</dt>
            <dd>{data.yardage}</dd>
          </>
        )}
      </dl>
    </aside>
  </div>

  <!-- Description prose -->
  <section class="max-w-3xl mx-auto mt-20">
    <h2 class="font-serif text-2xl mb-6 sr-only">{t('pattern.description')}</h2>
    <div class="prose prose-charcoal max-w-none text-charcoal/80 leading-relaxed [&_h2]:font-serif [&_h2]:text-2xl [&_h2]:mt-10 [&_h2]:mb-4 [&_h3]:font-serif [&_h3]:text-lg [&_h3]:mt-6 [&_h3]:mb-3 [&_p]:mb-4 [&_ul]:my-4 [&_ul]:list-disc [&_ul]:pl-6 [&_li]:mb-1">
      <Content />
    </div>
  </section>

  <!-- Related -->
  {related.length > 0 && (
    <section class="mt-24">
      <h2 class="font-serif text-2xl mb-8">{t('pattern.related')}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {related.map((p) => <PatternCard pattern={p} lang={lang} />)}
      </div>
    </section>
  )}
</article>
