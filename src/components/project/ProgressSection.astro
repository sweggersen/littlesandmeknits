---
// "Fremdrift" (progress) collapsible section for a project page.
// Shows progress bar when both currentRows and targetRows are set,
// and lets the user edit either. Extracted from
// src/pages/studio/projects/[id].astro.

interface Props {
  projectId: string;
  currentRows: number | null;
  targetRows: number | null;
  progressPct: number | null;
}
const { projectId, currentRows, targetRows, progressPct } = Astro.props;
---

<section class="bg-white rounded-3xl p-6 border border-sage-500/10 mb-8">
  <details class="group">
    <summary class="flex items-baseline justify-between gap-3 cursor-pointer list-none">
      <h2 class="font-serif text-lg">Fremdrift</h2>
      {progressPct !== null ? (
        <span class="text-sm text-charcoal/65 font-medium">
          {currentRows} / {targetRows} rader · {progressPct}%
        </span>
      ) : currentRows !== null ? (
        <span class="text-sm text-charcoal/65 font-medium">{currentRows} rader</span>
      ) : (
        <span class="text-xs text-charcoal/45">Sett mål for å vise fremdrift</span>
      )}
    </summary>

    {progressPct !== null && (
      <div class="mt-4 h-2 bg-sage-500/10 rounded-full overflow-hidden">
        <div
          class="h-full bg-sage-500 transition-all"
          style={`width: ${progressPct}%`}
        ></div>
      </div>
    )}

    <form method="post" action={`/api/projects/${projectId}/progress`} class="mt-5 grid grid-cols-1 sm:grid-cols-3 gap-3 items-end">
      <div>
        <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">Rader strikket</label>
        <input
          type="number"
          name="current_rows"
          min="0"
          step="1"
          value={currentRows ?? ''}
          placeholder="0"
          class="w-full bg-linen rounded-xl px-3 py-2 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500"
        />
      </div>
      <div>
        <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">Mål (totalt)</label>
        <input
          type="number"
          name="target_rows"
          min="0"
          step="1"
          value={targetRows ?? ''}
          placeholder="—"
          class="w-full bg-linen rounded-xl px-3 py-2 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500"
        />
      </div>
      <button
        type="submit"
        class="bg-primary text-primary-fg px-4 py-2 rounded-full text-xs font-medium hover:bg-primary-hover transition-colors"
      >
        Lagre
      </button>
    </form>
  </details>
</section>
