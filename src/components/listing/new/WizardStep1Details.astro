---
// Step 1 of the new-listing wizard: type, title, category, size,
// condition, plus an optional "more details" disclosure (age range,
// colorway, pattern title, knitted-by, location, description).
// Includes the example-fill helper row at the top.
//
// Extracted from src/pages/market/listing/new.astro.

interface Store {
  id: string;
  name: string;
}

interface Props {
  userEmail: string | null | undefined;
  myStores: Store[];
  preselectedStoreId: string | null;
  preselectedKind?: 'pre_loved' | 'ready_made';
}
const { userEmail, myStores, preselectedStoreId, preselectedKind = 'pre_loved' } = Astro.props;
---

<section data-step="1" class="space-y-6">
  <div class="bg-sage-100/40 rounded-2xl px-4 py-3 text-sm" data-example-row>
    <p class="text-charcoal/70 mb-2">Førstegang? Velg en snarvei, så fyller vi inn type og kategori. Resten skriver du selv.</p>
    <div class="flex flex-wrap gap-2">
      <button type="button" data-fill-template="preloved" class="rounded-full border border-sage-500/30 bg-white px-3 py-1.5 text-xs font-medium hover:border-terracotta-500 hover:text-terracotta-500 transition-colors">Brukt barneplagg</button>
      <button type="button" data-fill-template="cardigan" class="rounded-full border border-sage-500/30 bg-white px-3 py-1.5 text-xs font-medium hover:border-terracotta-500 hover:text-terracotta-500 transition-colors">Strikkejakke</button>
      <button type="button" data-fill-template="new" class="rounded-full border border-sage-500/30 bg-white px-3 py-1.5 text-xs font-medium hover:border-terracotta-500 hover:text-terracotta-500 transition-colors">Nystrikket plagg</button>
      <button type="button" data-fill-template="blanket" class="rounded-full border border-sage-500/30 bg-white px-3 py-1.5 text-xs font-medium hover:border-terracotta-500 hover:text-terracotta-500 transition-colors">Babyteppe</button>
      <button type="button" data-fill-template="accessories" class="rounded-full border border-sage-500/30 bg-white px-3 py-1.5 text-xs font-medium hover:border-terracotta-500 hover:text-terracotta-500 transition-colors">Votter</button>
      <button type="button" data-fill-template="blank" class="rounded-full px-3 py-1.5 text-xs font-medium text-charcoal/50 hover:text-charcoal transition-colors">Tomt ark</button>
    </div>
  </div>

  {myStores.length > 0 && (
    <div>
      <label for="store_id" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Selg som</label>
      <select id="store_id" name="store_id" class="w-full bg-linen rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors">
        <option value="">{userEmail} (privat)</option>
        {myStores.map((s) => (
          <option value={s.id} selected={s.id === preselectedStoreId}>{s.name}</option>
        ))}
      </select>
    </div>
  )}

  <div>
    <label for="kind" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Type *</label>
    <select id="kind" name="kind" required class="w-full bg-linen rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors">
      <option value="pre_loved" selected={preselectedKind === 'pre_loved'}>Brukt</option>
      <option value="ready_made" selected={preselectedKind === 'ready_made'}>Nytt, aldri brukt</option>
    </select>
  </div>

  <div>
    <label for="title" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Tittel *</label>
    <input id="title" name="title" type="text" required maxlength="80" placeholder="Sondre cardigan str. 92, dustyrosa"
      class="w-full bg-linen rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors" />
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="category" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Kategori *</label>
      <select id="category" name="category" required class="w-full bg-linen rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors">
        <option value="genser">Genser</option>
        <option value="cardigan">Cardigan</option>
        <option value="lue">Lue</option>
        <option value="votter">Votter</option>
        <option value="sokker">Sokker</option>
        <option value="teppe">Teppe</option>
        <option value="kjole">Kjole</option>
        <option value="bukser">Bukser</option>
        <option value="annet">Annet</option>
      </select>
    </div>
    <div>
      <label for="size_label" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Størrelse *</label>
      <input id="size_label" name="size_label" type="text" required maxlength="20" placeholder="92, 2 år, S…"
        class="w-full bg-linen rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors" />
    </div>
  </div>

  <div data-condition-wrapper>
    <label for="condition" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Tilstand * (kun for brukt)</label>
    <select id="condition" name="condition" class="w-full bg-linen rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors">
      <option value="som_ny">Som ny</option>
      <option value="lite_brukt">Lite brukt</option>
      <option value="brukt">Brukt</option>
      <option value="slitt">Slitt</option>
    </select>
  </div>

  <details class="text-sm">
    <summary class="cursor-pointer text-xs font-bold uppercase tracking-widest text-charcoal/45">Flere detaljer (valgfritt)</summary>
    <div class="space-y-4 mt-4">
      <details class="bg-linen/40 rounded-xl p-3">
        <summary class="cursor-pointer text-xs text-charcoal/55">Alder (kun for barneklær)</summary>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-3">
          <div>
            <label for="size_age_months_min" class="block text-xs text-charcoal/55 mb-1">Fra (mnd)</label>
            <input id="size_age_months_min" name="size_age_months_min" type="number" min="0" max="240" placeholder="18" class="w-full bg-white rounded-xl px-4 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500" />
          </div>
          <div>
            <label for="size_age_months_max" class="block text-xs text-charcoal/55 mb-1">Til (mnd)</label>
            <input id="size_age_months_max" name="size_age_months_max" type="number" min="0" max="240" placeholder="24" class="w-full bg-white rounded-xl px-4 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500" />
          </div>
        </div>
        <p class="text-[11px] text-charcoal/45 mt-2">La feltene stå tomme for voksenplagg.</p>
      </details>

      <div>
        <label for="colorway" class="block text-xs text-charcoal/55 mb-1">Farge</label>
        <input id="colorway" name="colorway" type="text" maxlength="60" placeholder="Dustyrosa, naturhvit…" class="w-full bg-linen rounded-xl px-4 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500" />
      </div>
      <div>
        <label for="pattern_external_title" class="block text-xs text-charcoal/55 mb-1">Oppskrift</label>
        <input id="pattern_external_title" name="pattern_external_title" type="text" maxlength="120" placeholder="Sondre cardigan, av Weggersen Design" class="w-full bg-linen rounded-xl px-4 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500" />
      </div>
      <div>
        <label for="knitted_by" class="block text-xs text-charcoal/55 mb-1">Strikket av</label>
        <input id="knitted_by" name="knitted_by" type="text" maxlength="80" placeholder="Meg, mormor, en strikker hos oss…" class="w-full bg-linen rounded-xl px-4 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500" />
      </div>
      <div>
        <label for="location" class="block text-xs text-charcoal/55 mb-1">Sted</label>
        <input id="location" name="location" type="text" maxlength="80" placeholder="Oslo, Bergen, Tromsø…" class="w-full bg-linen rounded-xl px-4 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500" />
      </div>
      <div>
        <label for="description" class="block text-xs text-charcoal/55 mb-1">Beskrivelse</label>
        <textarea id="description" name="description" rows="4" maxlength="2000" placeholder="Garn, vask, små feil, hvor lenge brukt…" class="w-full bg-linen rounded-xl px-4 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 resize-none"></textarea>
      </div>
    </div>
  </details>
</section>
