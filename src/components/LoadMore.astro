---
interface Props {
  params: string | null;
  label?: string;
}
const { params, label = 'Last flere' } = Astro.props;
---

{params && (
  <div class="text-center mt-8">
    <a href={`?${params}`}
      class="inline-block bg-charcoal text-linen px-6 py-3 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors">
      {label}
    </a>
  </div>
)}
