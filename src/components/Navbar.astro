---
import { useTranslations, localizedPath, type Lang } from '../lib/i18n';
import LangSwitcher from './LangSwitcher.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const section = currentPath.startsWith('/marked')
  ? 'strikketorget'
  : currentPath.startsWith('/studio')
    ? 'strikkestua'
    : 'home';

const regularItems = [
  { href: localizedPath(lang, '/oppskrifter'), label: t('nav.shop') },
  { href: localizedPath(lang, '/prosjekter'), label: t('nav.projects') },
  { href: localizedPath(lang, '/om'), label: t('nav.about') },
];

const sectionItems = [
  { href: localizedPath(lang, '/marked'), label: t('nav.marketplace'), authOnly: false },
  { href: '/studio', label: t('nav.studio'), authOnly: true },
];

const brandName = section === 'strikketorget'
  ? 'Strikketorget'
  : section === 'strikkestua'
    ? 'Strikkestua'
    : 'Littles and Me Knits';

const brandHref = section === 'strikketorget'
  ? '/marked'
  : section === 'strikkestua'
    ? '/studio'
    : localizedPath(lang, '/');
---

<nav class="sticky top-0 z-50 bg-linen/80 backdrop-blur-md border-b border-sage-500/10" transition:animate="none">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-8">
      <a href={brandHref} class="group min-w-[180px]" transition:name="brand-logo">
        <span class="font-serif text-xl font-medium tracking-tight text-charcoal group-hover:text-terracotta-500 transition-colors">
          {brandName}
        </span>
        {section !== 'home' && (
          <span class="block font-serif text-[11px] text-charcoal/35 group-hover:text-terracotta-500/50 transition-colors">
            by Littles and Me Knits
          </span>
        )}
      </a>
      <div class="hidden md:flex items-center gap-6">
        <ul class="flex items-center gap-1">
          {regularItems.map((item) => {
            const isActive = currentPath.startsWith(item.href) && item.href !== localizedPath(lang, '/');
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'text-sm font-medium px-3 py-1.5 transition-colors',
                    isActive ? 'text-terracotta-500' : 'text-charcoal/70 hover:text-charcoal',
                  ]}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
        <span class="w-px h-4 bg-sage-500/20" />
        <ul class="flex items-center gap-1.5">
          {sectionItems.map((item) => {
            const isActive = currentPath.startsWith(item.href);
            return (
              <li class:list={[item.authOnly && 'hidden']} data-auth-link={item.authOnly ? 'studio' : undefined}>
                <a
                  href={item.href}
                  class:list={[
                    'text-sm font-medium px-3 py-1.5 rounded-full border transition-colors',
                    isActive
                      ? 'bg-terracotta-500/10 border-terracotta-500/30 text-terracotta-500'
                      : 'border-sage-500/20 text-charcoal/70 hover:border-terracotta-500/30 hover:text-terracotta-500',
                  ]}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </div>

    <div class="flex items-center gap-4">
      <span data-public-only>
        <LangSwitcher lang={lang} />
      </span>
      <a
        href="/varsler"
        class="hidden sm:inline-flex relative p-1.5 text-charcoal/50 hover:text-charcoal transition-colors"
        data-auth-link="notifications"
        data-bell
        style="display:none;"
        aria-label="Varsler"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        <span data-notif-badge class="hidden absolute -top-0.5 -right-0.5 min-w-[16px] h-4 px-1 rounded-full bg-terracotta-500 text-white text-[10px] font-bold flex items-center justify-center">0</span>
        <span data-mod-dot class="hidden absolute -bottom-0.5 -left-0.5 h-2.5 w-2.5">
          <span class="animate-ping absolute inset-0 rounded-full bg-amber-400 opacity-75"></span>
          <span class="relative block h-2.5 w-2.5 rounded-full bg-amber-500"></span>
        </span>
      </a>
      <a
        href="/profil"
        class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-charcoal/70 hover:text-charcoal transition-colors"
        data-auth-link="profile"
        style="display:none;"
      >
        <span data-profile-avatar class="w-6 h-6 rounded-full bg-sage-100 flex items-center justify-center shrink-0 text-[10px] font-serif text-sage-700">?</span>
        <span data-profile-name>Min profil</span>
        <span data-profile-badge class="hidden w-2 h-2 rounded-full bg-terracotta-500 shrink-0"></span>
      </a>
      <a
        href={localizedPath(lang, '/logg-inn')}
        class="hidden sm:inline-flex text-sm font-medium text-charcoal/70 hover:text-charcoal transition-colors"
        data-auth-link="login"
      >
        {t('nav.login')}
      </a>
      <button
        type="button"
        class="md:hidden p-2 -mr-2 text-charcoal/70 hover:text-charcoal"
        aria-label="Menu"
        data-mobile-menu-trigger
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M3 6h18M3 12h18M3 18h18" />
        </svg>
      </button>
    </div>
  </div>

  <div class="hidden md:hidden border-t border-sage-500/10 px-6 py-4" data-mobile-menu>
    <ul class="flex flex-col gap-3">
      {regularItems.map((item) => (
        <li>
          <a href={item.href} class="block py-2 text-base font-medium text-charcoal/80">
            {item.label}
          </a>
        </li>
      ))}
      <li class="pt-2 border-t border-sage-500/10">
        <a href={localizedPath(lang, '/marked')} class="block py-2 text-base font-medium text-charcoal/80">
          {t('nav.marketplace')}
        </a>
      </li>
      {sectionItems.filter(i => i.authOnly).map((item) => (
        <li class="hidden" data-auth-link="studio">
          <a href={item.href} class="block py-2 text-base font-medium text-charcoal/80">
            {item.label}
          </a>
        </li>
      ))}
      <li class="hidden" data-auth-link="notifications">
        <a href="/varsler" class="flex items-center gap-2 py-2 text-base font-medium text-charcoal/80">
          Varsler
          <span data-notif-badge-mobile class="hidden min-w-[16px] h-4 px-1 rounded-full bg-terracotta-500 text-white text-[10px] font-bold inline-flex items-center justify-center">0</span>
          <span data-mod-badge-mobile class="hidden min-w-[16px] h-4 px-1 rounded-full bg-amber-500 text-white text-[10px] font-bold inline-flex items-center justify-center">0</span>
        </a>
      </li>
      <li class="hidden" data-auth-link="profile">
        <a href="/profil" class="block py-2 text-base font-medium text-charcoal/80">
          Min profil
        </a>
      </li>
      <li class="hidden" data-auth-link="settings">
        <a href="/innstillinger" class="block py-2 text-base font-medium text-charcoal/80">
          Innstillinger
        </a>
      </li>
      <li data-auth-link="login">
        <a href={localizedPath(lang, '/logg-inn')} class="block py-2 text-base font-medium text-charcoal/80">
          {t('nav.login')}
        </a>
      </li>
    </ul>
  </div>
</nav>

<style is:inline>
[data-bell][data-mod-active] { color: #d97706; }
[data-bell][data-mod-active]:hover { color: #92400e; }
</style>

<script is:inline>
  function applyAuthUI(loggedIn) {
    if (!loggedIn) return;
    document.querySelectorAll('[data-auth-link="login"]').forEach(function(el) {
      el.style.display = 'none';
    });
    document.querySelectorAll('[data-auth-link="studio"]').forEach(function(el) {
      el.classList.remove('hidden');
    });
    document.querySelectorAll('[data-auth-link="profile"]').forEach(function(el) {
      el.style.display = '';
      el.classList.remove('hidden');
    });
    document.querySelectorAll('[data-auth-link="notifications"]').forEach(function(el) {
      el.style.display = '';
      el.classList.remove('hidden');
    });
    document.querySelectorAll('[data-auth-link="settings"]').forEach(function(el) {
      el.style.display = '';
      el.classList.remove('hidden');
    });
    document.querySelectorAll('[data-public-only]').forEach(function(el) {
      el.style.display = 'none';
    });
    // Restore cached profile info
    var cached = sessionStorage.getItem('lm-profile');
    if (cached) applyProfileInfo(JSON.parse(cached));
  }

  function applyProfileInfo(u) {
    var nameEl = document.querySelector('[data-profile-name]');
    var avatarEl = document.querySelector('[data-profile-avatar]');
    var badgeEl = document.querySelector('[data-profile-badge]');
    var notifBadge = document.querySelector('[data-notif-badge]');
    if (nameEl && u.display_name) nameEl.textContent = u.display_name;
    if (avatarEl && u.display_name) avatarEl.textContent = u.display_name[0].toUpperCase();
    if (badgeEl) {
      if (u.unread > 0) badgeEl.classList.remove('hidden');
      else badgeEl.classList.add('hidden');
    }
    var n = u.notifications || 0;
    [notifBadge, document.querySelector('[data-notif-badge-mobile]')].forEach(function(el) {
      if (!el) return;
      if (n > 0) {
        el.textContent = n > 99 ? '99+' : String(n);
        el.classList.remove('hidden');
      } else {
        el.classList.add('hidden');
      }
    });
    // Admin/moderator: pending moderation indicator
    var pm = u.pending_moderation || 0;
    var modDot = document.querySelector('[data-mod-dot]');
    var modBadgeMobile = document.querySelector('[data-mod-badge-mobile]');
    var bell = document.querySelector('[data-bell]');
    if (modDot) {
      if (pm > 0) modDot.classList.remove('hidden');
      else modDot.classList.add('hidden');
    }
    if (modBadgeMobile) {
      if (pm > 0) {
        modBadgeMobile.textContent = pm > 99 ? '99+' : String(pm);
        modBadgeMobile.classList.remove('hidden');
      } else {
        modBadgeMobile.classList.add('hidden');
      }
    }
    if (bell) {
      if (pm > 0) bell.setAttribute('data-mod-active', '');
      else bell.removeAttribute('data-mod-active');
    }
  }

  // Apply cached state synchronously — no flash
  if (sessionStorage.getItem('lm-auth') === '1') {
    applyAuthUI(true);
  }
</script>

<script>
  function initNavbar() {
    const trigger = document.querySelector<HTMLButtonElement>('[data-mobile-menu-trigger]');
    const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
    trigger?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });

    // Apply cached state immediately after DOM swap
    const cached = sessionStorage.getItem('lm-auth') === '1';
    if (cached) (window as any).applyAuthUI(true);

    // Refresh in background
    fetch('/api/me', { credentials: 'same-origin' })
      .then((r) => (r.ok ? r.json() : null))
      .then((data) => {
        if (data?.user) {
          sessionStorage.setItem('lm-auth', '1');
          sessionStorage.setItem('lm-profile', JSON.stringify(data.user));
          (window as any).applyAuthUI(true);
          (window as any).applyProfileInfo(data.user);
        } else {
          sessionStorage.removeItem('lm-auth');
          sessionStorage.removeItem('lm-profile');
        }
      })
      .catch(() => {});
  }

  initNavbar();
  document.addEventListener('astro:page-load', initNavbar);
</script>
