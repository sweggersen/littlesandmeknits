---
interface Props {
  rating: number;
  size?: number;
}
const { rating, size = 14 } = Astro.props;
---

<div class="flex gap-0.5">
  {[1,2,3,4,5].map((star) => (
    <svg width={size} height={size} viewBox="0 0 24 24" fill={star <= rating ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="1.5" class={star <= rating ? 'text-terracotta-500' : 'text-charcoal/20'}>
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
  ))}
</div>
