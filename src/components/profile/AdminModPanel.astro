---
// Admin / moderator quick-links, rendered inside a dashboard widget. Tiles are
// individual white cards on the linen page (matching the stat row) and auto-fit
// so they reflow when the widget is resized S/M/L. Shows the pending moderation
// count with a soft amber highlight + pulse when > 0.

interface Props {
  isAdmin: boolean;
  pendingQueueCount: number;
}
const { isAdmin, pendingQueueCount } = Astro.props;

const tileBase = 'bg-white rounded-2xl border border-sage-500/20 p-4 text-center hover:border-sage-500/30 transition-colors';
---

<section class="dash-group rounded-2xl border border-sage-500/20 overflow-hidden">
  <div class="dash-group-head flex items-center gap-2 px-5 py-3.5 border-b border-sage-500/15">
    <h2 class="font-serif text-lg">{isAdmin ? 'Admin' : 'Moderator'}</h2>
    {pendingQueueCount > 0 && (
      <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-terracotta-500 text-white text-[10px] font-bold">{pendingQueueCount}</span>
    )}
  </div>
  <div class="p-4 dash-tiles">
    <a href="/admin" data-tile class={tileBase}>
      <p class="text-sm font-medium">Dashboard</p>
      <p class="text-[11px] text-charcoal/45 mt-0.5 dash-sub">Oversikt</p>
    </a>
    <a href="/admin/moderation" data-tile class:list={[
      'rounded-2xl border p-4 text-center transition-colors relative',
      pendingQueueCount > 0 ? 'bg-amber-500/5 border-amber-500/50 ring-1 ring-amber-500/30' : 'bg-white border-sage-500/20 hover:border-sage-500/30',
    ]}>
      <p class="text-sm font-medium">Modereringskø</p>
      {pendingQueueCount > 0 ? (
        <div class="flex items-center justify-center gap-1.5 mt-0.5">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
          </span>
          <p class="text-[11px] text-amber-600 font-bold">{pendingQueueCount} venter</p>
        </div>
      ) : (
        <p class="text-[11px] text-charcoal/45 mt-0.5 dash-sub">Ingen ventende</p>
      )}
    </a>
    <a href="/admin/reports" data-tile class={tileBase}>
      <p class="text-sm font-medium">Rapporter</p>
      <p class="text-[11px] text-charcoal/45 mt-0.5 dash-sub">Flagget innhold</p>
    </a>
    {isAdmin && (
      <>
        <a href="/admin/users" data-tile class={tileBase}>
          <p class="text-sm font-medium">Brukere</p>
          <p class="text-[11px] text-charcoal/45 mt-0.5 dash-sub">Roller og tillit</p>
        </a>
        <a href="/admin/moderators" data-tile class={tileBase}>
          <p class="text-sm font-medium">Moderatorer</p>
          <p class="text-[11px] text-charcoal/45 mt-0.5 dash-sub">Ytelse og stats</p>
        </a>
        <a href="/admin/log" data-tile class={tileBase}>
          <p class="text-sm font-medium">Aktivitetslogg</p>
          <p class="text-[11px] text-charcoal/45 mt-0.5 dash-sub">Revisjon</p>
        </a>
      </>
    )}
  </div>
</section>
