---
// Small circular medal icon for an achievement, keyed by category (replaces the
// emoji). Stroke SVGs in a sage-tinted circle, matching the profile stat icons.
import type { AchievementDef } from '../../lib/achievements';
interface Props {
  category: AchievementDef['category'];
  class?: string;
}
const { category, class: cls } = Astro.props;
const paths: Record<AchievementDef['category'], string> = {
  profil: '<circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/>',
  strikking: '<circle cx="12" cy="12" r="8.5"/><path d="M4 10c5 3 11 3 16 0M5 15c4 2 10 2 14 0M12 3.5v17"/>',
  marked: '<path d="M20 13 13 20a2 2 0 0 1-3 0L3 13V4h9l8 8a2 2 0 0 1 0 1Z"/><circle cx="7.5" cy="7.5" r="1.2"/>',
  fellesskap: '<circle cx="9" cy="8" r="3"/><path d="M3 20a6 6 0 0 1 12 0"/><path d="M16 11a3 3 0 0 0 0-6M21 20a6 6 0 0 0-5-5.9"/>',
  moderering: '<path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6Z"/>',
};
---
<span class:list={['w-5 h-5 rounded-full bg-sage-100 text-sage-700 grid place-items-center shrink-0', cls]}>
  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={paths[category] ?? paths.profil} />
</span>
