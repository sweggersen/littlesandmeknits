---
import ProjectCard from '../ProjectCard.astro';
import ListingCard from '../ListingCard.astro';
import EmptyState from '../EmptyState.astro';
import { projectPhotoUrl } from '../../lib/storage';
import { CATEGORY_LABEL, COMMISSION_STATUS, OFFER_STATUS, KIND_LABEL } from '../../lib/labels';
import { formatNok } from '../../lib/format';

function isPdf(path: string | null): boolean {
  return !!path && path.toLowerCase().endsWith('.pdf');
}

// The two-column staggered card grid on the profile dashboard:
// Messages / Oppdrag / Kjøpte oppskrifter / Mine butikker / Bibliotek
// (all half-width) + Prosjekter / Annonser (full-width).
//
// Extracted from src/pages/profile/index.astro. Each section is small
// enough that splitting per-card would be over-fragmentation; bundled
// into one component that's the entire "dashboard content" surface.

interface Props {
  unreadCount: number;
  allRequests: any[];
  allOffers: any[];
  allPurchases: any[];
  myStores: any[];
  allBibliotek: any[];
  allProjects: any[];
  allListings: any[];
}
const {
  unreadCount, allRequests, allOffers, allPurchases,
  myStores, allBibliotek, allProjects, allListings,
} = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-10">

  <section>
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-serif text-lg">
        Meldinger
        {unreadCount > 0 && (
          <span class="inline-flex items-center justify-center ml-1.5 w-5 h-5 rounded-full bg-terracotta-500 text-white text-[10px] font-bold">{unreadCount}</span>
        )}
      </h2>
      <a href="/market/messages" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Se alle →</a>
    </div>
    {unreadCount === 0 ? (
      <p class="text-sm text-charcoal/45">Ingen uleste meldinger.</p>
    ) : (
      <a href="/market/messages" class="block bg-white rounded-xl p-4 border border-sage-500/10 hover:border-sage-500/30 transition-colors">
        <p class="text-sm font-medium">{unreadCount} ulest{unreadCount === 1 ? '' : 'e'} melding{unreadCount === 1 ? '' : 'er'}</p>
        <p class="text-xs text-charcoal/45 mt-1">Åpne innboksen for å svare.</p>
      </a>
    )}
  </section>

  <section>
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-serif text-lg">Oppdrag</h2>
      <a href="/market/commissions/my-listings" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Se alle →</a>
    </div>
    {allRequests.length === 0 && allOffers.length === 0 ? (
      <div class="text-center py-2">
        <p class="text-sm text-charcoal/45 mb-3">Ingen aktive oppdrag.</p>
        <a href="/market/commissions" class="inline-block bg-primary text-primary-fg px-4 py-2 rounded-full text-xs font-medium hover:bg-primary-hover transition-colors">
          Se forespørsler →
        </a>
      </div>
    ) : (
      <div class="space-y-2">
        {allRequests.slice(0, 3).map((r) => {
          const hasReceipt = ['awarded', 'completed', 'delivered'].includes(r.status);
          return (
            <div class="bg-white rounded-xl border border-sage-500/10 hover:border-sage-500/30 transition-colors">
              <a href={`/market/commissions/${r.id}`} class="flex items-center justify-between gap-3 p-3">
                <div class="min-w-0">
                  <div class="flex items-center gap-1.5 mb-0.5">
                    <span class="text-[9px] font-bold uppercase tracking-widest text-terracotta-500/70">Bestiller</span>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-charcoal/45">{CATEGORY_LABEL[r.category]}</span>
                    <span class:list={[
                      'text-[9px] font-bold uppercase tracking-widest',
                      r.status === 'open' ? 'text-sage-700' : r.status === 'awarded' ? 'text-terracotta-500' : 'text-charcoal/35',
                    ]}>{COMMISSION_STATUS[r.status]}</span>
                  </div>
                  <p class="text-sm font-medium line-clamp-1">{r.title}</p>
                </div>
                <p class="font-mono tabular-nums text-xs shrink-0">{r.budget_nok_min}–{r.budget_nok_max}</p>
              </a>
              {hasReceipt && (
                <a href={`/market/commissions/${r.id}/kvittering`} class="block px-3 py-1.5 text-[11px] text-charcoal/55 hover:text-terracotta-500 border-t border-sage-500/10">📄 Se kvittering</a>
              )}
            </div>
          );
        })}
        {allOffers.slice(0, 3).map((o) => {
          const reqData = o.commission_requests;
          if (!reqData) return null;
          return (
            <a href={`/market/commissions/${reqData.id}`} class="flex items-center justify-between gap-3 bg-white rounded-xl p-3 border border-sage-500/10 hover:border-sage-500/30 transition-colors">
              <div class="min-w-0">
                <div class="flex items-center gap-1.5 mb-0.5">
                  <span class="text-[9px] font-bold uppercase tracking-widest text-charcoal/45">Strikker</span>
                  <span class:list={[
                    'text-[9px] font-bold uppercase tracking-widest',
                    o.status === 'accepted' ? 'text-terracotta-500' : 'text-charcoal/35',
                  ]}>{OFFER_STATUS[o.status]}</span>
                </div>
                <p class="text-sm font-medium line-clamp-1">{reqData.title}</p>
              </div>
              <p class="font-mono tabular-nums text-xs shrink-0">{o.price_nok} NOK</p>
            </a>
          );
        })}
      </div>
    )}
  </section>

  <section>
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-serif text-lg">Kjøpte oppskrifter</h2>
      <div class="flex items-center gap-3">
        <a href="/patterns" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Kjøp →</a>
        {allPurchases.length > 0 && (
          <a href="/profile/purchases" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Se alle →</a>
        )}
      </div>
    </div>
    {allPurchases.length === 0 ? (
      <div class="text-center py-2">
        <p class="text-sm text-charcoal/45 mb-3">Ingen kjøpte oppskrifter.</p>
        <a href="/patterns" class="inline-block bg-primary text-primary-fg px-4 py-2 rounded-full text-xs font-medium hover:bg-primary-hover transition-colors">
          Se oppskrifter →
        </a>
      </div>
    ) : (
      <div class="space-y-2">
        {allPurchases.map((p) => (
          <div class="flex items-center justify-between gap-3 bg-white rounded-xl p-3 border border-sage-500/10">
            <div class="min-w-0">
              <p class="text-sm font-medium line-clamp-1">{p.title}</p>
              <p class="text-[11px] text-charcoal/45 mt-0.5">
                {formatNok(p.amount_nok, 'nb')} · {new Date(p.created_at).toLocaleDateString('nb-NO')}
              </p>
            </div>
            <a href={`/api/download/${p.id}`} target="_blank" rel="noopener"
              class="shrink-0 bg-primary text-primary-fg px-3 py-1.5 rounded-full text-[11px] font-medium hover:bg-primary-hover transition-colors">
              Last ned
            </a>
          </div>
        ))}
      </div>
    )}
  </section>

  <section>
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-serif text-lg">Mine butikker</h2>
      <div class="flex items-center gap-3">
        <a href="/profile/stores/new" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">+ Ny →</a>
        {myStores.length > 0 && (
          <a href="/profile/stores" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Se alle →</a>
        )}
      </div>
    </div>
    {myStores.length === 0 ? (
      <div class="text-center py-2">
        <p class="text-sm text-charcoal/45 mb-3">Driver du en virksomhet?</p>
        <a href="/profile/stores/new" class="inline-block bg-primary text-primary-fg px-4 py-2 rounded-full text-xs font-medium hover:bg-primary-hover transition-colors">
          Opprett butikk →
        </a>
      </div>
    ) : (
      <ul class="space-y-2">
        {myStores.slice(0, 4).map((s) => (
          <li>
            <a href={s.href} class="flex items-center gap-3 bg-white rounded-xl border border-sage-500/10 hover:border-sage-500/30 transition-colors p-2.5">
              {s.logo_path ? (
                <img src={projectPhotoUrl(s.logo_path)} alt="" class="w-10 h-10 rounded-lg object-cover shrink-0" />
              ) : (
                <div class="w-10 h-10 rounded-lg bg-sage-100 flex items-center justify-center font-serif text-base text-sage-700 shrink-0">
                  {s.name?.[0]?.toUpperCase() ?? '?'}
                </div>
              )}
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-1.5 flex-wrap">
                  <p class="text-sm font-medium truncate">{s.name}</p>
                  {s.verified && <span class="text-[9px] font-bold uppercase tracking-widest bg-sage-500/20 text-sage-700 px-1.5 py-0.5 rounded-full shrink-0">✓</span>}
                  {s.promo_year_one_free && <span class="text-[9px] font-bold uppercase tracking-widest bg-terracotta-500/20 text-terracotta-500 px-1.5 py-0.5 rounded-full shrink-0">🎉</span>}
                </div>
                <p class="text-[11px] text-charcoal/45">{s.statusLabel}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section>
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-serif text-lg">Bibliotek</h2>
      <div class="flex items-center gap-3">
        <a href="/profile/library/new" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">+ Ny →</a>
        {allBibliotek.length > 0 && (
          <a href="/profile/library" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Se alle →</a>
        )}
      </div>
    </div>
    {allBibliotek.length === 0 ? (
      <div class="text-center py-2">
        <p class="text-sm text-charcoal/45 mb-3">Ingen oppskrifter i biblioteket.</p>
        <a href="/profile/library/new" class="inline-block bg-primary text-primary-fg px-4 py-2 rounded-full text-xs font-medium hover:bg-primary-hover transition-colors">
          Last opp oppskrift →
        </a>
      </div>
    ) : (
      <div class="grid grid-cols-3 gap-2">
        {allBibliotek.map((pat) => {
          const cover = projectPhotoUrl(pat.cover_path);
          return (
            <a href={`/profile/library/${pat.id}`} class="block rounded-xl overflow-hidden hover:opacity-90 transition-opacity">
              {cover ? (
                <img src={cover} alt={pat.title} class="aspect-[3/4] object-cover w-full rounded-xl" loading="lazy" />
              ) : (
                <div class="aspect-[3/4] bg-gradient-to-br from-sage-100 to-oatmeal rounded-xl flex items-center justify-center">
                  <span class="font-serif text-lg text-sage-900/50">{isPdf(pat.file_path) ? 'PDF' : '✎'}</span>
                </div>
              )}
              <p class="text-[11px] font-medium line-clamp-1 mt-1.5">{pat.title}</p>
            </a>
          );
        })}
      </div>
    )}
  </section>

  <section class="md:col-span-2">
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-serif text-lg">Prosjekter</h2>
      <div class="flex items-center gap-3">
        <a href="/studio/projects/new" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">+ Nytt →</a>
        {allProjects.length > 0 && (
          <a href="/studio/projects" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Strikkestua →</a>
        )}
      </div>
    </div>
    {allProjects.length === 0 ? (
      <EmptyState message="Ingen prosjekter ennå." ctaText="Start et prosjekt →" ctaHref="/studio/projects/new" compact />
    ) : (
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {allProjects.map((p) => {
          const isCommission = !!p.commission_offer_id;
          const commissionData = isCommission ? p.commission_offers : null;
          const reqData = commissionData?.commission_requests;
          const buyerName = reqData?.profiles?.display_name;
          return (
            <ProjectCard
              id={p.id}
              title={p.title}
              status={p.status}
              heroPhotoPath={p.hero_photo_path}
              compact
              isCommission={isCommission}
              buyerName={buyerName}
            />
          );
        })}
      </ul>
    )}
  </section>

  <section class="md:col-span-2">
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-serif text-lg">Mine annonser</h2>
      <div class="flex items-center gap-3">
        <a href="/market/listing/new" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">+ Ny →</a>
        {allListings.length > 0 && (
          <a href="/market/my-listings" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Se alle →</a>
        )}
      </div>
    </div>
    {allListings.length === 0 ? (
      <EmptyState message="Du har ingen annonser ennå." ctaText="Opprett annonse →" ctaHref="/market/listing/new" compact />
    ) : (
      <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        {allListings.map((l) => (
          <ListingCard
            id={l.id}
            title={l.title}
            price={l.price_nok}
            imgUrl={projectPhotoUrl(l.hero_photo_path)}
            meta={KIND_LABEL[l.kind]}
          />
        ))}
      </ul>
    )}
  </section>

</div>
