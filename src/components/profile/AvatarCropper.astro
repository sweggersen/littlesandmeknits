---
// Square-crop modal for profile avatar uploads. Opens when the user
// picks a file via the [data-avatar-input] input elsewhere in the
// page. Renders the modal markup + the cropper script. The page just
// needs the file <input data-avatar-input> and an <img data-avatar-preview>.
//
// Extracted from src/pages/profile/edit.astro.
---

<div data-crop-modal class="hidden fixed inset-0 z-[60] bg-charcoal/60 backdrop-blur-sm flex items-center justify-center p-4" aria-modal="true" role="dialog">
  <div class="bg-white rounded-3xl p-5 sm:p-6 w-full max-w-md shadow-2xl">
    <h3 class="font-serif text-lg mb-4 text-center">Tilpass profilbildet</h3>
    <div
      data-crop-container
      class="relative mx-auto bg-charcoal/5 rounded-2xl overflow-hidden touch-none select-none cursor-grab"
      style="width: 288px; height: 288px;"
    >
      <img data-crop-image alt="" class="absolute top-0 left-0 max-w-none origin-top-left pointer-events-none" />
      {/* Round overlay mask */}
      <div class="absolute inset-0 pointer-events-none" style="box-shadow: 0 0 0 144px rgba(60, 60, 60, 0.55) inset; border-radius: 9999px;"></div>
    </div>
    <label class="block mt-5">
      <span class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Zoom</span>
      <input data-crop-zoom type="range" min="1" max="3" step="0.01" value="1" class="w-full accent-terracotta-500" />
    </label>
    <div class="flex gap-3 mt-5">
      <button type="button" data-crop-cancel class="flex-1 rounded-full py-2.5 px-4 text-sm font-medium border border-sage-500/30 text-charcoal/80 hover:bg-sage-100/40">Avbryt</button>
      <button type="button" data-crop-confirm class="flex-1 btn-primary rounded-full py-2.5 px-4 text-sm font-semibold">Bruk bilde</button>
    </div>
  </div>
</div>

<script>
  import { init } from "../../lib/client/controllers/avatar-cropper";
  import { registerController } from "../../lib/client/dom";
  registerController(init);
</script>
