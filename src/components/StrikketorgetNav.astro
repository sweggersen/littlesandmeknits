---
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/market';

const navLinks = [
  { href: '/market/used', label: 'Brukt' },
  { href: '/market/new', label: 'Nytt' },
  { href: '/market/commissions', label: 'Strikk for meg' },
  { href: '/market/stores', label: 'Butikker' },
];

const externalLinks = [
  { href: 'https://littlesandmeknits.com', label: 'Til hovedsiden' },
  { href: 'https://littlesandmeknits.com/studio', label: 'Til Strikkestua' },
];
---

<nav class="sticky top-0 z-50 bg-linen/80 backdrop-blur-md border-b border-sage-500/10" transition:animate="none">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <a href="/market" class="group shrink-0 flex items-center gap-2.5" transition:name="brand-logo">
        <img src="/strikketorget-icon.svg" alt="" width="32" height="32" class="shrink-0 group-hover:opacity-90 transition-opacity" />
        <span class="font-serif text-xl font-medium tracking-tight text-charcoal group-hover:text-terracotta-500 transition-colors">
          Strikketorget
        </span>
      </a>

      <div class="hidden sm:flex items-center gap-1">
      {navLinks.map((l) => {
        const isActive = currentPath.startsWith(l.href);
        return (
          <a
            href={l.href}
            class:list={[
              'text-sm font-medium px-3 py-1.5 rounded-full transition-colors',
              isActive
                ? 'bg-terracotta-500/10 text-terracotta-500'
                : 'text-charcoal/70 hover:text-charcoal',
            ]}
          >
            {l.label}
          </a>
        );
      })}
      </div>
    </div>

    <div class="flex items-center gap-2">
      <!-- Dev/admin menu (localhost or staff only) -->
      <div class="relative hidden" data-dev-menu>
        <button type="button" class="p-1.5 text-amber-600 hover:text-amber-800 transition-colors" aria-label="Dev menu" data-dev-menu-trigger>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/>
          </svg>
        </button>
        <div class="hidden absolute right-0 top-full mt-2 w-52 bg-white rounded-xl border border-sage-500/15 shadow-lg py-1.5 z-50" data-dev-menu-dropdown>
          <p class="px-3 py-1 text-[9px] font-bold uppercase tracking-widest text-amber-600">Dev</p>
          <a href="/dev/login" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Dev login</a>
          <a href="/dev/test-tower" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Test tower</a>
          <a href="/market/test-panel" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Marked test panel</a>
          <hr class="my-1 border-sage-500/10" />
          <p class="px-3 py-1 text-[9px] font-bold uppercase tracking-widest text-charcoal/35">Admin</p>
          <a href="/admin" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Dashboard</a>
          <a href="/admin/moderation" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Moderering</a>
          <a href="/admin/users" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Brukere</a>
          <a href="/admin/reports" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Rapporter</a>
          <a href="/admin/disputes" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Tvister</a>
          <a href="/admin/payouts" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Utbetalinger</a>
          <a href="/admin/moderators" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Moderatorer</a>
          <a href="/admin/log" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Aktivitetslogg</a>
        </div>
      </div>

      <!-- Unified bell: notifications + messages + moderation -->
      <a
        href="/inbox"
        class="hidden sm:inline-flex relative p-1.5 text-charcoal/50 hover:text-charcoal transition-colors"
        data-auth-link="bell"
        data-bell
        style="display:none;"
        aria-label="Innboks"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        <span data-inbox-badge class="hidden absolute -top-0.5 -right-0.5 min-w-[16px] h-4 px-1 rounded-full bg-terracotta-500 text-white text-[10px] font-bold flex items-center justify-center">0</span>
      </a>

      <!-- Profile dropdown -->
      <div class="hidden sm:block relative" data-auth-link="profile-menu" style="display:none;">
        <button type="button" data-profile-menu-trigger class="flex items-center gap-1.5 text-sm font-medium text-charcoal/70 hover:text-charcoal transition-colors p-1.5 rounded-full">
          <span data-profile-avatar class="w-6 h-6 rounded-full bg-sage-100 flex items-center justify-center shrink-0 text-[10px] font-serif text-sage-700">?</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>

        <div data-profile-menu class="hidden absolute right-0 top-full mt-2 w-64 bg-white rounded-2xl border border-sage-500/15 shadow-lg py-2 z-50">
          <a href="/profile" class="block px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Min profil</a>
          <a href="/market/my-listings" class="block px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Mine annonser</a>
          <a href="/market/my-purchases" class="block px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Mine kjøp</a>
          <a href="/market/favorites" class="block px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Favoritter</a>
          <a href="/profile/stores" data-link-my-stores class="hidden px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Mine butikker</a>
          <a href="/market/commissions/my-listings" data-link-my-requests class="hidden px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Mine oppdrag</a>
          <div class="border-t border-sage-500/10 my-1"></div>
          {externalLinks.map((l) => (
            <a href={l.href} class="block px-4 py-2 text-sm text-charcoal/60 hover:bg-sage-100/40">{l.label} →</a>
          ))}
          <div class="border-t border-sage-500/10 my-1"></div>
          <a href="/profile/edit" class="block px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Innstillinger</a>
          <form method="post" action="/api/auth/signout">
            <button type="submit" class="w-full text-left px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Logg ut</button>
          </form>
        </div>
      </div>

      <a
        href="/login"
        class="hidden sm:inline-flex text-sm font-medium text-charcoal/70 hover:text-charcoal transition-colors"
        data-auth-link="login"
      >
        Logg inn
      </a>

      <button
        type="button"
        class="sm:hidden p-2 -mr-2 text-charcoal/70 hover:text-charcoal relative"
        aria-label="Meny"
        data-mobile-menu-trigger
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M3 6h18M3 12h18M3 18h18" />
        </svg>
        <span data-mobile-bell-badge class="hidden absolute top-0 right-0 min-w-[16px] h-4 px-1 rounded-full bg-terracotta-500 text-white text-[10px] font-bold flex items-center justify-center">0</span>
      </button>
    </div>
  </div>

  <div class="hidden sm:hidden border-t border-sage-500/10 px-6 py-4" data-mobile-menu>
    <ul class="flex flex-col gap-1">
      {navLinks.map((l) => (
        <li>
          <a href={l.href} class:list={[
            'block py-2 text-base font-medium',
            currentPath.startsWith(l.href) ? 'text-terracotta-500' : 'text-charcoal/80',
          ]}>
            {l.label}
          </a>
        </li>
      ))}
      <li class="border-t border-sage-500/10 pt-2 mt-1">
        <a href="/inbox" class="flex items-center justify-between py-2 text-base font-medium text-charcoal/80 hidden" data-st-auth>
          <span>Innboks</span>
          <span data-mobile-inbox-badge class="hidden min-w-[18px] h-5 px-1.5 rounded-full bg-terracotta-500 text-white text-[11px] font-bold flex items-center justify-center">0</span>
        </a>
      </li>
      <li>
        <a href="/market/my-listings" class="block py-2 text-base font-medium text-charcoal/80 hidden" data-st-auth>Mine annonser</a>
      </li>
      <li>
        <a href="/market/my-purchases" class="block py-2 text-base font-medium text-charcoal/80 hidden" data-st-auth>Mine kjøp</a>
      </li>
      <li>
        <a href="/market/favorites" class="block py-2 text-base font-medium text-charcoal/80 hidden" data-st-auth>Favoritter</a>
      </li>
      <li>
        <a href="/profile/stores" data-link-my-stores-mobile class="hidden py-2 text-base font-medium text-charcoal/80">Mine butikker</a>
      </li>
      <li>
        <a href="/market/commissions/my-listings" data-link-my-requests-mobile class="hidden py-2 text-base font-medium text-charcoal/80">Mine oppdrag</a>
      </li>
      <li>
        <a href="/profile" class="block py-2 text-base font-medium text-charcoal/80 hidden" data-st-auth>Min profil</a>
      </li>
      <li class="border-t border-sage-500/10 pt-2 mt-1">
        {externalLinks.map((l) => (
          <a href={l.href} class="block py-2 text-sm font-medium text-charcoal/45">{l.label} →</a>
        ))}
      </li>
      <li data-auth-link="login">
        <a href="/login" class="block py-2 text-base font-medium text-charcoal/80">Logg inn</a>
      </li>
      <li class="hidden" data-st-auth>
        <form method="post" action="/api/auth/signout">
          <button type="submit" class="block py-2 text-base font-medium text-charcoal/80">Logg ut</button>
        </form>
      </li>
    </ul>
  </div>
</nav>

<script is:inline>
  function applyAuthUI(loggedIn) {
    if (!loggedIn) {
      document.querySelectorAll('[data-auth-link="profile-menu"]').forEach(function(el) {
        el.style.display = 'none';
        el.classList.add('hidden');
      });
      document.querySelectorAll('[data-auth-link="bell"]').forEach(function(el) {
        el.style.display = 'none';
        el.classList.add('hidden');
      });
      document.querySelectorAll('[data-st-auth]').forEach(function(el) {
        el.classList.add('hidden');
      });
      document.querySelectorAll('[data-auth-link="login"]').forEach(function(el) {
        el.style.display = '';
      });
      return;
    }
    document.querySelectorAll('[data-auth-link="login"]').forEach(function(el) {
      el.style.display = 'none';
    });
    document.querySelectorAll('[data-auth-link="profile-menu"]').forEach(function(el) {
      el.style.display = '';
      el.classList.remove('hidden');
    });
    document.querySelectorAll('[data-auth-link="bell"]').forEach(function(el) {
      el.style.display = '';
      el.classList.remove('hidden');
    });
    document.querySelectorAll('[data-st-auth]').forEach(function(el) {
      el.classList.remove('hidden');
    });
    var cached = sessionStorage.getItem('lm-profile');
    if (cached) applyProfileInfo(JSON.parse(cached));
  }

  function applyProfileInfo(u) {
    var avatarEl = document.querySelector('[data-profile-avatar]');
    if (avatarEl && u.display_name) avatarEl.textContent = u.display_name[0].toUpperCase();

    var inboxN = u.inbox_unread || ((u.notifications || 0) + (u.unread || 0));
    var badgeText = inboxN > 99 ? '99+' : String(inboxN);
    [document.querySelector('[data-inbox-badge]'),
     document.querySelector('[data-mobile-bell-badge]'),
     document.querySelector('[data-mobile-inbox-badge]')].forEach(function(el) {
      if (!el) return;
      if (inboxN > 0) { el.textContent = badgeText; el.classList.remove('hidden'); }
      else { el.classList.add('hidden'); }
    });

    if (u.has_stores) {
      document.querySelectorAll('[data-link-my-stores], [data-link-my-stores-mobile]').forEach(function(el) {
        el.classList.remove('hidden');
      });
    }
    if (u.has_requests) {
      document.querySelectorAll('[data-link-my-requests], [data-link-my-requests-mobile]').forEach(function(el) {
        el.classList.remove('hidden');
      });
    }
  }

  if (sessionStorage.getItem('lm-auth') === '1') {
    applyAuthUI(true);
  }
</script>

<script>
  function initStrikketorgetNav() {
    const trigger = document.querySelector<HTMLButtonElement>('[data-mobile-menu-trigger]');
    const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
    trigger?.addEventListener('click', () => menu?.classList.toggle('hidden'));

    // Dev menu — localhost-only convenience.
    const isLocal = location.hostname === 'localhost' || location.hostname === '127.0.0.1';
    if (isLocal) {
      document.querySelectorAll('[data-dev-menu]').forEach((el) => el.classList.remove('hidden'));
      document.querySelectorAll<HTMLButtonElement>('[data-dev-menu-trigger]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const dd = btn.parentElement?.querySelector('[data-dev-menu-dropdown]');
          dd?.classList.toggle('hidden');
        });
      });
      document.addEventListener('click', () => {
        document.querySelectorAll('[data-dev-menu-dropdown]').forEach((el) => el.classList.add('hidden'));
      });
    }

    // Profile dropdown
    const profileTrigger = document.querySelector<HTMLButtonElement>('[data-profile-menu-trigger]');
    const profileMenu = document.querySelector<HTMLElement>('[data-profile-menu]');
    profileTrigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      profileMenu?.classList.toggle('hidden');
    });
    document.addEventListener('click', (e) => {
      if (!profileMenu) return;
      const wrapper = profileTrigger?.parentElement;
      if (!wrapper?.contains(e.target as Node)) profileMenu.classList.add('hidden');
    });

    if (sessionStorage.getItem('lm-auth') === '1') {
      (window as any).applyAuthUI(true);
    }

    fetch('/api/me', { credentials: 'same-origin' })
      .then((r) => (r.ok ? r.json() : null))
      .then((data) => {
        if (data?.user) {
          sessionStorage.setItem('lm-auth', '1');
          sessionStorage.setItem('lm-profile', JSON.stringify(data.user));
          (window as any).applyAuthUI(true);
          (window as any).applyProfileInfo(data.user);
        } else {
          sessionStorage.removeItem('lm-auth');
          sessionStorage.removeItem('lm-profile');
          (window as any).applyAuthUI(false);
        }
      })
      .catch(() => {});
  }

  document.addEventListener('astro:page-load', initStrikketorgetNav);
</script>
