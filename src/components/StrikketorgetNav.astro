---
// SectionNav (kept under the StrikketorgetNav filename for now to avoid
// churn). Used by both Strikketorget and Strikkestua via the `variant`
// prop — same chrome (bell, dev menu, avatar dropdown, hamburger), only
// the brand and item set change.
interface Props {
  variant?: 'strikketorget' | 'strikkestua';
}
const { variant = 'strikketorget' } = Astro.props;
const isStudio = variant === 'strikkestua';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || (isStudio ? '/studio' : '/market');

const sectionRoot = isStudio ? '/studio' : '/market';
const ROOT_PATHS = isStudio
  ? new Set(['/studio'])
  : new Set(['/market', '/inbox']);
const showBack = !ROOT_PATHS.has(currentPath);
const parentPath = (() => {
  const parts = currentPath.split('/').filter(Boolean);
  if (parts.length <= 1) return sectionRoot;
  parts.pop();
  return '/' + parts.join('/');
})();

const navLinks = isStudio
  ? [
      { href: '/studio', label: 'Oversikt', exact: true },
      { href: '/studio/projects', label: 'Prosjekter' },
      { href: '/studio/yarn', label: 'Garn' },
      { href: '/studio/tools', label: 'Verktøy' },
      { href: '/studio/learn', label: 'Lær' },
    ]
  : [
      { href: '/market/used', label: 'Brukt' },
      { href: '/market/new', label: 'Nytt' },
      { href: '/market/commissions', label: 'Oppdrag' },
      { href: '/market/stores', label: 'Butikker' },
    ];

const externalLinks = isStudio
  ? [
      { href: 'https://littlesandmeknits.com', label: 'Til hovedsiden' },
    ]
  : [
      { href: 'https://littlesandmeknits.com', label: 'Til hovedsiden' },
      { href: '/studio', label: 'Til Strikkestua' },
    ];

// Strikkestua-only: a "Back to Strikketorget" pill on the right.
const seenMarket = Astro.cookies.get('seen_market')?.value === '1';
const marketBackLabel = seenMarket ? 'Tilbake til Strikketorget' : 'Strikketorget';
---

<nav class="sticky top-0 z-50 bg-linen/80 backdrop-blur-md border-b border-sage-500/10" transition:animate="none">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-2 sm:gap-6">
      <!-- Always rendered; JS toggles `hidden` based on route (nav is
           transition:persist'd, so we can't rely on server-side conditional). -->
      <a
        href={parentPath}
        data-st-back
        class:list={['lg:hidden -ml-1 p-2 text-charcoal/70 hover:text-charcoal', !showBack && 'hidden']}
        aria-label="Tilbake"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </a>
      <a href={sectionRoot} class="group shrink-0 flex items-center gap-2.5">
        {!isStudio && (
          <img src="/strikketorget-icon.svg" alt="" width="32" height="32" class="shrink-0 group-hover:opacity-90 transition-opacity" />
        )}
        <span class="flex flex-col leading-tight">
          <span class="font-serif text-xl font-medium tracking-tight text-charcoal group-hover:text-terracotta-500 transition-colors">
            {isStudio ? 'Strikkestua' : 'Strikketorget'}
          </span>
          {isStudio && (
            <span class="font-serif text-[11px] text-charcoal/35 group-hover:text-terracotta-500/50 transition-colors">
              by Littles and Me Knits
            </span>
          )}
        </span>
      </a>

      <div class="hidden sm:flex items-center gap-1">
      {navLinks.map((l) => {
        // 'exact' items only match an exact equality (used by /studio
        // Oversikt, which would otherwise match all /studio/* sub-pages).
        const isActive = ('exact' in l && (l as any).exact)
          ? currentPath === l.href
          : currentPath.startsWith(l.href);
        return (
          <a
            href={l.href}
            data-nav-link={l.href}
            data-nav-link-exact={('exact' in l && (l as any).exact) ? '1' : undefined}
            class:list={[
              'text-sm font-medium px-3 py-1.5 rounded-full transition-colors',
              isActive
                ? 'bg-terracotta-500/10 text-terracotta-500'
                : 'text-charcoal/70 hover:text-charcoal hover:bg-sage-100/60',
            ]}
          >
            {l.label}
          </a>
        );
      })}
      </div>
    </div>

    {isStudio && (
      <a
        href="/market"
        class="hidden lg:inline-flex items-center gap-1.5 ml-auto mr-2 text-sm font-medium px-4 py-1.5 rounded-full border border-sage-500/30 text-charcoal/80 hover:border-terracotta-500/40 hover:text-terracotta-500 transition-colors"
      >
        {seenMarket && (
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        )}
        <span>{marketBackLabel}</span>
      </a>
    )}

    <div class="flex items-center gap-2">
      <!-- Dev/admin menu (localhost or staff only) -->
      <div class="relative hidden" data-dev-menu>
        <button type="button" class="p-1.5 text-amber-600 hover:text-amber-800 transition-colors" aria-label="Dev menu" data-dev-menu-trigger>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/>
          </svg>
        </button>
        <div class="hidden absolute right-0 top-full mt-2 w-52 bg-white rounded-xl border border-sage-500/15 shadow-lg py-1.5 z-50" data-dev-menu-dropdown>
          <p class="px-3 py-1 text-[9px] font-bold uppercase tracking-widest text-amber-600">Dev</p>
          <a href="/dev/login" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Dev login</a>
          <a href="/dev/screens" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Skjermkatalog</a>
          <a href="/dev/ui-flows" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">UI Flows</a>
          <a href="/dev/offline" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Offline-side</a>
          <a href="/dev/test-tower" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Test tower</a>
          <a href="/market/test-panel" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Marked test panel</a>
          <hr class="my-1 border-sage-500/10" />
          <p class="px-3 py-1 text-[9px] font-bold uppercase tracking-widest text-charcoal/35">Admin</p>
          <a href="/admin" data-astro-reload class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Dashboard</a>
          <a href="/admin/moderation" data-astro-reload class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Moderering</a>
          <a href="/admin/users" data-astro-reload class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Brukere</a>
          <a href="/admin/reports" data-astro-reload class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Rapporter</a>
          <a href="/admin/disputes" data-astro-reload class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Tvister</a>
          <a href="/admin/payouts" data-astro-reload class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Utbetalinger</a>
          <a href="/admin/moderators" data-astro-reload class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Moderatorer</a>
          <a href="/admin/log" data-astro-reload class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Aktivitetslogg</a>
          <hr class="my-1 border-sage-500/10" />
          <p class="px-3 py-1 text-[9px] font-bold uppercase tracking-widest text-charcoal/35">Lokale verktøy</p>
          <a href="http://127.0.0.1:54324" target="_blank" rel="noopener" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Mailpit ↗</a>
          <a href="http://127.0.0.1:54323" target="_blank" rel="noopener" class="block px-3 py-1.5 text-sm text-charcoal/70 hover:bg-sage-50">Supabase Studio ↗</a>
        </div>
      </div>

      <!-- Unified bell: notifications + messages + moderation -->
      <a
        href="/inbox"
        class="hidden sm:inline-flex relative p-1.5 text-charcoal/50 hover:text-charcoal transition-colors"
        data-auth-link="bell"
        data-bell
        style="display:none;"
        aria-label="Innboks"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        <span data-inbox-badge class="hidden absolute -top-0.5 -right-0.5 min-w-[16px] h-4 px-1 rounded-full bg-terracotta-500 text-white text-[10px] font-bold flex items-center justify-center">0</span>
      </a>

      <!-- Mobile/tablet: avatar that links straight to the profile page -->
      <a href="/profile" class="lg:hidden inline-flex" data-auth-link="profile-avatar-mobile" style="display:none;" aria-label="Min profil">
        <span data-profile-avatar-mobile class="w-7 h-7 rounded-full bg-sage-100 flex items-center justify-center shrink-0 text-[11px] font-serif text-sage-700">?</span>
      </a>

      <!-- Desktop: clickable avatar with dropdown -->
      <div class="hidden lg:block relative" data-auth-link="profile-menu" style="display:none;">
        <button type="button" data-profile-menu-trigger class="flex items-center gap-1.5 text-sm font-medium text-charcoal/70 hover:text-charcoal transition-colors p-1.5 rounded-full">
          <span data-profile-avatar class="w-6 h-6 rounded-full bg-sage-100 flex items-center justify-center shrink-0 text-[10px] font-serif text-sage-700">?</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>

        <div data-profile-menu class="hidden absolute right-0 top-full mt-2 w-64 bg-white rounded-2xl border border-sage-500/15 shadow-lg py-2 z-50">
          <div class="flex items-center gap-3 px-4 py-3 border-b border-sage-500/10 mb-1">
            <span data-profile-header-avatar class="w-9 h-9 rounded-full bg-sage-100 flex items-center justify-center shrink-0 text-sm font-serif text-sage-700">?</span>
            <span class="flex flex-col min-w-0">
              <span data-profile-header-name class="font-serif text-sm text-charcoal truncate">Profil</span>
              <span data-profile-header-sub class="text-[11px] text-charcoal/45 truncate"></span>
            </span>
          </div>
          <a href="/profile" class="block px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Min profil</a>
          <a href="/market/my-listings" class="block px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Mine annonser</a>
          <a href="/market/my-purchases" class="block px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Mine kjøp</a>
          <a href="/market/favorites" class="block px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Favoritter</a>
          <a href="/profile/stores" data-link-my-stores class="hidden px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Mine butikker</a>
          <a href="/market/commissions/my-listings" data-link-my-requests class="hidden px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Mine oppdrag</a>
          <div class="border-t border-sage-500/10 my-1"></div>
          {externalLinks.map((l) => (
            <a href={l.href} class="block px-4 py-2 text-sm text-charcoal/60 hover:bg-sage-100/40">{l.label} →</a>
          ))}
          <div class="border-t border-sage-500/10 my-1"></div>
          <a href="/profile/edit" class="block px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Innstillinger</a>
          <a href="/profile/data" class="block px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Mine data og personvern</a>
          <form method="post" action="/api/auth/signout">
            <button type="submit" class="w-full text-left px-4 py-2 text-sm text-charcoal/80 hover:bg-sage-100/40">Logg ut</button>
          </form>
        </div>
      </div>

      <a
        href="/login"
        class="hidden sm:inline-flex text-sm font-medium text-charcoal/70 hover:text-charcoal transition-colors"
        data-auth-link="login"
      >
        Logg inn
      </a>

      <button
        type="button"
        class="lg:hidden p-2 -mr-2 text-charcoal/70 hover:text-charcoal relative"
        aria-label="Meny"
        data-mobile-menu-trigger
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M3 6h18M3 12h18M3 18h18" />
        </svg>
        <span data-mobile-bell-badge class="hidden absolute top-0 right-0 min-w-[16px] h-4 px-1 rounded-full bg-terracotta-500 text-white text-[10px] font-bold flex items-center justify-center">0</span>
      </button>
    </div>
  </div>

  <!-- Click-to-dismiss backdrop, sibling of the dropdown, covers content below the nav -->
  <div class="hidden fixed inset-x-0 top-[64px] bottom-0 bg-charcoal/20 backdrop-blur-[1px] z-40 lg:hidden" data-mobile-backdrop aria-hidden="true"></div>

  <div class="hidden absolute left-0 right-0 top-full bg-linen border-t border-sage-500/10 px-6 py-4 shadow-lg z-50 lg:hidden" data-mobile-menu>
    <ul class="flex flex-col gap-1">
      {navLinks.map((l) => (
        <li>
          <a href={l.href} data-mobile-nav-link={l.href} class="block py-2 text-base font-medium text-charcoal/80">
            {l.label}
          </a>
        </li>
      ))}
      <li class="border-t border-sage-500/10 pt-2 mt-1">
        <a href="/inbox" class="flex items-center justify-between py-2 text-base font-medium text-charcoal/80 hidden" data-st-auth>
          <span>Innboks</span>
          <span data-mobile-inbox-badge class="hidden min-w-[18px] h-5 px-1.5 rounded-full bg-terracotta-500 text-white text-[11px] font-bold flex items-center justify-center">0</span>
        </a>
      </li>
      <li>
        <a href="/market/my-listings" class="block py-2 text-base font-medium text-charcoal/80 hidden" data-st-auth>Mine annonser</a>
      </li>
      <li>
        <a href="/market/my-purchases" class="block py-2 text-base font-medium text-charcoal/80 hidden" data-st-auth>Mine kjøp</a>
      </li>
      <li>
        <a href="/market/favorites" class="block py-2 text-base font-medium text-charcoal/80 hidden" data-st-auth>Favoritter</a>
      </li>
      <li>
        <a href="/profile/stores" data-link-my-stores-mobile class="hidden py-2 text-base font-medium text-charcoal/80">Mine butikker</a>
      </li>
      <li>
        <a href="/market/commissions/my-listings" data-link-my-requests-mobile class="hidden py-2 text-base font-medium text-charcoal/80">Mine oppdrag</a>
      </li>
      <li>
        <a href="/profile" class="block py-2 text-base font-medium text-charcoal/80 hidden" data-st-auth>Min profil</a>
      </li>
      <li class="border-t border-sage-500/10 pt-2 mt-1">
        {externalLinks.map((l) => (
          <a href={l.href} class="block py-2 text-sm font-medium text-charcoal/45">{l.label} →</a>
        ))}
      </li>
      <li data-auth-link="login">
        <a href="/login" class="block py-2 text-base font-medium text-charcoal/80">Logg inn</a>
      </li>
      <li class="hidden" data-st-auth>
        <form method="post" action="/api/auth/signout">
          <button type="submit" class="block py-2 text-base font-medium text-charcoal/80">Logg ut</button>
        </form>
      </li>
    </ul>
  </div>
</nav>

<script is:inline>
  function applyAuthUI(loggedIn) {
    if (!loggedIn) {
      document.querySelectorAll('[data-auth-link="profile-menu"], [data-auth-link="profile-avatar-mobile"]').forEach(function(el) {
        el.style.display = 'none';
      });
      document.querySelectorAll('[data-auth-link="bell"]').forEach(function(el) {
        el.style.display = 'none';
      });
      document.querySelectorAll('[data-st-auth]').forEach(function(el) {
        el.classList.add('hidden');
      });
      document.querySelectorAll('[data-auth-link="login"]').forEach(function(el) {
        el.style.display = '';
      });
      return;
    }
    document.querySelectorAll('[data-auth-link="login"]').forEach(function(el) {
      el.style.display = 'none';
    });
    // Only clear inline display:none — keep responsive `hidden lg:block`
    // / `hidden sm:inline-flex` classes intact so the elements respect
    // the viewport breakpoints.
    document.querySelectorAll('[data-auth-link="profile-menu"]').forEach(function(el) {
      el.style.display = '';
    });
    document.querySelectorAll('[data-auth-link="profile-avatar-mobile"]').forEach(function(el) {
      el.style.display = '';
    });
    document.querySelectorAll('[data-auth-link="bell"]').forEach(function(el) {
      el.style.display = '';
    });
    document.querySelectorAll('[data-st-auth]').forEach(function(el) {
      el.classList.remove('hidden');
    });
    var cached = sessionStorage.getItem('lm-profile');
    if (cached) applyProfileInfo(JSON.parse(cached));
  }

  function applyProfileInfo(u) {
    var initial = (u.display_name || '?')[0].toUpperCase();
    document.querySelectorAll('[data-profile-avatar], [data-profile-avatar-mobile], [data-profile-header-avatar]').forEach(function(el) {
      if (u.avatar_url) {
        // Render the actual avatar image as a background, fall back to
        // the initial if the image fails to load. Cache-busted server-side
        // via ?v=<updated_at> so fresh uploads show immediately.
        el.style.backgroundImage = "url('" + u.avatar_url + "')";
        el.style.backgroundSize = 'cover';
        el.style.backgroundPosition = 'center';
        el.style.color = 'transparent';
      } else if (u.display_name) {
        el.style.backgroundImage = '';
        el.style.color = '';
        el.textContent = initial;
      }
    });
    if (u.display_name) {
      document.querySelectorAll('[data-profile-header-name]').forEach(function(el) {
        el.textContent = u.display_name;
      });
    }
    if (u.member_since) {
      document.querySelectorAll('[data-profile-header-sub]').forEach(function(el) {
        el.textContent = u.member_since;
      });
    } else {
      document.querySelectorAll('[data-profile-header-sub]').forEach(function(el) {
        el.textContent = '';
      });
    }

    var inboxN = u.inbox_unread || ((u.notifications || 0) + (u.unread || 0));
    var badgeText = inboxN > 99 ? '99+' : String(inboxN);
    [document.querySelector('[data-inbox-badge]'),
     document.querySelector('[data-mobile-bell-badge]'),
     document.querySelector('[data-mobile-inbox-badge]')].forEach(function(el) {
      if (!el) return;
      if (inboxN > 0) { el.textContent = badgeText; el.classList.remove('hidden'); }
      else { el.classList.add('hidden'); }
    });

    if (u.has_stores) {
      document.querySelectorAll('[data-link-my-stores], [data-link-my-stores-mobile]').forEach(function(el) {
        el.classList.remove('hidden');
      });
    }
    if (u.has_requests) {
      document.querySelectorAll('[data-link-my-requests], [data-link-my-requests-mobile]').forEach(function(el) {
        el.classList.remove('hidden');
      });
    }
  }

  if (sessionStorage.getItem('lm-auth') === '1') {
    applyAuthUI(true);
  }
</script>

<script>
  function syncRouteState() {
    const path = location.pathname.replace(/\/$/, '') || '/market';
    const ROOTS = new Set(['/market', '/inbox']);

    // Active tab pills
    document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]').forEach((el) => {
      const href = el.dataset.navLink!;
      const exact = el.dataset.navLinkExact === '1';
      const active = exact ? path === href : path.startsWith(href);
      el.classList.toggle('bg-terracotta-500/10', active);
      el.classList.toggle('text-terracotta-500', active);
      el.classList.toggle('text-charcoal/70', !active);
      el.classList.toggle('hover:text-charcoal', !active);
      el.classList.toggle('hover:bg-sage-100/60', !active);
    });
    document.querySelectorAll<HTMLAnchorElement>('[data-mobile-nav-link]').forEach((el) => {
      const href = el.dataset.mobileNavLink!;
      const active = path.startsWith(href);
      el.classList.toggle('text-terracotta-500', active);
      el.classList.toggle('text-charcoal/80', !active);
    });

    // Mobile back button visibility + parent fallback
    const back = document.querySelector<HTMLAnchorElement>('[data-st-back]');
    if (back) {
      const showBack = !ROOTS.has(path);
      back.classList.toggle('hidden', !showBack);
      // Recompute parent path for fallback
      const parts = path.split('/').filter(Boolean);
      let parent = '/market';
      if (parts.length > 1) { parts.pop(); parent = '/' + parts.join('/'); }
      back.href = parent;
    }
  }

  function initStrikketorgetNav() {
    const trigger = document.querySelector<HTMLButtonElement>('[data-mobile-menu-trigger]');
    const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
    const backdrop = document.querySelector<HTMLElement>('[data-mobile-backdrop]');

    function setMenuOpen(open: boolean) {
      menu?.classList.toggle('hidden', !open);
      backdrop?.classList.toggle('hidden', !open);
      document.body.style.overflow = open ? 'hidden' : '';
    }

    // Always reset state on a fresh page-load — nav is transition:persist'd,
    // so without this the menu could carry the "open" state across navigations.
    setMenuOpen(false);

    // Bind listeners ONCE — nav is persisted, so initStrikketorgetNav runs
    // on every navigation. Guard with a sentinel on each element.
    if (trigger && !(trigger as any)._stBound) {
      (trigger as any)._stBound = true;
      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        setMenuOpen(menu?.classList.contains('hidden') ?? false);
      });
    }
    if (backdrop && !(backdrop as any)._stBound) {
      (backdrop as any)._stBound = true;
      backdrop.addEventListener('click', () => setMenuOpen(false));
    }
    if (menu && !(menu as any)._stBound) {
      (menu as any)._stBound = true;
      // Use event delegation so newly-added links also close the menu.
      menu.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('a, button')) setMenuOpen(false);
      });
    }
    if (!(window as any)._stEscBound) {
      (window as any)._stEscBound = true;
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !(menu?.classList.contains('hidden') ?? true)) setMenuOpen(false);
      });
    }

    // Nav is `transition:persist`'d across page changes, so we manually
    // re-sync per-route state (active tab pill + back-button visibility).
    syncRouteState();

    // Mobile back button: prefer history.back() when we have same-origin
    // history; the href fallback (parent path) is what runs otherwise.
    const back = document.querySelector<HTMLAnchorElement>('[data-st-back]');
    if (back && !(back as any)._bound) {
      (back as any)._bound = true;
      back.addEventListener('click', (e) => {
        const ref = document.referrer;
        const sameOrigin = ref && new URL(ref).origin === location.origin;
        if (history.length > 1 && sameOrigin) {
          e.preventDefault();
          history.back();
        }
      });
    }

    // Dev menu — localhost-only convenience. Nav is transition:persist'd
    // so we MUST guard against re-binding on every page-load.
    const isLocal = location.hostname === 'localhost' || location.hostname === '127.0.0.1';
    if (isLocal) {
      document.querySelectorAll('[data-dev-menu]').forEach((el) => el.classList.remove('hidden'));
      document.querySelectorAll<HTMLButtonElement>('[data-dev-menu-trigger]').forEach((btn) => {
        if ((btn as any)._stBound) return;
        (btn as any)._stBound = true;
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const dd = btn.parentElement?.querySelector('[data-dev-menu-dropdown]');
          dd?.classList.toggle('hidden');
        });
      });
      // Close dev dropdowns on outside click — bind once at the window level.
      if (!(window as any)._stDevOutsideBound) {
        (window as any)._stDevOutsideBound = true;
        document.addEventListener('click', (e) => {
          const target = e.target as Element | null;
          // Don't close if the click was inside the dev dropdown (let nav happen).
          if (target?.closest('[data-dev-menu]')) return;
          document.querySelectorAll('[data-dev-menu-dropdown]').forEach((el) => el.classList.add('hidden'));
        });
      }
    }
    // Always force-close dev dropdown on a fresh navigation.
    document.querySelectorAll('[data-dev-menu-dropdown]').forEach((el) => el.classList.add('hidden'));

    // Profile dropdown (also persisted — guard against re-binding)
    const profileTrigger = document.querySelector<HTMLButtonElement>('[data-profile-menu-trigger]');
    const profileMenu = document.querySelector<HTMLElement>('[data-profile-menu]');
    if (profileTrigger && !(profileTrigger as any)._stBound) {
      (profileTrigger as any)._stBound = true;
      profileTrigger.addEventListener('click', (e) => {
        e.stopPropagation();
        profileMenu?.classList.toggle('hidden');
      });
    }
    if (!(window as any)._stProfileOutsideBound) {
      (window as any)._stProfileOutsideBound = true;
      document.addEventListener('click', (e) => {
        const pm = document.querySelector<HTMLElement>('[data-profile-menu]');
        const pt = document.querySelector<HTMLButtonElement>('[data-profile-menu-trigger]');
        if (!pm || !pt) return;
        if (!pt.parentElement?.contains(e.target as Node)) pm.classList.add('hidden');
      });
    }

    if (sessionStorage.getItem('lm-auth') === '1') {
      (window as any).applyAuthUI(true);
    }

    fetch('/api/me', { credentials: 'same-origin' })
      .then((r) => (r.ok ? r.json() : null))
      .then((data) => {
        if (data?.user) {
          sessionStorage.setItem('lm-auth', '1');
          sessionStorage.setItem('lm-profile', JSON.stringify(data.user));
          (window as any).applyAuthUI(true);
          (window as any).applyProfileInfo(data.user);
        } else {
          sessionStorage.removeItem('lm-auth');
          sessionStorage.removeItem('lm-profile');
          (window as any).applyAuthUI(false);
        }
      })
      .catch(() => {});
  }

  document.addEventListener('astro:page-load', initStrikketorgetNav);
</script>
