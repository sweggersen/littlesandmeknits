---
// Reusable sticky sub-nav strip used at the top of grouped studio
// surfaces.
//
// `variant`:
//   "flush"  (default) — pulls up over the studio layout's top padding
//                        so the strip sits right under the brand bar.
//                        Use when the sub-nav is the very first child
//                        of the slot (Garn/Pinner, Profil/Bibliotek/Kjøp,
//                        Prosjekter status filter).
//   "inline"           — no negative top margin; sits where you place it
//                        in the document. Use when the page renders
//                        H1+intro above the sub-nav (Verktøy tools).

export interface SubNavItem {
  key: string;
  label: string;
  href: string;
  count?: number | null;
}

interface Props {
  items: SubNavItem[];
  active: string;
  variant?: 'flush' | 'inline';
  className?: string;
}

const { items, active, variant = 'flush', className = '' } = Astro.props;
const flushPull = variant === 'flush' ? '-mt-8 sm:-mt-10' : '';
---

<nav class:list={['sticky top-0 sm:top-[64px] -mx-4 sm:-mx-6 px-4 sm:px-6 mb-6 bg-linen/90 backdrop-blur-md z-20', flushPull, className]}>
  <ul class="flex gap-5 sm:gap-7 overflow-x-auto py-2 -mb-px text-sm font-medium">
    {items.map((item) => {
      const isActive = item.key === active;
      return (
        <li>
          <a
            href={item.href}
            class:list={[
              'inline-flex items-center gap-2 py-2 border-b-2 whitespace-nowrap transition-colors',
              isActive ? 'border-terracotta-500 text-charcoal' : 'border-transparent text-charcoal/55 hover:text-charcoal',
            ]}
          >
            <span>{item.label}</span>
            {typeof item.count === 'number' && (
              <span class:list={[
                'text-[10px] font-bold rounded-full px-1.5 py-0.5',
                isActive ? 'bg-terracotta-500/15 text-terracotta-500' : 'bg-sage-500/10 text-charcoal/55',
              ]}>{item.count}</span>
            )}
          </a>
        </li>
      );
    })}
  </ul>
</nav>
