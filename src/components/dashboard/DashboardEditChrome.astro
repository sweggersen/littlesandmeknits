---
// Shared dashboard edit chrome: the "Rediger" toggle (view mode) and the
// edit-actions bar (grid/staggered toggle, reset, cancel, save). The controller
// (dashboard-edit.ts) wires these by data-attribute. Both are rendered as the
// two right-aligned groups of a page header; only one shows at a time.
//
// Pages inject page-specific extras via the `view-extra` and `edit-extra`
// slots (e.g. profile's "Offentlig profil" and "Rediger detaljer" links).
---
<div class="ml-auto flex items-center gap-2 shrink-0" data-view-actions>
  <button type="button" data-edit-toggle class="inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-full border border-sage-500/25 text-charcoal/70 hover:border-sage-500/50 transition-colors">
    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
    Rediger
  </button>
  <slot name="view-extra" />
</div>
<div class="ml-auto items-center gap-2 shrink-0 hidden" data-edit-actions>
  <slot name="edit-extra" />
  <button type="button" data-edit-mode title="Bytt mellom rutenett og stablet visning" class="text-sm font-medium px-3 py-2 rounded-full border border-sage-500/25 text-charcoal/70 hover:border-sage-500/50 transition-colors">
    <span data-mode-label>Rutenett</span>
  </button>
  <button type="button" data-edit-reset class="text-sm font-medium px-3 py-2 rounded-full text-charcoal/45 hover:text-terracotta-500 transition-colors">Tilbakestill</button>
  <button type="button" data-edit-cancel class="text-sm font-medium px-4 py-2 rounded-full border border-sage-500/25 text-charcoal/70 hover:border-sage-500/50 transition-colors">Avbryt</button>
  <button type="button" data-edit-save class="btn-primary px-4 py-2 rounded-full text-sm font-medium">Lagre</button>
</div>
