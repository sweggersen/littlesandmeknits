---
interface Props {
  current?: string;
}
// `current` kept for backwards-compat with existing call sites — nav is
// now rendered by Layout via StrikketorgetNav, so we no longer use it.
const { current: _current } = Astro.props;
---

<div class="bg-linen min-h-[60vh]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-2 sm:py-6">
    <slot />
  </div>
</div>
