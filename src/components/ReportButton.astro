---
interface Props {
  targetType: string;
  targetId: string;
}

const { targetType, targetId } = Astro.props;
const formId = `report-${targetId}`;
---

<div class="relative inline-block" data-report-wrapper>
  <button
    type="button"
    class="text-xs text-charcoal/35 hover:text-terracotta-500 transition-colors"
    data-report-toggle
  >
    Rapporter
  </button>

  <div class="hidden absolute right-0 bottom-full mb-2 w-64 bg-white rounded-xl border border-sage-500/15 shadow-lg p-4 z-20" data-report-dropdown>
    <p class="text-xs font-bold uppercase tracking-widest text-charcoal/40 mb-2">Rapporter innhold</p>
    <form id={formId} data-report-form class="space-y-2">
      <input type="hidden" name="target_type" value={targetType} />
      <input type="hidden" name="target_id" value={targetId} />
      <select name="reason" required class="w-full bg-linen rounded-lg px-3 py-2 text-xs border border-sage-500/15 focus:outline-none focus:border-sage-500">
        <option value="">Velg grunn…</option>
        <option value="scam">Svindel</option>
        <option value="inappropriate">Upassende innhold</option>
        <option value="wrong_category">Feil kategori</option>
        <option value="spam">Spam</option>
        <option value="other">Annet</option>
      </select>
      <textarea name="description" rows="2" maxlength="500" placeholder="Beskriv problemet (valgfritt)…" class="w-full bg-linen rounded-lg px-3 py-2 text-xs border border-sage-500/15 focus:outline-none focus:border-sage-500 resize-none"></textarea>
      <label class="flex items-start gap-1.5 text-[11px] text-charcoal/65 cursor-pointer">
        <input type="checkbox" name="anonymous" class="mt-0.5" />
        <span>Hold meg anonym. Moderator kan ikke kontakte meg for oppfølging.</span>
      </label>
      <button type="submit" class="w-full bg-red-500 text-white px-3 py-2 rounded-lg text-xs font-medium hover:bg-red-600 transition-colors disabled:bg-charcoal/20 disabled:hover:bg-charcoal/20 disabled:cursor-not-allowed">Send rapport</button>
      <p class="text-[10px] text-charcoal/40 hidden" data-report-status></p>
    </form>
  </div>
</div>

<script>
  import { init } from "../lib/client/controllers/report-button";
  import { registerController } from "../lib/client/dom";
  registerController(init);
</script>
