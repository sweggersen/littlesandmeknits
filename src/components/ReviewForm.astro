---
interface Props {
  commissionRequestId: string;
  existingReview?: boolean;
}

const { commissionRequestId, existingReview = false } = Astro.props;
---

{existingReview ? (
  <div class="bg-sage-100 rounded-2xl p-4 text-sm text-sage-900">
    Du har allerede gitt en vurdering for dette oppdraget.
  </div>
) : (
  <div class="bg-white rounded-2xl p-5 border border-sage-500/10" data-review-form-wrapper>
    <p class="font-medium text-sm mb-3">Gi en vurdering</p>
    <form data-review-form class="space-y-3">
      <input type="hidden" name="commission_request_id" value={commissionRequestId} />

      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">Vurdering</p>
        <div class="flex gap-1" data-star-group>
          {[1,2,3,4,5].map(star => (
            <button
              type="button"
              data-star={star}
              class="w-8 h-8 rounded-lg hover:bg-sage-100/50 flex items-center justify-center transition-colors"
              aria-label={`${star} stjerner`}
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-charcoal/20">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            </button>
          ))}
        </div>
        <input type="hidden" name="rating" value="" data-rating-input />
      </div>

      <textarea name="comment" rows="2" maxlength="500" placeholder="Skriv en kommentar (valgfritt)…" class="w-full bg-linen rounded-lg px-3 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 resize-none"></textarea>

      <button type="submit" disabled class="w-full bg-primary text-primary-fg px-4 py-2.5 rounded-full text-xs font-medium hover:bg-primary-hover transition-colors disabled:opacity-40 disabled:cursor-not-allowed">Send vurdering</button>
      <p class="text-[10px] text-charcoal/40 hidden" data-review-status></p>
    </form>
  </div>
)}

<script>
  import { init } from "../lib/client/controllers/review-form";
  import { registerController } from "../lib/client/dom";
  registerController(init);
</script>
