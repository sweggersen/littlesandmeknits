---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';

const topics = [
  {
    href: '/hjelp/selge',
    title: 'Hvordan selge',
    body: 'Lag den første annonsen, gode bilder, riktig pris og hvordan sende varen.',
    icon: '🧶',
  },
  {
    href: '/hjelp/kjope',
    title: 'Hvordan kjøpe',
    body: 'Slik finner du riktig plagg, betaler trygt og mottar varen.',
    icon: '🛒',
  },
  {
    href: '/hjelp/trygg-betaling',
    title: 'Trygg betaling forklart',
    body: 'Kjøperen belastes først når varen sendes, og kjøpet er beskyttet til det er fullført. Slik fungerer det.',
    icon: '🛡️',
  },
];

const faqs = [
  {
    q: 'Hvor gammel må jeg være?',
    a: 'Du må være minst 13 år for Strikkestua, og 15 år for å kjøpe eller selge på Strikketorget. Aldersgrensen for kjøp og salg følger vergemålsloven § 12.',
  },
  {
    q: 'Hvor mye koster det å legge ut en annonse?',
    a: 'Det er gratis å legge ut og publisere annonser. Vi tar ingen prosent av salget. Kjøperen betaler en liten avgift (9–29 kr avhengig av pris) når trygg betaling er aktivert, og du som selger får hele beløpet.',
  },
  {
    q: 'Hvor lang tid tar det før annonsen blir synlig?',
    a: 'Annonser gjennomgår kort moderering, vanligvis innen et døgn. Du får varsel når den er publisert.',
  },
  {
    q: 'Hva hvis kjøperen ikke svarer etter at jeg har sendt varen?',
    a: 'Med trygg betaling regnes varen som levert 14 dager etter sending, og handelen fullføres automatisk. Du trenger ikke jage kjøperen.',
  },
  {
    q: 'Kan jeg selge på vegne av en butikk eller organisasjon?',
    a: 'Ja. Opprett en butikk via Strikkestua og knytt den til organisasjonen din via Tier-2-verifisering. Da kan du publisere som butikk.',
  },
];
---

<Layout title="Hjelp · Strikketorget" lang="nb">
  <div class="max-w-3xl mx-auto px-6 py-14">
    <h1 class="font-serif text-4xl sm:text-5xl mb-3">Hjelp</h1>
    <p class="text-charcoal/55 text-base mb-10">
      Korte guider og svar på vanlige spørsmål. Finner du ikke det du leter etter?
      Send en e-post til <a href="mailto:hei@littlesandmeknits.com" class="text-terracotta-500 hover:underline">hei@littlesandmeknits.com</a>.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-14">
      {topics.map((t) => (
        <a href={t.href} class="block bg-white rounded-3xl p-5 border border-sage-500/10 hover:border-sage-500/30 transition-colors">
          <p class="text-2xl mb-3">{t.icon}</p>
          <h2 class="font-serif text-lg mb-2">{t.title}</h2>
          <p class="text-sm text-charcoal/65 leading-relaxed">{t.body}</p>
        </a>
      ))}
    </div>

    <h2 class="font-serif text-2xl mb-5">Vanlige spørsmål</h2>
    <div class="space-y-3">
      {faqs.map((f) => (
        <details class="bg-white rounded-2xl border border-sage-500/10 p-4">
          <summary class="cursor-pointer text-sm font-medium">{f.q}</summary>
          <p class="text-sm text-charcoal/70 mt-3 leading-relaxed">{f.a}</p>
        </details>
      ))}
    </div>

    <section id="kontakt" class="mt-14 pt-10 border-t border-sage-500/10">
      <h2 class="font-serif text-2xl mb-2">Kontakt oss</h2>
      <p class="text-sm text-charcoal/55 mb-5">
        Fant du ikke svaret? Send oss en melding, så svarer vi så fort vi kan. Du må være innlogget for å bruke skjemaet, eller send en
        <a href="mailto:hei@littlesandmeknits.com" class="text-terracotta-500 hover:underline">e-post</a>.
      </p>

      <div data-support-sent class="hidden mb-5 rounded-2xl bg-sage-100/60 border border-sage-500/20 p-4 text-sm text-sage-900">
        Takk! Meldingen er sendt. Vi tar kontakt så snart vi kan.
      </div>

      <form method="post" action="/api/support/submit" class="bg-white rounded-3xl p-6 border border-sage-500/10 space-y-4">
        <div>
          <label for="support-category" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Tema</label>
          <select id="support-category" name="category" class="w-full bg-linen rounded-xl px-4 py-3 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500">
            <option value="kjop">Kjøp</option>
            <option value="salg">Salg</option>
            <option value="betaling">Betaling og utbetaling</option>
            <option value="konto">Konto</option>
            <option value="annet" selected>Annet</option>
          </select>
        </div>
        <div>
          <label for="support-subject" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Emne (valgfritt)</label>
          <input id="support-subject" name="subject" type="text" maxlength="200" class="w-full bg-linen rounded-xl px-4 py-3 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500" />
        </div>
        <div>
          <label for="support-body" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Melding</label>
          <textarea id="support-body" name="body" required minlength="5" maxlength="4000" rows="5" placeholder="Hva kan vi hjelpe deg med?"
            class="w-full bg-linen rounded-xl px-4 py-3 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 resize-none"></textarea>
        </div>
        <button type="submit" class="btn-primary rounded-full py-2.5 px-5 text-sm font-semibold">Send melding</button>
      </form>
    </section>
  </div>

  <script is:inline>
    if (new URLSearchParams(location.search).get('sent') === '1') {
      document.querySelector('[data-support-sent]')?.classList.remove('hidden');
      document.getElementById('kontakt')?.scrollIntoView({ block: 'start' });
    }
  </script>
</Layout>
