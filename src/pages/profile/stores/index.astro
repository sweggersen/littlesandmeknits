---
import Layout from '../../../layouts/Layout.astro';
import { buildServiceContext } from '../../../lib/services/context';
import { listMyStores } from '../../../lib/services/stores';
import { ROLE_LABEL_NB } from '../../../lib/services/store-permissions';
import { projectPhotoUrl } from '../../../lib/storage';

const ctx = await buildServiceContext(Astro.request, Astro.cookies);
if (!ctx) return Astro.redirect('/login?next=/profile/stores');

const res = await listMyStores(ctx);
const stores = res.ok ? res.data : [];

const STATUS_LABEL: Record<string, string> = {
  draft: 'Utkast',
  pending_review: 'Til moderering',
  active: 'Aktiv',
  suspended: 'Suspendert',
  archived: 'Slettet (kan gjenopprettes)',
};
const STATUS_TONE: Record<string, string> = {
  draft: 'bg-charcoal/10 text-charcoal/70',
  pending_review: 'bg-amber-100 text-amber-800',
  active: 'bg-sage-100 text-sage-800',
  suspended: 'bg-red-100 text-red-800',
  archived: 'bg-charcoal/10 text-charcoal/55',
};
---

<Layout title="Mine butikker — Strikketorget" lang="nb">
  <div class="bg-linen min-h-[60vh]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="font-serif text-3xl sm:text-4xl">Mine butikker</h1>
          <p class="text-charcoal/55 mt-1">Butikker du eier eller er medlem av</p>
        </div>
        <a
          href="/profile/stores/new"
          class="bg-charcoal text-linen px-4 sm:px-5 py-2.5 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors shrink-0"
        >
          + Ny butikk
        </a>
      </div>

      {stores.length === 0 && (
        <div class="bg-white rounded-3xl border border-sage-500/10 p-8 text-center">
          <p class="text-charcoal/70 mb-3">Du har ingen butikker ennå.</p>
          <p class="text-sm text-charcoal/55 mb-6">
            Har du et registrert foretak? Opprett en butikk og selg som virksomhet.
          </p>
          <a
            href="/profile/stores/new"
            class="inline-block bg-charcoal text-linen px-5 py-2.5 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors"
          >
            Opprett din første butikk
          </a>
        </div>
      )}

      {stores.length > 0 && (
        <ul class="space-y-3">
          {stores.map((s: any) => (
            <li>
              <a
                href={`/market/store/${s.slug}/admin`}
                class="block bg-white rounded-2xl border border-sage-500/10 hover:border-sage-500/30 transition-colors p-5"
              >
                <div class="flex items-center gap-4">
                  {s.logo_path ? (
                    <img src={projectPhotoUrl(s.logo_path)} alt="" class="w-14 h-14 rounded-xl object-cover shrink-0" />
                  ) : (
                    <div class="w-14 h-14 rounded-xl bg-sage-100 flex items-center justify-center font-serif text-xl text-sage-700 shrink-0">
                      {s.name?.[0]?.toUpperCase() ?? '?'}
                    </div>
                  )}
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <h2 class="font-serif text-lg truncate">{s.name}</h2>
                      <span class={`text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-full ${STATUS_TONE[s.status]}`}>
                        {STATUS_LABEL[s.status]}
                      </span>
                    </div>
                    <p class="text-xs text-charcoal/55 mt-0.5">
                      {ROLE_LABEL_NB[s.my_role as keyof typeof ROLE_LABEL_NB]} · /{s.slug}
                    </p>
                  </div>
                  <span class="text-charcoal/30 text-xl shrink-0">→</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</Layout>
