---
// Profile design variant V4 — "Focus". A calm, task-first single column: a
// prominent "today" card of what needs action, quick actions, then compact
// stacked sections. Mobile-first. Same data as /profile via the shared loader.
import Layout from '../../layouts/Layout.astro';
import ProfileAvatar from '../../components/ProfileAvatar.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import AdminModPanel from '../../components/profile/AdminModPanel.astro';
import VariantSwitcher from '../../components/profile/VariantSwitcher.astro';
import { createServerSupabase } from '../../lib/supabase';
import { projectPhotoUrl } from '../../lib/storage';
import { loadProfileDashboard } from '../../lib/profile-dashboard-data';
import { COMMISSION_STATUS, LISTING_STATUS, KIND_LABEL } from '../../lib/labels';

const user = Astro.locals.user!;
const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const d = await loadProfileDashboard(supabase, user);

// "Today" — the actionable items, each a link.
type Todo = { label: string; href: string; icon: string };
const todos: Todo[] = [];
if (d.unreadCount > 0) todos.push({ label: `${d.unreadCount} ulest${d.unreadCount === 1 ? '' : 'e'} melding${d.unreadCount === 1 ? '' : 'er'}`, href: '/market/messages', icon: '✉️' });
if (d.awaitingPayment > 0) todos.push({ label: `${d.awaitingPayment} oppdrag venter på betaling`, href: '/market/commissions/my-listings', icon: '⏳' });
if (d.acceptedOffers > 0) todos.push({ label: `${d.acceptedOffers} akseptert${d.acceptedOffers === 1 ? '' : 'e'} tilbud å følge opp`, href: '/market/commissions/my-listings', icon: '✅' });
if (d.pendingOffers > 0) todos.push({ label: `${d.pendingOffers} ${d.pendingOffers === 1 ? 'nytt' : 'nye'} tilbud å vurdere`, href: '/market/commissions/my-listings', icon: '📩' });
if (d.activeProjects > 0) todos.push({ label: `${d.activeProjects} aktiv${d.activeProjects === 1 ? 't' : 'e'} prosjekt${d.activeProjects === 1 ? '' : 'er'}`, href: '/studio', icon: '🧶' });

const quickActions = [
  { label: 'Ny annonse', href: '/market/listing/new', icon: '🏷️' },
  { label: 'Nytt oppdrag', href: '/market/commissions', icon: '🪡' },
  { label: 'Meldinger', href: '/market/messages', icon: '✉️' },
  { label: 'Strikkestua', href: '/studio', icon: '🧶' },
];
function comVariant(s: string) {
  if (['awaiting_payment', 'disputed'].includes(s)) return 'red';
  if (['awaiting_yarn', 'awarded', 'open'].includes(s)) return 'amber';
  if (['completed', 'delivered'].includes(s)) return 'sage';
  return 'default';
}
---

<Layout title="Min profil (V4) — Littles and Me Knits" lang="nb">
  <div class="bg-linen min-h-screen">
    <div class="max-w-xl mx-auto px-4 py-8 pb-24 space-y-6">

      <!-- Compact header -->
      <div class="flex items-center gap-3">
        <ProfileAvatar url={d.avatarUrl} name={d.displayName} size="md" />
        <div class="min-w-0 flex-1">
          <h1 class="font-serif text-xl truncate">{d.displayName}</h1>
          <a href={`/market/seller/${user.id}`} class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Se offentlig profil →</a>
        </div>
        <a href="/profile/edit" class="text-sm font-medium text-charcoal/45 hover:text-terracotta-500 transition-colors shrink-0">Rediger</a>
      </div>

      {d.isStaff && <AdminModPanel isAdmin={d.isAdmin} pendingQueueCount={d.pendingQueueCount} />}

      <!-- Today -->
      <section class:list={['rounded-3xl p-5', todos.length > 0 ? 'bg-charcoal text-linen' : 'bg-white border border-sage-500/10']}>
        <p class:list={['text-[10px] font-bold uppercase tracking-widest mb-3', todos.length > 0 ? 'text-linen/45' : 'text-charcoal/40']}>I dag</p>
        {todos.length === 0 ? (
          <p class="text-sm text-charcoal/60">Alt er i orden, ingenting krever handling akkurat nå. ☕</p>
        ) : (
          <ul class="space-y-1">
            {todos.map((t) => (
              <li>
                <a href={t.href} class="flex items-center gap-3 -mx-2 px-2 py-2 rounded-xl hover:bg-white/10 transition-colors">
                  <span class="text-base leading-none">{t.icon}</span>
                  <span class="text-sm flex-1">{t.label}</span>
                  <span class="text-linen/40">›</span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>

      <!-- Quick actions -->
      <div class="grid grid-cols-4 gap-2">
        {quickActions.map((a) => (
          <a href={a.href} class="flex flex-col items-center gap-1.5 bg-white rounded-2xl border border-sage-500/10 hover:border-sage-500/30 transition-colors py-3">
            <span class="text-lg leading-none">{a.icon}</span>
            <span class="text-[11px] text-charcoal/60 text-center leading-tight">{a.label}</span>
          </a>
        ))}
      </div>

      <!-- Oppdrag -->
      {(d.allRequests.length > 0 || d.allOffers.length > 0) && (
        <section class="bg-white rounded-2xl border border-sage-500/10 overflow-hidden">
          <div class="flex items-center justify-between px-4 py-3 border-b border-sage-500/10">
            <h2 class="font-serif text-base">Oppdrag</h2>
            <a href="/market/commissions/my-listings" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Se alle →</a>
          </div>
          <ul class="divide-y divide-sage-500/8">
            {d.allRequests.slice(0, 3).map((r) => (
              <li><a href={`/market/commissions/${r.id}`} class="flex items-center gap-3 px-4 py-3 hover:bg-linen/60 transition-colors">
                <div class="min-w-0 flex-1"><p class="text-sm font-medium truncate">{r.title}</p><p class="text-[11px] text-charcoal/50">{r.offer_count ?? 0} tilbud</p></div>
                <StatusBadge label={COMMISSION_STATUS[r.status] ?? r.status} variant={comVariant(r.status) as any} />
              </a></li>
            ))}
            {d.allOffers.slice(0, 2).map((o) => {
              const req = (o as any).commission_requests;
              return req && (
                <li><a href={`/market/commissions/${req.id}`} class="flex items-center gap-3 px-4 py-3 hover:bg-linen/60 transition-colors">
                  <div class="min-w-0 flex-1"><p class="text-sm font-medium truncate">{req.title}</p><p class="text-[11px] text-charcoal/50">Ditt tilbud · {o.price_nok} kr</p></div>
                  <StatusBadge label={COMMISSION_STATUS[o.status] ?? o.status} variant={comVariant(o.status) as any} />
                </a></li>
              );
            })}
          </ul>
        </section>
      )}

      <!-- Prosjekter -->
      {d.allProjects.length > 0 && (
        <section class="bg-white rounded-2xl border border-sage-500/10 overflow-hidden">
          <div class="flex items-center justify-between px-4 py-3 border-b border-sage-500/10">
            <h2 class="font-serif text-base">Prosjekter</h2>
            <a href="/studio" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Alle →</a>
          </div>
          <div class="flex gap-3 overflow-x-auto p-4">
            {d.allProjects.slice(0, 6).map((p) => (
              <a href={`/studio/projects/${p.id}`} class="shrink-0 w-28">
                <div class="aspect-square rounded-xl overflow-hidden bg-oatmeal/60 mb-1.5">
                  {p.hero_photo_path ? <img src={projectPhotoUrl(p.hero_photo_path)!} alt="" class="w-full h-full object-cover" /> : <div class="w-full h-full grid place-items-center text-xl">🧶</div>}
                </div>
                <p class="text-xs font-medium truncate">{p.title}</p>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Annonser -->
      {d.allListings.length > 0 && (
        <section class="bg-white rounded-2xl border border-sage-500/10 overflow-hidden">
          <div class="flex items-center justify-between px-4 py-3 border-b border-sage-500/10">
            <h2 class="font-serif text-base">Annonser</h2>
            <a href="/market/my-listings" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Alle →</a>
          </div>
          <ul class="divide-y divide-sage-500/8">
            {d.allListings.slice(0, 4).map((l) => (
              <li><a href={`/market/listing/${l.id}`} class="flex items-center gap-3 px-4 py-2.5 hover:bg-linen/60 transition-colors">
                {l.hero_photo_path ? <img src={projectPhotoUrl(l.hero_photo_path)!} alt="" class="w-10 h-10 rounded-lg object-cover" /> : <div class="w-10 h-10 rounded-lg bg-oatmeal/60"></div>}
                <div class="min-w-0 flex-1"><p class="text-sm font-medium truncate">{l.title}</p><p class="text-[11px] text-charcoal/50">{KIND_LABEL[l.kind] ?? l.kind} · {l.price_nok} kr · {LISTING_STATUS[l.status] ?? l.status}</p></div>
              </a></li>
            ))}
          </ul>
        </section>
      )}

      <!-- Butikker + Bibliotek compact -->
      {(d.myStores.length > 0 || d.allBibliotek.length > 0) && (
        <section class="bg-white rounded-2xl border border-sage-500/10 p-4 space-y-3">
          {d.myStores.length > 0 && (
            <div>
              <div class="flex items-center justify-between mb-2"><h2 class="font-serif text-base">Butikker</h2><a href="/profile/stores" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Alle →</a></div>
              <div class="flex flex-wrap gap-2">
                {d.myStores.slice(0, 4).map((s) => (
                  <a href={s.href} class="flex items-center gap-2 rounded-full border border-sage-500/15 pl-1.5 pr-3 py-1 hover:border-sage-500/40 transition-colors">
                    {s.logo_path ? <img src={projectPhotoUrl(s.logo_path)!} alt="" class="w-6 h-6 rounded-full object-cover" /> : <div class="w-6 h-6 rounded-full bg-oatmeal grid place-items-center text-xs">🏪</div>}
                    <span class="text-xs font-medium">{s.name}</span>
                  </a>
                ))}
              </div>
            </div>
          )}
          {d.allBibliotek.length > 0 && (
            <div>
              <div class="flex items-center justify-between mb-2"><h2 class="font-serif text-base">Bibliotek</h2><a href="/profile/library" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Alle →</a></div>
              <p class="text-xs text-charcoal/55">{d.allBibliotek.length} oppskrift{d.allBibliotek.length === 1 ? '' : 'er'} lagret</p>
            </div>
          )}
        </section>
      )}

      <div class="pt-4 flex flex-wrap gap-x-4 gap-y-2 text-sm justify-center">
        <a href="/profile/badges" class="text-charcoal/45 hover:text-terracotta-500 transition-colors">Merker ({d.totalEarned})</a>
        <a href="/market/my-purchases" class="text-charcoal/45 hover:text-terracotta-500 transition-colors">Kjøp</a>
        <a href="/profile/data" class="text-charcoal/45 hover:text-terracotta-500 transition-colors">Data</a>
        <a href="/innstillinger" class="text-charcoal/45 hover:text-terracotta-500 transition-colors">Innstillinger</a>
        <form method="post" action="/api/auth/signout" class="inline"><button type="submit" class="text-charcoal/45 hover:text-terracotta-500 transition-colors">Logg ut</button></form>
      </div>
    </div>
  </div>
  <VariantSwitcher current="v4" />
</Layout>
