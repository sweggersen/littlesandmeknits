---
// Profile dashboard — "Command Center": stat cards + a needs-attention activity
// feed + side panels. The default /profile. Data comes from the shared loader
// (src/lib/profile-dashboard-data.ts). The previous layout is kept, unlinked,
// at /profile/original.
import Layout from '../../layouts/Layout.astro';
import ProfileAvatar from '../../components/ProfileAvatar.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import StatIcon from '../../components/profile/StatIcon.astro';
import BadgeMedal from '../../components/profile/BadgeMedal.astro';
import AdminModPanel from '../../components/profile/AdminModPanel.astro';
import { createServerSupabase } from '../../lib/supabase';
import { projectPhotoUrl } from '../../lib/storage';
import { loadProfileDashboard } from '../../lib/profile-dashboard-data';
import { COMMISSION_STATUS, LISTING_STATUS, PROJECT_STATUS, KIND_LABEL, CATEGORY_LABEL } from '../../lib/labels';
import { formatDate } from '../../lib/time';

const user = Astro.locals.user!; // middleware-gated
const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const d = await loadProfileDashboard(supabase, user);

// Status → StatusBadge colour.
function comVariant(s: string) {
  if (['awaiting_payment', 'disputed'].includes(s)) return 'red';
  if (['awaiting_yarn', 'awarded', 'open'].includes(s)) return 'amber';
  if (['completed', 'delivered'].includes(s)) return 'sage';
  return 'default';
}
function listVariant(s: string) {
  if (s === 'active') return 'sage';
  if (['reserved', 'shipped'].includes(s)) return 'amber';
  if (s === 'disputed' || s === 'rejected') return 'red';
  return 'muted';
}

const stats = [
  { label: 'Uleste meldinger', value: d.unreadCount, icon: 'mail' as const, href: '/market/messages', hot: d.unreadCount > 0 },
  { label: 'Nye tilbud', value: d.pendingOffers, icon: 'offer' as const, href: '/market/commissions/my-listings', hot: d.pendingOffers > 0 },
  { label: 'Venter på betaling', value: d.awaitingPayment, icon: 'clock' as const, href: '/market/commissions/my-listings', hot: d.awaitingPayment > 0 },
  { label: 'Aktive prosjekter', value: d.activeProjects, icon: 'project' as const, href: '/studio', hot: false },
  { label: 'Annonser', value: d.allListings.length, icon: 'tag' as const, href: '/market/my-listings', hot: false },
  { label: 'Kjøpte oppskrifter', value: d.allPurchases.length, icon: 'book' as const, href: '/profile/purchases', hot: false },
];

// Merge requests + offers + a message row into one "needs attention" feed.
type FeedRow = { title: string; meta: string; status: string; statusLabel: string; variant: string; href: string };
const feed: FeedRow[] = [];
for (const r of d.allRequests.slice(0, 4)) {
  feed.push({
    title: r.title, meta: `Oppdrag · ${r.offer_count ?? 0} tilbud`,
    status: r.status, statusLabel: COMMISSION_STATUS[r.status] ?? r.status,
    variant: comVariant(r.status), href: `/market/commissions/${r.id}`,
  });
}
for (const o of d.allOffers.slice(0, 4)) {
  const req = (o as any).commission_requests;
  if (!req) continue;
  feed.push({
    title: req.title, meta: `Ditt tilbud · ${o.price_nok} kr`,
    status: o.status, statusLabel: COMMISSION_STATUS[o.status] ?? o.status,
    variant: comVariant(o.status), href: `/market/commissions/${req.id}`,
  });
}
---

<Layout title="Min profil — Littles and Me Knits" lang="nb">
  <div class="bg-linen min-h-screen">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 pb-24">

      <!-- Header -->
      <div class="flex items-center gap-4 mb-6">
        <ProfileAvatar url={d.avatarUrl} name={d.displayName} size="lg" />
        <div class="min-w-0">
          <h1 class="font-serif text-2xl sm:text-3xl truncate">{d.displayName}</h1>
        </div>
        <div class="ml-auto flex items-center gap-2 shrink-0" data-view-actions>
          <button type="button" data-edit-toggle class="inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-full border border-sage-500/25 text-charcoal/70 hover:border-sage-500/50 transition-colors">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
            Rediger
          </button>
          <a href={`/market/seller/${user.id}`} class="btn-primary px-4 py-2 rounded-full text-sm font-medium">Offentlig profil</a>
        </div>
        <!-- shown while editing the layout -->
        <div class="ml-auto items-center gap-2 shrink-0 hidden" data-edit-actions>
          <a href="/profile/edit" class="text-sm font-medium text-charcoal/50 hover:text-terracotta-500 transition-colors mr-1">Rediger detaljer →</a>
          <button type="button" data-edit-reset class="text-sm font-medium px-3 py-2 rounded-full text-charcoal/45 hover:text-terracotta-500 transition-colors">Tilbakestill</button>
          <button type="button" data-edit-cancel class="text-sm font-medium px-4 py-2 rounded-full border border-sage-500/25 text-charcoal/70 hover:border-sage-500/50 transition-colors">Avbryt</button>
          <button type="button" data-edit-save class="btn-primary px-4 py-2 rounded-full text-sm font-medium">Lagre</button>
        </div>
      </div>

      {d.isStaff && <div class="mb-6"><AdminModPanel isAdmin={d.isAdmin} pendingQueueCount={d.pendingQueueCount} /></div>}

      <!-- Stat cards -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3 mb-6">
        {stats.map((s) => (
          <a href={s.href} class="bg-white rounded-2xl border border-sage-500/20 p-4 hover:border-sage-500/30 transition-colors">
            <div class="flex items-center justify-between mb-3">
              <StatIcon name={s.icon} class="text-charcoal/35" />
              {s.hot && <span class="w-2 h-2 rounded-full bg-terracotta-500"></span>}
            </div>
            <p class="font-serif text-3xl leading-none tabular-nums">{s.value}</p>
            <p class="text-[11px] text-charcoal/55 mt-1.5 leading-tight">{s.label}</p>
          </a>
        ))}
      </div>

      <div data-edit-hint class="hidden mb-4 rounded-2xl bg-terracotta-500/8 border border-terracotta-500/20 px-4 py-3 text-sm text-terracotta-500">
        Dra kortene for å flytte dem, og bruk størrelse&shy;knappen (S · M · L) for å endre bredde. Trykk «Lagre» når du er fornøyd.
      </div>

      <div id="dashgrid" class="grid grid-cols-1 md:grid-cols-6 gap-4 md:gap-5 items-start" data-user={user.id} data-saved-layout={JSON.stringify(d.savedLayout)}>
        <!-- Trenger oppmerksomhet -->
        <div class="dash-widget md:col-span-4" data-widget="needsAttention" data-size="m" data-default="1" data-label="Trenger oppmerksomhet">
          <section class="bg-white rounded-2xl border border-sage-500/20 overflow-hidden">
            <div class="flex items-center justify-between px-5 py-3.5 border-b border-sage-500/15">
              <h2 class="font-serif text-lg">Trenger oppmerksomhet</h2>
              <a href="/market/commissions/my-listings" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Se alle →</a>
            </div>
            {feed.length === 0 ? (
              <p class="px-5 py-8 text-sm text-charcoal/50 text-center">Ingenting krever handling akkurat nå.</p>
            ) : (
              <ul class="divide-y divide-sage-500/8">
                {feed.map((f) => (
                  <li>
                    <a href={f.href} class="flex items-center gap-3 px-5 py-3 hover:bg-linen/60 transition-colors">
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-medium truncate">{f.title}</p>
                        <p class="text-[11px] text-charcoal/50">{f.meta}</p>
                      </div>
                      <StatusBadge label={f.statusLabel} variant={f.variant as any} />
                      <span class="text-charcoal/25">›</span>
                    </a>
                  </li>
                ))}
                {d.unreadCount > 0 && (
                  <li>
                    <a href="/market/messages" class="flex items-center gap-3 px-5 py-3 hover:bg-linen/60 transition-colors">
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-medium">Uleste meldinger</p>
                        <p class="text-[11px] text-charcoal/50">Innboks</p>
                      </div>
                      <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-terracotta-500 text-white text-[10px] font-bold">{d.unreadCount}</span>
                      <span class="text-charcoal/25">›</span>
                    </a>
                  </li>
                )}
              </ul>
            )}
          </section>
        </div>

        <!-- Nye merker -->
        {d.recentAchievements.length > 0 && (
          <div class="dash-widget md:col-span-2" data-widget="badges" data-size="s" data-default="1" data-label="Nye merker">
            <section class="bg-white rounded-2xl border border-sage-500/20 p-5 h-full">
              <div class="flex items-center justify-between mb-3">
                <h2 class="font-serif text-lg">Nye merker</h2>
                <a href="/profile/badges" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Alle →</a>
              </div>
              <div class="flex flex-wrap gap-2">
                {d.recentAchievements.map((a) => (
                  <a href="/profile/badges" class="group relative flex items-center gap-1.5 pl-1.5 pr-3 py-1 rounded-full text-xs font-medium border bg-linen border-sage-500/20 hover:border-sage-500/40 transition-colors">
                    <BadgeMedal category={a.category} /><span>{a.label}</span>
                    <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2.5 py-1.5 bg-charcoal text-linen text-[10px] leading-snug rounded-lg w-max max-w-[200px] text-center opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity z-20">
                      {a.description}
                      <span class="block text-linen/55 mt-0.5">Oppnådd {formatDate(a.granted_at)}</span>
                    </span>
                  </a>
                ))}
              </div>
            </section>
          </div>
        )}

        <!-- Prosjekter -->
        <div class="dash-widget md:col-span-4" data-widget="projects" data-size="m" data-default="1" data-label="Prosjekter">
          <section class="bg-white rounded-2xl border border-sage-500/20 overflow-hidden">
            <div class="flex items-center justify-between px-5 py-3.5 border-b border-sage-500/15">
              <h2 class="font-serif text-lg">Prosjekter</h2>
              <a href="/studio" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Strikkestua →</a>
            </div>
            {d.allProjects.length === 0 ? (
              <p class="px-5 py-8 text-sm text-charcoal/50 text-center">Ingen prosjekter ennå.</p>
            ) : (
              <div class="grid sm:grid-cols-2 gap-3 p-4">
                {d.allProjects.slice(0, 4).map((p) => (
                  <a href={`/studio/projects/${p.id}`} class="flex items-center gap-3 rounded-xl border border-sage-500/20 hover:border-sage-500/30 transition-colors p-2.5">
                    {p.hero_photo_path
                      ? <img src={projectPhotoUrl(p.hero_photo_path)!} alt="" class="w-12 h-12 rounded-lg object-cover shrink-0" />
                      : <div class="w-12 h-12 rounded-lg bg-oatmeal/60 shrink-0"></div>}
                    <div class="min-w-0 flex-1">
                      <p class="text-sm font-medium truncate">{p.title}</p>
                      <StatusBadge label={PROJECT_STATUS[p.status] ?? p.status} variant={p.status === 'active' ? 'sage' : 'muted'} class="mt-1" />
                    </div>
                  </a>
                ))}
              </div>
            )}
          </section>
        </div>

        <!-- Mine butikker -->
        <div class="dash-widget md:col-span-2" data-widget="stores" data-size="s" data-default="1" data-label="Mine butikker">
          <section class="bg-white rounded-2xl border border-sage-500/20 p-5 h-full">
            <div class="flex items-center justify-between mb-3">
              <h2 class="font-serif text-lg">Mine butikker</h2>
              <a href="/profile/stores/new" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">+ Ny</a>
            </div>
            {d.myStores.length === 0 ? (
              <p class="text-sm text-charcoal/50">Ingen butikker.</p>
            ) : (
              <ul class="space-y-2">
                {d.myStores.slice(0, 4).map((s) => (
                  <li>
                    <a href={s.href} class="flex items-center gap-3 rounded-xl border border-sage-500/20 hover:border-sage-500/30 transition-colors p-2.5">
                      {s.logo_path
                        ? <img src={projectPhotoUrl(s.logo_path)!} alt="" class="w-9 h-9 rounded-lg object-cover shrink-0" />
                        : <div class="w-9 h-9 rounded-lg bg-oatmeal/60 shrink-0 grid place-items-center font-serif text-sm text-charcoal/40">{(s.name?.[0] ?? '?').toUpperCase()}</div>}
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-medium truncate">{s.name}</p>
                        <p class="text-[11px] text-charcoal/50">{s.statusLabel}</p>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </section>
        </div>

        <!-- Annonser -->
        <div class="dash-widget md:col-span-4" data-widget="listings" data-size="m" data-default="1" data-label="Annonser">
          <section class="bg-white rounded-2xl border border-sage-500/20 overflow-hidden">
            <div class="flex items-center justify-between px-5 py-3.5 border-b border-sage-500/15">
              <h2 class="font-serif text-lg">Annonser</h2>
              <a href="/market/my-listings" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Se alle →</a>
            </div>
            {d.allListings.length === 0 ? (
              <div class="px-5 py-8 text-center">
                <p class="text-sm text-charcoal/50 mb-3">Ingen annonser ennå.</p>
                <a href="/market/listing/new" class="btn-primary px-4 py-2 rounded-full text-xs font-medium">Legg ut annonse</a>
              </div>
            ) : (
              <ul class="divide-y divide-sage-500/8">
                {d.allListings.slice(0, 5).map((l) => (
                  <li>
                    <a href={`/market/listing/${l.id}`} class="flex items-center gap-3 px-5 py-3 hover:bg-linen/60 transition-colors">
                      {l.hero_photo_path
                        ? <img src={projectPhotoUrl(l.hero_photo_path)!} alt="" class="w-11 h-11 rounded-lg object-cover shrink-0" />
                        : <div class="w-11 h-11 rounded-lg bg-oatmeal/60 shrink-0"></div>}
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-medium truncate">{l.title}</p>
                        <p class="text-[11px] text-charcoal/50">{KIND_LABEL[l.kind] ?? l.kind} · {l.price_nok} kr</p>
                      </div>
                      <StatusBadge label={LISTING_STATUS[l.status] ?? l.status} variant={listVariant(l.status) as any} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </section>
        </div>

        <!-- Bibliotek -->
        <div class="dash-widget md:col-span-2" data-widget="library" data-size="s" data-default="1" data-label="Bibliotek">
          <section class="bg-white rounded-2xl border border-sage-500/20 p-5 h-full">
            <div class="flex items-center justify-between mb-3">
              <h2 class="font-serif text-lg">Bibliotek</h2>
              <a href="/profile/library/new" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">+ Ny</a>
            </div>
            {d.allBibliotek.length === 0 ? (
              <p class="text-sm text-charcoal/50">Ingen oppskrifter lagret.</p>
            ) : (
              <ul class="space-y-1">
                {d.allBibliotek.slice(0, 4).map((b: any) => (
                  <li>
                    <a href={`/profile/library/${b.id}`} class="flex items-center gap-3 -mx-1.5 px-1.5 py-1.5 rounded-xl hover:bg-linen/70 transition-colors">
                      {b.cover_path
                        ? <img src={projectPhotoUrl(b.cover_path)!} alt="" class="w-9 h-12 rounded object-cover shrink-0" />
                        : <div class="w-9 h-12 rounded bg-oatmeal/60 shrink-0"></div>}
                      <div class="min-w-0">
                        <p class="text-sm font-medium truncate">{b.title}</p>
                        {b.designer && <p class="text-[11px] text-charcoal/50 truncate">{b.designer}</p>}
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </section>
        </div>

        <!-- Snarveier -->
        <div class="dash-widget md:col-span-2" data-widget="snarveier" data-size="s" data-default="1" data-label="Snarveier">
          <section class="bg-white rounded-2xl border border-sage-500/20 p-5 h-full">
            <h2 class="font-serif text-lg mb-3">Snarveier</h2>
            <div class="flex flex-col gap-2 text-sm">
              <a href="/market/my-purchases" class="text-charcoal/60 hover:text-terracotta-500 transition-colors">Kjøp og kvitteringer →</a>
              <a href="/market/favorites" class="text-charcoal/60 hover:text-terracotta-500 transition-colors">Favoritter →</a>
              <a href="/profile/data" class="text-charcoal/60 hover:text-terracotta-500 transition-colors">Personvern og data →</a>
              <a href="/innstillinger" class="text-charcoal/60 hover:text-terracotta-500 transition-colors">Innstillinger →</a>
              <form method="post" action="/api/auth/signout" class="inline">
                <button type="submit" class="text-charcoal/60 hover:text-terracotta-500 transition-colors">Logg ut →</button>
              </form>
            </div>
          </section>
        </div>

        <!-- Kjøpte oppskrifter (valgfritt panel) -->
        <div class="dash-widget md:col-span-2" data-widget="purchases" data-size="s" data-default="0" data-label="Kjøpte oppskrifter">
          <section class="bg-white rounded-2xl border border-sage-500/20 p-5 h-full">
            <div class="flex items-center justify-between mb-3">
              <h2 class="font-serif text-lg">Kjøpte oppskrifter</h2>
              <a href="/market/my-purchases" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Alle →</a>
            </div>
            {d.allPurchases.length === 0 ? (
              <p class="text-sm text-charcoal/50">Ingen kjøpte oppskrifter.</p>
            ) : (
              <ul class="space-y-1">
                {d.allPurchases.slice(0, 5).map((p: any) => (
                  <li>
                    <a href="/market/my-purchases" class="flex items-center justify-between gap-3 -mx-1.5 px-1.5 py-1.5 rounded-xl hover:bg-linen/70 transition-colors">
                      <span class="text-sm font-medium truncate">{p.title}</span>
                      <span class="text-[11px] text-charcoal/50 shrink-0">{p.amount_nok} kr</span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </section>
        </div>

        <!-- Mine tilbud (valgfritt panel) -->
        <div class="dash-widget md:col-span-4" data-widget="offers" data-size="m" data-default="0" data-label="Mine tilbud">
          <section class="bg-white rounded-2xl border border-sage-500/20 overflow-hidden">
            <div class="flex items-center justify-between px-5 py-3.5 border-b border-sage-500/15">
              <h2 class="font-serif text-lg">Mine tilbud</h2>
              <a href="/market/commissions" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Oppdrag →</a>
            </div>
            {d.allOffers.length === 0 ? (
              <p class="px-5 py-8 text-sm text-charcoal/50 text-center">Du har ikke sendt noen tilbud.</p>
            ) : (
              <ul class="divide-y divide-sage-500/8">
                {d.allOffers.slice(0, 5).map((o: any) => (
                  <li>
                    <a href={o.commission_requests?.id ? `/market/commissions/${o.commission_requests.id}` : '/market/commissions'} class="flex items-center gap-3 px-5 py-3 hover:bg-linen/60 transition-colors">
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-medium truncate">{o.commission_requests?.title ?? 'Oppdrag'}</p>
                        <p class="text-[11px] text-charcoal/50">{o.price_nok} kr · {o.turnaround_weeks} uker</p>
                      </div>
                      <StatusBadge label={COMMISSION_STATUS[o.status] ?? o.status} variant={comVariant(o.status) as any} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </section>
        </div>

        <!-- Mine forespørsler (valgfritt panel) -->
        <div class="dash-widget md:col-span-4" data-widget="requests" data-size="m" data-default="0" data-label="Mine forespørsler">
          <section class="bg-white rounded-2xl border border-sage-500/20 overflow-hidden">
            <div class="flex items-center justify-between px-5 py-3.5 border-b border-sage-500/15">
              <h2 class="font-serif text-lg">Mine forespørsler</h2>
              <a href="/market/commissions/new" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">+ Ny</a>
            </div>
            {d.allRequests.length === 0 ? (
              <p class="px-5 py-8 text-sm text-charcoal/50 text-center">Ingen forespørsler ennå.</p>
            ) : (
              <ul class="divide-y divide-sage-500/8">
                {d.allRequests.slice(0, 5).map((r: any) => (
                  <li>
                    <a href={`/market/commissions/${r.id}`} class="flex items-center gap-3 px-5 py-3 hover:bg-linen/60 transition-colors">
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-medium truncate">{r.title}</p>
                        <p class="text-[11px] text-charcoal/50">{CATEGORY_LABEL[r.category] ?? r.category} · {r.budget_nok_min}–{r.budget_nok_max} kr · {r.offer_count} tilbud</p>
                      </div>
                      <StatusBadge label={COMMISSION_STATUS[r.status] ?? r.status} variant={comVariant(r.status) as any} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </section>
        </div>

        <!-- Om meg (valgfritt panel) -->
        <div class="dash-widget md:col-span-2" data-widget="about" data-size="s" data-default="0" data-label="Om meg">
          <section class="bg-white rounded-2xl border border-sage-500/20 p-5 h-full">
            <div class="flex items-center justify-between mb-3">
              <h2 class="font-serif text-lg">Om meg</h2>
              <a href="/innstillinger" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Rediger →</a>
            </div>
            {d.profile?.bio
              ? <p class="text-sm text-charcoal/70 leading-relaxed whitespace-pre-line">{d.profile.bio}</p>
              : <p class="text-sm text-charcoal/50">Ingen presentasjon ennå.</p>}
            <div class="mt-3 space-y-1.5 text-[13px] text-charcoal/60">
              {d.profile?.location && <p>📍 {d.profile.location}</p>}
              {d.profile?.instagram_handle && <p>Instagram: @{d.profile.instagram_handle.replace(/^@/, '')}</p>}
            </div>
            {Array.isArray(d.profile?.seller_tags) && d.profile.seller_tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1.5">
                {d.profile.seller_tags.map((t: string) => (
                  <span class="px-2.5 py-1 rounded-full text-[11px] font-medium bg-linen border border-sage-500/20">{t}</span>
                ))}
              </div>
            )}
          </section>
        </div>
      </div>

      <!-- Panel-palett (kun i redigeringsmodus): fjernede paneler du kan legge til igjen -->
      <div data-dash-palette class="hidden mt-5 bg-white rounded-2xl border border-dashed border-sage-500/30 p-5">
        <h2 class="font-serif text-base mb-1">Legg til paneler</h2>
        <p class="text-[11px] text-charcoal/45 mb-3">Paneler du har fjernet dukker opp her. Klikk for å legge dem tilbake.</p>
        <div data-dash-palette-list class="flex flex-wrap gap-2"></div>
        <p data-dash-palette-empty class="text-sm text-charcoal/45">Alle paneler er i bruk.</p>
      </div>
    </div>
  </div>

  <style is:global>
    .dash-widget { position: relative; }
    /* Removed panels are hidden from the grid; they live in the palette. */
    .dash-widget.dash-removed { display: none; }
    .dash-tools { display: none; position: absolute; top: 8px; right: 8px; z-index: 20; gap: 6px; align-items: center; }
    body.dash-editing .dash-tools { display: flex; pointer-events: auto; }
    body.dash-editing .dash-widget { cursor: grab; outline: 2px dashed transparent; outline-offset: 3px; border-radius: 18px; transition: outline-color .12s; }
    body.dash-editing .dash-widget:hover { outline-color: rgba(194,96,74,.35); }
    /* Freeze card interactions while editing so drags don't fire links. */
    body.dash-editing .dash-widget > section { pointer-events: none; user-select: none; }
    .dash-tools .dash-grip { display: grid; place-items: center; width: 26px; height: 26px; border-radius: 8px; background: #3B3733; color: #F7F2EA; cursor: grab; }
    /* Segmented size control: S / M / L, active highlighted. */
    .dash-sizes { display: inline-flex; border-radius: 8px; overflow: hidden; background: #3B3733; }
    .dash-sizes .dash-size { min-width: 24px; height: 26px; padding: 0 8px; border: 0; background: transparent; color: rgba(247,242,234,.55); font-size: 11px; font-weight: 700; cursor: pointer; transition: background .12s, color .12s; }
    .dash-sizes .dash-size:hover { color: #F7F2EA; }
    .dash-sizes .dash-size.is-active { background: #C2604A; color: #fff; }
    .dash-tools .dash-remove { display: grid; place-items: center; width: 26px; height: 26px; border-radius: 8px; border: 0; background: #3B3733; color: #F7F2EA; font-size: 15px; line-height: 1; cursor: pointer; }
    .dash-tools .dash-remove:hover { background: #C2604A; }
    .dash-widget.dash-dragging { opacity: .4; }
    /* Palette add-chips. */
    [data-dash-palette] { display: none; }
    body.dash-editing [data-dash-palette] { display: block; }
    .dash-add { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 9999px; border: 1px solid rgba(122,138,110,.3); background: #F7F2EA; color: #3B3733; font-size: 13px; font-weight: 500; cursor: pointer; transition: border-color .12s, background .12s; }
    .dash-add:hover { border-color: rgba(194,96,74,.5); background: #fff; }
    .dash-add .dash-add-plus { color: #C2604A; font-weight: 700; }
    @media (prefers-reduced-motion: reduce) { body.dash-editing .dash-widget { transition: none; } }
  </style>
  <script>
    import { init } from '../../lib/client/controllers/profile-dashboard-edit';
    import { registerController } from '../../lib/client/dom';
    registerController(init);
  </script>
</Layout>
