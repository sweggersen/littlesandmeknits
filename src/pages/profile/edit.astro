---
import Layout from '../../layouts/Layout.astro';
import { createServerSupabase } from '../../lib/supabase';
import { projectPhotoUrl } from '../../lib/storage';

const user = Astro.locals.user!;  // middleware-gated route

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const { data: profile } = await supabase
  .from('profiles')
  .select('display_name, first_name, last_name, bio, location, avatar_path, seller_tags, instagram_handle, profile_visible, stripe_onboarded, stripe_account_id, updated_at')
  .eq('id', user.id)
  .maybeSingle();

const meta = (user.user_metadata ?? {}) as { language?: 'nb' | 'en' };
const language = meta.language ?? 'nb';

// Cache-buster — the avatar path stays the same on every upload, so
// without this the browser/CDN serves the stale image after a re-upload.
const avatarVersion = profile?.updated_at ? new Date(profile.updated_at).getTime() : '';
const avatarBase = profile?.avatar_path ? projectPhotoUrl(profile.avatar_path) : null;
const avatarUrl = avatarBase ? `${avatarBase}?v=${avatarVersion}` : null;
const displayName = profile?.display_name ?? user.user_metadata?.display_name ?? '';

const ALL_TAGS = [
  { value: 'knitter', label: 'Strikker' },
  { value: 'sells_pre_loved', label: 'Selger brukt' },
  { value: 'sells_ready_made', label: 'Selger ferdigstrikket' },
];
const currentTags = profile?.seller_tags ?? [];
const saved = Astro.url.searchParams.get('saved') === '1';
---

<Layout title="Rediger profil — Littles and Me Knits" lang="nb">
  <div class="bg-linen min-h-[60vh]">
    <div class="max-w-xl mx-auto px-4 sm:px-6 py-8 sm:py-12 relative">
      <a href="/profile" class="text-sm text-charcoal/45 hover:text-terracotta-500 transition-colors mb-4 block">← Tilbake til profil</a>
      <div class="flex items-start justify-between gap-4 mb-2">
        <h1 class="font-serif text-3xl">Rediger profil</h1>
        {/* Save button — appears next to the heading when the user stages
            an avatar (or has unsaved changes) so they don't have to scroll
            down to submit. Sits inside the content column. */}
        <button
          type="submit"
          form="profile-edit-form"
          data-sticky-save
          class="hidden shrink-0 btn-primary rounded-full py-2 px-4 text-sm font-semibold shadow-sm"
        >
          Lagre profil
        </button>
      </div>
      <p class="text-sm text-charcoal/55 mb-8">
        Dine innstillinger for Strikketorget og Strikkestua.
      </p>

      {saved && (
        <div class="bg-sage-100 text-sage-900 rounded-2xl p-4 mb-6 text-sm">
          Profilen er oppdatert.
        </div>
      )}

      <form id="profile-edit-form" method="post" action="/api/profile/edit" enctype="multipart/form-data" data-astro-reload class="space-y-6">

        <!-- Avatar -->
        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Profilbilde</label>
          <div class="flex items-center gap-4">
            {avatarUrl ? (
              <img src={avatarUrl} alt="" data-avatar-preview class="w-16 h-16 rounded-full object-cover shrink-0" />
            ) : (
              <div class="w-16 h-16 rounded-full bg-sage-100 flex items-center justify-center shrink-0 overflow-hidden">
                <img data-avatar-preview alt="" class="w-16 h-16 rounded-full object-cover" style="display:none;" onload="this.style.display=''" />
                <span class="font-serif text-xl text-sage-700">
                  {(displayName || '?')[0].toUpperCase()}
                </span>
              </div>
            )}
            <input name="avatar" type="file" accept="image/jpeg,image/png,image/webp" data-avatar-input
              class="text-sm file:mr-2 file:rounded-full file:border-0 file:bg-charcoal file:text-linen file:px-4 file:py-2 file:text-xs file:font-medium hover:file:bg-terracotta-500 file:transition-colors file:cursor-pointer" />
          </div>
        </div>

        {/* Square-crop modal, opens when the user picks an avatar file */}
        <div data-crop-modal class="hidden fixed inset-0 z-[60] bg-charcoal/60 backdrop-blur-sm flex items-center justify-center p-4" aria-modal="true" role="dialog">
          <div class="bg-white rounded-3xl p-5 sm:p-6 w-full max-w-md shadow-2xl">
            <h3 class="font-serif text-lg mb-4 text-center">Tilpass profilbildet</h3>
            <div
              data-crop-container
              class="relative mx-auto bg-charcoal/5 rounded-2xl overflow-hidden touch-none select-none cursor-grab"
              style="width: 288px; height: 288px;"
            >
              <img data-crop-image alt="" class="absolute top-0 left-0 max-w-none origin-top-left pointer-events-none" />
              {/* Round overlay mask */}
              <div class="absolute inset-0 pointer-events-none" style="box-shadow: 0 0 0 144px rgba(60, 60, 60, 0.55) inset; border-radius: 9999px;"></div>
            </div>
            <label class="block mt-5">
              <span class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Zoom</span>
              <input data-crop-zoom type="range" min="1" max="3" step="0.01" value="1" class="w-full accent-terracotta-500" />
            </label>
            <div class="flex gap-3 mt-5">
              <button type="button" data-crop-cancel class="flex-1 rounded-full py-2.5 px-4 text-sm font-medium border border-sage-500/30 text-charcoal/80 hover:bg-sage-100/40">Avbryt</button>
              <button type="button" data-crop-confirm class="flex-1 btn-primary rounded-full py-2.5 px-4 text-sm font-semibold">Bruk bilde</button>
            </div>
          </div>
        </div>

        <!-- First + Last name -->
        <div class="grid grid-cols-2 gap-3">
          <label class="block">
            <span class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Fornavn</span>
            <input name="first_name" type="text" maxlength="40" value={profile?.first_name ?? ''} autocomplete="given-name"
              class="w-full bg-white rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors" />
          </label>
          <label class="block">
            <span class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Etternavn</span>
            <input name="last_name" type="text" maxlength="40" value={profile?.last_name ?? ''} autocomplete="family-name"
              class="w-full bg-white rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors" />
          </label>
        </div>

        <!-- Display name (public) -->
        <label class="block">
          <span class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Visningsnavn (offentlig)</span>
          <input name="display_name" type="text" maxlength="60" value={displayName}
            placeholder="La stå tomt for å bruke fornavn + etternavn"
            class="w-full bg-white rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors" />
          <span class="block text-xs text-charcoal/45 mt-1.5">Dette vises på annonsene dine og selgerprofilen.</span>
        </label>

        <!-- Bio -->
        <label class="block">
          <span class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Om deg</span>
          <textarea name="bio" rows="3" maxlength="500" placeholder="Fortell litt om deg selv og hva du strikker…"
            class="w-full bg-white rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors resize-none"
          >{profile?.bio ?? ''}</textarea>
        </label>

        <!-- Location -->
        <label class="block">
          <span class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Sted</span>
          <input name="location" type="text" maxlength="100" placeholder="F.eks. Oslo, Bergen, Tromsø…" value={profile?.location ?? ''}
            class="w-full bg-white rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors" />
        </label>

        <!-- Instagram -->
        <label class="block">
          <span class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Instagram</span>
          <div class="flex items-center bg-white rounded-xl border border-sage-500/15 focus-within:border-sage-500 transition-colors">
            <span class="pl-4 text-charcoal/40">@</span>
            <input name="instagram_handle" type="text" maxlength="30" value={profile?.instagram_handle ?? user.user_metadata?.instagram_handle ?? ''}
              class="flex-1 bg-transparent px-2 py-3 text-base focus:outline-none" />
          </div>
        </label>

        <!-- Language -->
        <label class="block">
          <span class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Språk</span>
          <select name="language"
            class="w-full bg-white rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors">
            <option value="nb" selected={language === 'nb'}>Norsk (bokmål)</option>
            <option value="en" selected={language === 'en'}>English</option>
          </select>
        </label>

        <!-- Seller tags -->
        <fieldset>
          <legend class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Hva beskriver deg?</legend>
          <div class="flex flex-wrap gap-2">
            {ALL_TAGS.map((tag) => (
              <label class="cursor-pointer">
                <input type="checkbox" name="seller_tags" value={tag.value} checked={currentTags.includes(tag.value)} class="peer sr-only" />
                <span class="inline-block text-sm font-medium px-3 py-1.5 rounded-full border border-sage-500/20 text-charcoal/60 peer-checked:bg-terracotta-500/10 peer-checked:border-terracotta-500/30 peer-checked:text-terracotta-500 transition-colors">
                  {tag.label}
                </span>
              </label>
            ))}
          </div>
        </fieldset>

        <!-- Visibility -->
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" name="profile_visible" value="1" checked={profile?.profile_visible !== false}
            class="w-5 h-5 rounded border-sage-500/30 text-terracotta-500 focus:ring-terracotta-500/30" />
          <span class="text-sm">Vis profilen min offentlig på Strikketorget</span>
        </label>

        <button type="submit" class="w-full bg-primary text-primary-fg px-6 py-3.5 rounded-full text-base font-medium hover:bg-primary-hover transition-colors">
          Lagre profil
        </button>
      </form>

      <!-- Seller payouts (Stripe Connect Custom under the hood) -->
      {currentTags.length > 0 && (
        <div class="mt-8 bg-white rounded-3xl p-6 border border-sage-500/10">
          <h2 class="text-sm font-bold uppercase tracking-widest text-charcoal/55 mb-3">Utbetalinger</h2>
          {profile?.stripe_onboarded ? (
            <div>
              <p class="text-sm text-sage-600 mb-3">Du er verifisert som selger. Vi setter pengene rett i kontoen din etter hvert salg.</p>
              <a href="/profile/become-seller" class="text-sm text-charcoal/55 hover:text-charcoal underline">
                Oppdater utbetalingsinformasjon
              </a>
            </div>
          ) : (
            <div>
              <p class="text-sm text-charcoal/55 mb-3">Registrer kontoen din for å motta betaling når du selger.</p>
              <a
                href="/profile/become-seller"
                class="inline-block bg-primary text-primary-fg px-5 py-2.5 rounded-full text-sm font-medium hover:bg-primary-hover transition-colors"
              >
                Bli selger
              </a>
            </div>
          )}
        </div>
      )}

      <!-- Account details -->
      <details class="mt-8">
        <summary class="text-xs text-charcoal/55 cursor-pointer hover:text-charcoal">Konto-detaljer</summary>
        <dl class="grid grid-cols-[max-content_1fr] gap-x-6 gap-y-3 text-sm mt-4 bg-white rounded-2xl p-5 border border-sage-500/10">
          <dt class="text-charcoal/50">Epost</dt>
          <dd class="text-charcoal break-all">{user.email}</dd>
          <dt class="text-charcoal/50">Bruker-ID</dt>
          <dd class="text-charcoal/70 font-mono text-xs break-all">{user.id}</dd>
        </dl>
      </details>
    </div>
  </div>
</Layout>

<script>
  function initAvatarCropper() {
    const fileInput = document.querySelector<HTMLInputElement>('[data-avatar-input]');
    const modal = document.querySelector<HTMLElement>('[data-crop-modal]');
    if (!fileInput || !modal) return;
    if ((fileInput as any)._cropBound) return;
    (fileInput as any)._cropBound = true;

    const container = modal.querySelector<HTMLElement>('[data-crop-container]')!;
    const img = modal.querySelector<HTMLImageElement>('[data-crop-image]')!;
    const zoom = modal.querySelector<HTMLInputElement>('[data-crop-zoom]')!;
    const cancel = modal.querySelector<HTMLButtonElement>('[data-crop-cancel]')!;
    const confirm = modal.querySelector<HTMLButtonElement>('[data-crop-confirm]')!;

    const CROP = 288; // visible square in CSS px
    const OUT = 512;  // output image px (uploaded to storage)
    let baseScale = 1;
    let scale = 1;
    let tx = 0;
    let ty = 0;
    let dragging = false;
    let lastX = 0;
    let lastY = 0;

    function clamp(v: number, min: number, max: number) {
      return Math.max(min, Math.min(max, v));
    }

    function applyBounds() {
      const totalScale = baseScale * scale;
      const w = img.naturalWidth * totalScale;
      const h = img.naturalHeight * totalScale;
      // Keep image covering the crop square at all times.
      tx = clamp(tx, CROP - w, 0);
      ty = clamp(ty, CROP - h, 0);
    }

    function render() {
      applyBounds();
      img.style.transform = `translate(${tx}px, ${ty}px) scale(${baseScale * scale})`;
    }

    function openModal(file: File) {
      const reader = new FileReader();
      reader.onload = () => {
        img.onload = () => {
          // Fit shortest side to crop square; user can zoom in further.
          baseScale = CROP / Math.min(img.naturalWidth, img.naturalHeight);
          scale = 1;
          zoom.value = '1';
          // Center
          tx = (CROP - img.naturalWidth * baseScale) / 2;
          ty = (CROP - img.naturalHeight * baseScale) / 2;
          render();
          modal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        };
        img.src = String(reader.result);
      };
      reader.readAsDataURL(file);
    }

    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    fileInput.addEventListener('change', () => {
      const f = fileInput.files?.[0];
      if (!f) return;
      openModal(f);
    });

    zoom.addEventListener('input', () => { scale = parseFloat(zoom.value); render(); });

    // Drag (mouse + touch)
    function startDrag(x: number, y: number) { dragging = true; lastX = x; lastY = y; container.style.cursor = 'grabbing'; }
    function moveDrag(x: number, y: number) {
      if (!dragging) return;
      tx += (x - lastX); ty += (y - lastY); lastX = x; lastY = y; render();
    }
    function endDrag() { dragging = false; container.style.cursor = 'grab'; }

    container.addEventListener('mousedown', (e) => startDrag(e.clientX, e.clientY));
    window.addEventListener('mousemove', (e) => moveDrag(e.clientX, e.clientY));
    window.addEventListener('mouseup', endDrag);
    container.addEventListener('touchstart', (e) => { const t = e.touches[0]; startDrag(t.clientX, t.clientY); }, { passive: true });
    window.addEventListener('touchmove', (e) => { const t = e.touches[0]; moveDrag(t.clientX, t.clientY); }, { passive: true });
    window.addEventListener('touchend', endDrag);

    cancel.addEventListener('click', () => {
      fileInput.value = '';
      closeModal();
    });

    confirm.addEventListener('click', async () => {
      const canvas = document.createElement('canvas');
      canvas.width = OUT;
      canvas.height = OUT;
      const ctx = canvas.getContext('2d')!;
      const totalScale = baseScale * scale;
      const srcX = -tx / totalScale;
      const srcY = -ty / totalScale;
      const srcSize = CROP / totalScale;
      ctx.drawImage(img, srcX, srcY, srcSize, srcSize, 0, 0, OUT, OUT);
      const blob = await new Promise<Blob | null>((resolve) => canvas.toBlob(resolve, 'image/jpeg', 0.92));
      if (!blob) { closeModal(); return; }
      const cropped = new File([blob], 'avatar.jpg', { type: 'image/jpeg' });
      const dt = new DataTransfer();
      dt.items.add(cropped);
      fileInput.files = dt.files;
      // Reveal the floating Lagre-profil button so the user can submit
      // without scrolling. Also flip the inline preview eagerly.
      document.querySelector<HTMLButtonElement>('[data-sticky-save]')?.classList.remove('hidden');
      const previewUrl = URL.createObjectURL(cropped);
      document.querySelectorAll<HTMLImageElement>('[data-avatar-preview]').forEach((el) => {
        el.src = previewUrl;
      });
      closeModal();
    });

    modal.addEventListener('click', (e) => { if (e.target === modal) { fileInput.value = ''; closeModal(); } });
  }

  document.addEventListener('astro:page-load', initAvatarCropper);
</script>
