---
// Profile design variant V2 — "Command Center". A SaaS-dashboard treatment
// (stat cards + a needs-attention activity feed + side panels), inspired by the
// referenced ops dashboard but on the Littles-and-Me palette. Same data as
// /profile via the shared loader. Non-destructive: the original /profile stays.
import Layout from '../../layouts/Layout.astro';
import ProfileAvatar from '../../components/ProfileAvatar.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import AdminModPanel from '../../components/profile/AdminModPanel.astro';
import VariantSwitcher from '../../components/profile/VariantSwitcher.astro';
import { createServerSupabase } from '../../lib/supabase';
import { projectPhotoUrl } from '../../lib/storage';
import { loadProfileDashboard } from '../../lib/profile-dashboard-data';
import { COMMISSION_STATUS, LISTING_STATUS, PROJECT_STATUS, KIND_LABEL } from '../../lib/labels';

const user = Astro.locals.user!; // middleware-gated
const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const d = await loadProfileDashboard(supabase, user);

// Status → StatusBadge colour.
function comVariant(s: string) {
  if (['awaiting_payment', 'disputed'].includes(s)) return 'red';
  if (['awaiting_yarn', 'awarded', 'open'].includes(s)) return 'amber';
  if (['completed', 'delivered'].includes(s)) return 'sage';
  return 'default';
}
function listVariant(s: string) {
  if (s === 'active') return 'sage';
  if (['reserved', 'shipped'].includes(s)) return 'amber';
  if (s === 'disputed' || s === 'rejected') return 'red';
  return 'muted';
}

const stats = [
  { label: 'Uleste meldinger', value: d.unreadCount, icon: '✉️', href: '/market/messages', hot: d.unreadCount > 0 },
  { label: 'Nye tilbud', value: d.pendingOffers, icon: '📩', href: '/market/commissions/my-listings', hot: d.pendingOffers > 0 },
  { label: 'Venter på betaling', value: d.awaitingPayment, icon: '⏳', href: '/market/commissions/my-listings', hot: d.awaitingPayment > 0 },
  { label: 'Aktive prosjekter', value: d.activeProjects, icon: '🧶', href: '/studio', hot: false },
  { label: 'Annonser', value: d.allListings.length, icon: '🏷️', href: '/market/my-listings', hot: false },
  { label: 'Kjøpte oppskrifter', value: d.allPurchases.length, icon: '📘', href: '/profile/purchases', hot: false },
];

// Merge requests + offers + a message row into one "needs attention" feed.
type FeedRow = { title: string; meta: string; status: string; statusLabel: string; variant: string; href: string };
const feed: FeedRow[] = [];
for (const r of d.allRequests.slice(0, 4)) {
  feed.push({
    title: r.title, meta: `Oppdrag · ${r.offer_count ?? 0} tilbud`,
    status: r.status, statusLabel: COMMISSION_STATUS[r.status] ?? r.status,
    variant: comVariant(r.status), href: `/market/commissions/${r.id}`,
  });
}
for (const o of d.allOffers.slice(0, 4)) {
  const req = (o as any).commission_requests;
  if (!req) continue;
  feed.push({
    title: req.title, meta: `Ditt tilbud · ${o.price_nok} kr`,
    status: o.status, statusLabel: COMMISSION_STATUS[o.status] ?? o.status,
    variant: comVariant(o.status), href: `/market/commissions/${req.id}`,
  });
}
---

<Layout title="Min profil (V2) — Littles and Me Knits" lang="nb">
  <div class="bg-linen min-h-screen">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 pb-24">

      <!-- Header -->
      <div class="flex items-center gap-4 mb-6">
        <ProfileAvatar url={d.avatarUrl} name={d.displayName} size="lg" />
        <div class="min-w-0">
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">Kommandosenter</p>
          <h1 class="font-serif text-2xl sm:text-3xl truncate">{d.displayName}</h1>
        </div>
        <div class="ml-auto flex items-center gap-2 shrink-0">
          <a href="/profile/edit" class="text-sm font-medium px-4 py-2 rounded-full border border-sage-500/25 text-charcoal/70 hover:border-sage-500/50 transition-colors">Rediger</a>
          <a href={`/market/seller/${user.id}`} class="btn-primary px-4 py-2 rounded-full text-sm font-medium">Offentlig profil</a>
        </div>
      </div>

      {d.isStaff && <div class="mb-6"><AdminModPanel isAdmin={d.isAdmin} pendingQueueCount={d.pendingQueueCount} /></div>}

      <!-- Stat cards -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3 mb-6">
        {stats.map((s) => (
          <a href={s.href} class="bg-white rounded-2xl border border-sage-500/10 p-4 hover:border-sage-500/30 transition-colors">
            <div class="flex items-center justify-between mb-3">
              <span class="text-base leading-none">{s.icon}</span>
              {s.hot && <span class="w-2 h-2 rounded-full bg-terracotta-500"></span>}
            </div>
            <p class="font-serif text-3xl leading-none tabular-nums">{s.value}</p>
            <p class="text-[11px] text-charcoal/55 mt-1.5 leading-tight">{s.label}</p>
          </a>
        ))}
      </div>

      <div class="grid lg:grid-cols-3 gap-6 items-start">
        <!-- Left: needs attention + projects + listings -->
        <div class="lg:col-span-2 space-y-6">
          <section class="bg-white rounded-2xl border border-sage-500/10 overflow-hidden">
            <div class="flex items-center justify-between px-5 py-3.5 border-b border-sage-500/10">
              <h2 class="font-serif text-lg">Trenger oppmerksomhet</h2>
              <a href="/market/commissions/my-listings" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Se alle →</a>
            </div>
            {feed.length === 0 ? (
              <p class="px-5 py-8 text-sm text-charcoal/50 text-center">Ingenting krever handling akkurat nå.</p>
            ) : (
              <ul class="divide-y divide-sage-500/8">
                {feed.map((f) => (
                  <li>
                    <a href={f.href} class="flex items-center gap-3 px-5 py-3 hover:bg-linen/60 transition-colors">
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-medium truncate">{f.title}</p>
                        <p class="text-[11px] text-charcoal/50">{f.meta}</p>
                      </div>
                      <StatusBadge label={f.statusLabel} variant={f.variant as any} />
                      <span class="text-charcoal/25">›</span>
                    </a>
                  </li>
                ))}
                {d.unreadCount > 0 && (
                  <li>
                    <a href="/market/messages" class="flex items-center gap-3 px-5 py-3 hover:bg-linen/60 transition-colors">
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-medium">Uleste meldinger</p>
                        <p class="text-[11px] text-charcoal/50">Innboks</p>
                      </div>
                      <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-terracotta-500 text-white text-[10px] font-bold">{d.unreadCount}</span>
                      <span class="text-charcoal/25">›</span>
                    </a>
                  </li>
                )}
              </ul>
            )}
          </section>

          <!-- Projects -->
          <section class="bg-white rounded-2xl border border-sage-500/10 overflow-hidden">
            <div class="flex items-center justify-between px-5 py-3.5 border-b border-sage-500/10">
              <h2 class="font-serif text-lg">Prosjekter</h2>
              <a href="/studio" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Strikkestua →</a>
            </div>
            {d.allProjects.length === 0 ? (
              <p class="px-5 py-8 text-sm text-charcoal/50 text-center">Ingen prosjekter ennå.</p>
            ) : (
              <div class="grid sm:grid-cols-2 gap-3 p-4">
                {d.allProjects.slice(0, 4).map((p) => (
                  <a href={`/studio/projects/${p.id}`} class="flex items-center gap-3 rounded-xl border border-sage-500/10 hover:border-sage-500/30 transition-colors p-2.5">
                    {p.hero_photo_path
                      ? <img src={projectPhotoUrl(p.hero_photo_path)!} alt="" class="w-12 h-12 rounded-lg object-cover shrink-0" />
                      : <div class="w-12 h-12 rounded-lg bg-oatmeal/60 shrink-0 grid place-items-center text-base">🧶</div>}
                    <div class="min-w-0 flex-1">
                      <p class="text-sm font-medium truncate">{p.title}</p>
                      <StatusBadge label={PROJECT_STATUS[p.status] ?? p.status} variant={p.status === 'active' ? 'sage' : 'muted'} class="mt-1" />
                    </div>
                  </a>
                ))}
              </div>
            )}
          </section>

          <!-- Listings -->
          <section class="bg-white rounded-2xl border border-sage-500/10 overflow-hidden">
            <div class="flex items-center justify-between px-5 py-3.5 border-b border-sage-500/10">
              <h2 class="font-serif text-lg">Annonser</h2>
              <a href="/market/my-listings" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Se alle →</a>
            </div>
            {d.allListings.length === 0 ? (
              <div class="px-5 py-8 text-center">
                <p class="text-sm text-charcoal/50 mb-3">Ingen annonser ennå.</p>
                <a href="/market/listing/new" class="btn-primary px-4 py-2 rounded-full text-xs font-medium">Legg ut annonse</a>
              </div>
            ) : (
              <ul class="divide-y divide-sage-500/8">
                {d.allListings.slice(0, 5).map((l) => (
                  <li>
                    <a href={`/market/listing/${l.id}`} class="flex items-center gap-3 px-5 py-3 hover:bg-linen/60 transition-colors">
                      {l.hero_photo_path
                        ? <img src={projectPhotoUrl(l.hero_photo_path)!} alt="" class="w-11 h-11 rounded-lg object-cover shrink-0" />
                        : <div class="w-11 h-11 rounded-lg bg-oatmeal/60 shrink-0"></div>}
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-medium truncate">{l.title}</p>
                        <p class="text-[11px] text-charcoal/50">{KIND_LABEL[l.kind] ?? l.kind} · {l.price_nok} kr</p>
                      </div>
                      <StatusBadge label={LISTING_STATUS[l.status] ?? l.status} variant={listVariant(l.status) as any} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </section>
        </div>

        <!-- Right: side panels -->
        <div class="space-y-6">
          {d.recentAchievements.length > 0 && (
            <section class="bg-white rounded-2xl border border-sage-500/10 p-5">
              <div class="flex items-center justify-between mb-3">
                <h2 class="font-serif text-lg">Nye merker</h2>
                <a href="/profile/badges" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Alle →</a>
              </div>
              <div class="flex flex-wrap gap-2">
                {d.recentAchievements.map((a) => (
                  <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium border bg-linen border-sage-500/20" title={a.description}>
                    <span>{a.emoji}</span><span>{a.label}</span>
                  </span>
                ))}
              </div>
            </section>
          )}

          <section class="bg-white rounded-2xl border border-sage-500/10 p-5">
            <div class="flex items-center justify-between mb-3">
              <h2 class="font-serif text-lg">Mine butikker</h2>
              <a href="/profile/stores/new" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">+ Ny</a>
            </div>
            {d.myStores.length === 0 ? (
              <p class="text-sm text-charcoal/50">Ingen butikker.</p>
            ) : (
              <ul class="space-y-2">
                {d.myStores.slice(0, 4).map((s) => (
                  <li>
                    <a href={s.href} class="flex items-center gap-3 rounded-xl border border-sage-500/10 hover:border-sage-500/30 transition-colors p-2.5">
                      {s.logo_path
                        ? <img src={projectPhotoUrl(s.logo_path)!} alt="" class="w-9 h-9 rounded-lg object-cover shrink-0" />
                        : <div class="w-9 h-9 rounded-lg bg-oatmeal/60 shrink-0 grid place-items-center text-sm">🏪</div>}
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-medium truncate">{s.name}</p>
                        <p class="text-[11px] text-charcoal/50">{s.statusLabel}</p>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </section>

          <section class="bg-white rounded-2xl border border-sage-500/10 p-5">
            <div class="flex items-center justify-between mb-3">
              <h2 class="font-serif text-lg">Bibliotek</h2>
              <a href="/profile/library/new" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">+ Ny</a>
            </div>
            {d.allBibliotek.length === 0 ? (
              <p class="text-sm text-charcoal/50">Ingen oppskrifter lagret.</p>
            ) : (
              <ul class="space-y-2">
                {d.allBibliotek.slice(0, 4).map((b: any) => (
                  <li class="flex items-center gap-3">
                    {b.cover_path
                      ? <img src={projectPhotoUrl(b.cover_path)!} alt="" class="w-9 h-12 rounded object-cover shrink-0" />
                      : <div class="w-9 h-12 rounded bg-oatmeal/60 shrink-0"></div>}
                    <div class="min-w-0">
                      <p class="text-sm font-medium truncate">{b.title}</p>
                      {b.designer && <p class="text-[11px] text-charcoal/50 truncate">{b.designer}</p>}
                    </div>
                  </li>
                ))}
              </ul>
            )}
          </section>

          <div class="bg-white rounded-2xl border border-sage-500/10 p-5">
            <h2 class="font-serif text-lg mb-3">Snarveier</h2>
            <div class="flex flex-col gap-2 text-sm">
              <a href="/market/my-purchases" class="text-charcoal/60 hover:text-terracotta-500 transition-colors">Kjøp og kvitteringer →</a>
              <a href="/market/favorites" class="text-charcoal/60 hover:text-terracotta-500 transition-colors">Favoritter →</a>
              <a href="/profile/data" class="text-charcoal/60 hover:text-terracotta-500 transition-colors">Personvern og data →</a>
              <a href="/innstillinger" class="text-charcoal/60 hover:text-terracotta-500 transition-colors">Innstillinger →</a>
              <form method="post" action="/api/auth/signout" class="inline">
                <button type="submit" class="text-charcoal/60 hover:text-terracotta-500 transition-colors">Logg ut →</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <VariantSwitcher current="v2" />
</Layout>
