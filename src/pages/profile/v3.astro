---
// Profile design variant V3 — "Editorial". A boutique/magazine treatment: a
// warm hero band, large serif headers, generous spacing, soft cards. Same data
// as /profile via the shared loader.
import Layout from '../../layouts/Layout.astro';
import ProfileAvatar from '../../components/ProfileAvatar.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import AdminModPanel from '../../components/profile/AdminModPanel.astro';
import VariantSwitcher from '../../components/profile/VariantSwitcher.astro';
import { createServerSupabase } from '../../lib/supabase';
import { projectPhotoUrl } from '../../lib/storage';
import { loadProfileDashboard } from '../../lib/profile-dashboard-data';
import { COMMISSION_STATUS, LISTING_STATUS, PROJECT_STATUS, KIND_LABEL } from '../../lib/labels';

const user = Astro.locals.user!;
const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const d = await loadProfileDashboard(supabase, user);

const heroStats = [
  { label: 'Prosjekter', value: d.allProjects.length },
  { label: 'Annonser', value: d.allListings.length },
  { label: 'Oppskrifter', value: d.allPurchases.length + d.allBibliotek.length },
  { label: 'Merker', value: d.totalEarned },
];
function comVariant(s: string) {
  if (['awaiting_payment', 'disputed'].includes(s)) return 'red';
  if (['awaiting_yarn', 'awarded', 'open'].includes(s)) return 'amber';
  if (['completed', 'delivered'].includes(s)) return 'sage';
  return 'default';
}
---

<Layout title="Min profil (V3) — Littles and Me Knits" lang="nb">
  <!-- Hero band -->
  <div class="bg-charcoal text-linen">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
      <div class="flex flex-col sm:flex-row sm:items-end gap-6">
        <ProfileAvatar url={d.avatarUrl} name={d.displayName} size="xl" />
        <div class="min-w-0 flex-1">
          <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-linen/45 mb-2">Min profil</p>
          <h1 class="font-serif text-4xl sm:text-5xl leading-none">{d.displayName}</h1>
          {d.profile?.bio && <p class="text-linen/65 mt-3 max-w-xl text-sm leading-relaxed">{d.profile.bio}</p>}
          {d.profile?.location && <p class="text-linen/45 text-xs mt-2">📍 {d.profile.location}</p>}
        </div>
        <div class="flex gap-2 shrink-0">
          <a href="/profile/edit" class="text-sm font-medium px-4 py-2 rounded-full ring-1 ring-linen/25 text-linen/80 hover:ring-linen/50 transition-colors">Rediger</a>
          <a href={`/market/seller/${user.id}`} class="text-sm font-medium px-4 py-2 rounded-full bg-linen text-charcoal hover:bg-linen/90 transition-colors">Offentlig</a>
        </div>
      </div>

      <div class="grid grid-cols-4 gap-3 mt-10 max-w-lg">
        {heroStats.map((s) => (
          <div>
            <p class="font-serif text-3xl leading-none tabular-nums">{s.value}</p>
            <p class="text-[10px] uppercase tracking-widest text-linen/45 mt-1.5">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="bg-linen min-h-[40vh]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 pb-24 space-y-14">

      {d.isStaff && <AdminModPanel isAdmin={d.isAdmin} pendingQueueCount={d.pendingQueueCount} />}

      {d.subtitleParts.length > 0 && (
        <div class="bg-terracotta-500/8 border border-terracotta-500/20 rounded-2xl px-5 py-4">
          <p class="text-sm text-charcoal/75"><span class="font-medium">Til deg i dag:</span> {d.subtitleParts.join(' · ')}</p>
        </div>
      )}

      <!-- Oppdrag -->
      <section>
        <div class="flex items-baseline justify-between mb-5 pb-2 border-b border-sage-500/15">
          <h2 class="font-serif text-2xl">Oppdrag</h2>
          <a href="/market/commissions/my-listings" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Se alle →</a>
        </div>
        {d.allRequests.length === 0 && d.allOffers.length === 0 ? (
          <p class="text-sm text-charcoal/50">Ingen aktive oppdrag. <a href="/market/commissions" class="text-terracotta-500 hover:underline">Utforsk oppdrag →</a></p>
        ) : (
          <div class="grid sm:grid-cols-2 gap-4">
            {d.allRequests.slice(0, 2).map((r) => (
              <a href={`/market/commissions/${r.id}`} class="block bg-white rounded-2xl border border-sage-500/10 hover:border-sage-500/30 transition-colors p-5">
                <div class="flex items-start justify-between gap-3 mb-2">
                  <h3 class="font-serif text-lg leading-snug">{r.title}</h3>
                  <StatusBadge label={COMMISSION_STATUS[r.status] ?? r.status} variant={comVariant(r.status) as any} />
                </div>
                <p class="text-sm text-charcoal/55">{r.offer_count ?? 0} tilbud · {r.budget_nok_min}–{r.budget_nok_max} kr</p>
              </a>
            ))}
            {d.allOffers.slice(0, 2).map((o) => {
              const req = (o as any).commission_requests;
              return req && (
                <a href={`/market/commissions/${req.id}`} class="block bg-white rounded-2xl border border-sage-500/10 hover:border-sage-500/30 transition-colors p-5">
                  <div class="flex items-start justify-between gap-3 mb-2">
                    <h3 class="font-serif text-lg leading-snug">{req.title}</h3>
                    <StatusBadge label={COMMISSION_STATUS[o.status] ?? o.status} variant={comVariant(o.status) as any} />
                  </div>
                  <p class="text-sm text-charcoal/55">Ditt tilbud · {o.price_nok} kr · {o.turnaround_weeks} uker</p>
                </a>
              );
            })}
          </div>
        )}
      </section>

      <!-- Prosjekter -->
      <section>
        <div class="flex items-baseline justify-between mb-5 pb-2 border-b border-sage-500/15">
          <h2 class="font-serif text-2xl">Prosjekter</h2>
          <a href="/studio" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Strikkestua →</a>
        </div>
        {d.allProjects.length === 0 ? (
          <p class="text-sm text-charcoal/50">Ingen prosjekter ennå.</p>
        ) : (
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
            {d.allProjects.slice(0, 6).map((p) => (
              <a href={`/studio/projects/${p.id}`} class="group block">
                <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-oatmeal/60 mb-2">
                  {p.hero_photo_path
                    ? <img src={projectPhotoUrl(p.hero_photo_path)!} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                    : <div class="w-full h-full grid place-items-center text-2xl">🧶</div>}
                </div>
                <p class="text-sm font-medium truncate">{p.title}</p>
                <p class="text-[11px] text-charcoal/45">{PROJECT_STATUS[p.status] ?? p.status}</p>
              </a>
            ))}
          </div>
        )}
      </section>

      <!-- Annonser -->
      <section>
        <div class="flex items-baseline justify-between mb-5 pb-2 border-b border-sage-500/15">
          <h2 class="font-serif text-2xl">Annonser</h2>
          <a href="/market/my-listings" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Se alle →</a>
        </div>
        {d.allListings.length === 0 ? (
          <p class="text-sm text-charcoal/50">Ingen annonser. <a href="/market/listing/new" class="text-terracotta-500 hover:underline">Legg ut en →</a></p>
        ) : (
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
            {d.allListings.slice(0, 6).map((l) => (
              <a href={`/market/listing/${l.id}`} class="group block">
                <div class="aspect-square rounded-2xl overflow-hidden bg-oatmeal/60 mb-2">
                  {l.hero_photo_path
                    ? <img src={projectPhotoUrl(l.hero_photo_path)!} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                    : <div class="w-full h-full grid place-items-center text-2xl">🏷️</div>}
                </div>
                <p class="text-sm font-medium truncate">{l.title}</p>
                <p class="text-[11px] text-charcoal/45">{KIND_LABEL[l.kind] ?? l.kind} · {l.price_nok} kr · {LISTING_STATUS[l.status] ?? l.status}</p>
              </a>
            ))}
          </div>
        )}
      </section>

      <!-- Butikker + Bibliotek -->
      <div class="grid sm:grid-cols-2 gap-10">
        <section>
          <div class="flex items-baseline justify-between mb-4 pb-2 border-b border-sage-500/15">
            <h2 class="font-serif text-xl">Butikker</h2>
            <a href="/profile/stores/new" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">+ Ny</a>
          </div>
          {d.myStores.length === 0 ? (
            <p class="text-sm text-charcoal/50">Ingen butikker.</p>
          ) : (
            <ul class="space-y-2">
              {d.myStores.slice(0, 4).map((s) => (
                <li><a href={s.href} class="flex items-center gap-3 p-2 rounded-xl hover:bg-white transition-colors">
                  {s.logo_path ? <img src={projectPhotoUrl(s.logo_path)!} alt="" class="w-9 h-9 rounded-lg object-cover" /> : <div class="w-9 h-9 rounded-lg bg-oatmeal grid place-items-center">🏪</div>}
                  <div class="min-w-0"><p class="text-sm font-medium truncate">{s.name}</p><p class="text-[11px] text-charcoal/45">{s.statusLabel}</p></div>
                </a></li>
              ))}
            </ul>
          )}
        </section>
        <section>
          <div class="flex items-baseline justify-between mb-4 pb-2 border-b border-sage-500/15">
            <h2 class="font-serif text-xl">Bibliotek</h2>
            <a href="/profile/library/new" class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">+ Ny</a>
          </div>
          {d.allBibliotek.length === 0 ? (
            <p class="text-sm text-charcoal/50">Ingen oppskrifter lagret.</p>
          ) : (
            <ul class="space-y-2">
              {d.allBibliotek.slice(0, 4).map((b: any) => (
                <li>
                  <a href={`/profile/library/${b.id}`} class="flex items-center gap-3 p-2 rounded-xl hover:bg-white transition-colors">
                    {b.cover_path ? <img src={projectPhotoUrl(b.cover_path)!} alt="" class="w-9 h-12 rounded object-cover" /> : <div class="w-9 h-12 rounded bg-oatmeal"></div>}
                    <div class="min-w-0"><p class="text-sm font-medium truncate">{b.title}</p>{b.designer && <p class="text-[11px] text-charcoal/45 truncate">{b.designer}</p>}</div>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </section>
      </div>

      <div class="pt-6 border-t border-sage-500/10 flex flex-wrap gap-4 text-sm">
        <a href="/market/my-purchases" class="text-charcoal/45 hover:text-terracotta-500 transition-colors">Kjøp og kvitteringer →</a>
        <a href="/profile/badges" class="text-charcoal/45 hover:text-terracotta-500 transition-colors">Merker ({d.totalEarned}/{d.visibleAchievements.length}) →</a>
        <a href="/innstillinger" class="text-charcoal/45 hover:text-terracotta-500 transition-colors">Innstillinger →</a>
        <form method="post" action="/api/auth/signout" class="inline"><button type="submit" class="text-charcoal/45 hover:text-terracotta-500 transition-colors">Logg ut →</button></form>
      </div>
    </div>
  </div>
  <VariantSwitcher current="v3" />
</Layout>
