---
import Layout from '../../layouts/Layout.astro';
import MarketplaceShell from '../../components/MarketplaceShell.astro';
import ListingCard from '../../components/ListingCard.astro';
import CommissionCard from '../../components/CommissionCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import FavScript from '../../components/FavScript.astro';
import ImpressionTracker from '../../components/ImpressionTracker.astro';
import { createServerSupabase } from '../../lib/supabase';
import { getCurrentUser } from '../../lib/auth';
import { projectPhotoUrl } from '../../lib/storage';
import { KIND_LABEL, CATEGORY_LABEL } from '../../lib/labels';

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const user = await getCurrentUser({ request: Astro.request, cookies: Astro.cookies });

const [{ data: latest }, { data: latestRequests }] = await Promise.all([
  supabase
    .from('listings')
    .select('id, title, kind, price_nok, size_label, hero_photo_path, published_at, promoted_until, promotion_tier')
    .eq('status', 'active')
    .order('promoted_until', { ascending: false, nullsFirst: false })
    .order('published_at', { ascending: false })
    .limit(8),
  supabase
    .from('commission_requests')
    .select('id, title, category, size_label, budget_nok_min, budget_nok_max, offer_count, needed_by')
    .eq('status', 'open')
    .order('created_at', { ascending: false })
    .limit(4),
]);

let favIds: string[] = [];
if (user) {
  try {
    const { data: favs } = await supabase
      .from('favorites')
      .select('item_id')
      .eq('user_id', user.id)
      .eq('item_type', 'listing');
    favIds = (favs ?? []).map(f => f.item_id);
  } catch {}
}

---

<Layout title="Strikketorget — Littles and Me Knits" lang="nb">
  <MarketplaceShell current="home">
      <div class="mb-10">
        <h1 class="font-serif text-4xl sm:text-5xl mb-3">Strikketorget</h1>
        <p class="text-charcoal/55 max-w-lg mb-6">
          Kjøp brukt og nytt strikket fra fellesskapet, eller bestill at noen strikker for deg.
        </p>
        <form action="/marked/brukt" method="get" class="relative max-w-md">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-charcoal/30 pointer-events-none" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" name="q" placeholder="Søk etter plagg, garn, størrelse..."
            class="w-full bg-white rounded-full pl-11 pr-5 py-3 text-sm border border-sage-500/15 focus:border-sage-500/30 focus:outline-none shadow-sm" />
        </form>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 mb-12">
        <a href="/marked/brukt" class="group relative block overflow-hidden rounded-3xl p-6 pb-8 border border-sage-500/10 hover:border-terracotta-500/30 transition-all hover:shadow-md bg-gradient-to-br from-oatmeal/60 to-white">
          <svg class="absolute -right-3 -bottom-3 w-28 h-28 text-terracotta-500/[0.07] transition-transform group-hover:scale-110" viewBox="0 0 80 80" fill="currentColor">
            <path d="M40 8c-4 0-8 2-10 5l-2 4c-2 3-6 5-10 5h-2c-3 0-6 3-6 6v30c0 4 3 7 7 7h46c4 0 7-3 7-7V28c0-3-3-6-6-6h-2c-4 0-8-2-10-5l-2-4c-2-3-6-5-10-5zm0 6a3 3 0 0 1 2 1l3 5c2 3 5 5 9 6v1H26c4-1 7-3 9-6l3-5a3 3 0 0 1 2-1zM27 32h26c1 0 2 1 2 2v16c0 4-3 7-7 7H32c-4 0-7-3-7-7V34c0-1 1-2 2-2zm2 4v14c0 2 1 3 3 3h16c2 0 3-1 3-3V36H29z"/>
          </svg>
          <p class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500 mb-2">Brukt</p>
          <h2 class="font-serif text-2xl mb-2">Pre-loved</h2>
          <p class="text-sm text-charcoal/55">Plagg ungene har vokst fra. Som regel under 500&nbsp;kr.</p>
        </a>
        <a href="/marked/nytt" class="group relative block overflow-hidden rounded-3xl p-6 pb-8 border border-sage-500/10 hover:border-sage-500/30 transition-all hover:shadow-md bg-gradient-to-br from-sage-100/40 to-white">
          <svg class="absolute -right-2 -bottom-2 w-28 h-28 text-sage-500/[0.08] transition-transform group-hover:scale-110" viewBox="0 0 80 80" fill="currentColor">
            <circle cx="40" cy="42" r="22"/>
            <path d="M40 20c-12 0-22 10-22 22s10 22 22 22 22-10 22-22-10-22-22-22zm0 6c9 0 16 7 16 16s-7 16-16 16-16-7-16-16 7-16 16-16z"/>
            <path d="M36 28c-3 2-6 6-6 14 0 6 4 12 10 12s10-6 10-12c0-8-3-12-6-14" fill="none" stroke="currentColor" stroke-width="2.5"/>
            <path d="M40 20V8M44 10l-4-4-4 4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M50 24l8-6M54 14l6 6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <p class="text-[10px] font-bold uppercase tracking-widest text-sage-900 mb-2">Nytt</p>
          <h2 class="font-serif text-2xl mb-2">Ferdigstrikket</h2>
          <p class="text-sm text-charcoal/55">Strikkere selger plagg de har strikket på spec.</p>
        </a>
        <a href="/marked/oppdrag" class="group relative block overflow-hidden rounded-3xl p-6 pb-8 border border-sage-500/10 hover:border-terracotta-500/30 transition-all hover:shadow-md bg-gradient-to-br from-terracotta-500/[0.06] to-white">
          <svg class="absolute -right-2 -bottom-4 w-28 h-28 text-terracotta-500/[0.07] transition-transform group-hover:scale-110" viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 58l10-40c1-3 4-5 7-4l6 2c3 1 5 4 4 7l-8 32"/>
            <path d="M46 58l-10-40c-1-3 1-6 4-7l6-2c3-1 6 1 7 4l8 32"/>
            <path d="M24 40c4 6 12 10 16 10s12-4 16-10"/>
            <circle cx="40" cy="56" r="6" fill="currentColor" opacity="0.3"/>
          </svg>
          <p class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500 mb-2">Bestill</p>
          <h2 class="font-serif text-2xl mb-2">Strikk for meg</h2>
          <p class="text-sm text-charcoal/55">Bestill et plagg fra en strikker i fellesskapet.</p>
        </a>
      </div>

      <h2 class="font-serif text-2xl mb-4">Nyeste annonser</h2>
      {(latest ?? []).length === 0 ? (
        <EmptyState message="Ingen annonser ennå. Kom tilbake snart." />
      ) : (
        <ul class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
          {(latest ?? []).map((l) => (
            <ListingCard
              id={l.id}
              title={l.title}
              price={l.price_nok}
              imgUrl={projectPhotoUrl(l.hero_photo_path)}
              meta={`${KIND_LABEL[l.kind] ?? l.kind} · str. ${l.size_label}`}
              showFav={!!user}
              isFav={favIds.includes(l.id)}
              promoted={!!(l.promoted_until && new Date(l.promoted_until) > new Date() && l.promotion_tier === 'highlight')}
            />
          ))}
        </ul>
      )}
      {(latestRequests ?? []).length > 0 && (
        <>
          <h2 class="font-serif text-2xl mb-4 mt-12">Nyeste forespørsler</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
            {(latestRequests ?? []).map((r) => (
              <CommissionCard
                id={r.id}
                title={r.title}
                category={r.category}
                sizeLabel={r.size_label}
                budgetMin={r.budget_nok_min}
                budgetMax={r.budget_nok_max}
                offerCount={r.offer_count}
              />
            ))}
          </ul>
          <a href="/marked/oppdrag" class="inline-block mt-4 text-sm font-medium text-charcoal/55 hover:text-terracotta-500 transition-colors">
            Se alle forespørsler →
          </a>
        </>
      )}
  </MarketplaceShell>
  <FavScript />
  <ImpressionTracker source="home" />
</Layout>
