---
import Layout from '../../layouts/Layout.astro';
import MarketplaceNav from '../../components/MarketplaceNav.astro';
import { createServerSupabase } from '../../lib/supabase';
import { projectPhotoUrl } from '../../lib/storage';

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const [{ data: latest }, { data: latestRequests }] = await Promise.all([
  supabase
    .from('listings')
    .select('id, title, kind, price_nok, size_label, hero_photo_path, published_at')
    .eq('status', 'active')
    .order('published_at', { ascending: false })
    .limit(8),
  supabase
    .from('commission_requests')
    .select('id, title, category, size_label, budget_nok_min, budget_nok_max, offer_count, needed_by')
    .eq('status', 'open')
    .order('created_at', { ascending: false })
    .limit(4),
]);

const KIND_LABEL: Record<string, string> = { pre_loved: 'Brukt', ready_made: 'Nytt' };
const CATEGORY_LABEL: Record<string, string> = {
  genser: 'Genser', cardigan: 'Cardigan', lue: 'Lue', votter: 'Votter',
  sokker: 'Sokker', teppe: 'Teppe', kjole: 'Kjole', bukser: 'Bukser', annet: 'Annet',
};
---

<Layout title="Strikketorget — Littles and Me Knits" lang="nb">
  <MarketplaceNav current="home" />
  <div class="bg-linen min-h-[60vh]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
      <p class="text-charcoal/65 max-w-xl mb-10">
        Kjøp brukt og nytt strikket fra fellesskapet, eller bestill at noen strikker for deg.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 mb-12">
        <a href="/marked/brukt" class="block bg-white rounded-3xl p-6 border border-sage-500/10 hover:border-terracotta-500/40 transition-colors">
          <p class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500 mb-2">Brukt</p>
          <h2 class="font-serif text-2xl mb-2">Pre-loved</h2>
          <p class="text-sm text-charcoal/65">Plagg ungene har vokst fra. Som regel under 500 NOK.</p>
        </a>
        <a href="/marked/nytt" class="block bg-white rounded-3xl p-6 border border-sage-500/10 hover:border-terracotta-500/40 transition-colors">
          <p class="text-[10px] font-bold uppercase tracking-widest text-sage-900 mb-2">Nytt</p>
          <h2 class="font-serif text-2xl mb-2">Ferdigstrikket</h2>
          <p class="text-sm text-charcoal/65">Strikkere selger plagg de har strikket på spec.</p>
        </a>
        <a href="/marked/oppdrag" class="block bg-white rounded-3xl p-6 border border-sage-500/10 hover:border-terracotta-500/40 transition-colors">
          <p class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500 mb-2">Nytt</p>
          <h2 class="font-serif text-2xl mb-2">Strikk for meg</h2>
          <p class="text-sm text-charcoal/65">Bestill et plagg fra en strikker i fellesskapet.</p>
        </a>
      </div>

      <h2 class="font-serif text-2xl mb-4">Nyeste annonser</h2>
      {(latest ?? []).length === 0 ? (
        <div class="bg-white rounded-3xl p-12 text-center border border-sage-500/10">
          <p class="text-charcoal/55">Ingen annonser ennå. Kom tilbake snart.</p>
        </div>
      ) : (
        <ul class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
          {(latest ?? []).map((l) => (
            <li>
              <a href={`/marked/listing/${l.id}`} class="block bg-white rounded-2xl border border-sage-500/10 hover:border-sage-500/30 transition-colors overflow-hidden">
                {projectPhotoUrl(l.hero_photo_path) ? (
                  <img src={projectPhotoUrl(l.hero_photo_path)!} alt={l.title} class="aspect-square object-cover" />
                ) : (
                  <div class="aspect-square bg-oatmeal/40"></div>
                )}
                <div class="p-3">
                  <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">
                    {KIND_LABEL[l.kind] ?? l.kind} · str. {l.size_label}
                  </p>
                  <p class="text-sm font-medium line-clamp-2">{l.title}</p>
                  <p class="font-mono tabular-nums text-sm mt-1">{l.price_nok} NOK</p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
      {(latestRequests ?? []).length > 0 && (
        <>
          <h2 class="font-serif text-2xl mb-4 mt-12">Nyeste forespørsler</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
            {(latestRequests ?? []).map((r) => (
              <li>
                <a href={`/marked/oppdrag/${r.id}`} class="block bg-white rounded-2xl border border-sage-500/10 hover:border-sage-500/30 transition-colors p-4">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500">
                      {CATEGORY_LABEL[r.category] ?? r.category}
                    </span>
                    <span class="text-[10px] text-charcoal/40">·</span>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45">str. {r.size_label}</span>
                  </div>
                  <p class="text-sm font-medium line-clamp-1">{r.title}</p>
                  <div class="flex items-center justify-between mt-2 text-xs text-charcoal/45">
                    <span class="font-mono tabular-nums">{r.budget_nok_min}–{r.budget_nok_max} NOK</span>
                    <span>{r.offer_count} tilbud</span>
                  </div>
                </a>
              </li>
            ))}
          </ul>
          <a href="/marked/oppdrag" class="inline-block mt-4 text-sm font-medium text-charcoal/55 hover:text-terracotta-500 transition-colors">
            Se alle forespørsler →
          </a>
        </>
      )}
    </div>
  </div>
</Layout>
