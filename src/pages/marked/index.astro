---
import Layout from '../../layouts/Layout.astro';
import MarketplaceShell from '../../components/MarketplaceShell.astro';
import ListingCard from '../../components/ListingCard.astro';
import CommissionCard from '../../components/CommissionCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import FavScript from '../../components/FavScript.astro';
import ImpressionTracker from '../../components/ImpressionTracker.astro';
import { createServerSupabase } from '../../lib/supabase';
import { getCurrentUser } from '../../lib/auth';
import { projectPhotoUrl } from '../../lib/storage';
import { KIND_LABEL, CATEGORY_LABEL } from '../../lib/labels';

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const user = await getCurrentUser({ request: Astro.request, cookies: Astro.cookies });

const [{ data: latest }, { data: latestRequests }] = await Promise.all([
  supabase
    .from('listings')
    .select('id, title, kind, price_nok, size_label, hero_photo_path, published_at, promoted_until, promotion_tier')
    .eq('status', 'active')
    .order('promoted_until', { ascending: false, nullsFirst: false })
    .order('published_at', { ascending: false })
    .limit(8),
  supabase
    .from('commission_requests')
    .select('id, title, category, size_label, budget_nok_min, budget_nok_max, offer_count, needed_by')
    .eq('status', 'open')
    .order('created_at', { ascending: false })
    .limit(4),
]);

let favIds: string[] = [];
if (user) {
  try {
    const { data: favs } = await supabase
      .from('favorites')
      .select('item_id')
      .eq('user_id', user.id)
      .eq('item_type', 'listing');
    favIds = (favs ?? []).map(f => f.item_id);
  } catch {}
}

---

<Layout title="Strikketorget — Littles and Me Knits" lang="nb">
  <MarketplaceShell current="home">
      <p class="text-charcoal/65 max-w-xl mb-10">
        Kjøp brukt og nytt strikket fra fellesskapet, eller bestill at noen strikker for deg.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 mb-12">
        <a href="/marked/brukt" class="block bg-white rounded-3xl p-6 border border-sage-500/10 hover:border-terracotta-500/40 transition-colors">
          <p class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500 mb-2">Brukt</p>
          <h2 class="font-serif text-2xl mb-2">Pre-loved</h2>
          <p class="text-sm text-charcoal/65">Plagg ungene har vokst fra. Som regel under 500 NOK.</p>
        </a>
        <a href="/marked/nytt" class="block bg-white rounded-3xl p-6 border border-sage-500/10 hover:border-terracotta-500/40 transition-colors">
          <p class="text-[10px] font-bold uppercase tracking-widest text-sage-900 mb-2">Nytt</p>
          <h2 class="font-serif text-2xl mb-2">Ferdigstrikket</h2>
          <p class="text-sm text-charcoal/65">Strikkere selger plagg de har strikket på spec.</p>
        </a>
        <a href="/marked/oppdrag" class="block bg-white rounded-3xl p-6 border border-sage-500/10 hover:border-terracotta-500/40 transition-colors">
          <p class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500 mb-2">Nytt</p>
          <h2 class="font-serif text-2xl mb-2">Strikk for meg</h2>
          <p class="text-sm text-charcoal/65">Bestill et plagg fra en strikker i fellesskapet.</p>
        </a>
      </div>

      <h2 class="font-serif text-2xl mb-4">Nyeste annonser</h2>
      {(latest ?? []).length === 0 ? (
        <EmptyState message="Ingen annonser ennå. Kom tilbake snart." />
      ) : (
        <ul class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
          {(latest ?? []).map((l) => (
            <ListingCard
              id={l.id}
              title={l.title}
              price={l.price_nok}
              imgUrl={projectPhotoUrl(l.hero_photo_path)}
              meta={`${KIND_LABEL[l.kind] ?? l.kind} · str. ${l.size_label}`}
              showFav={!!user}
              isFav={favIds.includes(l.id)}
              promoted={!!(l.promoted_until && new Date(l.promoted_until) > new Date() && l.promotion_tier === 'highlight')}
            />
          ))}
        </ul>
      )}
      {(latestRequests ?? []).length > 0 && (
        <>
          <h2 class="font-serif text-2xl mb-4 mt-12">Nyeste forespørsler</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
            {(latestRequests ?? []).map((r) => (
              <CommissionCard
                id={r.id}
                title={r.title}
                category={r.category}
                sizeLabel={r.size_label}
                budgetMin={r.budget_nok_min}
                budgetMax={r.budget_nok_max}
                offerCount={r.offer_count}
              />
            ))}
          </ul>
          <a href="/marked/oppdrag" class="inline-block mt-4 text-sm font-medium text-charcoal/55 hover:text-terracotta-500 transition-colors">
            Se alle forespørsler →
          </a>
        </>
      )}
  </MarketplaceShell>
  <FavScript />
  <ImpressionTracker source="home" />
</Layout>
