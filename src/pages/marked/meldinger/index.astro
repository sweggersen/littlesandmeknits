---
import Layout from '../../../layouts/Layout.astro';
import MarketplaceShell from '../../../components/MarketplaceShell.astro';
import { getCurrentUser } from '../../../lib/auth';
import { createServerSupabase } from '../../../lib/supabase';

const user = await getCurrentUser({ request: Astro.request, cookies: Astro.cookies });
if (!user) return Astro.redirect('/logg-inn?next=/marked/meldinger');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });

const { data: conversations } = await supabase
  .from('marketplace_conversations')
  .select(`
    id, updated_at, listing_id, buyer_id, seller_id, commission_request_id,
    listings(title, hero_photo_path),
    commission_requests(title),
    marketplace_messages(body, sender_id, created_at, read_at)
  `)
  .or(`buyer_id.eq.${user.id},seller_id.eq.${user.id}`)
  .order('updated_at', { ascending: false })
  .limit(50);

const profileIds = new Set<string>();
for (const c of conversations ?? []) {
  profileIds.add(c.buyer_id);
  profileIds.add(c.seller_id);
}
const { data: profiles } = profileIds.size > 0
  ? await supabase
      .from('profiles')
      .select('id, display_name')
      .in('id', [...profileIds])
  : { data: [] };
const profileMap = new Map((profiles ?? []).map((p) => [p.id, p.display_name]));

function otherName(conv: { buyer_id: string; seller_id: string }) {
  const otherId = conv.buyer_id === user!.id ? conv.seller_id : conv.buyer_id;
  return profileMap.get(otherId) ?? 'Anonym';
}

function lastMessage(conv: { marketplace_messages: { body: string; created_at: string }[] }) {
  const msgs = conv.marketplace_messages ?? [];
  if (msgs.length === 0) return '';
  const sorted = msgs.sort((a, b) => b.created_at.localeCompare(a.created_at));
  const text = sorted[0].body;
  return text.length > 80 ? text.slice(0, 80) + '…' : text;
}

function hasUnread(conv: { marketplace_messages: { sender_id: string; read_at: string | null }[] }) {
  return (conv.marketplace_messages ?? []).some(m => m.sender_id !== user!.id && !m.read_at);
}
---

<Layout title="Meldinger — Strikketorget" lang="nb">
  <MarketplaceShell current="meldinger">
      <h1 class="font-serif text-3xl sm:text-4xl mb-8">Meldinger</h1>

      {(!conversations || conversations.length === 0) ? (
        <div class="bg-white rounded-3xl p-10 text-center border border-sage-500/10">
          <p class="text-charcoal/55 text-sm">Ingen meldinger ennå.</p>
        </div>
      ) : (
        <ul class="space-y-2">
          {conversations.map((c) => {
            const unread = hasUnread(c);
            return (
            <li>
              <a
                href={`/marked/meldinger/${c.id}`}
                class:list={[
                  'block bg-white rounded-2xl p-4 border transition-colors',
                  unread
                    ? 'border-terracotta-500/20 hover:border-terracotta-500/40'
                    : 'border-sage-500/10 hover:border-sage-500/30',
                ]}
              >
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0">
                    <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">
                      {c.commission_request_id
                        ? `Oppdrag: ${(c.commission_requests as any)?.title ?? 'Oppdrag'}`
                        : (c.listings as any)?.title ?? 'Annonse'}
                    </p>
                    <p class:list={['', unread ? 'font-semibold' : 'font-medium']}>{otherName(c)}</p>
                    <p class:list={['text-sm truncate mt-1', unread ? 'text-charcoal/75 font-medium' : 'text-charcoal/55']}>{lastMessage(c)}</p>
                  </div>
                  <div class="flex items-center gap-2 shrink-0 mt-2">
                    {unread && <span class="w-2 h-2 rounded-full bg-terracotta-500"></span>}
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-charcoal/40">
                      <path d="m9 18 6-6-6-6" />
                    </svg>
                  </div>
                </div>
              </a>
            </li>
            );
          })}
        </ul>
      )}
  </MarketplaceShell>
</Layout>
