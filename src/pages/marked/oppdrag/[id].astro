---
import Layout from '../../../layouts/Layout.astro';
import MarketplaceNav from '../../../components/MarketplaceNav.astro';
import { createServerSupabase } from '../../../lib/supabase';
import { getCurrentUser } from '../../../lib/auth';
import { projectPhotoUrl } from '../../../lib/storage';

const id = Astro.params.id;
if (!id) return Astro.redirect('/marked/oppdrag');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const user = await getCurrentUser({ request: Astro.request, cookies: Astro.cookies });

const { data: req } = await supabase
  .from('commission_requests')
  .select('*, profiles!commission_requests_buyer_id_fkey(display_name, avatar_path)')
  .eq('id', id)
  .maybeSingle();

if (!req) return Astro.redirect('/marked/oppdrag');

const isBuyer = user?.id === req.buyer_id;
const isOpen = req.status === 'open';

// Fetch offers — public prices, buyer sees all details
const { data: offers } = await supabase
  .from('commission_offers')
  .select('*, profiles!commission_offers_knitter_id_fkey(display_name, avatar_path, seller_tags)')
  .eq('request_id', id)
  .order('price_nok', { ascending: true });

const allOffers = offers ?? [];
const myOffer = user ? allOffers.find((o) => o.knitter_id === user.id) : null;
const isKnitter = !!myOffer;
const acceptedOffer = allOffers.find((o) => o.status === 'accepted');

// Fetch linked project if offer is accepted and has a project_id
let linkedProject: any = null;
let projectLogs: any[] = [];
if (acceptedOffer?.project_id) {
  const { data: proj } = await supabase
    .from('projects')
    .select('id, title, summary, status, recipient, target_size, yarn, needles, pattern_external, hero_photo_path, current_rows, target_rows, started_at, finished_at')
    .eq('id', acceptedOffer.project_id)
    .maybeSingle();
  linkedProject = proj;

  if (proj) {
    const { data: logs } = await supabase
      .from('project_logs')
      .select('id, body, log_date, photos, rows_at, created_at')
      .eq('project_id', proj.id)
      .order('log_date', { ascending: false })
      .order('created_at', { ascending: false });
    projectLogs = logs ?? [];
  }
}

// Knitter's projects for linking (only when accepted and no project linked yet)
let knitterProjects: any[] = [];
if (isKnitter && myOffer?.status === 'accepted' && req.status === 'awarded' && !myOffer?.project_id) {
  const { data: projects } = await supabase
    .from('projects')
    .select('id, title, status, hero_photo_path')
    .eq('user_id', user!.id)
    .in('status', ['planning', 'active'])
    .order('updated_at', { ascending: false })
    .limit(20);
  knitterProjects = projects ?? [];
}

// Check for existing commission conversation
let commissionConvId: string | null = null;
if (user && acceptedOffer && (isBuyer || isKnitter)) {
  const { data: conv } = await supabase
    .from('marketplace_conversations')
    .select('id')
    .eq('commission_request_id', id)
    .maybeSingle();
  commissionConvId = conv?.id ?? null;
}

const CATEGORY_LABEL: Record<string, string> = {
  genser: 'Genser', cardigan: 'Cardigan', lue: 'Lue', votter: 'Votter',
  sokker: 'Sokker', teppe: 'Teppe', kjole: 'Kjole', bukser: 'Bukser', annet: 'Annet',
};
const STATUS_LABEL: Record<string, string> = {
  open: 'Åpen', awaiting_payment: 'Venter på betaling', awaiting_yarn: 'Venter på garn', awarded: 'Pågår', completed: 'Ferdigstrikket', delivered: 'Levert', cancelled: 'Avbrutt', expired: 'Utløpt',
};
const isPrivate = !!req.target_knitter_id;
const daysUntilAutoRelease = req.auto_release_at ? Math.max(0, Math.ceil((new Date(req.auto_release_at).getTime() - Date.now()) / 86400000)) : null;
const PROJECT_STATUS: Record<string, string> = {
  planning: 'Planlegger', active: 'Pågår', finished: 'Ferdig', frogged: 'Røket opp',
};
const buyerProfile = (req as any).profiles;

const projectProgressPct = linkedProject?.target_rows && linkedProject.target_rows > 0 && linkedProject.current_rows !== null
  ? Math.min(100, Math.round((linkedProject.current_rows / linkedProject.target_rows) * 100))
  : null;
---

<Layout title={`${req.title} — Strikk for meg`} lang="nb">
  <MarketplaceNav current="oppdrag" />
  <div class="bg-linen min-h-[60vh]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 sm:py-12">

      <!-- Status badge -->
      <div class="flex items-center gap-2 mb-4">
        {req.status !== 'open' && (
          <span class:list={[
            'inline-block text-[10px] font-bold uppercase tracking-widest rounded-full px-3 py-1',
            req.status === 'delivered' ? 'text-sage-700 bg-sage-100' : req.status === 'completed' ? 'text-terracotta-500 bg-terracotta-500/10' : 'text-charcoal/45 bg-oatmeal/60',
          ]}>
            {STATUS_LABEL[req.status]}
          </span>
        )}
        {isPrivate && (
          <span class="inline-block text-[10px] font-bold uppercase tracking-widest text-charcoal/35 bg-oatmeal/40 rounded-full px-3 py-1">
            Privat forespørsel
          </span>
        )}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Request details (2 cols) -->
        <div class="md:col-span-2">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500">
              {CATEGORY_LABEL[req.category] ?? req.category}
            </span>
            <span class="text-[10px] text-charcoal/40">·</span>
            <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45">
              str. {req.size_label}
            </span>
          </div>
          <h1 class="font-serif text-3xl sm:text-4xl mb-4">{req.title}</h1>

          {acceptedOffer && ['awaiting_payment', 'awaiting_yarn', 'awarded', 'completed', 'delivered'].includes(req.status) ? (
            <p class="font-mono tabular-nums text-2xl mb-6">
              {acceptedOffer.price_nok} NOK
            </p>
          ) : (
            <p class="font-mono tabular-nums text-2xl mb-6">
              {req.budget_nok_min}–{req.budget_nok_max} NOK
            </p>
          )}

          <dl class="grid grid-cols-2 gap-3 text-sm mb-6">
            {req.colorway && (
              <div>
                <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Farge</dt>
                <dd>{req.colorway}</dd>
              </div>
            )}
            {req.pattern_external_title && (
              <div>
                <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Oppskrift</dt>
                <dd>{req.pattern_external_title}</dd>
              </div>
            )}
            {req.yarn_preference && (
              <div class="col-span-2">
                <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Garnpreferanse</dt>
                <dd>{req.yarn_preference}</dd>
              </div>
            )}
            {req.yarn_provided_by_buyer && (
              <div>
                <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Garn</dt>
                <dd>Kjøper sender garnet</dd>
              </div>
            )}
            {req.needed_by && (
              <div>
                <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Trengs innen</dt>
                <dd>{new Date(req.needed_by).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long', year: 'numeric' })}</dd>
              </div>
            )}
          </dl>

          {req.description && (
            <p class="text-sm text-charcoal/75 leading-relaxed whitespace-pre-line mb-6">{req.description}</p>
          )}

          <!-- Buyer info -->
          <a href={`/marked/selger/${req.buyer_id}`} class="flex items-center gap-3 pt-4 border-t border-sage-500/10 group">
            {buyerProfile?.avatar_path ? (
              <img src={projectPhotoUrl(buyerProfile.avatar_path)!} alt="" class="w-10 h-10 rounded-full object-cover shrink-0" />
            ) : (
              <div class="w-10 h-10 rounded-full bg-sage-100 flex items-center justify-center shrink-0">
                <span class="font-serif text-base text-sage-700">{(buyerProfile?.display_name ?? '?')[0].toUpperCase()}</span>
              </div>
            )}
            <div>
              <p class="font-medium group-hover:text-terracotta-500 transition-colors">{buyerProfile?.display_name ?? 'Anonym'}</p>
              <p class="text-xs text-charcoal/45">Bestiller</p>
            </div>
          </a>

          <!-- Commission messaging -->
          {(isBuyer || isKnitter) && acceptedOffer && !isOpen && (
            <div class="mt-4">
              {commissionConvId ? (
                <a href={`/marked/meldinger/${commissionConvId}`} class="text-sm text-charcoal/55 hover:text-terracotta-500 transition-colors">
                  Gå til samtale →
                </a>
              ) : (
                <details class="group">
                  <summary class="text-sm text-charcoal/55 hover:text-terracotta-500 transition-colors cursor-pointer">Send melding</summary>
                  <form method="post" action="/api/marketplace/conversations/create-commission" data-astro-reload class="mt-3 space-y-2">
                    <input type="hidden" name="commission_request_id" value={req.id} />
                    <textarea name="message" required rows="3" maxlength="1000" placeholder="Skriv en melding…"
                      class="w-full bg-white rounded-xl px-4 py-2.5 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors resize-none"></textarea>
                    <button type="submit" class="bg-charcoal text-linen px-4 py-2 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors">
                      Send
                    </button>
                  </form>
                </details>
              )}
            </div>
          )}

          <!-- Read-only project view for buyer (shown once knitter has posted logs) -->
          {isBuyer && acceptedOffer && linkedProject && projectLogs.length > 0 && ['awarded', 'awaiting_yarn', 'completed', 'delivered'].includes(req.status) && (
            <div class="mt-8 pt-8 border-t border-sage-500/10">
              {linkedProject.hero_photo_path && (
                <div class="aspect-[16/10] rounded-3xl overflow-hidden bg-oatmeal mb-6 border border-sage-500/10">
                  <img src={projectPhotoUrl(linkedProject.hero_photo_path)!} alt={linkedProject.title} class="w-full h-full object-cover" loading="lazy" />
                </div>
              )}

              <div class="flex items-start gap-3 mb-4">
                <span class:list={[
                  'text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full shrink-0',
                  linkedProject.status === 'finished' ? 'bg-terracotta-500/10 text-terracotta-500'
                    : linkedProject.status === 'active' ? 'bg-sage-100 text-sage-900'
                    : 'bg-oatmeal text-charcoal/70',
                ]}>
                  {PROJECT_STATUS[linkedProject.status]}
                </span>
              </div>
              <h2 class="font-serif text-2xl sm:text-3xl mb-2">{linkedProject.title}</h2>
              {linkedProject.summary && (
                <p class="text-charcoal/65 leading-relaxed mb-4">{linkedProject.summary}</p>
              )}

              {projectProgressPct !== null && (
                <div class="bg-white rounded-2xl p-4 border border-sage-500/10 mb-4">
                  <div class="flex items-center justify-between text-xs text-charcoal/55 mb-2">
                    <span class="font-bold uppercase tracking-widest">Fremdrift</span>
                    <span>{linkedProject.current_rows} / {linkedProject.target_rows} rader · {projectProgressPct}%</span>
                  </div>
                  <div class="h-2 bg-sage-500/10 rounded-full overflow-hidden">
                    <div class="h-full bg-sage-500 rounded-full transition-all" style={`width: ${projectProgressPct}%`}></div>
                  </div>
                </div>
              )}

              {(linkedProject.recipient || linkedProject.yarn || linkedProject.needles || linkedProject.target_size || linkedProject.pattern_external) && (
                <div class="bg-white rounded-2xl p-4 border border-sage-500/10 mb-6">
                  <dl class="grid grid-cols-2 gap-3 text-sm">
                    {linkedProject.recipient && (
                      <div>
                        <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">For</dt>
                        <dd>{linkedProject.recipient}</dd>
                      </div>
                    )}
                    {linkedProject.target_size && (
                      <div>
                        <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Størrelse</dt>
                        <dd>{linkedProject.target_size}</dd>
                      </div>
                    )}
                    {linkedProject.pattern_external && (
                      <div>
                        <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Oppskrift</dt>
                        <dd>{linkedProject.pattern_external}</dd>
                      </div>
                    )}
                    {linkedProject.yarn && (
                      <div>
                        <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Garn</dt>
                        <dd>{linkedProject.yarn}</dd>
                      </div>
                    )}
                    {linkedProject.needles && (
                      <div>
                        <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Pinner</dt>
                        <dd>{linkedProject.needles}</dd>
                      </div>
                    )}
                  </dl>
                </div>
              )}

              <h3 class="font-serif text-lg mb-4">Tidslinje</h3>
              <ol class="space-y-4">
                {projectLogs.map((log) => (
                  <li class="bg-white rounded-2xl p-5 border border-sage-500/10">
                    <div class="flex items-baseline gap-3 flex-wrap mb-2">
                      <time class="text-xs font-bold uppercase tracking-wider text-sage-900">
                        {new Date(log.log_date).toLocaleDateString('nb-NO', { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric' })}
                      </time>
                      {log.rows_at !== null && log.rows_at !== undefined && (
                        <span class="text-[10px] font-medium uppercase tracking-wider text-charcoal/45">
                          Rad {log.rows_at}
                        </span>
                      )}
                    </div>
                    {log.body && <p class="text-sm text-charcoal/80 leading-relaxed whitespace-pre-wrap">{log.body}</p>}
                    {log.photos?.length > 0 && (
                      <div class={`mt-4 grid gap-2 ${log.photos.length === 1 ? 'grid-cols-1' : log.photos.length === 2 ? 'grid-cols-2' : 'grid-cols-3'}`}>
                        {log.photos.map((photo: string) => (
                          <a href={projectPhotoUrl(photo)} target="_blank" rel="noopener" class="aspect-square rounded-xl overflow-hidden bg-oatmeal hover:opacity-90 transition-opacity">
                            <img src={projectPhotoUrl(photo)!} alt="" class="w-full h-full object-cover" loading="lazy" />
                          </a>
                        ))}
                      </div>
                    )}
                  </li>
                ))}
              </ol>
            </div>
          )}

          <!-- Buyer controls -->
          {isBuyer && isOpen && (
            <div class="mt-6">
              <form method="post" action="/api/marketplace/commissions/cancel" data-astro-reload>
                <input type="hidden" name="request_id" value={req.id} />
                <button type="submit" class="text-sm text-charcoal/45 hover:text-terracotta-500 transition-colors">
                  Avbryt forespørsel
                </button>
              </form>
            </div>
          )}
        </div>

        <!-- Sidebar: offers + actions -->
        <div class="space-y-4">

          <!-- Offer form (for knitters who haven't bid yet) -->
          {!isBuyer && !myOffer && isOpen && user && (
            <div class="bg-white rounded-3xl p-5 border border-sage-500/10">
              <h2 class="font-serif text-xl mb-3">Send tilbud</h2>
              <form method="post" action="/api/marketplace/commissions/offer" data-astro-reload class="space-y-3">
                <input type="hidden" name="request_id" value={req.id} />
                <label class="block">
                  <span class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-1">Din pris (NOK) *</span>
                  <input name="price_nok" type="number" required min="1" step="1" placeholder="600"
                    class="w-full bg-linen rounded-xl px-4 py-2.5 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors" />
                </label>
                <label class="block">
                  <span class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-1">Leveringstid (uker) *</span>
                  <input name="turnaround_weeks" type="number" required min="1" max="52" placeholder="3"
                    class="w-full bg-linen rounded-xl px-4 py-2.5 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors" />
                </label>
                <label class="block">
                  <span class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-1">Melding til bestiller *</span>
                  <textarea name="message" required rows="3" maxlength="500" placeholder="Fortell kort om din erfaring og hvorfor du passer til dette oppdraget…"
                    class="w-full bg-linen rounded-xl px-4 py-2.5 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors resize-none"></textarea>
                </label>
                <button type="submit" class="w-full bg-charcoal text-linen px-5 py-3 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors">
                  Send tilbud
                </button>
              </form>
            </div>
          )}

          {!user && isOpen && (
            <div class="bg-white rounded-3xl p-5 border border-sage-500/10 text-center">
              <p class="text-sm text-charcoal/55 mb-3">Logg inn for å sende tilbud</p>
              <a href={`/logg-inn?next=/marked/oppdrag/${id}`} class="inline-block bg-charcoal text-linen px-5 py-2.5 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors">
                Logg inn
              </a>
            </div>
          )}

          <!-- My offer status (for knitter who already bid) -->
          {myOffer && !isBuyer && (
            <div class="bg-white rounded-3xl p-5 border border-sage-500/10">
              <h2 class="font-serif text-xl mb-2">Ditt tilbud</h2>
              <p class="font-mono tabular-nums text-lg">{myOffer.price_nok} NOK · {myOffer.turnaround_weeks} uker</p>
              <p class="text-xs text-charcoal/45 mt-1 capitalize">{myOffer.status === 'pending' ? 'Venter på svar' : myOffer.status === 'accepted' && req.status === 'awaiting_payment' ? 'Akseptert — venter på betaling' : myOffer.status === 'accepted' && req.status === 'awaiting_yarn' ? 'Akseptert — venter på garn fra kjøper' : myOffer.status === 'accepted' ? 'Akseptert og betalt!' : myOffer.status}</p>

              {myOffer.status === 'pending' && (
                <form method="post" action="/api/marketplace/commissions/withdraw" data-astro-reload class="mt-3">
                  <input type="hidden" name="offer_id" value={myOffer.id} />
                  <button type="submit" class="text-sm text-charcoal/45 hover:text-terracotta-500 transition-colors">
                    Trekk tilbake
                  </button>
                </form>
              )}

              {myOffer.status === 'accepted' && req.status === 'awarded' && !myOffer.project_id && knitterProjects.length > 0 && (
                <div class="mt-4 pt-4 border-t border-sage-500/10">
                  <p class="text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Knytt til prosjekt i Strikkestua</p>
                  <form method="post" action="/api/marketplace/commissions/link-project" data-astro-reload class="space-y-2">
                    <input type="hidden" name="offer_id" value={myOffer.id} />
                    <select name="project_id" required class="w-full bg-linen rounded-xl px-3 py-2 text-sm border border-sage-500/15">
                      <option value="">Velg prosjekt…</option>
                      {knitterProjects.map((p) => (
                        <option value={p.id}>{p.title} ({PROJECT_STATUS[p.status]})</option>
                      ))}
                    </select>
                    <button type="submit" class="w-full bg-charcoal text-linen px-4 py-2 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors">
                      Knytt til
                    </button>
                  </form>
                  <a href="/studio/prosjekter/ny" class="block text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors mt-2 text-center">
                    Opprett nytt prosjekt →
                  </a>
                </div>
              )}

              {myOffer.status === 'accepted' && req.status === 'awarded' && myOffer.project_id && linkedProject && (
                <div class="mt-4 pt-4 border-t border-sage-500/10">
                  <p class="text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Prosjekt i Strikkestua</p>
                  <a href={`/studio/prosjekter/${linkedProject.id}`} class="flex items-center gap-3 bg-linen rounded-xl p-3 hover:bg-oatmeal/60 transition-colors">
                    {linkedProject.hero_photo_path ? (
                      <img src={projectPhotoUrl(linkedProject.hero_photo_path)!} alt="" class="w-10 h-10 rounded-lg object-cover shrink-0" />
                    ) : (
                      <div class="w-10 h-10 rounded-lg bg-oatmeal/60 shrink-0"></div>
                    )}
                    <div class="min-w-0 flex-1">
                      <p class="text-sm font-medium line-clamp-1">{linkedProject.title}</p>
                      <p class="text-[10px] text-charcoal/45">{PROJECT_STATUS[linkedProject.status]} · Åpne i Strikkestua</p>
                    </div>
                  </a>
                </div>
              )}
            </div>
          )}

          <!-- Payment step (buyer, after accepting an offer) -->
          {isBuyer && req.status === 'awaiting_payment' && acceptedOffer && (
            <div class="bg-white rounded-3xl p-5 border border-terracotta-500/30">
              <h2 class="font-serif text-xl mb-2">Betal for oppdraget</h2>
              <p class="text-sm text-charcoal/65 mb-3">
                Du har valgt tilbudet fra {(() => { const p = (acceptedOffer as any).profiles; return p?.display_name ?? 'Anonym'; })()}.
                Betal for å starte oppdraget — pengene holdes til prosjektet er levert.
              </p>
              <p class="font-mono tabular-nums text-2xl mb-4">{acceptedOffer.price_nok} NOK</p>
              <form method="post" action="/api/marketplace/commissions/pay" data-astro-reload>
                <input type="hidden" name="request_id" value={req.id} />
                <button type="submit" class="w-full bg-charcoal text-linen px-5 py-3 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors">
                  Betal nå
                </button>
              </form>
              <p class="text-[11px] text-charcoal/40 text-center mt-2">Stripe-betaling kommer snart. Klikk for å simulere.</p>
            </div>
          )}

          <!-- Yarn shipping step (when buyer provides yarn) -->
          {req.status === 'awaiting_yarn' && isBuyer && !req.yarn_shipped_at && (
            <div class="bg-white rounded-3xl p-5 border border-terracotta-500/20">
              <h2 class="font-serif text-xl mb-2">Send garnet</h2>
              <p class="text-sm text-charcoal/65 mb-4">
                Betaling er mottatt. Send garnet til strikkeren.
              </p>

              <div class="space-y-3">
                <details class="group">
                  <summary class="cursor-pointer text-sm font-medium text-charcoal/70 hover:text-charcoal flex items-center gap-1">
                    <span class="group-open:rotate-90 transition-transform text-xs">▶</span>
                    Allerede sendt? Registrer manuelt
                  </summary>
                  <form method="post" action="/api/marketplace/commissions/ship-yarn" data-astro-reload class="space-y-3 mt-3">
                    <input type="hidden" name="request_id" value={req.id} />
                    <label class="block">
                      <span class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-1">Sporingskode (valgfritt)</span>
                      <input name="tracking_code" type="text" maxlength="50" placeholder="F.eks. BRING-1234-5678"
                        class="w-full bg-linen rounded-xl px-4 py-2.5 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors" />
                    </label>
                    <button type="submit" class="w-full bg-charcoal text-linen px-5 py-3 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors">
                      Merk som sendt
                    </button>
                  </form>
                </details>
              </div>
            </div>
          )}

          {req.status === 'awaiting_yarn' && isBuyer && req.yarn_shipped_at && (
            <div class="bg-white rounded-3xl p-5 border border-sage-500/10">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-sage-700 text-lg">✓</span>
                <h2 class="font-serif text-xl">Garnet er sendt</h2>
              </div>
              <p class="text-sm text-charcoal/55">
                Sendt {new Date(req.yarn_shipped_at).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long' })}
                {req.yarn_tracking_code && <span> · Sporing: <span class="font-mono text-xs">{req.yarn_tracking_code}</span></span>}
              </p>
              {req.label_free_code && (
                <p class="text-sm text-charcoal/55 mt-1">Labelfri kode: <span class="font-mono font-bold">{req.label_free_code}</span></p>
              )}
              {req.yarn_bring_shipment_number && (
                <div data-tracking-events class="mt-3 text-xs text-charcoal/55"></div>
              )}
              <p class="text-xs text-charcoal/40 mt-2">Venter på bekreftelse fra strikkeren.</p>
            </div>
          )}

          {req.status === 'awaiting_yarn' && isKnitter && !req.yarn_shipped_at && (
            <div class="bg-white rounded-3xl p-5 border border-sage-500/10">
              <h2 class="font-serif text-xl mb-2">Venter på garn</h2>
              <p class="text-sm text-charcoal/55">
                Kjøper sender garnet. Du får beskjed når det er sendt.
              </p>
            </div>
          )}

          {req.status === 'awaiting_yarn' && isKnitter && req.yarn_shipped_at && (
            <div class="bg-white rounded-3xl p-5 border border-terracotta-500/20">
              <h2 class="font-serif text-xl mb-2">Garnet er på vei!</h2>
              <p class="text-sm text-charcoal/65 mb-1">
                Sendt {new Date(req.yarn_shipped_at).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long' })}
              </p>
              {req.yarn_tracking_code && (
                <p class="text-sm text-charcoal/55 mb-1">Sporing: <span class="font-mono text-xs">{req.yarn_tracking_code}</span></p>
              )}
              {req.yarn_bring_shipment_number && (
                <div data-tracking-events class="mt-2 mb-3 text-xs text-charcoal/55"></div>
              )}
              <form method="post" action="/api/marketplace/commissions/receive-yarn" data-astro-reload>
                <input type="hidden" name="request_id" value={req.id} />
                <button type="submit" class="w-full bg-charcoal text-linen px-5 py-3 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors">
                  Bekreft mottatt
                </button>
              </form>
            </div>
          )}

          <!-- Offers section — role-based visibility -->
          <div>
            {isBuyer ? (
              <>
                {/* Buyer sees all offers in full */}
                <h2 class="font-serif text-xl mb-3">Tilbud ({allOffers.filter(o => o.status === 'pending' || o.status === 'accepted').length})</h2>
                {allOffers.length === 0 ? (
                  <p class="text-sm text-charcoal/45">Ingen tilbud ennå.</p>
                ) : (
                  <div class="space-y-2">
                    {allOffers.filter(o => o.status === 'pending' || o.status === 'accepted').map((o) => {
                      const knitterProfile = (o as any).profiles;
                      const isAccepted = o.status === 'accepted';
                      return (
                        <div class:list={[
                          'bg-white rounded-2xl p-4 border transition-colors',
                          isAccepted ? 'border-terracotta-500/30 bg-terracotta-500/5' : 'border-sage-500/10',
                        ]}>
                          <div class="flex items-center gap-2 mb-2">
                            {knitterProfile?.avatar_path ? (
                              <img src={projectPhotoUrl(knitterProfile.avatar_path)!} alt="" class="w-7 h-7 rounded-full object-cover" />
                            ) : (
                              <div class="w-7 h-7 rounded-full bg-sage-100 flex items-center justify-center">
                                <span class="font-serif text-xs text-sage-700">{(knitterProfile?.display_name ?? '?')[0].toUpperCase()}</span>
                              </div>
                            )}
                            <a href={`/marked/selger/${o.knitter_id}`} class="text-sm font-medium hover:text-terracotta-500 transition-colors">
                              {knitterProfile?.display_name ?? 'Anonym'}
                            </a>
                            {isAccepted && (
                              <span class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500">Valgt</span>
                            )}
                          </div>
                          <p class="font-mono tabular-nums text-lg">{o.price_nok} NOK</p>
                          <p class="text-xs text-charcoal/55 mt-0.5">{o.turnaround_weeks} {o.turnaround_weeks === 1 ? 'uke' : 'uker'} leveringstid</p>
                          {o.message && (
                            <p class="text-sm text-charcoal/70 mt-2 whitespace-pre-line">{o.message}</p>
                          )}
                          {isOpen && o.status === 'pending' && (
                            <form method="post" action="/api/marketplace/commissions/accept" data-astro-reload class="mt-3">
                              <input type="hidden" name="offer_id" value={o.id} />
                              <button type="submit" class="bg-charcoal text-linen px-4 py-2 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors">
                                Aksepter dette tilbudet
                              </button>
                            </form>
                          )}
                        </div>
                      );
                    })}
                  </div>
                )}
              </>
            ) : (
              <>
                {/* Public / knitter view: only count + status */}
                <h2 class="font-serif text-xl mb-3">Tilbud</h2>
                <div class="bg-white rounded-2xl p-4 border border-sage-500/10">
                  {['awarded', 'awaiting_payment', 'awaiting_yarn', 'completed', 'delivered'].includes(req.status) ? (
                    <p class="text-sm text-charcoal/55">
                      Tilbud er akseptert.
                      {req.offer_count > 1 && ` ${req.offer_count - 1} andre tilbud ble vurdert.`}
                    </p>
                  ) : req.offer_count === 0 ? (
                    <p class="text-sm text-charcoal/45">Ingen tilbud ennå.</p>
                  ) : (
                    <p class="text-sm text-charcoal/55">
                      {myOffer
                        ? (req.offer_count > 1 ? `${req.offer_count - 1} andre tilbud` : 'Ingen andre tilbud ennå')
                        : `${req.offer_count} ${req.offer_count === 1 ? 'tilbud' : 'tilbud'}`
                      }
                    </p>
                  )}
                </div>
              </>
            )}
          </div>

          <!-- Buyer status card (awarded, no progress yet) -->
          {isBuyer && req.status === 'awarded' && (!linkedProject || projectLogs.length === 0) && (
            <div class="bg-white rounded-3xl p-5 border border-sage-500/10">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-charcoal/30 text-lg">&#9676;</span>
                <h2 class="font-serif text-xl">Oppdraget pågår</h2>
              </div>
              <p class="text-sm text-charcoal/55">
                Strikkeren jobber med bestillingen din. Du får beskjed når det er oppdateringer.
              </p>
            </div>
          )}

          <!-- Completion: knitter marks done -->
          {isKnitter && req.status === 'awarded' && myOffer?.status === 'accepted' && (
            <div class="bg-white rounded-3xl p-5 border border-sage-500/10">
              <h2 class="font-serif text-xl mb-2">Ferdig strikket?</h2>
              <p class="text-sm text-charcoal/55 mb-3">
                Når du er ferdig, merk oppdraget som fullført. Kjøper har 14 dager på å bekrefte mottak.
              </p>
              <form method="post" action="/api/marketplace/commissions/mark-completed" data-astro-reload>
                <input type="hidden" name="request_id" value={req.id} />
                <button type="submit" class="w-full bg-charcoal text-linen px-5 py-3 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors">
                  Merk som ferdig
                </button>
              </form>
            </div>
          )}

          <!-- Completion: buyer confirms delivery -->
          {isBuyer && req.status === 'completed' && (
            <div class="bg-white rounded-3xl p-5 border border-terracotta-500/20">
              <h2 class="font-serif text-xl mb-2">Bekreft mottak</h2>
              <p class="text-sm text-charcoal/65 mb-3">
                Strikkeren har merket oppdraget som ferdig. Har du mottatt arbeidet?
              </p>
              {daysUntilAutoRelease !== null && (
                <p class="text-xs text-charcoal/40 mb-3">
                  Automatisk godkjenning om {daysUntilAutoRelease} {daysUntilAutoRelease === 1 ? 'dag' : 'dager'}.
                </p>
              )}
              <form method="post" action="/api/marketplace/commissions/confirm-delivery" data-astro-reload>
                <input type="hidden" name="request_id" value={req.id} />
                <button type="submit" class="w-full bg-charcoal text-linen px-5 py-3 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors">
                  Bekreft mottatt
                </button>
              </form>
            </div>
          )}

          {isKnitter && req.status === 'completed' && (
            <div class="bg-white rounded-3xl p-5 border border-sage-500/10">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-sage-700 text-lg">✓</span>
                <h2 class="font-serif text-xl">Merket som ferdig</h2>
              </div>
              <p class="text-sm text-charcoal/55">Venter på at kjøper bekrefter mottak.</p>
              {daysUntilAutoRelease !== null && (
                <p class="text-xs text-charcoal/40 mt-1">
                  Automatisk godkjenning om {daysUntilAutoRelease} {daysUntilAutoRelease === 1 ? 'dag' : 'dager'}.
                </p>
              )}
            </div>
          )}

          <!-- Delivered state -->
          {req.status === 'delivered' && (isBuyer || isKnitter) && (
            <div class="bg-sage-100/50 rounded-3xl p-5 border border-sage-500/20">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-sage-700 text-lg">✓</span>
                <h2 class="font-serif text-xl text-sage-800">Levert</h2>
              </div>
              <p class="text-sm text-charcoal/55">
                Oppdraget er fullført og levert{req.delivered_at ? ` ${new Date(req.delivered_at).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long', year: 'numeric' })}` : ''}.
              </p>
            </div>
          )}

        </div>
      </div>
    </div>
  </div>
</Layout>

{req.yarn_bring_shipment_number && (
<script is:inline define:vars={{ requestId: req.id }}>
  (async function() {
    var containers = document.querySelectorAll('[data-tracking-events]');
    if (!containers.length) return;
    try {
      var res = await fetch('/api/marketplace/commissions/tracking?request_id=' + requestId);
      if (!res.ok) return;
      var events = await res.json();
      if (!events.length) return;
      var html = '<p class="font-bold mb-1">Sporingshendelser:</p><ul class="space-y-1">';
      events.slice(0, 5).forEach(function(e) {
        var d = new Date(e.dateTime);
        var ts = d.toLocaleDateString('nb-NO', { day: 'numeric', month: 'short' }) + ' ' + d.toLocaleTimeString('nb-NO', { hour: '2-digit', minute: '2-digit' });
        html += '<li>' + ts + ' — ' + e.description + (e.city ? ' (' + e.city + ')' : '') + '</li>';
      });
      html += '</ul>';
      containers.forEach(function(el) { el.innerHTML = html; });
    } catch {}
  })();
</script>
)}
