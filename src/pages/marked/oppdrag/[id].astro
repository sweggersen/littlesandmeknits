---
import Layout from '../../../layouts/Layout.astro';
import MarketplaceShell from '../../../components/MarketplaceShell.astro';
import ReportButton from '../../../components/ReportButton.astro';
import ReviewForm from '../../../components/ReviewForm.astro';
import ProfileAvatar from '../../../components/ProfileAvatar.astro';
import { createServerSupabase } from '../../../lib/supabase';
import { createAdminSupabase } from '../../../lib/supabase';
import { getCurrentUser } from '../../../lib/auth';
import { projectPhotoUrl } from '../../../lib/storage';
import { env } from 'cloudflare:workers';
import { CATEGORY_LABEL, COMMISSION_STATUS, PROJECT_STATUS } from '../../../lib/labels';

const id = Astro.params.id;
if (!id) return Astro.redirect('/marked/oppdrag');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const user = await getCurrentUser({ request: Astro.request, cookies: Astro.cookies });

let { data: req } = await supabase
  .from('commission_requests')
  .select('*, profiles!commission_requests_buyer_id_fkey(display_name, avatar_path)')
  .eq('id', id)
  .maybeSingle();

const { data: viewerProfile } = user ? await supabase.from('profiles').select('role').eq('id', user.id).maybeSingle() : { data: null };
const isStaff = viewerProfile?.role === 'admin' || viewerProfile?.role === 'moderator';

if (!req && isStaff) {
  const admin = createAdminSupabase(env.SUPABASE_SERVICE_ROLE_KEY);
  const { data } = await admin
    .from('commission_requests')
    .select('*, profiles!commission_requests_buyer_id_fkey(display_name, avatar_path)')
    .eq('id', id)
    .maybeSingle();
  req = data;
}

if (!req) return Astro.redirect('/marked/oppdrag');

const isBuyer = user?.id === req.buyer_id;
const isOpen = req.status === 'open';

// Fetch offers — public prices, buyer sees all details
const { data: offers } = await supabase
  .from('commission_offers')
  .select('*, profiles!commission_offers_knitter_id_fkey(display_name, avatar_path, seller_tags)')
  .eq('request_id', id)
  .order('price_nok', { ascending: true });

const allOffers = offers ?? [];
const myOffer = user ? allOffers.find((o) => o.knitter_id === user.id) : null;
const isKnitter = !!myOffer;
const acceptedOffer = allOffers.find((o) => o.status === 'accepted');

// Fetch linked project if offer is accepted and has a project_id
let linkedProject: any = null;
let projectLogs: any[] = [];
if (acceptedOffer?.project_id) {
  const { data: proj } = await supabase
    .from('projects')
    .select('id, title, summary, status, recipient, target_size, yarn, needles, pattern_external, hero_photo_path, current_rows, target_rows, started_at, finished_at')
    .eq('id', acceptedOffer.project_id)
    .maybeSingle();
  linkedProject = proj;

  if (proj) {
    const { data: logs } = await supabase
      .from('project_logs')
      .select('id, body, log_date, photos, rows_at, created_at')
      .eq('project_id', proj.id)
      .order('log_date', { ascending: false })
      .order('created_at', { ascending: false });
    projectLogs = logs ?? [];
  }
}

// Knitter's projects for linking (only when accepted and no project linked yet)
let knitterProjects: any[] = [];
if (isKnitter && myOffer?.status === 'accepted' && req.status === 'awarded' && !myOffer?.project_id) {
  const { data: projects } = await supabase
    .from('projects')
    .select('id, title, status, hero_photo_path')
    .eq('user_id', user!.id)
    .in('status', ['planning', 'active'])
    .order('updated_at', { ascending: false })
    .limit(20);
  knitterProjects = projects ?? [];
}

// Check for existing commission conversation
let commissionConvId: string | null = null;
if (user && acceptedOffer && (isBuyer || isKnitter)) {
  const { data: conv } = await supabase
    .from('marketplace_conversations')
    .select('id')
    .eq('commission_request_id', id)
    .maybeSingle();
  commissionConvId = conv?.id ?? null;
}

const isPrivate = !!req.target_knitter_id;
const daysUntilAutoRelease = req.auto_release_at ? Math.max(0, Math.ceil((new Date(req.auto_release_at).getTime() - Date.now()) / 86400000)) : null;
const daysUntilExpiry = req.expires_at ? Math.max(0, Math.ceil((new Date(req.expires_at).getTime() - Date.now()) / 86400000)) : null;
const expiringSoon = daysUntilExpiry !== null && daysUntilExpiry <= 7;
const buyerProfile = (req as any).profiles;

const projectProgressPct = linkedProject?.target_rows && linkedProject.target_rows > 0 && linkedProject.current_rows !== null
  ? Math.min(100, Math.round((linkedProject.current_rows / linkedProject.target_rows) * 100))
  : null;

const knitterProfile = acceptedOffer ? (acceptedOffer as any).profiles : null;
const knitterName = knitterProfile?.display_name ?? 'Anonym';

// Check if user already submitted a review
let hasUserReview = false;
if (user && req.status === 'delivered') {
  const adminClient = createAdminSupabase(env.SUPABASE_SERVICE_ROLE_KEY);
  const { count } = await adminClient
    .from('transaction_reviews')
    .select('id', { count: 'exact', head: true })
    .eq('commission_request_id', id)
    .eq('reviewer_id', user.id);
  hasUserReview = (count ?? 0) > 0;
}

const STATUS_ORDER = ['open', 'awaiting_payment', 'awaiting_yarn', 'awarded', 'completed', 'delivered', 'disputed'];
const statusIdx = STATUS_ORDER.indexOf(req.status);
const isPast = (phase: string) => STATUS_ORDER.indexOf(phase) < statusIdx;
const isActive = (phase: string) => phase === req.status;
const yarnPhase = req.yarn_provided_by_buyer;
---

<Layout title={`${req.title} — Strikk for meg`} lang="nb">
  <MarketplaceShell current="oppdrag">

      {isStaff && !isBuyer && (req.status === 'pending_review' || req.status === 'rejected') && (
        <div class="bg-blue-50 text-blue-900 rounded-2xl p-4 mb-6 text-sm">
          Du ser denne som {viewerProfile?.role}. Status: <strong>{COMMISSION_STATUS[req.status]}</strong>
        </div>
      )}

      {isBuyer && req.status === 'pending_review' && (
        <div class="bg-amber-50 text-amber-900 rounded-2xl p-4 mb-6 text-sm">
          Forespørselen din er under vurdering. Den blir synlig når den er godkjent.
        </div>
      )}

      {isBuyer && req.status === 'rejected' && (
        <div class="bg-red-50 text-red-900 rounded-2xl p-4 mb-6 text-sm">
          Forespørselen ble avvist. {(req as any).moderation_notes ? `Grunn: ${(req as any).moderation_notes}` : 'Innholdet oppfyller ikke retningslinjene våre.'}
        </div>
      )}

      <!-- Request header -->
      <div class="mb-10">
        <div class="flex items-center gap-2 mb-4">
          {req.status !== 'open' && (
            <span class:list={[
              'inline-block text-[10px] font-bold uppercase tracking-widest rounded-full px-3 py-1',
              req.status === 'delivered' ? 'text-sage-700 bg-sage-100' : req.status === 'completed' ? 'text-terracotta-500 bg-terracotta-500/10' : 'text-charcoal/45 bg-oatmeal/60',
            ]}>
              {COMMISSION_STATUS[req.status]}
            </span>
          )}
          {isPrivate && (
            <span class="inline-block text-[10px] font-bold uppercase tracking-widest text-charcoal/35 bg-oatmeal/40 rounded-full px-3 py-1">Privat</span>
          )}
        </div>

        <div class="flex items-center gap-2 mb-2">
          <span class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500">{CATEGORY_LABEL[req.category] ?? req.category}</span>
          <span class="text-[10px] text-charcoal/40">·</span>
          <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45">str. {req.size_label}</span>
        </div>
        <h1 class="font-serif text-3xl sm:text-4xl mb-3">{req.title}</h1>

        {acceptedOffer && !isOpen ? (
          <p class="font-mono tabular-nums text-2xl mb-5">{acceptedOffer.price_nok} NOK</p>
        ) : (
          <p class="font-mono tabular-nums text-2xl mb-5">{req.budget_nok_min}–{req.budget_nok_max} NOK</p>
        )}

        <dl class="grid grid-cols-2 gap-3 text-sm mb-5">
          {req.colorway && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Farge</dt>
              <dd>{req.colorway}</dd>
            </div>
          )}
          {req.yarn_preference && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Garnpreferanse</dt>
              <dd>{req.yarn_preference}</dd>
            </div>
          )}
          {req.yarn_provided_by_buyer && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Garn</dt>
              <dd>Kjøper sender garnet</dd>
            </div>
          )}
          {req.needed_by && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Trengs innen</dt>
              <dd>{new Date(req.needed_by).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long', year: 'numeric' })}</dd>
            </div>
          )}
        </dl>

        {req.description && (
          <p class="text-sm text-charcoal/75 leading-relaxed whitespace-pre-line mb-5">{req.description}</p>
        )}

        <div class="flex items-center justify-between pt-4 border-t border-sage-500/10">
          <a href={`/marked/selger/${req.buyer_id}`} class="flex items-center gap-3 group">
            <ProfileAvatar url={buyerProfile?.avatar_path ? projectPhotoUrl(buyerProfile.avatar_path) : null} name={buyerProfile?.display_name ?? '?'} size="sm" />
            <div>
              <p class="text-sm font-medium group-hover:text-terracotta-500 transition-colors">{buyerProfile?.display_name ?? 'Anonym'}</p>
              <p class="text-[10px] text-charcoal/45">Bestiller</p>
            </div>
          </a>
          {(isBuyer || isKnitter) && acceptedOffer && !isOpen && (
            commissionConvId ? (
              <a href={`/marked/meldinger/${commissionConvId}`} class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors">Gå til samtale →</a>
            ) : (
              <form method="post" action="/api/marketplace/conversations/create-commission" data-astro-reload class="flex items-center gap-2">
                <input type="hidden" name="commission_request_id" value={req.id} />
                <input name="message" required maxlength="1000" placeholder="Skriv en melding…" class="bg-white rounded-full px-4 py-2 text-xs border border-sage-500/15 focus:outline-none focus:border-sage-500 w-48" />
                <button type="submit" class="bg-charcoal text-linen px-3 py-2 rounded-full text-[10px] font-medium hover:bg-terracotta-500 transition-colors">Send</button>
              </form>
            )
          )}
        </div>
      </div>

      <!-- ═══ OPEN: Offers list (no timeline) ═══ -->
      {isOpen && (
        <div class="mb-10">
          {isBuyer ? (
            allOffers.length === 0 ? (
              <div class="text-center py-8">
                <p class="text-sm text-charcoal/55 mb-1">Ingen tilbud ennå</p>
                <p class="text-xs text-charcoal/40">Strikkere kan se forespørselen din og sende tilbud.</p>
              </div>
            ) : (
              <div>
                <h2 class="font-serif text-xl mb-4">{allOffers.length} {allOffers.length === 1 ? 'tilbud' : 'tilbud'} mottatt</h2>
                <div class="space-y-3">
                  {allOffers.map(o => {
                    const kp = (o as any).profiles;
                    return (
                      <div class="bg-white rounded-2xl p-5 border border-sage-500/10">
                        <div class="flex items-start gap-4">
                          <a href={`/marked/selger/${o.knitter_id}`} class="shrink-0">
                            <ProfileAvatar url={kp?.avatar_path ? projectPhotoUrl(kp.avatar_path) : null} name={kp?.display_name ?? '?'} size="md" />
                          </a>
                          <div class="flex-1 min-w-0">
                            <div class="flex items-baseline justify-between gap-3 mb-1">
                              <a href={`/marked/selger/${o.knitter_id}`} class="font-medium hover:text-terracotta-500 transition-colors">{kp?.display_name ?? 'Anonym'}</a>
                              <p class="font-mono tabular-nums text-lg shrink-0">{o.price_nok} NOK</p>
                            </div>
                            <p class="text-xs text-charcoal/55 mb-2">{o.turnaround_weeks} {o.turnaround_weeks === 1 ? 'uke' : 'uker'} leveringstid</p>
                            {o.message && <p class="text-sm text-charcoal/70 whitespace-pre-line mb-3">{o.message}</p>}
                            <form method="post" action="/api/marketplace/commissions/accept" data-astro-reload>
                              <input type="hidden" name="offer_id" value={o.id} />
                              <button type="submit" class="bg-charcoal text-linen px-5 py-2.5 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors">Aksepter tilbud</button>
                            </form>
                          </div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            )
          ) : !isBuyer && !myOffer && user ? (
            <div class="max-w-md mx-auto bg-white rounded-2xl p-5 border border-sage-500/10">
              <p class="font-medium text-sm mb-3">Send tilbud</p>
              <form method="post" action="/api/marketplace/commissions/offer" data-astro-reload class="space-y-2">
                <input type="hidden" name="request_id" value={req.id} />
                <div class="grid grid-cols-2 gap-2">
                  <label class="block">
                    <span class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-1">Pris (NOK)</span>
                    <input name="price_nok" type="number" required min="1" step="1" placeholder="600" class="w-full bg-linen rounded-lg px-3 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500" />
                  </label>
                  <label class="block">
                    <span class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-1">Uker</span>
                    <input name="turnaround_weeks" type="number" required min="1" max="52" placeholder="3" class="w-full bg-linen rounded-lg px-3 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500" />
                  </label>
                </div>
                <textarea name="message" required rows="2" maxlength="500" placeholder="Kort melding til bestiller…" class="w-full bg-linen rounded-lg px-3 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 resize-none"></textarea>
                <button type="submit" class="w-full bg-charcoal text-linen px-4 py-2.5 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors">Send tilbud</button>
              </form>
            </div>
          ) : myOffer ? (
            <div class="max-w-md mx-auto bg-white rounded-2xl p-5 border border-sage-500/10">
              <p class="text-xs font-bold uppercase tracking-widest text-charcoal/45 mb-1">Ditt tilbud</p>
              <p class="font-mono tabular-nums">{myOffer.price_nok} NOK · {myOffer.turnaround_weeks} uker</p>
              <p class="text-[10px] text-charcoal/45 mt-1">Venter på svar fra bestiller</p>
              <form method="post" action="/api/marketplace/commissions/withdraw" data-astro-reload class="mt-2">
                <input type="hidden" name="offer_id" value={myOffer.id} />
                <button type="submit" class="text-[10px] text-charcoal/35 hover:text-terracotta-500 transition-colors">Trekk tilbake</button>
              </form>
            </div>
          ) : !user ? (
            <div class="max-w-md mx-auto bg-white rounded-2xl p-5 border border-sage-500/10 text-center">
              <p class="text-sm text-charcoal/55 mb-2">Logg inn for å gi tilbud</p>
              <a href={`/logg-inn?next=/marked/oppdrag/${id}`} class="inline-block bg-charcoal text-linen px-4 py-2 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors">Logg inn</a>
            </div>
          ) : null}

          {isBuyer && (
            <div class="mt-4 text-center space-y-2">
              {daysUntilExpiry !== null && (
                <p class="text-xs text-charcoal/45">
                  {expiringSoon ? (
                    <span class="text-amber-600">Utloper om {daysUntilExpiry} {daysUntilExpiry === 1 ? 'dag' : 'dager'}</span>
                  ) : (
                    <span>Utloper om {daysUntilExpiry} dager</span>
                  )}
                </p>
              )}
              {isBuyer && expiringSoon && (
                <form method="post" action="/api/marketplace/commissions/extend" data-astro-reload>
                  <input type="hidden" name="request_id" value={req.id} />
                  <button type="submit" class="text-xs text-charcoal/55 hover:text-terracotta-500 transition-colors">Forleng 30 dager</button>
                </form>
              )}
              <form method="post" action="/api/marketplace/commissions/cancel" data-astro-reload>
                <input type="hidden" name="request_id" value={req.id} />
                <button type="submit" class="text-xs text-charcoal/35 hover:text-terracotta-500 transition-colors">Avbryt forespørsel</button>
              </form>
            </div>
          )}
        </div>
      )}

      <!-- ═══ TIMELINE (after offer accepted) ═══ -->
      {!isOpen && (
      <div class="relative">
        <!-- Column labels -->
        <div class="hidden md:grid grid-cols-[1fr_32px_1fr] gap-x-4 mb-6">
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/35 text-right">Bestiller</p>
          <div></div>
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/35">Strikker</p>
        </div>

        <!-- Center line -->
        <div class="hidden md:block absolute left-1/2 top-10 bottom-0 w-px bg-sage-500/15 -translate-x-1/2 pointer-events-none"></div>

        <!-- ── Phase 1: Valgt tilbud ── -->
        <div class="md:grid md:grid-cols-[1fr_32px_1fr] md:gap-x-4 mb-8">
          <div class="md:text-right mb-4 md:mb-0">
            {isBuyer ? (
              <div>
                <p class="text-xs text-charcoal/45 mb-2">Du valgte:</p>
                <div class="md:ml-auto md:max-w-[260px] bg-white rounded-2xl p-4 border border-terracotta-500/30 bg-terracotta-500/5 md:text-left">
                  <div class="flex items-center gap-2 mb-1">
                    <ProfileAvatar url={knitterProfile?.avatar_path ? projectPhotoUrl(knitterProfile.avatar_path) : null} name={knitterName} size="xs" />
                    <a href={`/marked/selger/${acceptedOffer!.knitter_id}`} class="text-sm font-medium hover:text-terracotta-500 transition-colors">{knitterName}</a>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500">Valgt</span>
                  </div>
                  <p class="font-mono tabular-nums">{acceptedOffer!.price_nok} NOK</p>
                  <p class="text-xs text-charcoal/55">{acceptedOffer!.turnaround_weeks} {acceptedOffer!.turnaround_weeks === 1 ? 'uke' : 'uker'} leveringstid</p>
                </div>
              </div>
            ) : (
              <div>
                <p class="text-xs text-charcoal/45 mb-2">Valgt tilbud:</p>
                <div class="md:ml-auto md:max-w-[260px] bg-white rounded-2xl p-4 border border-terracotta-500/30 bg-terracotta-500/5 md:text-left">
                  <div class="flex items-center gap-2 mb-1">
                    <ProfileAvatar url={knitterProfile?.avatar_path ? projectPhotoUrl(knitterProfile.avatar_path) : null} name={knitterName} size="xs" />
                    <span class="text-sm font-medium">{knitterName}</span>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500">Valgt</span>
                  </div>
                  <p class="font-mono tabular-nums">{acceptedOffer!.price_nok} NOK</p>
                  <p class="text-xs text-charcoal/55">{acceptedOffer!.turnaround_weeks} {acceptedOffer!.turnaround_weeks === 1 ? 'uke' : 'uker'} leveringstid</p>
                  {req.offer_count > 1 && (
                    <p class="text-[10px] text-charcoal/40 mt-2">{req.offer_count - 1} {req.offer_count - 1 === 1 ? 'annet tilbud' : 'andre tilbud'} ble vurdert.</p>
                  )}
                </div>
              </div>
            )}
          </div>
          <div class="hidden md:flex justify-center relative z-10">
            <div class="w-3 h-3 rounded-full mt-1 bg-sage-500"></div>
          </div>
          <div>
            {isKnitter ? (
              <div class="bg-white rounded-2xl p-4 border border-sage-500/10">
                <p class="text-xs font-bold uppercase tracking-widest text-charcoal/45 mb-1">Ditt tilbud — akseptert</p>
                <p class="font-mono tabular-nums">{myOffer!.price_nok} NOK · {myOffer!.turnaround_weeks} uker</p>
              </div>
            ) : (
              <p class="text-xs text-charcoal/40">Tilbud akseptert</p>
            )}
          </div>
        </div>

        <!-- ── Phase 2: Betaling ── -->
        {(
          <div class="md:grid md:grid-cols-[1fr_32px_1fr] md:gap-x-4 mb-8">
            <div class="md:text-right mb-4 md:mb-0">
              {isActive('awaiting_payment') && isBuyer ? (
                <div class="md:ml-auto md:max-w-[280px] bg-white rounded-2xl p-4 border border-terracotta-500/30 md:text-left">
                  <p class="font-medium text-sm mb-1">Betal for oppdraget</p>
                  <p class="text-xs text-charcoal/55 mb-3">Pengene holdes til prosjektet er levert.</p>
                  <p class="font-mono tabular-nums text-lg mb-3">{acceptedOffer!.price_nok} NOK</p>
                  <form method="post" action="/api/marketplace/commissions/pay" data-astro-reload>
                    <input type="hidden" name="request_id" value={req.id} />
                    <button type="submit" class="w-full bg-charcoal text-linen px-4 py-2.5 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors">Betal nå</button>
                  </form>
                  <p class="text-[10px] text-charcoal/30 text-center mt-2">Stripe-betaling kommer snart.</p>
                </div>
              ) : isPast('awaiting_payment') ? (
                <p class="text-xs text-charcoal/45"><span class="text-sage-700">✓</span> Betalt</p>
              ) : (
                <p class="text-xs text-charcoal/30">Betaling</p>
              )}
            </div>
            <div class="hidden md:flex justify-center relative z-10">
              <div class:list={['w-3 h-3 rounded-full mt-1', isPast('awaiting_payment') ? 'bg-sage-500' : isActive('awaiting_payment') ? 'bg-terracotta-500 ring-4 ring-terracotta-500/15' : 'bg-sage-500/20']}></div>
            </div>
            <div>
              {isActive('awaiting_payment') ? (
                <p class="text-xs text-charcoal/45">Venter på betaling fra bestiller…</p>
              ) : isPast('awaiting_payment') ? (
                <p class="text-xs text-charcoal/45"><span class="text-sage-700">✓</span> Betaling mottatt</p>
              ) : (
                <p class="text-xs text-charcoal/30">—</p>
              )}
            </div>
          </div>
        )}

        <!-- ── Phase 3: Garn (conditional) ── -->
        {yarnPhase && !isOpen && !isActive('awaiting_payment') && (
          <div class="md:grid md:grid-cols-[1fr_32px_1fr] md:gap-x-4 mb-8">
            <div class="md:text-right mb-4 md:mb-0">
              {isActive('awaiting_yarn') && !req.yarn_shipped_at && isBuyer ? (
                <div class="md:ml-auto md:max-w-[280px] bg-white rounded-2xl p-4 border border-terracotta-500/20 md:text-left">
                  <p class="font-medium text-sm mb-1">Send garnet</p>
                  <p class="text-xs text-charcoal/55 mb-3">Send garnet til strikkeren med sporing.</p>
                  <form method="post" action="/api/marketplace/commissions/ship-yarn" data-astro-reload class="space-y-2">
                    <input type="hidden" name="request_id" value={req.id} />
                    <input name="tracking_code" type="text" maxlength="50" placeholder="Sporingskode (valgfritt)" class="w-full bg-linen rounded-lg px-3 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500" />
                    <button type="submit" class="w-full bg-charcoal text-linen px-4 py-2.5 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors">Merk som sendt</button>
                  </form>
                </div>
              ) : isActive('awaiting_yarn') && req.yarn_shipped_at ? (
                <div class="md:ml-auto md:max-w-[260px] md:text-left">
                  <p class="text-xs text-charcoal/45"><span class="text-sage-700">✓</span> Garnet er sendt</p>
                  <p class="text-[10px] text-charcoal/40 mt-0.5">
                    {new Date(req.yarn_shipped_at).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long' })}
                    {req.yarn_tracking_code && <span> · <span class="font-mono">{req.yarn_tracking_code}</span></span>}
                  </p>
                </div>
              ) : isPast('awaiting_yarn') ? (
                <p class="text-xs text-charcoal/45"><span class="text-sage-700">✓</span> Garn sendt og mottatt</p>
              ) : (
                <p class="text-xs text-charcoal/30">Send garn</p>
              )}
            </div>
            <div class="hidden md:flex justify-center relative z-10">
              <div class:list={['w-3 h-3 rounded-full mt-1', isPast('awaiting_yarn') ? 'bg-sage-500' : isActive('awaiting_yarn') ? 'bg-terracotta-500 ring-4 ring-terracotta-500/15' : 'bg-sage-500/20']}></div>
            </div>
            <div>
              {isActive('awaiting_yarn') && !req.yarn_shipped_at ? (
                <p class="text-xs text-charcoal/45">Venter på garn fra bestiller…</p>
              ) : isActive('awaiting_yarn') && req.yarn_shipped_at ? (
                <div class="bg-white rounded-2xl p-4 border border-terracotta-500/20">
                  <p class="font-medium text-sm mb-1">Garnet er på vei!</p>
                  {req.yarn_tracking_code && <p class="text-xs text-charcoal/55 mb-2">Sporing: <span class="font-mono">{req.yarn_tracking_code}</span></p>}
                  {req.yarn_bring_shipment_number && <div data-tracking-events class="text-xs text-charcoal/55 mb-3"></div>}
                  <form method="post" action="/api/marketplace/commissions/receive-yarn" data-astro-reload>
                    <input type="hidden" name="request_id" value={req.id} />
                    <button type="submit" class="w-full bg-charcoal text-linen px-4 py-2.5 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors">Bekreft mottatt</button>
                  </form>
                </div>
              ) : isPast('awaiting_yarn') ? (
                <p class="text-xs text-charcoal/45"><span class="text-sage-700">✓</span> Garn mottatt</p>
              ) : (
                <p class="text-xs text-charcoal/30">—</p>
              )}
            </div>
          </div>
        )}

        <!-- ── Phase 4: Pågår ── -->
        {isPast('awaiting_payment') && (isPast('awaiting_yarn') || !yarnPhase) && (
          <div class="md:grid md:grid-cols-[1fr_32px_1fr] md:gap-x-4 mb-8">
            <div class="md:text-right mb-4 md:mb-0">
              {isActive('awarded') ? (
                isBuyer && linkedProject && projectLogs.length > 0 ? (
                  <div class="md:ml-auto md:max-w-[280px] md:text-left">
                    <p class="text-xs text-charcoal/45 mb-2">Strikkeren jobber…</p>
                    {projectProgressPct !== null && (
                      <div class="bg-white rounded-xl p-3 border border-sage-500/10">
                        <div class="flex items-center justify-between text-[10px] text-charcoal/55 mb-1">
                          <span class="font-bold uppercase tracking-widest">Fremdrift</span>
                          <span>{projectProgressPct}%</span>
                        </div>
                        <div class="h-1.5 bg-sage-500/10 rounded-full overflow-hidden">
                          <div class="h-full bg-sage-500 rounded-full" style={`width: ${projectProgressPct}%`}></div>
                        </div>
                      </div>
                    )}
                  </div>
                ) : (
                  <p class="text-xs text-charcoal/45">Strikkeren jobber med bestillingen din.</p>
                )
              ) : isPast('awarded') ? (
                <p class="text-xs text-charcoal/45"><span class="text-sage-700">✓</span> Strikking ferdig</p>
              ) : (
                <p class="text-xs text-charcoal/30">Pågår</p>
              )}
            </div>
            <div class="hidden md:flex justify-center relative z-10">
              <div class:list={['w-3 h-3 rounded-full mt-1', isPast('awarded') ? 'bg-sage-500' : isActive('awarded') ? 'bg-terracotta-500 ring-4 ring-terracotta-500/15' : 'bg-sage-500/20']}></div>
            </div>
            <div>
              {isActive('awarded') && isKnitter ? (
                <div class="space-y-3">
                  {linkedProject && (
                    <a href={`/studio/prosjekter/${linkedProject.id}`} class="flex items-center gap-3 bg-white rounded-xl p-3 border border-sage-500/10 hover:border-sage-500/30 transition-colors">
                      {linkedProject.hero_photo_path ? (
                        <img src={projectPhotoUrl(linkedProject.hero_photo_path)!} alt="" class="w-10 h-10 rounded-lg object-cover shrink-0" />
                      ) : (
                        <div class="w-10 h-10 rounded-lg bg-oatmeal/60 shrink-0"></div>
                      )}
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-medium line-clamp-1">{linkedProject.title}</p>
                        <p class="text-[10px] text-charcoal/45">{PROJECT_STATUS[linkedProject.status]} · Åpne i Strikkestua</p>
                      </div>
                    </a>
                  )}
                  {!myOffer?.project_id && knitterProjects.length > 0 && (
                    <div class="bg-white rounded-2xl p-4 border border-sage-500/10">
                      <p class="text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Knytt til prosjekt</p>
                      <form method="post" action="/api/marketplace/commissions/link-project" data-astro-reload class="space-y-2">
                        <input type="hidden" name="offer_id" value={myOffer!.id} />
                        <select name="project_id" required class="w-full bg-linen rounded-lg px-3 py-2 text-sm border border-sage-500/15">
                          <option value="">Velg prosjekt…</option>
                          {knitterProjects.map(p => <option value={p.id}>{p.title}</option>)}
                        </select>
                        <button type="submit" class="w-full bg-charcoal text-linen px-4 py-2 rounded-full text-[10px] font-medium hover:bg-terracotta-500 transition-colors">Knytt til</button>
                      </form>
                    </div>
                  )}
                  <div class="bg-white rounded-2xl p-4 border border-sage-500/10">
                    <p class="text-sm font-medium mb-1">Ferdig strikket?</p>
                    <p class="text-xs text-charcoal/55 mb-3">Kjøper har 14 dager på å bekrefte mottak.</p>
                    <form method="post" action="/api/marketplace/commissions/mark-completed" data-astro-reload class="space-y-2">
                      <input type="hidden" name="request_id" value={req.id} />
                      <input name="tracking_code" type="text" maxlength="50" placeholder="Sporingskode (valgfritt)" class="w-full bg-linen rounded-lg px-3 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500" />
                      <button type="submit" class="w-full bg-charcoal text-linen px-4 py-2.5 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors">Merk som ferdig</button>
                    </form>
                  </div>
                </div>
              ) : isActive('awarded') ? (
                <p class="text-xs text-charcoal/45">Strikkeren jobber…</p>
              ) : isPast('awarded') ? (
                <p class="text-xs text-charcoal/45"><span class="text-sage-700">✓</span> Ferdigstrikket</p>
              ) : (
                <p class="text-xs text-charcoal/30">—</p>
              )}
            </div>
          </div>
        )}

        <!-- ── Phase 5: Ferdigstilt ── -->
        {(isActive('completed') || isPast('completed')) && (
          <div class="md:grid md:grid-cols-[1fr_32px_1fr] md:gap-x-4 mb-8">
            <div class="md:text-right mb-4 md:mb-0">
              {isActive('completed') && isBuyer ? (
                <div class="md:ml-auto md:max-w-[280px] bg-white rounded-2xl p-4 border border-terracotta-500/20 md:text-left">
                  <p class="font-medium text-sm mb-1">Bekreft mottak</p>
                  <p class="text-xs text-charcoal/55 mb-3">Har du mottatt arbeidet?</p>
                  {req.finished_item_tracking_code && (
                    <p class="text-xs text-charcoal/55 mb-2">Sporing: <span class="font-mono">{req.finished_item_tracking_code}</span></p>
                  )}
                  {daysUntilAutoRelease !== null && (
                    <p class="text-[10px] text-charcoal/40 mb-3">Automatisk godkjenning om {daysUntilAutoRelease} {daysUntilAutoRelease === 1 ? 'dag' : 'dager'}.</p>
                  )}
                  <form method="post" action="/api/marketplace/commissions/confirm-delivery" data-astro-reload>
                    <input type="hidden" name="request_id" value={req.id} />
                    <button type="submit" class="w-full bg-charcoal text-linen px-4 py-2.5 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors">Bekreft mottatt</button>
                  </form>
                  <form method="post" action="/api/marketplace/commissions/dispute" data-astro-reload class="mt-2">
                    <input type="hidden" name="request_id" value={req.id} />
                    <input name="reason" required maxlength="500" placeholder="Beskriv problemet…" class="w-full bg-linen rounded-lg px-3 py-2 text-xs border border-sage-500/15 focus:outline-none focus:border-sage-500 mb-1" />
                    <button type="submit" class="w-full text-[10px] text-charcoal/35 hover:text-terracotta-500 transition-colors">Rapporter problem</button>
                  </form>
                </div>
              ) : isActive('completed') ? (
                <p class="text-xs text-charcoal/45">Venter på bekreftelse fra bestiller…</p>
              ) : (
                <p class="text-xs text-charcoal/45"><span class="text-sage-700">✓</span> Mottak bekreftet</p>
              )}
            </div>
            <div class="hidden md:flex justify-center relative z-10">
              <div class:list={['w-3 h-3 rounded-full mt-1', isPast('completed') ? 'bg-sage-500' : 'bg-terracotta-500 ring-4 ring-terracotta-500/15']}></div>
            </div>
            <div>
              {isActive('completed') ? (
                <div>
                  <p class="text-xs text-charcoal/45"><span class="text-sage-700">✓</span> Merket som ferdig</p>
                  {req.finished_item_tracking_code && (
                    <p class="text-[10px] text-charcoal/40 mt-0.5">Sporing: <span class="font-mono">{req.finished_item_tracking_code}</span></p>
                  )}
                  {daysUntilAutoRelease !== null && (
                    <p class="text-[10px] text-charcoal/40 mt-0.5">Automatisk godkjenning om {daysUntilAutoRelease}d</p>
                  )}
                </div>
              ) : (
                <p class="text-xs text-charcoal/45"><span class="text-sage-700">✓</span> Ferdigstrikket</p>
              )}
            </div>
          </div>
        )}

        <!-- ── Phase 6: Levert ── -->
        {req.status === 'delivered' && (
          <div class="md:grid md:grid-cols-[1fr_32px_1fr] md:gap-x-4">
            <div class="md:text-right mb-4 md:mb-0">
              <p class="text-sm font-medium text-sage-700">✓ Levert</p>
              {req.delivered_at && (
                <p class="text-[10px] text-charcoal/40">{new Date(req.delivered_at).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
              )}
            </div>
            <div class="hidden md:flex justify-center relative z-10">
              <div class="w-4 h-4 rounded-full bg-sage-500 ring-4 ring-sage-500/15 mt-0.5"></div>
            </div>
            <div>
              <p class="text-sm font-medium text-sage-700">✓ Betaling frigitt</p>
            </div>
          </div>
        )}

      </div>
      )}

      <!-- Review form (after delivery) -->
      {req.status === 'delivered' && (isBuyer || isKnitter) && (
        <div class="mt-8">
          <ReviewForm commissionRequestId={req.id} existingReview={hasUserReview} />
        </div>
      )}

      <!-- Report button -->
      {user && !isBuyer && !isKnitter && req.status === 'open' && (
        <div class="mt-6 text-right">
          <ReportButton targetType="commission_request" targetId={req.id} />
        </div>
      )}

      <!-- Project logs (buyer view, shown below timeline) -->
      {isBuyer && linkedProject && projectLogs.length > 0 && ['awarded', 'completed', 'delivered'].includes(req.status) && (
        <div class="mt-12 pt-8 border-t border-sage-500/10">
          <h2 class="font-serif text-xl mb-4">Prosjektoppdateringer</h2>
          <ol class="space-y-3">
            {projectLogs.map((log) => (
              <li class="bg-white rounded-2xl p-4 border border-sage-500/10">
                <div class="flex items-baseline gap-3 flex-wrap mb-1">
                  <time class="text-xs font-bold uppercase tracking-wider text-sage-900">
                    {new Date(log.log_date).toLocaleDateString('nb-NO', { weekday: 'short', day: 'numeric', month: 'long' })}
                  </time>
                  {log.rows_at != null && <span class="text-[10px] text-charcoal/45">Rad {log.rows_at}</span>}
                </div>
                {log.body && <p class="text-sm text-charcoal/80 whitespace-pre-wrap">{log.body}</p>}
                {log.photos?.length > 0 && (
                  <div class={`mt-3 grid gap-2 ${log.photos.length === 1 ? 'grid-cols-1' : 'grid-cols-3'}`}>
                    {log.photos.map((photo: string) => (
                      <a href={projectPhotoUrl(photo)} target="_blank" rel="noopener" class="aspect-square rounded-xl overflow-hidden bg-oatmeal">
                        <img src={projectPhotoUrl(photo)!} alt="" class="w-full h-full object-cover" loading="lazy" />
                      </a>
                    ))}
                  </div>
                )}
              </li>
            ))}
          </ol>
        </div>
      )}

  </MarketplaceShell>
</Layout>

{req.yarn_bring_shipment_number && (
<script is:inline define:vars={{ requestId: req.id }}>
  function escTrack(s) {
    var d = document.createElement('div');
    d.textContent = String(s ?? '');
    return d.innerHTML;
  }
  (async function() {
    var containers = document.querySelectorAll('[data-tracking-events]');
    if (!containers.length) return;
    try {
      var res = await fetch('/api/marketplace/commissions/tracking?request_id=' + requestId);
      if (!res.ok) return;
      var events = await res.json();
      if (!events.length) return;
      var html = '<p class="font-bold mb-1">Sporingshendelser:</p><ul class="space-y-1">';
      events.slice(0, 5).forEach(function(e) {
        var d = new Date(e.dateTime);
        var ts = d.toLocaleDateString('nb-NO', { day: 'numeric', month: 'short' }) + ' ' + d.toLocaleTimeString('nb-NO', { hour: '2-digit', minute: '2-digit' });
        html += '<li>' + escTrack(ts) + ' — ' + escTrack(e.description) + (e.city ? ' (' + escTrack(e.city) + ')' : '') + '</li>';
      });
      html += '</ul>';
      containers.forEach(function(el) { el.innerHTML = html; });
    } catch {}
  })();
</script>
)}
