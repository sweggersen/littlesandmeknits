---
import Layout from '../../../layouts/Layout.astro';
import MarketplaceShell from '../../../components/MarketplaceShell.astro';
import CommissionCard from '../../../components/CommissionCard.astro';
import EmptyState from '../../../components/EmptyState.astro';
import LoadMore from '../../../components/LoadMore.astro';
import { createServerSupabase } from '../../../lib/supabase';
import { CATEGORY_LABEL } from '../../../lib/labels';

const PAGE_SIZE = 24;
const url = Astro.url;
const category = url.searchParams.get('kategori');
const search = url.searchParams.get('q')?.trim();
const budgetMin = parseInt(url.searchParams.get('budsjett_min') ?? '', 10);
const budgetMax = parseInt(url.searchParams.get('budsjett_max') ?? '', 10);
const cursor = url.searchParams.get('cursor');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
let q = supabase
  .from('commission_requests')
  .select('id, title, category, size_label, budget_nok_min, budget_nok_max, needed_by, offer_count, created_at, expires_at, buyer_id, profiles!commission_requests_buyer_id_fkey(display_name)')
  .eq('status', 'open')
  .order('created_at', { ascending: false });

if (search) q = q.ilike('title', `%${search}%`);
if (category) q = q.eq('category', category);
if (Number.isFinite(budgetMin)) q = q.gte('budget_nok_max', budgetMin);
if (Number.isFinite(budgetMax)) q = q.lte('budget_nok_min', budgetMax);
if (cursor) q = q.lt('created_at', cursor);

const { data: requests } = await q.limit(PAGE_SIZE);
const hasMore = (requests?.length ?? 0) === PAGE_SIZE;
const lastCursor = requests?.length ? requests[requests.length - 1].created_at : null;

const nextPageParams = (() => {
  if (!hasMore || !lastCursor) return null;
  const p = new URLSearchParams(url.searchParams);
  p.set('cursor', lastCursor);
  return p.toString();
})();

function expiryDays(expiresAt: string | null): number | null {
  if (!expiresAt) return null;
  return Math.max(0, Math.ceil((new Date(expiresAt).getTime() - Date.now()) / 86400_000));
}

---

<Layout title="Strikk for meg — Strikketorget" lang="nb">
  <MarketplaceShell current="oppdrag">
      <div class="flex items-start justify-between gap-4 mb-2">
        <h1 class="font-serif text-4xl sm:text-5xl">Strikk for meg</h1>
        <a href="/marked/oppdrag/ny" class="shrink-0 bg-charcoal text-linen px-5 py-2.5 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors">
          + Ny forespørsel
        </a>
      </div>
      <p class="text-charcoal/65 mb-8">Bestill et plagg strikket av en dyktig strikker fra fellesskapet.</p>

      <form method="get" class="bg-white rounded-3xl p-4 sm:p-5 border border-sage-500/10 mb-8 flex flex-wrap gap-3 items-end">
        <div class="flex-1 min-w-[180px]">
          <label for="q" class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-1">Søk</label>
          <input id="q" name="q" type="text" value={search ?? ''} placeholder="Søk etter tittel..."
            class="w-full bg-linen rounded-xl px-3 py-2 text-sm border border-sage-500/15" />
        </div>
        <div class="flex-1 min-w-[140px]">
          <label for="kategori" class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-1">Kategori</label>
          <select id="kategori" name="kategori" class="w-full bg-linen rounded-xl px-3 py-2 text-sm border border-sage-500/15">
            <option value="">Alle</option>
            {Object.entries(CATEGORY_LABEL).map(([k, v]) => (
              <option value={k} selected={category === k}>{v}</option>
            ))}
          </select>
        </div>
        <div class="w-24">
          <label for="budsjett_min" class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-1">Budsjett fra</label>
          <input id="budsjett_min" name="budsjett_min" type="number" min="0" value={url.searchParams.get('budsjett_min') ?? ''} class="w-full bg-linen rounded-xl px-3 py-2 text-sm border border-sage-500/15" placeholder="NOK" />
        </div>
        <div class="w-24">
          <label for="budsjett_max" class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-1">Budsjett til</label>
          <input id="budsjett_max" name="budsjett_max" type="number" min="0" value={url.searchParams.get('budsjett_max') ?? ''} class="w-full bg-linen rounded-xl px-3 py-2 text-sm border border-sage-500/15" placeholder="NOK" />
        </div>
        <button type="submit" class="bg-charcoal text-linen px-5 py-2 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors">
          Filtrer
        </button>
      </form>

      {(requests ?? []).length === 0 ? (
        <EmptyState message="Ingen åpne forespørsler ennå." ctaText="Opprett den første" ctaHref="/marked/oppdrag/ny" />
      ) : (
        <Fragment>
        <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
          {(requests ?? []).map((r) => (
            <CommissionCard
              id={r.id}
              title={r.title}
              category={r.category}
              sizeLabel={r.size_label}
              budgetMin={r.budget_nok_min}
              budgetMax={r.budget_nok_max}
              offerCount={r.offer_count}
              buyerName={(r as any).profiles?.display_name ?? 'Anonym'}
              neededBy={r.needed_by}
              daysLeft={expiryDays(r.expires_at)}
            />
          ))}
        </ul>

        <LoadMore params={nextPageParams} />
        </Fragment>
      )}
  </MarketplaceShell>
</Layout>
