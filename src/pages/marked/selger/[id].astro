---
import Layout from '../../../layouts/Layout.astro';
import MarketplaceShell from '../../../components/MarketplaceShell.astro';
import ReportButton from '../../../components/ReportButton.astro';
import ProfileAvatar from '../../../components/ProfileAvatar.astro';
import ListingCard from '../../../components/ListingCard.astro';
import StarRating from '../../../components/StarRating.astro';
import EmptyState from '../../../components/EmptyState.astro';
import { createServerSupabase } from '../../../lib/supabase';
import { getCurrentUser } from '../../../lib/auth';
import { projectPhotoUrl } from '../../../lib/storage';
import { KIND_LABEL } from '../../../lib/labels';
import { getUserAchievements, ACHIEVEMENT_MAP, ACHIEVEMENTS } from '../../../lib/achievements';

const sellerId = Astro.params.id;
if (!sellerId) return Astro.redirect('/marked');

const user = await getCurrentUser({ request: Astro.request, cookies: Astro.cookies });

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });

const { data: seller } = await supabase
  .from('profiles')
  .select('id, display_name, bio, location, avatar_path, seller_tags, instagram_handle, profile_visible, created_at, role')
  .eq('id', sellerId)
  .maybeSingle();

if (!seller || !seller.profile_visible) return Astro.redirect('/marked');

const [{ data: listings }, { data: reviews }, { data: txnReviews }] = await Promise.all([
  supabase
    .from('listings')
    .select('id, title, kind, price_nok, size_label, hero_photo_path, published_at')
    .eq('seller_id', sellerId)
    .eq('status', 'active')
    .order('published_at', { ascending: false })
    .limit(12),
  supabase
    .from('seller_reviews')
    .select('id, rating, comment, created_at, reviewer_id, profiles!seller_reviews_reviewer_id_fkey(display_name)')
    .eq('seller_id', sellerId)
    .order('created_at', { ascending: false })
    .limit(20),
  supabase
    .from('transaction_reviews')
    .select('id, rating, comment, created_at, reviewer_role, profiles!transaction_reviews_reviewer_id_fkey(display_name)')
    .eq('reviewee_id', sellerId)
    .eq('visible', true)
    .order('created_at', { ascending: false })
    .limit(20),
]);

const transactionReviews = txnReviews ?? [];
const isAmbassador = (seller as any)?.role === 'ambassador';

const activeListings = listings ?? [];
const reviewList = reviews ?? [];
const avgRating = reviewList.length > 0
  ? (reviewList.reduce((s, r) => s + r.rating, 0) / reviewList.length).toFixed(1)
  : null;

const TAG_LABEL: Record<string, string> = {
  knitter: 'Strikker',
  sells_pre_loved: 'Selger brukt',
  sells_ready_made: 'Selger ferdigstrikket',
  open_for_requests: 'Åpen for bestillinger',
  dyer: 'Farger garn',
};

const memberSince = new Date(seller.created_at).toLocaleDateString('nb-NO', { year: 'numeric', month: 'long' });
const avatarUrl = seller.avatar_path ? projectPhotoUrl(seller.avatar_path) : null;

const earnedKeys = await getUserAchievements(supabase, sellerId);
const earnedSet = new Set(earnedKeys);
const earnedAchievements = ACHIEVEMENTS.filter(a => earnedSet.has(a.key) && a.category !== 'moderering');
---

<Layout title={`${seller.display_name ?? 'Selger'} — Strikketorget`} lang="nb">
  <MarketplaceShell>

      <!-- Profile header -->
      <div class="flex items-start gap-5 mb-8">
        <ProfileAvatar url={avatarUrl} name={seller.display_name ?? '?'} size="xl" />
        <div class="min-w-0">
          <div class="flex items-center gap-2">
            <h1 class="font-serif text-3xl">{seller.display_name ?? 'Anonym'}</h1>
            {isAmbassador && (
              <span class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500 bg-terracotta-500/10 rounded-full px-2.5 py-1">Ambassadør</span>
            )}
          </div>
          <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-1 text-sm text-charcoal/55">
            {seller.location && <span>{seller.location}</span>}
            <span>Medlem siden {memberSince}</span>
            {avgRating && (
              <span class="flex items-center gap-1">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-terracotta-500"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {avgRating} ({reviewList.length})
              </span>
            )}
          </div>
          {seller.seller_tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-3">
              {seller.seller_tags.map((tag: string) => (
                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-sage-100 text-sage-800">
                  {TAG_LABEL[tag] ?? tag}
                </span>
              ))}
            </div>
          )}
          {seller.bio && (
            <p class="text-sm text-charcoal/70 mt-3 max-w-xl whitespace-pre-line">{seller.bio}</p>
          )}
          {seller.instagram_handle && (
            <p class="text-sm text-charcoal/45 mt-2">
              @{seller.instagram_handle}
            </p>
          )}
          {user && user.id !== sellerId && seller.seller_tags.includes('open_for_requests') && (
            <a
              href={`/marked/oppdrag/ny?strikker=${sellerId}`}
              class="inline-block mt-4 bg-charcoal text-linen px-5 py-2.5 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors"
            >
              Send privat forespørsel →
            </a>
          )}
        </div>
      </div>

      <!-- Merker -->
      {earnedAchievements.length > 0 && (
        <div class="mb-8">
          <div class="flex flex-wrap gap-1.5">
            {earnedAchievements.map(a => (
              <span class="group relative flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-white border border-sage-500/15" title={a.description}>
                <span>{a.emoji}</span>
                <span>{a.label}</span>
                <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2.5 py-1 bg-charcoal text-linen text-[10px] rounded-lg whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity">
                  {a.description}
                </span>
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Active listings -->
      <section class="mb-12">
        <h2 class="font-serif text-2xl mb-4">
          Annonser ({activeListings.length})
        </h2>
        {activeListings.length === 0 ? (
          <EmptyState message="Ingen aktive annonser akkurat nå." compact />
        ) : (
          <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 sm:gap-4">
            {activeListings.map((l) => (
              <ListingCard
                id={l.id}
                title={l.title}
                price={l.price_nok}
                imgUrl={projectPhotoUrl(l.hero_photo_path)}
                meta={`${KIND_LABEL[l.kind] ?? l.kind} · str. ${l.size_label}`}
              />
            ))}
          </ul>
        )}
      </section>

      <!-- Reviews -->
      <section>
        <h2 class="font-serif text-2xl mb-4">
          Omtaler {reviewList.length > 0 ? `(${reviewList.length})` : ''}
        </h2>
        {reviewList.length === 0 ? (
          <EmptyState message="Ingen omtaler ennå." compact />
        ) : (
          <div class="space-y-3">
            {reviewList.map((r) => (
              <div class="bg-white rounded-2xl p-4 border border-sage-500/10">
                <div class="flex items-center gap-2 mb-2">
                  <StarRating rating={r.rating} />
                  <span class="text-sm font-medium">{(r as any).profiles?.display_name ?? 'Anonym'}</span>
                  <span class="text-xs text-charcoal/40">{new Date(r.created_at).toLocaleDateString('nb-NO')}</span>
                </div>
                {r.comment && <p class="text-sm text-charcoal/70">{r.comment}</p>}
              </div>
            ))}
          </div>
        )}
      </section>

      <!-- Transaction reviews -->
      {transactionReviews.length > 0 && (
        <section class="mb-12">
          <h2 class="font-serif text-2xl mb-4">
            Oppdragsvurderinger ({transactionReviews.length})
          </h2>
          <div class="space-y-3">
            {transactionReviews.map((r) => (
              <div class="bg-white rounded-2xl p-4 border border-sage-500/10">
                <div class="flex items-center gap-2 mb-2">
                  <StarRating rating={r.rating} />
                  <span class="text-sm font-medium">{(r as any).profiles?.display_name ?? 'Anonym'}</span>
                  <span class="text-[10px] text-charcoal/40">{r.reviewer_role === 'buyer' ? 'Bestiller' : 'Strikker'}</span>
                  <span class="text-xs text-charcoal/40">{new Date(r.created_at).toLocaleDateString('nb-NO')}</span>
                </div>
                {r.comment && <p class="text-sm text-charcoal/70">{r.comment}</p>}
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Report button -->
      {user && user.id !== sellerId && (
        <div class="text-right mt-8">
          <ReportButton targetType="user" targetId={sellerId} />
        </div>
      )}

  </MarketplaceShell>
</Layout>
