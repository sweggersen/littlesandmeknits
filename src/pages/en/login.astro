---
import Layout from '../../layouts/Layout.astro';
import LoginContent from '../../components/LoginContent.astro';
// Auth lookup moved to middleware → Astro.locals.user
const user = Astro.locals.user;
if (user) {
  return Astro.redirect('/studio');
}

const next = Astro.url.searchParams.get('next') ?? '/studio';
---

<Layout title="Log in — Littles and Me" lang="en">
  <LoginContent lang="en" redirectTo={next} />
</Layout>
