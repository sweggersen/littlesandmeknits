---
import Layout from '../../../../layouts/Layout.astro';
import { createServerSupabase, createAdminSupabase } from '../../../../lib/supabase';
import { getCurrentUser } from '../../../../lib/auth';
import { CATEGORY_LABEL } from '../../../../lib/labels';
import { env } from 'cloudflare:workers';

const id = Astro.params.id;
if (!id) return Astro.redirect('/market');

const user = await getCurrentUser({ request: Astro.request, cookies: Astro.cookies });
if (!user) return Astro.redirect(`/login?next=/market/commissions/${id}/kvittering`);

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const admin = createAdminSupabase(env.SUPABASE_SERVICE_ROLE_KEY);

const { data: req } = await admin
  .from('commission_requests')
  .select('id, buyer_id, awarded_offer_id, title, category, size_label, status, platform_fee_nok, delivered_at, completed_at, awarded_at, created_at')
  .eq('id', id)
  .maybeSingle();
if (!req) return Astro.redirect('/market/commissions');

// Knitter info via the awarded offer.
let knitterId: string | null = null;
let price = 0;
if (req.awarded_offer_id) {
  const { data: offer } = await admin
    .from('commission_offers')
    .select('knitter_id, price_nok')
    .eq('id', req.awarded_offer_id)
    .maybeSingle();
  if (offer) { knitterId = offer.knitter_id; price = offer.price_nok ?? 0; }
}

const { data: viewerProfile } = await admin.from('profiles').select('role').eq('id', user.id).maybeSingle();
const isStaff = viewerProfile?.role === 'admin' || viewerProfile?.role === 'moderator';
const isBuyer = req.buyer_id === user.id;
const isKnitter = knitterId === user.id;
if (!isBuyer && !isKnitter && !isStaff) return Astro.redirect(`/market/commissions/${id}`);

// Receipts only exist once the commission has been awarded.
if (!req.awarded_at && !req.awarded_offer_id) {
  return new Response('Kvittering finnes ikke — oppdraget er ikke tildelt', { status: 404 });
}

const [{ data: buyer }, { data: knitter }] = await Promise.all([
  admin.from('profiles').select('display_name, location').eq('id', req.buyer_id).maybeSingle(),
  knitterId
    ? admin.from('profiles').select('display_name, location').eq('id', knitterId).maybeSingle()
    : Promise.resolve({ data: null }),
]);

const gross = price;
const fee = req.platform_fee_nok ?? 0;
const net = gross - fee;
const dato = req.delivered_at ?? req.completed_at ?? req.awarded_at ?? req.created_at;
const dateLabel = new Date(dato).toLocaleDateString('nb-NO', { year: 'numeric', month: 'long', day: 'numeric' });
const receiptNo = `K-${req.id.slice(0, 8).toUpperCase()}-${(dato).slice(0, 10).replace(/-/g, '')}`;

function nok(n: number): string {
  return n.toLocaleString('nb-NO', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + ' kr';
}
---

<Layout title={`Kvittering — ${req.title}`} lang="nb">
  <div class="max-w-2xl mx-auto px-6 py-10 print:py-2 print:px-0">
    <div class="flex items-center justify-between mb-6 print:hidden">
      <a href={`/market/commissions/${req.id}`} class="text-xs text-charcoal/45 hover:text-terracotta-500">&larr; Tilbake til oppdraget</a>
      <button onclick="window.print()" class="bg-charcoal text-linen px-4 py-2 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors">Skriv ut / Last ned PDF</button>
    </div>

    <article class="bg-white rounded-3xl border border-sage-500/15 p-8 sm:p-10 print:border-0 print:rounded-none print:p-0">
      <header class="flex items-start justify-between gap-4 mb-6">
        <div>
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45">Kvittering — oppdrag</p>
          <h1 class="font-serif text-3xl mt-1">Strikketorget</h1>
        </div>
        <div class="text-right text-xs text-charcoal/55">
          <p class="font-mono">{receiptNo}</p>
          <p>{dateLabel}</p>
        </div>
      </header>

      <section class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
        <div>
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Strikker</p>
          <p class="font-medium">{knitter?.display_name ?? 'Privatperson'}</p>
          {knitter?.location && <p class="text-sm text-charcoal/65">{knitter.location}</p>}
          <p class="text-xs text-charcoal/45 mt-1">Privatsalg — ikke MVA-pliktig</p>
        </div>
        <div>
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Bestiller</p>
          <p class="font-medium">{buyer?.display_name ?? 'Kjøper'}</p>
          {buyer?.location && <p class="text-sm text-charcoal/65">{buyer.location}</p>}
        </div>
      </section>

      <section class="mb-8">
        <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-2">Oppdrag</p>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-sage-500/20 text-left text-xs text-charcoal/55">
              <th class="py-2 font-medium">Beskrivelse</th>
              <th class="py-2 font-medium text-right">Pris</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-sage-500/10">
              <td class="py-3">
                <p>{req.title}</p>
                <p class="text-xs text-charcoal/50">{CATEGORY_LABEL[req.category] ?? req.category} · str. {req.size_label}</p>
              </td>
              <td class="py-3 text-right font-mono">{nok(gross)}</td>
            </tr>
            <tr>
              <td class="py-3 text-right text-charcoal/55">Sum</td>
              <td class="py-3 text-right font-mono font-bold">{nok(gross)}</td>
            </tr>
          </tbody>
        </table>
      </section>

      {isKnitter && (
        <section class="mb-8 bg-linen rounded-xl p-4">
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-2">Strikker — payout</p>
          <table class="w-full text-sm">
            <tr><td>Brutto oppdrag</td><td class="text-right font-mono">{nok(gross)}</td></tr>
            <tr><td>Tjenestegebyr Strikketorget</td><td class="text-right font-mono">−{nok(fee)}</td></tr>
            <tr class="border-t border-sage-500/20"><td class="pt-2 font-medium">Netto utbetaling</td><td class="pt-2 text-right font-mono font-bold">{nok(net)}</td></tr>
          </table>
        </section>
      )}

      <section class="text-xs text-charcoal/55 space-y-2 mb-2">
        <p><strong>Betaling</strong>: Behandlet via Stripe Payments Europe Ltd. Trygg betaling med automatisk frigjøring 14 dager etter levering.</p>
        <p><strong>Reklamasjon</strong>: Krav meldes innen 14 dager via plattformens tvistesystem. Se <a href="/terms" class="text-terracotta-500 hover:underline">vilkår</a> punkt 7.</p>
        <p><strong>Privatsalg</strong>: Bestilt strikkearbeid mellom forbrukere. Kjøpsloven gjelder.</p>
      </section>

      <footer class="text-xs text-charcoal/40 mt-8 pt-4 border-t border-sage-500/10">
        <p>Strikketorget — drevet av Weggersen Design, org.nr. 935 918 146.</p>
        <p>Spørsmål: hei@strikketorget.no</p>
      </footer>
    </article>
  </div>

  <style>
    @media print {
      body { background: white; }
      .print\:hidden { display: none !important; }
      .print\:py-2 { padding-top: 0.5rem; padding-bottom: 0.5rem; }
      .print\:px-0 { padding-left: 0; padding-right: 0; }
      .print\:border-0 { border: 0; }
      .print\:rounded-none { border-radius: 0; }
      .print\:p-0 { padding: 0; }
    }
  </style>
</Layout>
