---
import Layout from '../../../../layouts/Layout.astro';
import MarketplaceShell from '../../../../components/MarketplaceShell.astro';
import { createServerSupabase } from '../../../../lib/supabase';
import { requireUser } from '../../../../lib/auth';
import { projectPhotoUrl } from '../../../../lib/storage';

const id = Astro.params.id;
if (!id) return Astro.redirect('/market/my-listings');

const guard = await requireUser(Astro);
if (guard instanceof Response) return guard;
const user = guard;

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });

const { data: listing } = await supabase
  .from('listings')
  .select('id, seller_id, title, status, price_nok, size_label, category')
  .eq('id', id)
  .maybeSingle();

// Only the owner can use this page, and only while the listing is a draft.
if (!listing || listing.seller_id !== user.id) return Astro.redirect('/market/my-listings');
if (listing.status !== 'draft') return Astro.redirect(`/market/listing/${id}`);

const { data: photoRows } = await supabase
  .from('listing_photos')
  .select('id, path, caption, position')
  .eq('listing_id', id)
  .order('position');
const photos = photoRows ?? [];

const STEPS = [
  { id: 1, label: 'Detaljer' },
  { id: 2, label: 'Pris & frakt' },
  { id: 3, label: 'Bilder' },
];
---

<Layout title="Last opp bilder — Strikketorget" lang="nb">
  <MarketplaceShell current="ny">
    <div class="max-w-2xl mx-auto">
      <h1 class="font-serif text-3xl sm:text-4xl mb-2">Last opp bilder</h1>
      <p class="text-sm text-charcoal/55 mb-6">
        Annonser med <strong>3+ bilder</strong> får betydelig flere visninger. Du kan publisere med ett, men flere er bedre.
      </p>

      <!-- Step progress (step 3 active) -->
      <ol class="flex items-center gap-1 mb-8 text-xs">
        {STEPS.map((s, i) => (
          <>
            <li class:list={[
              'flex items-center gap-2 px-3 py-1.5 rounded-full',
              s.id === 3 ? 'bg-primary text-primary-fg' : 'bg-sage-100 text-sage-900',
            ]}>
              <span class="font-mono font-bold">{s.id === 3 ? s.id : '✓'}</span>
              <span class="hidden sm:inline">{s.label}</span>
            </li>
            {i < STEPS.length - 1 && <li aria-hidden="true" class="flex-1 h-px bg-sage-500/15"></li>}
          </>
        ))}
      </ol>

      <div class="bg-white rounded-3xl p-6 sm:p-8 border border-sage-500/10 space-y-6">
        <!-- Mini-summary so seller remembers what they just created -->
        <div class="bg-linen/60 rounded-2xl p-4 text-sm">
          <p class="font-medium">{listing.title}</p>
          <p class="text-charcoal/55 mt-0.5">{listing.category} · str. {listing.size_label} · {listing.price_nok} kr</p>
        </div>

        <!-- Upload form -->
        <form method="post" action={`/api/marketplace/listings/${id}/photo`} enctype="multipart/form-data" class="space-y-3">
          <label class="block">
            <span class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">
              {photos.length > 0 ? `Legg til flere (${photos.length}/6)` : 'Velg bilder (maks 6)'}
            </span>
            <div class="flex items-center gap-2">
              <input name="photos" type="file" accept="image/*" multiple required
                class="text-sm file:mr-2 file:rounded-full file:border-0 file:bg-charcoal file:text-linen file:px-4 file:py-2 file:text-xs file:font-medium hover:file:bg-terracotta-500 file:transition-colors file:cursor-pointer" />
              <button type="submit" class="shrink-0 bg-primary text-primary-fg px-4 py-2 rounded-full text-xs font-medium hover:bg-primary-hover transition-colors">
                Last opp
              </button>
            </div>
          </label>
          <p class="text-[11px] text-charcoal/45">
            Tips: hovedbilde først. Naturlig lys og rene flater fungerer best. Bilder modereres før publisering.
          </p>
        </form>

        {photos.length > 0 && (
          <div class="space-y-2">
            <p class="text-xs font-bold uppercase tracking-widest text-charcoal/55">Dine bilder</p>
            {photos.map((p, i) => (
              <div class="flex items-start gap-3 bg-linen/40 rounded-xl p-3 border border-sage-500/10">
                <img src={projectPhotoUrl(p.path)!} alt="" class="w-14 h-14 rounded-lg object-cover shrink-0" />
                <div class="flex-1 min-w-0 space-y-2">
                  <form method="post" action={`/api/marketplace/listings/${id}/photo`} class="flex gap-2">
                    <input type="hidden" name="action" value="caption" />
                    <input type="hidden" name="photo_id" value={p.id} />
                    <input name="caption" type="text" maxlength="120" placeholder="Bildetekst (valgfritt)…" value={p.caption ?? ''}
                      class="flex-1 min-w-0 bg-white rounded-lg px-3 py-1.5 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors" />
                    <button type="submit" class="text-xs text-charcoal/55 hover:text-charcoal transition-colors px-2">Lagre</button>
                  </form>
                </div>
                <form method="post" action={`/api/marketplace/listings/${id}/photo`} class="shrink-0">
                  <input type="hidden" name="action" value="delete" />
                  <input type="hidden" name="photo_id" value={p.id} />
                  <button type="submit" class="w-7 h-7 rounded-lg bg-red-50 flex items-center justify-center text-red-500 hover:bg-red-100 transition-colors" title="Slett bilde">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
                  </button>
                </form>
              </div>
            ))}
          </div>
        )}

        <!-- Publish CTA -->
        <div class="border-t border-sage-500/10 pt-5">
          {photos.length === 0 ? (
            <div class="bg-amber-50 text-amber-800 rounded-2xl p-4 text-sm">
              Last opp minst ett bilde for å kunne publisere annonsen.
            </div>
          ) : (
            <form method="post" action={`/api/marketplace/listings/${id}/publish`}>
              <button type="submit"
                class="w-full bg-primary text-primary-fg px-6 py-3 rounded-full text-sm font-medium hover:bg-primary-hover transition-colors">
                Send inn til godkjenning
              </button>
              <p class="text-[11px] text-charcoal/45 text-center mt-2">
                Annonsen gjennomgår kort moderering før den blir synlig på Strikketorget.
              </p>
            </form>
          )}
        </div>

        <!-- Footer nav -->
        <div class="flex items-center justify-between gap-3 pt-2 border-t border-sage-500/10 text-sm">
          <a href={`/market/listing/${id}`} class="text-charcoal/55 hover:text-charcoal transition-colors">
            ← Til annonsen
          </a>
          <a href="/market/my-listings" class="text-charcoal/55 hover:text-charcoal transition-colors">
            Lagre og fortsett senere
          </a>
        </div>
      </div>
    </div>
  </MarketplaceShell>
</Layout>
