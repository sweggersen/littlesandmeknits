---
import Layout from '../../../layouts/Layout.astro';
import MarketplaceShell from '../../../components/MarketplaceShell.astro';
import ReportButton from '../../../components/ReportButton.astro';
import ProfileAvatar from '../../../components/ProfileAvatar.astro';
import StarRating from '../../../components/StarRating.astro';
import TryggBetaling from '../../../components/TryggBetaling.astro';
import Alert from '../../../components/Alert.astro';
import StatusBadge from '../../../components/StatusBadge.astro';
import OwnerStatusAlerts from '../../../components/listing/OwnerStatusAlerts.astro';
import BuyActions from '../../../components/listing/BuyActions.astro';
import ListingPhotos from '../../../components/listing/ListingPhotos.astro';
import { createServerSupabase, createAdminSupabase } from '../../../lib/supabase';
import { projectPhotoUrl } from '../../../lib/storage';
import { env } from '../../../lib/env';
import { KIND_LABEL, CONDITION_LABEL } from '../../../lib/labels';
import { extractListingId, listingPath } from '../../../lib/listing-url';

// Accept either a bare UUID (legacy URL) or `<slug>-<uuid>` (pretty URL).
// extractListingId hunts for the UUID at the END of the param so a slug
// can't shadow a real id.
const rawParam = Astro.params.id;
const id = extractListingId(rawParam);
if (!id) return Astro.redirect('/market');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const user = Astro.locals.user;

let { data: listing } = await supabase
  .from('listings')
  .select('id, seller_id, kind, title, description, price_nok, size_label, category, condition, status, colorway, knitted_by, pattern_external_title, hero_photo_path, location, shipping_info, published_at, listing_fee_nok, escrow_enabled, shipping_option, shipping_price_nok, store_id, buyer_id, stripe_payment_intent_id, reserved_at, shipped_at, tracking_code, auto_release_at, delivered_at, disputed_at, dispute_reason, dispute_resolution, promoted_until, promotion_tier, buyer_name, buyer_address, buyer_postal_code, buyer_city')
  .eq('id', id)
  .maybeSingle();

if (!listing) {
  const { data: fallback } = await supabase
    .from('listings')
    .select('id, seller_id, kind, title, description, price_nok, size_label, category, condition, status, colorway, knitted_by, pattern_external_title, hero_photo_path, location, shipping_info, published_at, listing_fee_nok, escrow_enabled, shipping_option, shipping_price_nok, store_id')
    .eq('id', id)
    .maybeSingle();
  if (fallback) listing = { ...fallback, buyer_id: null, stripe_payment_intent_id: null, reserved_at: null, shipped_at: null, tracking_code: null, auto_release_at: null, delivered_at: null, disputed_at: null, dispute_reason: null, dispute_resolution: null, buyer_name: null, buyer_address: null, buyer_postal_code: null, buyer_city: null } as any;
}

const { data: viewerProfile } = user ? await supabase.from('profiles').select('role').eq('id', user.id).maybeSingle() : { data: null };
const isStaff = viewerProfile?.role === 'admin' || viewerProfile?.role === 'moderator';

if (!listing && isStaff) {
  const admin = createAdminSupabase(env.SUPABASE_SERVICE_ROLE_KEY);
  let { data } = await admin
    .from('listings')
    .select('id, seller_id, kind, title, description, price_nok, size_label, category, condition, status, colorway, knitted_by, pattern_external_title, hero_photo_path, location, shipping_info, published_at, listing_fee_nok, escrow_enabled, shipping_option, shipping_price_nok, store_id, buyer_id, stripe_payment_intent_id, reserved_at, shipped_at, tracking_code, auto_release_at, delivered_at, disputed_at, dispute_reason, dispute_resolution')
    .eq('id', id)
    .maybeSingle();
  if (!data) {
    const { data: fallback } = await admin
      .from('listings')
      .select('id, seller_id, kind, title, description, price_nok, size_label, category, condition, status, colorway, knitted_by, pattern_external_title, hero_photo_path, location, shipping_info, published_at, listing_fee_nok, escrow_enabled, shipping_option, shipping_price_nok, store_id')
      .eq('id', id)
      .maybeSingle();
    if (fallback) data = { ...fallback, buyer_id: null, stripe_payment_intent_id: null, reserved_at: null, shipped_at: null, tracking_code: null, auto_release_at: null, delivered_at: null, disputed_at: null, dispute_reason: null, dispute_resolution: null } as any;
  }
  listing = data;
}

if (!listing) return Astro.redirect('/market');

// Canonical URL is `<slug>-<uuid>`. If the request came in on the legacy
// bare-UUID form (or a stale slug after a rename), 301 to the canonical
// pretty path. Preserves query string so `?published=1` etc. survive.
const canonicalParam = listingPath(listing).split('/').pop()!;
if (rawParam !== canonicalParam) {
  const target = `/market/listing/${canonicalParam}${Astro.url.search}`;
  return Astro.redirect(target, 301);
}

const isOwner = user?.id === listing.seller_id;
const isBuyer = user?.id === listing.buyer_id;
const viewableStatuses = new Set(['active', 'reserved', 'shipped', 'sold', 'disputed']);
if (!isOwner && !isBuyer && !isStaff && !viewableStatuses.has(listing.status)) return Astro.redirect('/market');

// Aggregate seller stats (all reviews ever — not just for this listing)
const { data: sellerRatingRows } = await supabase
  .from('seller_reviews')
  .select('rating')
  .eq('seller_id', listing.seller_id);
const sellerReviewCount = sellerRatingRows?.length ?? 0;
const sellerAvgRating = sellerReviewCount
  ? (sellerRatingRows!.reduce((s, r) => s + (r.rating ?? 0), 0) / sellerReviewCount)
  : 0;

const [{ data: sellerProfile }, { data: photoRows }, { data: reviews }, { data: storeRow }, { data: followRow }] = await Promise.all([
  supabase.from('profiles').select('display_name, avatar_path, location, seller_tags, stripe_connect_status').eq('id', listing.seller_id).maybeSingle(),
  supabase.from('listing_photos').select('id, path, caption, position').eq('listing_id', id).order('position'),
  supabase.from('seller_reviews').select('id, reviewer_id, rating, comment, created_at').eq('listing_id', id),
  listing.store_id
    ? supabase.from('stores').select('id, slug, name, logo_path, location_city, verified, stripe_onboarded').eq('id', listing.store_id).maybeSingle()
    : Promise.resolve({ data: null }),
  user && user.id !== listing.seller_id
    ? supabase.from('seller_follows').select('seller_id').eq('follower_id', user.id).eq('seller_id', listing.seller_id).maybeSingle()
    : Promise.resolve({ data: null }),
]);
const isFollowing = !!followRow;
const isStoreListing = !!storeRow;
const buyerReview = (reviews ?? []).find((r) => r.reviewer_id === user?.id);
const hasReviewed = !!buyerReview;

const photos = (photoRows ?? []).length > 0
  ? photoRows!
  : listing.hero_photo_path
    ? [{ id: 'legacy', path: listing.hero_photo_path, caption: null, position: 0 }]
    : [];
const photoUrls = photos.map((p) => projectPhotoUrl(p.path)).filter(Boolean) as string[];

let isFavorited = false;
if (user && !isOwner) {
  try {
    const { data } = await supabase.from('favorites').select('id').eq('user_id', user.id).eq('item_type', 'listing').eq('item_id', id).maybeSingle();
    isFavorited = !!data;
  } catch {}
}

// Refund request state (pulled separately because main select is large).
const { data: refundRow } = await supabase
  .from('listings')
  .select('refund_requested_at, refund_reason, refund_description, refund_resolved_at, refund_outcome, refund_notes')
  .eq('id', listing.id)
  .maybeSingle();
const refundOpen = !!(refundRow?.refund_requested_at && !refundRow?.refund_resolved_at);
const refundReasonLabels: Record<string, string> = {
  not_received: 'Ikke mottatt',
  damaged: 'Skadet',
  not_as_described: 'Ikke som beskrevet',
  wrong_size: 'Feil størrelse',
  changed_mind: 'Ombestemte meg',
  other: 'Annet',
};

const justPublished = Astro.url.searchParams.get('published') === '1';
const justPromoted = Astro.url.searchParams.get('promoted') === '1';
const justPurchased = Astro.url.searchParams.get('purchased') === '1';
// Store-level Stripe state is still the legacy boolean (refactor item 7
// only retired the profile-level one); seller profile uses the new enum.
const sellerOnboarded = isStoreListing
  ? !!(storeRow as any)?.stripe_onboarded
  : (sellerProfile as any)?.stripe_connect_status === 'verified';
let frozenThreadId: string | null = null;
if (isOwner && listing.status === 'frozen') {
  const { data: t } = await supabase
    .from('moderation_threads')
    .select('id')
    .eq('target_type', 'listing')
    .eq('target_id', listing.id)
    .eq('status', 'open')
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle();
  frozenThreadId = t?.id ?? null;
}
const autoReleaseDays = listing.auto_release_at
  ? Math.max(0, Math.ceil((new Date(listing.auto_release_at).getTime() - Date.now()) / 86400_000))
  : null;

// SEO: page-level meta + Product JSON-LD so listings can rank for
// long-tail Norwegian queries ("strikket genser str 92 brukt", etc.)
// and qualify for Google's product-rich-result treatment.
const SITE = 'https://littlesandmeknits.com';
const canonicalUrl = `${SITE}${listingPath(listing)}`;
const heroImageUrl = listing.hero_photo_path
  ? new URL(projectPhotoUrl(listing.hero_photo_path) ?? '', SITE).toString()
  : undefined;
const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: listing.title,
  description: (listing.description ?? '').slice(0, 500) || `${listing.title} på Strikketorget`,
  image: photoUrls.map((u) => new URL(u, SITE).toString()),
  category: listing.category,
  brand: { '@type': 'Brand', name: 'Strikketorget' },
  offers: {
    '@type': 'Offer',
    url: canonicalUrl,
    priceCurrency: 'NOK',
    price: listing.price_nok,
    availability:
      listing.status === 'active' ? 'https://schema.org/InStock'
      : listing.status === 'sold' ? 'https://schema.org/SoldOut'
      : 'https://schema.org/OutOfStock',
    itemCondition:
      listing.kind === 'pre_loved' ? 'https://schema.org/UsedCondition' : 'https://schema.org/NewCondition',
  },
};
const seoDescription = (listing.description ?? '').slice(0, 160).trim()
  || `${listing.title}. ${listing.price_nok} kr. Håndstrikket plagg på Strikketorget.`;
---

<Layout title={listing.title} description={seoDescription} ogImage={heroImageUrl} lang="nb">
  <script type="application/ld+json" set:html={JSON.stringify(productJsonLd)} is:inline />
  <MarketplaceShell current="listing">
      {isOwner && (
        <OwnerStatusAlerts
          status={listing.status}
          justPublished={justPublished}
          moderationNotes={(listing as any).moderation_notes}
          frozenThreadId={frozenThreadId}
        />
      )}

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <ListingPhotos
          listingId={listing.id}
          title={listing.title}
          transitionId={id}
          status={listing.status}
          isOwner={isOwner}
          photos={photos}
        />

        <!-- Listing details -->
        <div>
          <p class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500 mb-2">
            {KIND_LABEL[listing.kind]}
          </p>
          <div class="flex items-start justify-between gap-3 mb-4">
            <h1 class="font-serif text-3xl sm:text-4xl">{listing.title}</h1>
            {user && !isOwner && (
              <button
                type="button"
                data-fav-btn
                data-item-type="listing"
                data-item-id={id}
                data-favorited={isFavorited ? 'true' : 'false'}
                class:list={[
                  'shrink-0 mt-1 p-2 rounded-full hover:bg-sage-100/50 transition-colors',
                  isFavorited ? 'text-terracotta-500' : 'text-charcoal/40',
                ]}
                aria-label={isFavorited ? 'Fjern favoritt' : 'Legg til favoritt'}
              >
                <svg width="22" height="22" viewBox="0 0 24 24" fill={isFavorited ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-colors" data-fav-icon>
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </button>
            )}
          </div>
          <p class="font-mono tabular-nums text-3xl mb-6">{listing.price_nok} kr</p>

          <dl class="grid grid-cols-2 gap-3 text-sm mb-6">
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Størrelse</dt>
              <dd>{listing.size_label}</dd>
            </div>
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Kategori</dt>
              <dd>{listing.category}</dd>
            </div>
            {listing.condition && (
              <div>
                <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Tilstand</dt>
                <dd>{CONDITION_LABEL[listing.condition] ?? listing.condition}</dd>
              </div>
            )}
            {listing.colorway && (
              <div>
                <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Farge</dt>
                <dd>{listing.colorway}</dd>
              </div>
            )}
            {listing.location && (
              <div>
                <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Sted</dt>
                <dd>{listing.location}</dd>
              </div>
            )}
            {listing.shipping_info && (
              <div class="col-span-2">
                <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Frakt</dt>
                <dd>{listing.shipping_info}</dd>
              </div>
            )}
            {listing.pattern_external_title && (
              <div class="col-span-2">
                <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Oppskrift</dt>
                <dd>{listing.pattern_external_title}</dd>
              </div>
            )}
            {(listing as any).knitted_by && (
              <div class="col-span-2">
                <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Strikket av</dt>
                <dd>{(listing as any).knitted_by}</dd>
              </div>
            )}
          </dl>

          {listing.description && (
            <p class="text-sm text-charcoal/75 leading-relaxed whitespace-pre-line mb-6">{listing.description}</p>
          )}

          {isOwner ? (
            <div class="space-y-4">
              {listing.status === 'draft' && (
                <section class="bg-white rounded-3xl p-6 border border-sage-500/10">
                  <h2 class="font-serif text-xl mb-2">Publiser</h2>
                  {photos.length === 0 ? (
                    <div class="bg-amber-50 text-amber-800 rounded-2xl p-4 text-sm mb-4">
                      Du må legge til minst ett bilde før du kan publisere.
                    </div>
                  ) : photos.length < 3 ? (
                    <p class="text-sm text-charcoal/65 mb-4">
                      Publisering er gratis. <span class="text-terracotta-500 font-medium">Tips: Annonser med 3+ bilder får betydelig flere visninger og henvendelser.</span>
                    </p>
                  ) : (
                    <p class="text-sm text-charcoal/65 mb-4">
                      Publisering er gratis. Annonsen sendes til kort moderering før den blir synlig.
                    </p>
                  )}
                  <form method="post" action={`/api/marketplace/listings/${listing.id}/publish`}>
                    <button type="submit" disabled={photos.length === 0}
                      class:list={['px-6 py-3 rounded-full text-sm font-medium transition-colors',
                        photos.length === 0
                          ? 'bg-charcoal/30 text-linen cursor-not-allowed'
                          : 'bg-primary text-primary-fg hover:bg-primary-hover']}>
                      Publiser
                    </button>
                  </form>
                </section>
              )}
              {listing.status === 'active' && (
                <div class="bg-sage-100 rounded-2xl p-4 text-sm text-sage-900">
                  Annonsen er publisert og synlig for alle.
                </div>
              )}

              {/* Trygg betaling toggle — free for the seller (kjøper betaler ved kjøp). */}
              {isOwner && listing.status === 'active' && !listing.escrow_enabled && !listing.store_id && (
                <section class="bg-white rounded-3xl p-5 border border-sage-500/10 space-y-3">
                  <div class="flex items-start gap-3">
                    <div class="text-2xl">🛡️</div>
                    <div class="flex-1">
                      <h3 class="font-serif text-lg mb-1">Aktiver trygg betaling</h3>
                      <p class="text-sm text-charcoal/65">
                        Gratis for deg som selger. Kjøper betaler en liten beskyttelsesavgift
                        (9–29 kr avhengig av varens pris) som dekker kjøperbeskyttelse.
                        Pengene frigjøres når kjøper bekrefter mottak, ellers 14 dager
                        etter sending. Du får flere kjøpere som tør å handle.
                      </p>
                    </div>
                  </div>
                  <form method="post" action={`/api/marketplace/listings/${listing.id}/upgrade-escrow`}>
                    <input type="hidden" name="enabled" value="true" />
                    <button type="submit" class="w-full bg-primary text-primary-fg px-6 py-3 rounded-full text-sm font-medium hover:bg-primary-hover transition-colors">
                      Aktiver trygg betaling (gratis)
                    </button>
                  </form>
                </section>
              )}
              {isOwner && listing.escrow_enabled && (
                <div class="bg-sage-100/60 rounded-2xl p-4 text-sm text-sage-900 flex items-center justify-between gap-3 flex-wrap">
                  <div class="flex items-center gap-2">
                    <span>🛡️</span>
                    <span><TryggBetaling /> er aktivert. Kjøpere kan kjøpe trygt gjennom Strikketorget.</span>
                  </div>
                  <form method="post" action={`/api/marketplace/listings/${listing.id}/upgrade-escrow`} class="shrink-0">
                    <input type="hidden" name="enabled" value="false" />
                    <button type="submit" class="text-xs text-sage-900/60 hover:text-red-600 underline">Slå av</button>
                  </form>
                </div>
              )}
              {justPromoted && listing.status === 'active' && (
                <Alert type="success" class="mt-4">Annonsen din er nå fremhevet!</Alert>
              )}
              {listing.status === 'active' && listing.promoted_until && new Date(listing.promoted_until) > new Date() ? (
                <section id="promoter" class="bg-white rounded-3xl p-6 border border-terracotta-500/20 mt-4 scroll-mt-20">
                  <div class="flex items-center gap-2 mb-2">
                    <StatusBadge label="Fremhevet" variant="terracotta" />
                    <span class="text-xs text-charcoal/45">
                      {Math.max(0, Math.ceil((new Date(listing.promoted_until).getTime() - Date.now()) / 86400_000))} dager igjen
                    </span>
                  </div>
                  <p class="text-sm text-charcoal/65 mb-3">Annonsen vises øverst i søkeresultatene{listing.promotion_tier === 'highlight' ? ' med «Fremhevet»-merke' : ''}.</p>
                  <a href={`/market/stats/${listing.id}`} class="text-xs text-terracotta-500 hover:underline">Se statistikk →</a>
                </section>
              ) : listing.status === 'active' ? (
                <section id="promoter" class="bg-white rounded-3xl p-6 border border-sage-500/10 mt-4 scroll-mt-20">
                  <h2 class="font-serif text-xl mb-2">Fremhev annonsen</h2>
                  <p class="text-sm text-charcoal/65 mb-4">Gi annonsen din mer synlighet. Promoterte annonser vises øverst i søk og på forsiden.</p>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 items-stretch">
                    <div class="space-y-1.5 flex flex-col">
                      <form method="post" action={`/api/marketplace/listings/${listing.id}/promote`} class="flex-1">
                        <input type="hidden" name="tier" value="boost" />
                        <button type="submit" class="w-full h-full bg-white border-2 border-sage-500/20 rounded-2xl p-4 text-left hover:border-terracotta-500/30 transition-colors flex flex-col">
                          <p class="font-medium mb-1">Boost</p>
                          <p class="text-xs text-charcoal/55 mb-2 flex-1">Vises øverst i 7 dager</p>
                          <p class="font-mono tabular-nums">49 NOK</p>
                        </button>
                      </form>
                      <form method="post" action={`/api/marketplace/listings/${listing.id}/promote-simulate`} data-dev-only class="hidden">
                        <input type="hidden" name="tier" value="boost" />
                        <button type="submit" class="w-full text-[10px] text-amber-700 hover:text-amber-900 py-1 border border-dashed border-amber-300/40 rounded-full">⚡ Simuler (dev, uten betaling)</button>
                      </form>
                    </div>
                    <div class="space-y-1.5 flex flex-col">
                      <form method="post" action={`/api/marketplace/listings/${listing.id}/promote`} class="flex-1">
                        <input type="hidden" name="tier" value="highlight" />
                        <button type="submit" class="w-full h-full bg-terracotta-500/5 border-2 border-terracotta-500/20 rounded-2xl p-4 text-left hover:border-terracotta-500/40 transition-colors flex flex-col">
                          <p class="font-medium text-terracotta-500 mb-1">Fremhevet</p>
                          <p class="text-xs text-charcoal/55 mb-2 flex-1">Boost + «Fremhevet»-merke + forside</p>
                          <p class="font-mono tabular-nums">99 NOK</p>
                        </button>
                      </form>
                      <form method="post" action={`/api/marketplace/listings/${listing.id}/promote-simulate`} data-dev-only class="hidden">
                        <input type="hidden" name="tier" value="highlight" />
                        <button type="submit" class="w-full text-[10px] text-amber-700 hover:text-amber-900 py-1 border border-dashed border-amber-300/40 rounded-full">⚡ Simuler (dev, uten betaling)</button>
                      </form>
                    </div>
                  </div>
                  <script>
                    if (location.hostname === 'localhost' || location.hostname === '127.0.0.1' || location.hostname.startsWith('192.168.')) {
                      document.querySelectorAll<HTMLFormElement>('[data-dev-only]').forEach((el) => el.classList.remove('hidden'));
                    }
                  </script>
                </section>
              ) : null}

              {/* ── Manual "Marker som solgt" for non-escrow listings ── */}
              {isOwner && listing.status === 'active' && !listing.escrow_enabled && (
                <section class="bg-white rounded-3xl p-5 border border-sage-500/10 mt-4">
                  <h2 class="font-serif text-lg mb-2">Solgt utenfor Strikketorget?</h2>
                  <p class="text-sm text-charcoal/65 mb-4">
                    Denne annonsen bruker ikke <TryggBetaling />, så Strikketorget ser ingen kjøp.
                    Hvis du har solgt varen privat (Vipps, kontant, etc.), marker den selv så den
                    forsvinner fra søk.
                  </p>
                  <form method="post" action={`/api/marketplace/listings/${listing.id}/mark-sold`}
                    onsubmit="return confirm('Marker som solgt? Annonsen forsvinner fra søk og kan ikke gjenåpnes.');">
                    <button type="submit" class="bg-primary text-primary-fg px-5 py-2.5 rounded-full text-sm font-medium hover:bg-primary-hover transition-colors">
                      Marker som solgt
                    </button>
                  </form>
                  <p class="text-[11px] text-charcoal/45 mt-3">
                    Tips: Aktiver <a href={`/market/listing/${listing.id}?tb_info=1`} class="text-terracotta-500 hover:underline"><TryggBetaling tint="inherit" /></a> så håndteres alt automatisk neste gang.
                  </p>
                </section>
              )}

              {/* ── Seller view for reserved/shipped/disputed listings ── */}
              {listing.status === 'reserved' && (
                <section class="bg-white rounded-3xl p-5 border border-sage-500/10 space-y-4">
                  <div class="flex items-center gap-2">
                    <span class="inline-block w-2.5 h-2.5 rounded-full bg-sage-500"></span>
                    <h2 class="font-serif text-lg">Noen har kjøpt varen din!</h2>
                  </div>
                  {listing.buyer_name && (
                    <div class="bg-oatmeal/40 rounded-2xl p-4 text-sm space-y-1">
                      <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-2">Send til</p>
                      <p class="font-medium">{listing.buyer_name}</p>
                      {listing.buyer_address && <p class="text-charcoal/70">{listing.buyer_address}</p>}
                      {listing.buyer_postal_code && listing.buyer_city && (
                        <p class="text-charcoal/70">{listing.buyer_postal_code} {listing.buyer_city}</p>
                      )}
                    </div>
                  )}
                  <p class="text-sm text-charcoal/65">Pakk og send varen, og legg inn sporingskoden.</p>
                  {/* TODO(bring): replace the free-text input below with a
                      "Generer fraktetikett" button that calls Bring/Posten's
                      API, mints a label with the seeded buyer address, and
                      auto-fills tracking_code from the response. */}
                  <form method="post" action={`/api/marketplace/listings/${listing.id}/ship`} class="space-y-3">
                    <input name="tracking_code" type="text" maxlength="50" placeholder="Sporingskode fra Posten/Bring (valgfritt)"
                      class="w-full bg-linen rounded-xl px-4 py-3 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors" />
                    <button type="submit" class="w-full bg-primary text-primary-fg px-6 py-3 rounded-full text-sm font-medium hover:bg-primary-hover transition-colors">
                      Merk som sendt
                    </button>
                  </form>
                  <p class="text-[11px] text-charcoal/45">
                    Kommer snart: vi henter sporingskoden automatisk når du
                    bestiller fraktetikett via Strikketorget.
                  </p>
                </section>
              )}

              {listing.status === 'shipped' && (
                <div class="bg-sage-100 text-sage-900 rounded-2xl p-4 text-sm">
                  Varen er sendt. Venter på at kjøper bekrefter mottak.
                  {listing.tracking_code && (
                    <p class="mt-1">Sporingskode: <span class="font-mono">{listing.tracking_code}</span></p>
                  )}
                </div>
              )}

              {listing.status === 'disputed' && (
                <div class="bg-amber-50 text-amber-900 rounded-2xl p-4 text-sm">
                  Kjøper har åpnet en tvist. Saken er under behandling av admin.
                  {listing.dispute_reason && (
                    <p class="mt-1 text-xs">Grunn: {listing.dispute_reason}</p>
                  )}
                </div>
              )}
            </div>
          ) : (
            <div class="space-y-4">
              {/* ── Purchase states (buyer view) ── */}
              {isBuyer && justPurchased && listing.status === 'reserved' && (
                <div class="bg-sage-100 text-sage-900 rounded-2xl p-4 text-sm">
                  Kjøpet er registrert! Pengene holdes trygt til du bekrefter mottak.
                </div>
              )}

              {(isBuyer || isOwner) && listing.reserved_at && (
                <a href={`/market/listing/${listing.id}/kvittering`} class="inline-block text-xs text-charcoal/55 hover:text-terracotta-500">📄 Se kvittering →</a>
              )}

              {/* Refund request — buyer side */}
              {isBuyer && !refundOpen && ['reserved', 'shipped', 'sold'].includes(listing.status) && refundRow?.refund_outcome !== 'declined' && (
                <details class="bg-white rounded-3xl p-5 border border-sage-500/10">
                  <summary class="cursor-pointer text-sm font-medium text-charcoal/70 hover:text-charcoal">Be om refusjon</summary>
                  <form method="post" action={`/api/marketplace/listings/${listing.id}/refund-request`} class="mt-3 space-y-3">
                    <label class="block text-xs">
                      <span class="text-charcoal/55">Grunn</span>
                      <select name="reason" required class="block w-full mt-1 bg-linen rounded-lg px-3 py-2 text-sm border border-sage-500/15">
                        <option value="">Velg…</option>
                        <option value="not_received">Ikke mottatt</option>
                        <option value="damaged">Skadet</option>
                        <option value="not_as_described">Ikke som beskrevet</option>
                        <option value="wrong_size">Feil størrelse</option>
                        <option value="changed_mind">Ombestemte meg</option>
                        <option value="other">Annet</option>
                      </select>
                    </label>
                    <label class="block text-xs">
                      <span class="text-charcoal/55">Beskrivelse (valgfritt)</span>
                      <textarea name="description" rows="3" maxlength="1000" placeholder="Hva er problemet?" class="block w-full mt-1 bg-linen rounded-lg px-3 py-2 text-sm border border-sage-500/15 resize-none"></textarea>
                    </label>
                    <button type="submit" class="bg-primary text-primary-fg px-4 py-2 rounded-full text-xs font-medium hover:bg-primary-hover transition-colors">Send forespørsel</button>
                    <p class="text-[10px] text-charcoal/45">Selger får varsel og kan godta eller avvise. Hvis avvist, sendes saken til moderator.</p>
                  </form>
                </details>
              )}

              {/* Refund request — pending state for both parties */}
              {refundOpen && (isBuyer || isOwner) && (
                <div class="bg-amber-50 border border-amber-300 rounded-2xl p-4 text-sm">
                  <p class="font-medium text-amber-900 mb-1">Refusjon etterspurt</p>
                  <p class="text-amber-900/80 text-xs mb-2">
                    Grunn: <strong>{refundReasonLabels[refundRow?.refund_reason ?? ''] ?? refundRow?.refund_reason}</strong>
                  </p>
                  {refundRow?.refund_description && (
                    <p class="text-amber-900/80 text-xs mb-3 whitespace-pre-wrap">«{refundRow.refund_description}»</p>
                  )}
                  {isOwner ? (
                    <div class="flex flex-wrap gap-2">
                      <form method="post" action={`/api/marketplace/listings/${listing.id}/refund-respond`}>
                        <input type="hidden" name="action" value="accept" />
                        <button type="submit" class="bg-sage-500 text-white px-4 py-2 rounded-full text-xs font-medium hover:bg-sage-600 transition-colors">Godta refusjon</button>
                      </form>
                      <details class="inline-block">
                        <summary class="cursor-pointer text-xs text-amber-900/80 px-3 py-2 rounded-full border border-amber-300/40 hover:bg-amber-100">Avvis</summary>
                        <form method="post" action={`/api/marketplace/listings/${listing.id}/refund-respond`} class="mt-2 space-y-2 bg-white rounded-lg p-3 border border-amber-200">
                          <input type="hidden" name="action" value="decline" />
                          <label class="block text-xs">
                            <span class="text-charcoal/55">Begrunnelse (sees av moderator)</span>
                            <textarea name="notes" rows="2" required maxlength="1000" class="block w-full mt-1 bg-linen rounded-lg px-3 py-2 text-sm border border-sage-500/15 resize-none"></textarea>
                          </label>
                          <button type="submit" class="bg-red-600 text-white px-4 py-2 rounded-full text-xs font-medium hover:bg-red-700">Avvis og send til moderator</button>
                        </form>
                      </details>
                    </div>
                  ) : (
                    <p class="text-amber-900/70 text-xs">Venter på svar fra selger.</p>
                  )}
                </div>
              )}

              {isBuyer && (listing.status === 'reserved' || listing.status === 'shipped') && (
                <section class="bg-white rounded-3xl p-5 border border-sage-500/10 space-y-4">
                  <div class="flex items-center gap-2">
                    <span class="inline-block w-2.5 h-2.5 rounded-full bg-amber-400"></span>
                    <h2 class="font-serif text-lg">
                      {listing.status === 'shipped' ? 'Varen er sendt' : 'Venter på sending'}
                    </h2>
                  </div>
                  {listing.tracking_code && (
                    <p class="text-sm text-charcoal/65">
                      Sporingskode: <span class="font-mono">{listing.tracking_code}</span>
                    </p>
                  )}
                  {autoReleaseDays !== null && (
                    <p class="text-xs text-charcoal/45">
                      Betalingen frigis automatisk om {autoReleaseDays} {autoReleaseDays === 1 ? 'dag' : 'dager'} hvis du ikke svarer.
                    </p>
                  )}
                  <div class="flex gap-3">
                    <form method="post" action={`/api/marketplace/listings/${listing.id}/confirm-delivery`} class="flex-1">
                      <button type="submit" class="w-full bg-primary text-primary-fg px-6 py-3 rounded-full text-sm font-medium hover:bg-primary-hover transition-colors">
                        Bekreft mottatt
                      </button>
                    </form>
                    <details class="flex-1">
                      <summary class="cursor-pointer w-full bg-red-50 text-red-700 px-6 py-3 rounded-full text-sm font-medium text-center hover:bg-red-100 transition-colors">
                        Rapporter problem
                      </summary>
                      <form method="post" action={`/api/marketplace/listings/${listing.id}/dispute`} class="mt-3 space-y-3">
                        <textarea name="reason" required rows="3" maxlength="500" placeholder="Beskriv problemet..."
                          class="w-full bg-linen rounded-xl px-4 py-3 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors resize-none"></textarea>
                        <button type="submit" class="w-full bg-red-600 text-white px-4 py-2.5 rounded-full text-sm font-medium hover:bg-red-700 transition-colors">
                          Åpne tvist
                        </button>
                      </form>
                    </details>
                  </div>
                  <p class="text-[11px] text-charcoal/45 text-center">
                    Pengene holdes trygt av plattformen til du bekrefter mottak.
                  </p>
                </section>
              )}

              {isBuyer && listing.status === 'disputed' && (
                <div class="bg-amber-50 text-amber-900 rounded-2xl p-4 text-sm">
                  Du har åpnet en tvist. Saken er under behandling.
                  {listing.dispute_resolution && (
                    <p class="mt-2 font-medium">Resultat: {listing.dispute_resolution}</p>
                  )}
                </div>
              )}

              {isBuyer && listing.status === 'sold' && listing.delivered_at && (
                <div class="bg-sage-100 text-sage-900 rounded-2xl p-4 text-sm">
                  Levering bekreftet. Betalingen er frigitt til selger.
                </div>
              )}

              {isBuyer && listing.status === 'sold' && !hasReviewed && (
                <section class="bg-white rounded-3xl p-5 border border-sage-500/10 space-y-3">
                  <h2 class="font-serif text-lg">Gi selger en vurdering</h2>
                  <form method="post" action={`/api/marketplace/listings/${listing.id}/review`} class="space-y-3">
                    <fieldset class="flex gap-1" data-star-rating>
                      {[1, 2, 3, 4, 5].map((v) => (
                        <label class="cursor-pointer">
                          <input type="radio" name="rating" value={v} required class="sr-only" />
                          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-charcoal/20 hover:text-terracotta-500 transition-colors" data-star={v}>
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                          </svg>
                        </label>
                      ))}
                    </fieldset>
                    <textarea name="comment" rows="2" maxlength="500" placeholder="Valgfri kommentar..."
                      class="w-full bg-linen rounded-xl px-4 py-3 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors resize-none"></textarea>
                    <button type="submit" class="w-full bg-primary text-primary-fg px-6 py-3 rounded-full text-sm font-medium hover:bg-primary-hover transition-colors">
                      Send vurdering
                    </button>
                  </form>
                </section>
              )}

              {isBuyer && hasReviewed && (
                <div class="bg-oatmeal/40 rounded-2xl p-4 text-sm">
                  <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Din vurdering</p>
                  <div class="flex gap-0.5 mb-1">
                    {[1, 2, 3, 4, 5].map((v) => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill={v <= buyerReview!.rating ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="1.5" class={v <= buyerReview!.rating ? 'text-terracotta-500' : 'text-charcoal/20'}>
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    ))}
                  </div>
                  {buyerReview!.comment && <p class="text-charcoal/65">{buyerReview!.comment}</p>}
                </div>
              )}


              {/* ── Buyer CTAs (active listings, viewer is not owner/buyer) ── */}
              {!isOwner && !isBuyer && listing.status === 'active' && listing.escrow_enabled && sellerOnboarded && (
                <BuyActions
                  listingId={listing.id}
                  title={listing.title}
                  sizeLabel={listing.size_label}
                  priceNok={listing.price_nok}
                  shippingOption={(listing as any).shipping_option}
                  heroPhotoUrl={photoUrls[0]}
                />
              )}


              {/* ── No escrow / no Stripe — keep simple message + meet-up ── */}
              {!isOwner && !isBuyer && listing.status === 'active' && !(listing.escrow_enabled && sellerOnboarded) && (
                <section class="bg-amber-50/60 border border-amber-200 rounded-3xl p-5 text-sm">
                  <p class="font-medium text-amber-900 mb-1">⚠️ <TryggBetaling /> er ikke tilgjengelig</p>
                  <p class="text-charcoal/65">
                    {listing.escrow_enabled
                      ? 'Selger har ikke fullført Stripe-onboarding ennå.'
                      : <>Selger har ikke aktivert <TryggBetaling />.</>}
                    {' '}Du kan fortsatt sende melding og avtale møte eller Vipps, men Strikketorget gir
                    ingen kjøperbeskyttelse på dette salget.
                  </p>
                </section>
              )}

              {/* ── Send melding (tertiary, secondary surface) ─────────── */}
              {!isOwner && !isBuyer && listing.status === 'active' && (
                <details class="bg-white rounded-3xl border border-sage-500/10 mt-3 group">
                  <summary class="cursor-pointer p-4 text-sm font-medium text-charcoal/70 hover:text-charcoal flex items-center justify-between">
                    <span>Send melding til {isStoreListing ? 'butikken' : 'selger'}</span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-charcoal/30 group-open:rotate-180 transition-transform shrink-0">
                      <polyline points="6 9 12 15 18 9"/>
                    </svg>
                  </summary>
                  <form method="post" action="/api/marketplace/conversations/create" class="px-4 pb-4 space-y-3">
                    <input type="hidden" name="listing_id" value={listing.id} />
                    <textarea name="message" required rows="3" maxlength="1000"
                      placeholder="Hei! Er denne fortsatt tilgjengelig?"
                      class="w-full bg-linen rounded-xl px-4 py-3 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors resize-none"></textarea>
                    <button type="submit" class="w-full bg-charcoal/85 text-linen px-6 py-2.5 rounded-full text-sm font-medium hover:bg-charcoal transition-colors">
                      Send melding
                    </button>
                  </form>
                </details>
              )}
            </div>
          )}

          {!isOwner && user && listing.status === 'active' && (
            <div class="mt-4 text-right">
              <ReportButton targetType="listing" targetId={listing.id} />
            </div>
          )}

          {isStoreListing && storeRow ? (
            <a href={`/market/store/${storeRow.slug}`} class="mt-6 pt-6 border-t border-sage-500/10 flex items-center gap-3 group">
              {storeRow.logo_path ? (
                <img src={projectPhotoUrl(storeRow.logo_path)} alt={`${storeRow.name} logo`} class="w-10 h-10 rounded-xl object-cover shrink-0" />
              ) : (
                <div class="w-10 h-10 rounded-xl bg-sage-100 flex items-center justify-center font-serif text-lg text-sage-700 shrink-0">
                  {storeRow.name[0]?.toUpperCase()}
                </div>
              )}
              <div class="min-w-0">
                <p class="font-medium group-hover:text-terracotta-500 transition-colors flex items-center gap-1.5">
                  {storeRow.name}
                  {storeRow.verified && <span class="text-[9px] font-bold uppercase tracking-widest bg-sage-500/20 text-sage-700 px-1.5 py-0.5 rounded-full">✓</span>}
                </p>
                <p class="text-xs text-charcoal/45">
                  Butikk · {storeRow.location_city ?? 'Strikketorget'}
                </p>
              </div>
            </a>
          ) : (
            <div class="mt-6 pt-6 border-t border-sage-500/10 flex items-center gap-3">
              <a href={`/market/seller/${listing.seller_id}`} class="flex items-center gap-3 min-w-0 flex-1 group">
                <ProfileAvatar url={sellerProfile?.avatar_path ? projectPhotoUrl(sellerProfile.avatar_path) : null} name={sellerProfile?.display_name ?? '?'} size="md" />
                <div class="min-w-0">
                  <p class="font-medium group-hover:text-terracotta-500 transition-colors">
                    {sellerProfile?.display_name ?? 'Anonym'}
                  </p>
                  {sellerReviewCount > 0 ? (
                    <div class="flex items-center gap-1.5 mt-0.5">
                      <StarRating rating={Math.round(sellerAvgRating)} />
                      <span class="text-xs text-charcoal/55">{sellerAvgRating.toFixed(1)} · {sellerReviewCount} {sellerReviewCount === 1 ? 'omtale' : 'omtaler'}</span>
                    </div>
                  ) : (
                    <p class="text-xs text-charcoal/45">
                      {sellerProfile?.location ?? listing.location ?? 'Selger'}
                    </p>
                  )}
                </div>
              </a>
              {user && !isOwner && (
                <form method="post" action={`/api/seller/${listing.seller_id}/follow`} class="shrink-0">
                  <input type="hidden" name="action" value="toggle" />
                  <input type="hidden" name="next" value={`/market/listing/${id}`} />
                  <button type="submit"
                    class:list={[
                      'text-xs font-medium px-3 py-1.5 rounded-full transition-colors',
                      isFollowing
                        ? 'bg-sage-100 text-sage-900 hover:bg-sage-200'
                        : 'bg-primary text-primary-fg hover:bg-primary-hover',
                    ]}>
                    {isFollowing ? '✓ Følger' : '+ Følg'}
                  </button>
                </form>
              )}
            </div>
          )}
        </div>
      </div>
  </MarketplaceShell>


  <style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    /* showModal() centering is inconsistent across browsers — pin it explicitly. */
    dialog[open] {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      margin: 0;
    }
  </style>

  <script>
    function initFavBtn() {
      document.querySelectorAll<HTMLButtonElement>('[data-fav-btn]').forEach(btn => {
        if ((btn as any)._favBound) return;
        (btn as any)._favBound = true;
        const icon = btn.querySelector('[data-fav-icon]') as SVGElement;
        function render() {
          const on = btn.dataset.favorited === 'true';
          icon?.setAttribute('fill', on ? 'currentColor' : 'none');
          btn.style.color = on ? 'var(--color-primary)' : '';
          btn.setAttribute('aria-label', on ? 'Fjern favoritt' : 'Legg til favoritt');
        }
        render();
        btn.addEventListener('click', async () => {
          btn.disabled = true;
          const form = new FormData();
          form.set('item_type', btn.dataset.itemType!);
          form.set('item_id', btn.dataset.itemId!);
          try {
            const res = await fetch('/api/favorites/toggle', { method: 'POST', body: form, credentials: 'same-origin' });
            if (res.ok) {
              const data = await res.json();
              btn.dataset.favorited = data.favorited ? 'true' : 'false';
              render();
            }
          } finally { btn.disabled = false; }
        });
      });
    }
    initFavBtn();
    document.addEventListener('astro:page-load', initFavBtn);
  </script>
  <script>
    function initStarRating() {
      document.querySelectorAll<HTMLFieldSetElement>('[data-star-rating]').forEach(fs => {
        if ((fs as any)._bound) return;
        (fs as any)._bound = true;
        const stars = fs.querySelectorAll<SVGElement>('[data-star]');
        const inputs = fs.querySelectorAll<HTMLInputElement>('input[name="rating"]');
        function highlight(n: number) {
          stars.forEach(s => {
            const v = parseInt(s.dataset.star!, 10);
            s.setAttribute('fill', v <= n ? 'currentColor' : 'none');
            s.classList.toggle('text-terracotta-500', v <= n);
            s.classList.toggle('text-charcoal/20', v > n);
          });
        }
        inputs.forEach(inp => inp.addEventListener('change', () => highlight(parseInt(inp.value, 10))));
        stars.forEach(s => {
          s.addEventListener('mouseenter', () => highlight(parseInt(s.dataset.star!, 10)));
          s.addEventListener('mouseleave', () => {
            const checked = fs.querySelector<HTMLInputElement>('input[name="rating"]:checked');
            highlight(checked ? parseInt(checked.value, 10) : 0);
          });
        });
      });
    }
    initStarRating();
    document.addEventListener('astro:page-load', initStarRating);
  </script>
</Layout>
