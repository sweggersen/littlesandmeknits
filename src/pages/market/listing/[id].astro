                </div>
              )}

              {isBuyer && listing.status === 'sold' && !hasReviewed && (
                <section class="bg-white rounded-3xl p-5 border border-sage-500/10 space-y-3">
                  <h2 class="font-serif text-lg">Gi selger en vurdering</h2>
                  <form method="post" action={`/api/marketplace/listings/${listing.id}/review`} class="space-y-3">
                    <fieldset class="flex gap-1" data-star-rating>
                      {[1, 2, 3, 4, 5].map((v) => (
                        <label class="cursor-pointer">
                          <input type="radio" name="rating" value={v} required class="sr-only" />
                          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-charcoal/20 hover:text-terracotta-500 transition-colors" data-star={v}>
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                          </svg>
                        </label>
                      ))}
                    </fieldset>
                    <textarea name="comment" rows="2" maxlength="500" placeholder="Valgfri kommentar..."
                      class="w-full bg-linen rounded-xl px-4 py-3 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors resize-none"></textarea>
                    <button type="submit" class="w-full bg-charcoal text-linen px-6 py-3 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors">
                      Send vurdering
                    </button>
                  </form>
                </section>
              )}

              {isBuyer && hasReviewed && (
                <div class="bg-oatmeal/40 rounded-2xl p-4 text-sm">
                  <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">Din vurdering</p>
                  <div class="flex gap-0.5 mb-1">
                    {[1, 2, 3, 4, 5].map((v) => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill={v <= buyerReview!.rating ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="1.5" class={v <= buyerReview!.rating ? 'text-terracotta-500' : 'text-charcoal/20'}>
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    ))}
                  </div>
                  {buyerReview!.comment && <p class="text-charcoal/65">{buyerReview!.comment}</p>}
                </div>
              )}


              {/* ── Buyer CTAs (active listings, viewer is not owner/buyer) ── */}
              {!isOwner && !isBuyer && listing.status === 'active' && listing.escrow_enabled && sellerOnboarded && (() => {
                const bd = purchaseBreakdown(listing.price_nok, (listing as any).shipping_option ?? 'free', true);
                return (
                  <section class="space-y-3">
                    <div class="grid grid-cols-2 gap-2">
                      <button type="button" data-open-buy class="bg-charcoal text-linen px-5 py-3.5 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors">
                        Kjøp trygt
                      </button>
                      <button type="button" data-open-bid class="bg-white border border-sage-500/25 text-charcoal px-5 py-3.5 rounded-full text-sm font-medium hover:border-charcoal/40 transition-colors">
                        Gi et tilbud
                      </button>
                    </div>
                    <p class="text-[11px] text-charcoal/45 text-center">
                      Pengene holdes trygt til du bekrefter mottak.
                    </p>

                    {/* ── Kjøp-modal ──────────────────────────────────────── */}
                    <dialog id="buy-modal" class="rounded-3xl p-0 max-w-md w-[92vw] bg-white backdrop:bg-charcoal/55">
                      <div class="p-6 space-y-5">
                        <div class="flex items-start justify-between gap-3">
                          <div>
                            <p class="text-[10px] font-bold uppercase tracking-widest text-sage-700">Trygg betaling</p>
                            <h3 class="font-serif text-2xl mt-1">Bekreft kjøp</h3>
                          </div>
                          <button type="button" data-close-modal class="text-charcoal/45 hover:text-charcoal text-2xl leading-none -mt-1">&times;</button>
                        </div>

                        <div class="bg-linen/60 rounded-2xl p-4 flex items-center gap-3">
                          {(() => {
                            const heroUrl = photoUrls[0];
                            return heroUrl
                              ? <img src={heroUrl} alt="" class="w-14 h-14 rounded-lg object-cover shrink-0" />
                              : <div class="w-14 h-14 rounded-lg bg-oatmeal/50 shrink-0" />;
                          })()}
                          <div class="min-w-0">
                            <p class="text-sm font-medium line-clamp-2">{listing.title}</p>
                            <p class="text-xs text-charcoal/55 mt-0.5">str. {listing.size_label}</p>
                          </div>
                        </div>

                        <dl class="text-sm space-y-1.5">
                          <div class="flex items-baseline justify-between gap-3">
                            <dt class="text-charcoal/65 min-w-0">Vare</dt>
                            <dd class="font-mono tabular-nums whitespace-nowrap shrink-0">{bd.itemNok} kr</dd>
                          </div>
                          <div class="flex items-baseline justify-between gap-3">
                            <dt class="text-charcoal/65 min-w-0">{bd.shippingNok > 0 ? `Frakt (${bd.shippingLabel})` : 'Frakt'}</dt>
                            <dd class="font-mono tabular-nums whitespace-nowrap shrink-0">{bd.shippingNok > 0 ? `${bd.shippingNok} kr` : 'Gratis'}</dd>
                          </div>
                          <div class="flex items-baseline justify-between gap-3">
                            <dt class="text-charcoal/65 min-w-0">Trygg betaling</dt>
                            <dd class="font-mono tabular-nums whitespace-nowrap shrink-0">{bd.tbFeeNok} kr</dd>
                          </div>
                          <div class="flex items-baseline justify-between gap-3 pt-2 border-t border-sage-500/10">
                            <dt class="font-medium min-w-0">Du betaler totalt</dt>
                            <dd class="font-mono tabular-nums font-bold whitespace-nowrap shrink-0">{bd.totalNok} kr</dd>
                          </div>
                        </dl>

                        <form method="post" action={`/api/marketplace/listings/${listing.id}/buy`}>
                          <button type="submit" class="w-full bg-charcoal text-linen px-6 py-3.5 rounded-full text-base font-medium hover:bg-terracotta-500 transition-colors">
                            Bekreft kjøp — {bd.totalNok} kr
                          </button>
                        </form>
                        <p class="text-[11px] text-charcoal/45 text-center">
                          Du blir sendt til Stripe for leveringsadresse og betaling.
                        </p>
                      </div>
                    </dialog>

                    {/* ── Foreslå-pris-modal ──────────────────────────────── */}
                    <dialog id="bid-modal" class="rounded-3xl p-0 max-w-md w-[92vw] bg-white backdrop:bg-charcoal/55">
                      <div class="p-6 space-y-5">
                        <div class="flex items-start justify-between gap-3">
                          <div>
                            <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45">Tilbud</p>
                            <h3 class="font-serif text-2xl mt-1">Gi et tilbud</h3>
                          </div>
                          <button type="button" data-close-modal class="text-charcoal/45 hover:text-charcoal text-2xl leading-none -mt-1">&times;</button>
                        </div>

                        <p class="text-sm text-charcoal/65">
                          Annonseprisen er <strong>{listing.price_nok} kr</strong>. Send et tilbud
                          med din pris — selger får meldingen i innboksen og kan svare deg direkte.
                          Når dere er enige, fullfører dere kjøpet med Trygg betaling.
                        </p>

                        <form method="post" action="/api/marketplace/conversations/create" class="space-y-3">
                          <input type="hidden" name="listing_id" value={listing.id} />
                          <label class="block">
                            <span class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Ditt tilbud</span>
                            <div class="relative">
                              <input id="bid-amount" type="number" min="1" max={listing.price_nok} required
                                placeholder={String(Math.round(listing.price_nok * 0.8))}
                                class="w-full bg-linen rounded-xl pl-4 pr-12 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors" />
                              <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-charcoal/45 pointer-events-none">kr</span>
                            </div>
                          </label>
                          <label class="block">
                            <span class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">Melding til selger (valgfritt)</span>
                            <textarea id="bid-message" name="message" rows="2" maxlength="500"
                              placeholder="Hei! Kunne du tenke deg å selge den til denne prisen?"
                              class="w-full bg-linen rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors resize-none"></textarea>
                          </label>
                          <p class="text-[11px] text-charcoal/45">
                            Selger må godta tilbudet før kjøpet kan gjennomføres.
                          </p>
                          <button type="submit" class="w-full bg-charcoal text-linen px-6 py-3.5 rounded-full text-base font-medium hover:bg-terracotta-500 transition-colors">
                            Send tilbud
                          </button>
                        </form>
                      </div>
                    </dialog>

                    <script define:vars={{ listingPrice: listing.price_nok }}>
                      function init() {
                        const buyOpen = document.querySelector('[data-open-buy]');
                        const bidOpen = document.querySelector('[data-open-bid]');
                        const buyModal = document.querySelector('#buy-modal');
                        const bidModal = document.querySelector('#bid-modal');
                        const bidForm = bidModal?.querySelector('form');
                        const bidAmount = document.querySelector('#bid-amount');
                        const bidMessage = document.querySelector('#bid-message');
                        if (!buyOpen || !bidOpen || !buyModal || !bidModal) return;

                        buyOpen.addEventListener('click', () => buyModal.showModal && buyModal.showModal());
                        bidOpen.addEventListener('click', () => bidModal.showModal && bidModal.showModal());
                        document.querySelectorAll('[data-close-modal]').forEach((btn) => {
                          btn.addEventListener('click', (e) => {
                            const dlg = e.target.closest('dialog');
                            if (dlg) dlg.close();
                          });
                        });

                        // Submit-time: encode the bid as a structured message so the
                        // seller can recognise it. Server stays a plain conversation
                        // create — no schema changes needed.
                        bidForm?.addEventListener('submit', (e) => {
                          const amount = parseInt(bidAmount?.value || '0', 10);
                          if (!amount || amount < 1) {
                            e.preventDefault();
                            return;
                          }
                          const note = (bidMessage?.value || '').trim();
                          const prefix = `💸 Tilbud: ${amount} kr (full pris: ${listingPrice} kr).`;
                          bidMessage.value = note ? `${prefix}\n\n${note}` : prefix;
                        });
                      }
                      init();
                      document.addEventListener('astro:page-load', init);
                    </script>
                  </section>
                );
              })()}

              {/* ── No escrow / no Stripe — keep simple message + meet-up ── */}
              {!isOwner && !isBuyer && listing.status === 'active' && !(listing.escrow_enabled && sellerOnboarded) && (
                <section class="bg-amber-50/60 border border-amber-200 rounded-3xl p-5 text-sm">
                  <p class="font-medium text-amber-900 mb-1">⚠️ Trygg betaling er ikke tilgjengelig</p>
                  <p class="text-charcoal/65">
                    {listing.escrow_enabled
                      ? 'Selger har ikke fullført Stripe-onboarding ennå.'
                      : 'Selger har ikke aktivert Trygg betaling.'}
                    {' '}Du kan fortsatt sende melding og avtale møte/Vipps — men Strikketorget gir
                    ingen kjøperbeskyttelse på dette salget.
                  </p>
                </section>
              )}

              {/* ── Send melding (tertiary, secondary surface) ─────────── */}
              {!isOwner && !isBuyer && listing.status === 'active' && (
                <details class="bg-white rounded-3xl border border-sage-500/10 mt-3 group">
                  <summary class="cursor-pointer p-4 text-sm font-medium text-charcoal/70 hover:text-charcoal flex items-center justify-between">
                    <span>✉️ Send melding til {isStoreListing ? 'butikken' : 'selger'}</span>
                    <span class="text-charcoal/30 group-open:rotate-180 transition-transform">⌄</span>
                  </summary>
                  <form method="post" action="/api/marketplace/conversations/create" class="px-4 pb-4 space-y-3">
                    <input type="hidden" name="listing_id" value={listing.id} />
                    <textarea name="message" required rows="3" maxlength="1000"
                      placeholder="Hei! Er denne fortsatt tilgjengelig?"
                      class="w-full bg-linen rounded-xl px-4 py-3 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors resize-none"></textarea>
                    <button type="submit" class="w-full bg-charcoal/85 text-linen px-6 py-2.5 rounded-full text-sm font-medium hover:bg-charcoal transition-colors">
                      Send melding
                    </button>
                  </form>
                </details>
              )}
            </div>
          )}

          {!isOwner && user && listing.status === 'active' && (
            <div class="mt-4 text-right">
              <ReportButton targetType="listing" targetId={listing.id} />
            </div>
          )}

          {isStoreListing && storeRow ? (
            <a href={`/market/store/${storeRow.slug}`} class="mt-6 pt-6 border-t border-sage-500/10 flex items-center gap-3 group">
              {storeRow.logo_path ? (
                <img src={projectPhotoUrl(storeRow.logo_path)} alt="" class="w-10 h-10 rounded-xl object-cover shrink-0" />
              ) : (
                <div class="w-10 h-10 rounded-xl bg-sage-100 flex items-center justify-center font-serif text-lg text-sage-700 shrink-0">
                  {storeRow.name[0]?.toUpperCase()}
                </div>
              )}
              <div class="min-w-0">
                <p class="font-medium group-hover:text-terracotta-500 transition-colors flex items-center gap-1.5">
                  {storeRow.name}
                  {storeRow.verified && <span class="text-[9px] font-bold uppercase tracking-widest bg-sage-500/20 text-sage-700 px-1.5 py-0.5 rounded-full">✓</span>}
                </p>
                <p class="text-xs text-charcoal/45">
                  Butikk · {storeRow.location_city ?? 'Strikketorget'}
                </p>
              </div>
            </a>
          ) : (
            <div class="mt-6 pt-6 border-t border-sage-500/10 flex items-center gap-3">
              <a href={`/market/seller/${listing.seller_id}`} class="flex items-center gap-3 min-w-0 flex-1 group">
                <ProfileAvatar url={sellerProfile?.avatar_path ? projectPhotoUrl(sellerProfile.avatar_path) : null} name={sellerProfile?.display_name ?? '?'} size="md" />
                <div class="min-w-0">
                  <p class="font-medium group-hover:text-terracotta-500 transition-colors">
                    {sellerProfile?.display_name ?? 'Anonym'}
                  </p>
                  {sellerReviewCount > 0 ? (
                    <div class="flex items-center gap-1.5 mt-0.5">
                      <StarRating rating={Math.round(sellerAvgRating)} />
                      <span class="text-xs text-charcoal/55">{sellerAvgRating.toFixed(1)} · {sellerReviewCount} {sellerReviewCount === 1 ? 'omtale' : 'omtaler'}</span>
                    </div>
                  ) : (
                    <p class="text-xs text-charcoal/45">
                      {sellerProfile?.location ?? listing.location ?? 'Selger'}
                    </p>
                  )}
                </div>
              </a>
              {user && !isOwner && (
                <form method="post" action={`/api/seller/${listing.seller_id}/follow`} class="shrink-0">
                  <input type="hidden" name="action" value="toggle" />
                  <input type="hidden" name="next" value={`/market/listing/${id}`} />
                  <button type="submit"
                    class:list={[
                      'text-xs font-medium px-3 py-1.5 rounded-full transition-colors',
                      isFollowing
                        ? 'bg-sage-100 text-sage-900 hover:bg-sage-200'
                        : 'bg-charcoal text-linen hover:bg-terracotta-500',
                    ]}>
                    {isFollowing ? '✓ Følger' : '+ Følg'}
                  </button>
                </form>
              )}
            </div>
          )}
        </div>
      </div>
  </MarketplaceShell>

  <!-- Fullscreen lightbox -->
  <div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 hidden items-center justify-center" role="dialog" aria-modal="true">
    <button type="button" data-lb-close class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors z-10" aria-label="Lukk">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
    <button type="button" data-lb-prev class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors z-10" aria-label="Forrige">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <button type="button" data-lb-next class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors z-10" aria-label="Neste">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
    <div class="w-full h-full flex flex-col items-center px-4 pt-14 pb-4">
      <div class="flex-1 min-h-0 flex items-center justify-center w-full">
        <img id="lb-image" src="" alt="" class="max-h-full max-w-full object-contain rounded-lg" />
      </div>
      <p id="lb-caption" class="text-white/70 text-sm mt-3 text-center max-w-xl shrink-0"></p>
      <p id="lb-counter" class="text-white/40 text-xs mt-1 shrink-0"></p>
      <div class="flex gap-2 mt-3 overflow-x-auto max-w-[90vw] no-scrollbar shrink-0" id="lb-thumbs"></div>
    </div>
  </div>

  <style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    /* showModal() centering is inconsistent across browsers — pin it explicitly. */
    dialog[open] {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      margin: 0;
    }
  </style>

  <script define:vars={{ photoData: photos.map((p) => ({ url: projectPhotoUrl(p.path), caption: p.caption, id: p.id })), listingId: listing.id }}>
  function initListingGallery() {
    const mainPhoto = document.getElementById('main-photo');
    if (!mainPhoto) return; // page swapped to a non-listing route
    const thumbs = document.querySelectorAll('[data-thumb-idx]');
    const counter = document.querySelector('[data-gallery-counter]');
    const captionEl = document.querySelector('[data-photo-caption]');
    const prevBtn = document.querySelector('[data-gallery-prev]');
    const nextBtn = document.querySelector('[data-gallery-next]');

    let current = 0;
    const urls = photoData.map(p => p.url);
    const captions = photoData.map(p => p.caption || '');

    function showInline(idx) {
      current = (idx + urls.length) % urls.length;
      if (mainPhoto) mainPhoto.src = urls[current];
      if (counter) counter.textContent = `${current + 1} / ${urls.length}`;
      if (captionEl) captionEl.textContent = captions[current] || '';
      thumbs.forEach((t, i) => {
        t.classList.toggle('border-terracotta-500', i === current);
        t.classList.toggle('border-transparent', i !== current);
      });
    }

    if (thumbs.length > 1) {
      thumbs.forEach(t => t.addEventListener('click', () => showInline(parseInt(t.dataset.thumbIdx, 10))));
      prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); showInline(current - 1); });
      nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); showInline(current + 1); });
    }

    // Lightbox
    const lb = document.getElementById('lightbox');
    const lbImg = document.getElementById('lb-image');
    const lbCaption = document.getElementById('lb-caption');
    const lbCounter = document.getElementById('lb-counter');
    const lbThumbs = document.getElementById('lb-thumbs');

    function openLightbox(idx) {
      current = idx;
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
      showLightbox(idx);
    }

    function closeLightbox() {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      document.body.style.overflow = '';
    }

    function showLightbox(idx) {
      current = (idx + urls.length) % urls.length;
      lbImg.src = urls[current];
      lbImg.alt = captions[current] || '';
      lbCaption.textContent = captions[current] || '';
      lbCounter.textContent = `${current + 1} / ${urls.length}`;
      showInline(current);

      // Update lightbox thumbnails
      lbThumbs.innerHTML = '';
      urls.forEach((url, i) => {
        const btn = document.createElement('button');
        btn.className = `shrink-0 w-12 h-12 rounded-lg overflow-hidden border-2 transition-colors ${i === current ? 'border-white' : 'border-transparent opacity-50 hover:opacity-80'}`;
        btn.textContent = '';
        const img = document.createElement('img');
        img.src = url;
        img.className = 'w-full h-full object-cover';
        btn.appendChild(img);
        btn.addEventListener('click', () => showLightbox(i));
        lbThumbs.appendChild(btn);
      });
    }

    document.querySelector('[data-lightbox-trigger]')?.addEventListener('click', (e) => {
      if (e.target.closest('[data-gallery-prev]') || e.target.closest('[data-gallery-next]')) return;
      openLightbox(current);
    });

    thumbs.forEach(t => t.addEventListener('dblclick', () => openLightbox(parseInt(t.dataset.thumbIdx, 10))));

    document.querySelector('[data-lb-close]')?.addEventListener('click', closeLightbox);
    document.querySelector('[data-lb-prev]')?.addEventListener('click', () => showLightbox(current - 1));
    document.querySelector('[data-lb-next]')?.addEventListener('click', () => showLightbox(current + 1));

    lb?.addEventListener('click', (e) => {
      if (e.target === lb) closeLightbox();
    });

    document.addEventListener('keydown', (e) => {
      if (lb.classList.contains('hidden')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') showLightbox(current - 1);
      if (e.key === 'ArrowRight') showLightbox(current + 1);
    });

    const apiUrl = `/api/marketplace/listings/${listingId}/photo`;
    const manager = document.getElementById('photo-manager');

    function postAction(body) {
      return fetch(apiUrl, {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body,
        credentials: 'same-origin',
      });
    }

    function swapRows(idA, idB) {
      const rowA = manager?.querySelector(`[data-photo-row="${idA}"]`);
      const rowB = manager?.querySelector(`[data-photo-row="${idB}"]`);
      if (!rowA || !rowB) return;
      const parent = rowA.parentNode;
      const placeholder = document.createElement('div');
      parent.insertBefore(placeholder, rowA);
      parent.insertBefore(rowA, rowB.nextSibling);
      parent.insertBefore(rowB, placeholder);
      placeholder.remove();
      rebuildMoveButtons();
    }

    function rebuildMoveButtons() {
      if (!manager) return;
      const rows = [...manager.querySelectorAll('[data-photo-row]')];
      rows.forEach((row, i) => {
        const col = row.querySelector('.flex.flex-col');
        if (!col) return;
        const pid = row.dataset.photoRow;
        col.querySelectorAll('[data-move-up],[data-move-down]').forEach(b => b.remove());
        if (i > 0) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.dataset.moveUp = pid;
          btn.className = 'w-7 h-7 rounded-lg bg-oatmeal/60 flex items-center justify-center text-charcoal/55 hover:text-charcoal hover:bg-oatmeal transition-colors';
          btn.title = 'Flytt opp';
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m18 15-6-6-6 6"/></svg>';
          btn.addEventListener('click', () => reorder(pid, -1));
          col.insertBefore(btn, col.firstChild);
        }
        if (i < rows.length - 1) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.dataset.moveDown = pid;
          btn.className = 'w-7 h-7 rounded-lg bg-oatmeal/60 flex items-center justify-center text-charcoal/55 hover:text-charcoal hover:bg-oatmeal transition-colors';
          btn.title = 'Flytt ned';
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m6 9 6 6 6-6"/></svg>';
          const deleteForm = col.querySelector('form');
          col.insertBefore(btn, deleteForm);
          btn.addEventListener('click', () => reorder(pid, 1));
        }
      });
    }

    async function reorder(photoId, direction) {
      const idx = photoData.findIndex(p => p.id === photoId);
      if (idx < 0) return;
      const swapIdx = idx + direction;
      if (swapIdx < 0 || swapIdx >= photoData.length) return;

      [photoData[idx], photoData[swapIdx]] = [photoData[swapIdx], photoData[idx]];
      swapRows(photoData[idx].id, photoData[swapIdx].id);

      urls.length = 0;
      captions.length = 0;
      photoData.forEach(p => { urls.push(p.url); captions.push(p.caption || ''); });
      showInline(current);

      const body = new FormData();
      body.set('action', 'reorder');
      body.set('order', JSON.stringify(photoData.map(p => p.id)));
      await postAction(body);
    }

    document.querySelectorAll('[data-move-up]').forEach(btn => {
      btn.addEventListener('click', () => reorder(btn.dataset.moveUp, -1));
    });
    document.querySelectorAll('[data-move-down]').forEach(btn => {
      btn.addEventListener('click', () => reorder(btn.dataset.moveDown, 1));
    });

    // Inline caption save
    manager?.querySelectorAll('form').forEach(form => {
      const actionInput = form.querySelector('input[name="action"][value="caption"]');
      if (!actionInput) return;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const body = new FormData(form);
        const photoId = body.get('photo_id');
        const caption = body.get('caption')?.toString() ?? '';
        const pd = photoData.find(p => p.id === photoId);
        if (pd) {
          pd.caption = caption;
          captions[photoData.indexOf(pd)] = caption;
          if (captionEl && photoData.indexOf(pd) === current) captionEl.textContent = caption;
        }
        const btn = form.querySelector('button[type="submit"]');
        if (btn) btn.textContent = '✓';
        await postAction(body);
        setTimeout(() => { if (btn) btn.textContent = 'Lagre'; }, 1500);
      });
    });

    // Inline delete
    manager?.querySelectorAll('form').forEach(form => {
      const actionInput = form.querySelector('input[name="action"][value="delete"]');
      if (!actionInput) return;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const body = new FormData(form);
        const photoId = body.get('photo_id');
        const row = manager.querySelector(`[data-photo-row="${photoId}"]`);
        if (row) row.remove();
        const idx = photoData.findIndex(p => p.id === photoId);
        if (idx >= 0) {
          photoData.splice(idx, 1);
          urls.splice(idx, 1);
          captions.splice(idx, 1);
          if (current >= urls.length) current = Math.max(0, urls.length - 1);
          if (urls.length > 0) showInline(current);
        }
        rebuildMoveButtons();
        await postAction(body);
      });
    });
  }
  document.addEventListener('astro:page-load', initListingGallery);
  </script>
  <script>
    function initFavBtn() {
      document.querySelectorAll<HTMLButtonElement>('[data-fav-btn]').forEach(btn => {
        if ((btn as any)._favBound) return;
        (btn as any)._favBound = true;
        const icon = btn.querySelector('[data-fav-icon]') as SVGElement;
        function render() {
          const on = btn.dataset.favorited === 'true';
          icon?.setAttribute('fill', on ? 'currentColor' : 'none');
          btn.style.color = on ? '#c2604a' : '';
          btn.setAttribute('aria-label', on ? 'Fjern favoritt' : 'Legg til favoritt');
        }
        render();
        btn.addEventListener('click', async () => {
          btn.disabled = true;
          const form = new FormData();
          form.set('item_type', btn.dataset.itemType!);
          form.set('item_id', btn.dataset.itemId!);
          try {
            const res = await fetch('/api/favorites/toggle', { method: 'POST', body: form, credentials: 'same-origin' });
            if (res.ok) {
              const data = await res.json();
              btn.dataset.favorited = data.favorited ? 'true' : 'false';
              render();
            }
          } finally { btn.disabled = false; }
        });
      });
    }
    initFavBtn();
    document.addEventListener('astro:page-load', initFavBtn);
  </script>
  <script>
    function initStarRating() {
      document.querySelectorAll<HTMLFieldSetElement>('[data-star-rating]').forEach(fs => {
        if ((fs as any)._bound) return;
        (fs as any)._bound = true;
        const stars = fs.querySelectorAll<SVGElement>('[data-star]');
        const inputs = fs.querySelectorAll<HTMLInputElement>('input[name="rating"]');
        function highlight(n: number) {
          stars.forEach(s => {
            const v = parseInt(s.dataset.star!, 10);
            s.setAttribute('fill', v <= n ? 'currentColor' : 'none');
            s.classList.toggle('text-terracotta-500', v <= n);
            s.classList.toggle('text-charcoal/20', v > n);
          });
        }
        inputs.forEach(inp => inp.addEventListener('change', () => highlight(parseInt(inp.value, 10))));
        stars.forEach(s => {
          s.addEventListener('mouseenter', () => highlight(parseInt(s.dataset.star!, 10)));
          s.addEventListener('mouseleave', () => {
            const checked = fs.querySelector<HTMLInputElement>('input[name="rating"]:checked');
            highlight(checked ? parseInt(checked.value, 10) : 0);
          });
        });
      });
    }
    initStarRating();
    document.addEventListener('astro:page-load', initStarRating);
  </script>
</Layout>
