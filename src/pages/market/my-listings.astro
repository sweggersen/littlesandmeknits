---
import Layout from '../../layouts/Layout.astro';
import MarketplaceShell from '../../components/MarketplaceShell.astro';
import EmptyState from '../../components/EmptyState.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import { createServerSupabase } from '../../lib/supabase';
import { requireUser } from '../../lib/auth';
import { KIND_LABEL, LISTING_STATUS, COMMISSION_STATUS } from '../../lib/labels';

const guard = await requireUser(Astro);
if (guard instanceof Response) return guard;
const user = guard;

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });

const [{ data: listings }, { data: conversations }, { data: knitterOffers }] = await Promise.all([
  supabase
    .from('listings')
    .select('id, title, price_nok, status, kind, hero_photo_path, created_at, promoted_until, promotion_tier, buyer_name, buyer_city')
    .eq('seller_id', user.id)
    .order('created_at', { ascending: false }),
  // Conversations with at least one *unread* message (from the other party).
  supabase
    .from('marketplace_conversations')
    .select('id, marketplace_messages!inner(id, sender_id, read_at)')
    .or(`buyer_id.eq.${user.id},seller_id.eq.${user.id}`)
    .neq('marketplace_messages.sender_id', user.id)
    .is('marketplace_messages.read_at', null),
  supabase
    .from('commission_offers')
    .select('id, price_nok, request_id, status, commission_requests!commission_offers_request_id_fkey(id, title, status, category, delivered_at)')
    .eq('knitter_id', user.id)
    .eq('status', 'accepted'),
]);

const drafts = (listings ?? []).filter((l) => l.status === 'draft');
const inReview = (listings ?? []).filter((l) => l.status === 'pending_review');
const rejected = (listings ?? []).filter((l) => l.status === 'rejected');
const frozen = (listings ?? []).filter((l) => l.status === 'frozen');
const pending = (listings ?? []).filter((l) => ['reserved', 'shipped', 'disputed'].includes(l.status));
const live = (listings ?? []).filter((l) => l.status === 'active');
const sold = (listings ?? []).filter((l) => l.status === 'sold');
// Dedupe by conversation id — the join returns one row per unread message.
const unreadConvos = new Set((conversations ?? []).map((c: any) => c.id)).size;

// Commissions the user is knitting (or has knit). Filter out commissions
// where the request itself is in a non-active state, then split into
// "pågående" vs "levert".
const knitterCommissions = ((knitterOffers ?? []) as any[])
  .filter(o => o.commission_requests)
  .map(o => ({
    id: o.commission_requests.id,
    title: o.commission_requests.title,
    status: o.commission_requests.status,
    category: o.commission_requests.category,
    delivered_at: o.commission_requests.delivered_at,
    price_nok: o.price_nok,
  }));
const commissionsActive = knitterCommissions.filter(c => ['awarded', 'awaiting_payment', 'awaiting_yarn', 'completed'].includes(c.status));
const commissionsDelivered = knitterCommissions.filter(c => c.status === 'delivered');
const commissionsDisputed = knitterCommissions.filter(c => c.status === 'disputed');
---

<Layout title="Mine annonser og oppdrag — Strikketorget" lang="nb">
  <MarketplaceShell current="mine">
      <div class="flex items-end justify-between mb-8 gap-4 flex-wrap">
        <div>
          <h1 class="font-serif text-3xl sm:text-4xl">Mine annonser og oppdrag</h1>
          <p class="text-charcoal/55 mt-1">Alt jeg selger, har solgt, og strikker for andre.</p>
        </div>
        <a
          href="/market/listing/new"
          class="bg-primary text-primary-fg px-5 py-2.5 rounded-full text-sm font-medium hover:bg-primary-hover transition-colors"
        >
          + Ny annonse
        </a>
      </div>

      {unreadConvos > 0 && (
        <section class="mb-8">
          <a
            href="/market/messages"
            class="block bg-white rounded-2xl p-4 border border-terracotta-500/30 hover:border-terracotta-500/50 transition-colors"
          >
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500 mb-1">Uleste meldinger</p>
                <p class="text-sm text-charcoal/70">{unreadConvos} {unreadConvos === 1 ? 'samtale' : 'samtaler'} venter på svar</p>
              </div>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-charcoal/40">
                <path d="m9 18 6-6-6-6" />
              </svg>
            </div>
          </a>
        </section>
      )}

      {pending.length > 0 && (
        <section class="mb-8">
          <h2 class="font-serif text-xl mb-3">Ventende ordrer</h2>
          <ul class="space-y-2">
            {pending.map((l) => (
              <li class="bg-white rounded-2xl border border-terracotta-500/20 hover:border-terracotta-500/40 transition-colors">
                <a href={`/market/listing/${l.id}`} class="block p-4">
                  <div class="flex items-center justify-between gap-4">
                    <div>
                      <div class="flex items-center gap-2 mb-1">
                        <StatusBadge label={LISTING_STATUS[l.status]} variant={l.status === 'disputed' ? 'amber' : 'sage'} />
                        {l.buyer_name && (
                          <span class="text-xs text-charcoal/55">→ {l.buyer_name}{l.buyer_city ? `, ${l.buyer_city}` : ''}</span>
                        )}
                      </div>
                      <p class="font-medium">{l.title}</p>
                    </div>
                    <p class="font-mono tabular-nums text-sm">{l.price_nok} NOK</p>
                  </div>
                </a>
                <a href={`/market/listing/${l.id}/kvittering`} class="block px-4 py-2 text-xs text-charcoal/55 hover:text-terracotta-500 border-t border-terracotta-500/10">📄 Se kvittering</a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {drafts.length > 0 && (
        <section class="mb-8">
          <h2 class="font-serif text-xl mb-3">Utkast</h2>
          <ul class="space-y-2">
            {drafts.map((l) => (
              <li>
                <a href={`/market/listing/${l.id}`} class="block bg-white rounded-2xl p-4 border border-sage-500/10 hover:border-sage-500/30 transition-colors">
                  <div class="flex items-center justify-between gap-4">
                    <div>
                      <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">
                        {KIND_LABEL[l.kind] ?? l.kind} · {LISTING_STATUS[l.status]}
                      </p>
                      <p class="font-medium">{l.title}</p>
                    </div>
                    <p class="font-mono tabular-nums text-sm">{l.price_nok} NOK</p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {inReview.length > 0 && (
        <section class="mb-8">
          <h2 class="font-serif text-xl mb-3">Til vurdering</h2>
          <ul class="space-y-2">
            {inReview.map((l) => (
              <li>
                <a href={`/market/listing/${l.id}`} class="block bg-amber-50/60 rounded-2xl p-4 border border-amber-200 hover:border-amber-300 transition-colors">
                  <div class="flex items-center justify-between gap-4">
                    <div>
                      <p class="text-[10px] font-bold uppercase tracking-widest text-amber-700 mb-1">
                        {KIND_LABEL[l.kind] ?? l.kind} · {LISTING_STATUS[l.status]}
                      </p>
                      <p class="font-medium">{l.title}</p>
                      <p class="text-xs text-charcoal/55 mt-0.5">Sendt til moderering — blir synlig så snart vi har godkjent den.</p>
                    </div>
                    <p class="font-mono tabular-nums text-sm">{l.price_nok} NOK</p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {frozen.length > 0 && (
        <section class="mb-8">
          <h2 class="font-serif text-xl mb-3 text-amber-700">Frosset av moderator</h2>
          <ul class="space-y-2">
            {frozen.map((l) => (
              <li>
                <a href={`/market/listing/${l.id}`} class="block bg-amber-50 rounded-2xl p-4 border border-amber-300 hover:border-amber-400 transition-colors">
                  <div class="flex items-center justify-between gap-4">
                    <p class="font-medium">{l.title}</p>
                    <p class="font-mono tabular-nums text-sm">{l.price_nok} NOK</p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {rejected.length > 0 && (
        <section class="mb-8">
          <h2 class="font-serif text-xl mb-3 text-red-700">Avvist</h2>
          <ul class="space-y-2">
            {rejected.map((l) => (
              <li>
                <a href={`/market/listing/${l.id}`} class="block bg-red-50/60 rounded-2xl p-4 border border-red-200 hover:border-red-300 transition-colors">
                  <div class="flex items-center justify-between gap-4">
                    <p class="font-medium">{l.title}</p>
                    <p class="font-mono tabular-nums text-sm">{l.price_nok} NOK</p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="mb-8">
        <h2 class="font-serif text-xl mb-3">Aktive annonser</h2>
        {live.length === 0 ? (
          (() => {
            const hasHistory = sold.length > 0 || drafts.length > 0 || inReview.length > 0;
            const message = hasHistory
              ? 'Du har ingen aktive annonser akkurat nå.'
              : 'Ingen aktive annonser ennå.';
            const cta = hasHistory ? 'Legg ut en ny annonse' : 'Legg ut din første annonse';
            return (
              <div>
                <EmptyState message={message} ctaText={cta} ctaHref="/market/listing/new" compact />
                {!hasHistory && (
                  <p class="text-xs text-charcoal/55 text-center mt-3">
                    Førstegang? Les <a href="/hjelp/selge" class="text-terracotta-500 hover:underline">hvordan du selger</a>.
                  </p>
                )}
              </div>
            );
          })()
        ) : (
          <ul class="space-y-2">
            {live.map((l) => {
              const isPromoted = l.promoted_until && new Date(l.promoted_until) > new Date();
              return (
                <li>
                  <div class="bg-white rounded-2xl border border-sage-500/10 hover:border-sage-500/30 transition-colors">
                    <a href={`/market/listing/${l.id}`} class="block p-4">
                      <div class="flex items-center justify-between gap-4">
                        <div>
                          <div class="flex items-center gap-2 mb-1">
                            <p class="text-[10px] font-bold uppercase tracking-widest text-sage-900">
                              {KIND_LABEL[l.kind] ?? l.kind} · {LISTING_STATUS[l.status]}
                            </p>
                            {isPromoted && <StatusBadge label="Fremhevet" variant="terracotta" />}
                          </div>
                          <p class="font-medium">{l.title}</p>
                        </div>
                        <p class="font-mono tabular-nums text-sm">{l.price_nok} NOK</p>
                      </div>
                    </a>
                    <div class="border-t border-sage-500/10 flex divide-x divide-sage-500/10 text-xs">
                      <a href={`/market/stats/${l.id}`} class="flex-1 px-3 py-2 text-charcoal/60 hover:text-terracotta-500 hover:bg-sage-50/40 transition-colors text-center">
                        📊 Statistikk
                      </a>
                      <a href={`/market/listing/${l.id}#promoter`} class="flex-1 px-3 py-2 text-charcoal/60 hover:text-terracotta-500 hover:bg-sage-50/40 transition-colors text-center">
                        {isPromoted ? '⚡ Aktiv promotering' : '⚡ Promoter'}
                      </a>
                    </div>
                  </div>
                </li>
              );
            })}
          </ul>
        )}
      </section>

      {sold.length > 0 && (
        <section class="mb-8">
          <h2 class="font-serif text-xl mb-3 text-charcoal/55">Solgt</h2>
          <ul class="space-y-2">
            {sold.map((l) => (
              <li>
                <div class="bg-oatmeal/40 rounded-2xl border border-sage-500/10">
                  <div class="flex items-center justify-between gap-4 p-4">
                    <p class="font-medium text-charcoal/65">{l.title}</p>
                    <p class="font-mono tabular-nums text-sm text-charcoal/55">{l.price_nok} NOK</p>
                  </div>
                  <a href={`/market/listing/${l.id}/kvittering`} class="block px-4 py-2 text-xs text-charcoal/55 hover:text-terracotta-500 border-t border-sage-500/10">📄 Se kvittering</a>
                </div>
              </li>
            ))}
          </ul>
        </section>
      )}

      {(commissionsActive.length + commissionsDelivered.length + commissionsDisputed.length) > 0 && (
        <section>
          <h2 class="font-serif text-xl mb-3">Oppdrag jeg strikker</h2>
          <ul class="space-y-2">
            {[...commissionsActive, ...commissionsDelivered, ...commissionsDisputed].map((c) => {
              const isDone = c.status === 'delivered';
              const isDisp = c.status === 'disputed';
              const bg = isDone ? 'bg-oatmeal/40' : isDisp ? 'bg-amber-50 border-amber-200' : 'bg-white';
              const variant = isDone ? 'sage' : isDisp ? 'amber' : 'amber';
              return (
                <li class:list={[bg, 'rounded-2xl border border-sage-500/10 hover:border-sage-500/30 transition-colors']}>
                  <a href={`/market/commissions/${c.id}`} class="block p-4">
                    <div class="flex items-center justify-between gap-4">
                      <div>
                        <div class="flex items-center gap-2 mb-1">
                          <StatusBadge label={COMMISSION_STATUS[c.status] ?? c.status} variant={variant as any} />
                        </div>
                        <p class:list={['font-medium', isDone && 'text-charcoal/65']}>{c.title}</p>
                      </div>
                      <p class:list={['font-mono tabular-nums text-sm', isDone && 'text-charcoal/55']}>{c.price_nok} NOK</p>
                    </div>
                  </a>
                  <a href={`/market/commissions/${c.id}/kvittering`} class="block px-4 py-2 text-xs text-charcoal/55 hover:text-terracotta-500 border-t border-sage-500/10">📄 Se kvittering</a>
                </li>
              );
            })}
          </ul>
        </section>
      )}

  </MarketplaceShell>
</Layout>
