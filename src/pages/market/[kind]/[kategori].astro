---
import Layout from '../../../layouts/Layout.astro';
import MarketplaceShell from '../../../components/MarketplaceShell.astro';
import ListingCard from '../../../components/ListingCard.astro';
import EmptyState from '../../../components/EmptyState.astro';
import FavScript from '../../../components/FavScript.astro';
import { createServerSupabase } from '../../../lib/supabase';
import { projectPhotoUrl } from '../../../lib/storage';
import { CATEGORY_LABEL } from '../../../lib/labels';

const VALID_KINDS = new Set(['used', 'new']);
const VALID_CATEGORIES = new Set([
  'genser', 'cardigan', 'lue', 'votter', 'sokker', 'teppe', 'kjole', 'bukser', 'annet',
]);

const kindParam = Astro.params.kind ?? '';
const categoryParam = Astro.params.kategori ?? '';

if (!VALID_KINDS.has(kindParam) || !VALID_CATEGORIES.has(categoryParam)) {
  return Astro.redirect('/market');
}

const dbKind = kindParam === 'used' ? 'pre_loved' : 'ready_made';
const kindLabelNo = kindParam === 'used' ? 'Brukt' : 'Nytt';
const categoryLabel = CATEGORY_LABEL[categoryParam] ?? categoryParam;

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const user = Astro.locals.user;

const { data: listings } = await supabase
  .from('listings')
  .select('id, title, kind, price_nok, size_label, hero_photo_path, promoted_until, promotion_tier, category, favorite_count')
  .eq('status', 'active')
  .eq('kind', dbKind)
  .eq('category', categoryParam)
  .order('promoted_until', { ascending: false, nullsFirst: false })
  .order('published_at', { ascending: false })
  .limit(48);

const rows = listings ?? [];

let favIds: string[] = [];
if (user && rows.length > 0) {
  const { data: favs } = await supabase
    .from('favorites')
    .select('item_id')
    .eq('user_id', user.id)
    .eq('item_type', 'listing')
    .in('item_id', rows.map((r) => r.id));
  favIds = (favs ?? []).map((f) => f.item_id);
}

// SEO content
const h1 = `${kindLabelNo} ${categoryLabel.toLowerCase()} på Strikketorget`;
const subtitle = kindParam === 'used'
  ? `Brukt håndstrikket ${categoryLabel.toLowerCase()}. Sortiment fra strikkeglade folk i Norge.`
  : `Nye håndstrikkede ${categoryLabel.toLowerCase()} til salgs. Direkte fra strikkeren.`;
const seoTitle = `${kindLabelNo} ${categoryLabel.toLowerCase()}`;
const seoDescription = `${rows.length > 0 ? `${rows.length}+ annonser` : 'Annonser'} for ${kindLabelNo.toLowerCase()} ${categoryLabel.toLowerCase()} på Strikketorget. Trygg betaling, levering med Posten.`;
---

<Layout title={seoTitle} description={seoDescription} lang="nb">
  <MarketplaceShell current={kindParam === 'used' ? 'brukt' : 'nytt'}>
    <nav class="text-sm text-charcoal/55 mb-3" aria-label="Brødsmuler">
      <a href="/market" class="hover:text-charcoal">Strikketorget</a>
      <span class="mx-1.5">·</span>
      <a href={`/market/${kindParam}`} class="hover:text-charcoal">{kindLabelNo}</a>
      <span class="mx-1.5">·</span>
      <span>{categoryLabel}</span>
    </nav>

    <header class="mb-6">
      <h1 class="font-serif text-3xl sm:text-4xl mb-2">{h1}</h1>
      <p class="text-charcoal/65">{subtitle}</p>
    </header>

    {rows.length === 0 ? (
      <EmptyState
        message={`Ingen ${kindLabelNo.toLowerCase()} ${categoryLabel.toLowerCase()} akkurat nå.`}
        ctaText="Utforsk alle annonser"
        ctaHref={`/market/${kindParam}`}
      />
    ) : (
      <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
        {rows.map((l) => (
          <ListingCard
            id={l.id}
            title={l.title}
            price={l.price_nok}
            imgUrl={projectPhotoUrl(l.hero_photo_path)}
            meta={`${kindLabelNo} · str. ${l.size_label}`}
            showFav={!!user}
            isFav={favIds.includes(l.id)}
            promoted={!!(l.promoted_until && new Date(l.promoted_until) > new Date())}
            promotionTier={l.promotion_tier ?? null}
          />
        ))}
      </ul>
    )}

    <FavScript />
  </MarketplaceShell>
</Layout>
