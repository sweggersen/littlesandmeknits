---
import Layout from '../../layouts/Layout.astro';
import MarketplaceShell from '../../components/MarketplaceShell.astro';
import ListingCard from '../../components/ListingCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import { createServerSupabase } from '../../lib/supabase';
import { getCurrentUser } from '../../lib/auth';
import { projectPhotoUrl } from '../../lib/storage';
import { KIND_LABEL } from '../../lib/labels';

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const user = await getCurrentUser({ request: Astro.request, cookies: Astro.cookies });

if (!user) return Astro.redirect('/login?next=' + encodeURIComponent('/market/following'));

const { data: follows } = await supabase
  .from('seller_follows')
  .select('seller_id')
  .eq('follower_id', user.id);

const sellerIds = (follows ?? []).map((f) => f.seller_id);

let listings: any[] = [];
let favIds: string[] = [];

if (sellerIds.length > 0) {
  const { data } = await supabase
    .from('listings')
    .select('id, title, kind, price_nok, size_label, hero_photo_path, category, promoted_until, promotion_tier, seller_id')
    .eq('status', 'active')
    .in('seller_id', sellerIds)
    .order('published_at', { ascending: false })
    .limit(40);
  listings = data ?? [];

  if (listings.length > 0) {
    const { data: favs } = await supabase
      .from('favorites')
      .select('item_id')
      .eq('user_id', user.id)
      .eq('item_type', 'listing')
      .in('item_id', listings.map((l) => l.id));
    favIds = (favs ?? []).map((f) => f.item_id);
  }
}
---

<Layout title="Sellere du følger — Strikketorget" lang="nb">
  <MarketplaceShell current="market">
    <a href="/market" class="text-sm text-charcoal/55 hover:text-charcoal mb-4 inline-block">← Tilbake til Strikketorget</a>
    <h1 class="font-serif text-3xl sm:text-4xl mb-2">Sellere du følger</h1>
    <p class="text-charcoal/55 text-sm mb-8">
      Nyeste annonser fra sellerne du har valgt å følge. Sortert etter publiseringsdato.
    </p>

    {sellerIds.length === 0 ? (
      <EmptyState
        message="Du følger ingen sellere ennå. Trykk «+ Følg» på en selger du liker — så får du varsel når de legger ut nye annonser."
        ctaText="Utforsk Strikketorget"
        ctaHref="/market"
      />
    ) : listings.length === 0 ? (
      <EmptyState
        message="Sellerne du følger har ingen aktive annonser akkurat nå."
        ctaText="Utforsk Strikketorget"
        ctaHref="/market"
      />
    ) : (
      <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
        {listings.map((l) => (
          <ListingCard
            id={l.id}
            title={l.title}
            price={l.price_nok}
            imgUrl={projectPhotoUrl(l.hero_photo_path)}
            meta={`${KIND_LABEL[l.kind] ?? l.kind} · str. ${l.size_label}`}
            showFav
            isFav={favIds.includes(l.id)}
            promoted={!!(l.promoted_until && new Date(l.promoted_until) > new Date())}
            promotionTier={l.promotion_tier ?? null}
          />
        ))}
      </ul>
    )}
  </MarketplaceShell>
</Layout>
