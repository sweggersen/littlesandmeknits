---
import Layout from '../../layouts/Layout.astro';
import MarketplaceShell from '../../components/MarketplaceShell.astro';
import ListingCard from '../../components/ListingCard.astro';
import CommissionCard from '../../components/CommissionCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import FavScript from '../../components/FavScript.astro';
import ImpressionTracker from '../../components/ImpressionTracker.astro';
import { createServerSupabase } from '../../lib/supabase';
import { projectPhotoUrl } from '../../lib/storage';
import { KIND_LABEL, CATEGORY_LABEL } from '../../lib/labels';
import { rankPromoted, type UserPreferences } from '../../lib/promotion-ranker';

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const user = Astro.locals.user;

const SLOTS = 8;
const LISTING_COLS = 'id, title, kind, price_nok, size_label, size_age_months_min, size_age_months_max, hero_photo_path, published_at, promoted_until, promoted_at, promotion_tier, category, favorite_count, seller_id, store_id';

// 1) Active paid-promotion slots — we always surface a couple of these.
//    Listings whose promoted_until is still in the future, regardless of
//    other signals. Boosted, not auto-sorted.
const nowIso = new Date().toISOString();
const promotedRes = await supabase
  .from('listings')
  .select(LISTING_COLS)
  .eq('status', 'active')
  .gt('promoted_until', nowIso)
  .order('promoted_until', { ascending: false })
  .limit(20);
const promotedAll = promotedRes.data ?? [];

// Pull pacing data (daily_budget, daily_impressions_served) for the
// promoted listings so the ranker can de-prioritise exhausted budgets.
if (promotedAll.length) {
  const { data: pacingRows } = await supabase
    .from('listing_promotions')
    .select('listing_id, daily_budget, daily_impressions_served')
    .in('listing_id', promotedAll.map((p) => p.id))
    .eq('status', 'active');
  const pacingById = new Map((pacingRows ?? []).map((r: any) => [r.listing_id, r]));
  for (const p of promotedAll) {
    const pacing = pacingById.get(p.id);
    if (pacing) {
      p.daily_budget = pacing.daily_budget;
      p.daily_impressions_served = pacing.daily_impressions_served;
    }
  }
}

// Personalised ranking of the promoted pool. Reads from the user_preferences
// materialized view (refreshed by /api/cron/run). Anonymous viewers fall
// through with prefs=null → ranker uses the conditionBaseline only.
let userPrefs: UserPreferences = null;
if (user) {
  const { data: prefRow } = await supabase
    .from('user_preferences')
    .select('favorited_categories, clicked_categories, clicked_sizes, followed_sellers, price_band, age_band')
    .eq('user_id', user.id)
    .maybeSingle();
  if (prefRow) userPrefs = prefRow as UserPreferences;
}
const promoted = rankPromoted(promotedAll, userPrefs).slice(0, 3);

// 2) For-you / popular pool.
let pool: any[] = [];
let favIds: string[] = [];
let preferredCategories: string[] = [];

if (user) {
  // Pull the user's recent favorites to derive preferred categories.
  const { data: favs } = await supabase
    .from('favorites')
    .select('item_id')
    .eq('user_id', user.id)
    .eq('item_type', 'listing')
    .order('created_at', { ascending: false })
    .limit(40);
  favIds = (favs ?? []).map((f: any) => f.item_id);

  if (favIds.length) {
    const { data: favListings } = await supabase
      .from('listings')
      .select('category')
      .in('id', favIds);
    const counts = new Map<string, number>();
    for (const l of favListings ?? []) {
      if (l.category) counts.set(l.category, (counts.get(l.category) ?? 0) + 1);
    }
    preferredCategories = [...counts.entries()]
      .sort((a, b) => b[1] - a[1])
      .slice(0, 3)
      .map(([c]) => c);
  }
}

// Pool query: if we have preferred categories, prefer them; otherwise fall
// back to global popularity (favorite_count) + recency.
const promotedIds = promoted.map(p => p.id);

// Favorited listings stay in the recommendations — favoriting is a
// signal of interest, not a "remove from feed" gesture. The card just
// shows them with the heart filled.
const NIL = '00000000-0000-0000-0000-000000000000';

if (preferredCategories.length) {
  const { data } = await supabase
    .from('listings')
    .select(LISTING_COLS)
    .eq('status', 'active')
    .in('category', preferredCategories)
    .not('id', 'in', `(${[...promotedIds, NIL].map(v => `"${v}"`).join(',')})`)
    .order('favorite_count', { ascending: false })
    .order('published_at', { ascending: false })
    .limit(SLOTS * 2);
  pool = data ?? [];
}

if (pool.length < SLOTS) {
  // Top up with popular-then-recent listings.
  const exclude = [...promotedIds, ...pool.map(p => p.id), NIL];
  const { data } = await supabase
    .from('listings')
    .select(LISTING_COLS)
    .eq('status', 'active')
    .not('id', 'in', `(${exclude.map(v => `"${v}"`).join(',')})`)
    .order('favorite_count', { ascending: false })
    .order('published_at', { ascending: false })
    .limit(SLOTS * 2);
  pool = [...pool, ...(data ?? [])];
}

// Interleave: every 4th slot is a promoted item so paid placements get
// visibility without monopolising the feed.
const featured: any[] = [];
const promotedQueue = [...promoted];
const poolQueue = [...pool];
for (let i = 0; i < SLOTS; i++) {
  if (i > 0 && i % 4 === 0 && promotedQueue.length) {
    featured.push(promotedQueue.shift()!);
  } else if (poolQueue.length) {
    featured.push(poolQueue.shift()!);
  } else if (promotedQueue.length) {
    featured.push(promotedQueue.shift()!);
  }
}

// 3) Commission requests (unchanged).
const { data: latestRequests } = await supabase
  .from('commission_requests')
  .select('id, title, category, size_label, budget_nok_min, budget_nok_max, offer_count, needed_by')
  .eq('status', 'open')
  .order('created_at', { ascending: false })
  .limit(4);

// 4) "Nye fra sellere du følger" — only when the viewer follows ≥1 seller.
let followedListings: any[] = [];
if (userPrefs?.followed_sellers && userPrefs.followed_sellers.length > 0) {
  const { data } = await supabase
    .from('listings')
    .select(LISTING_COLS)
    .eq('status', 'active')
    .in('seller_id', userPrefs.followed_sellers)
    .order('published_at', { ascending: false })
    .limit(8);
  followedListings = data ?? [];
}

const featuredTitle = user ? 'Anbefalinger for deg' : 'Populære annonser';

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'OnlineStore',
  name: 'Strikketorget',
  url: 'https://littlesandmeknits.com/market',
  logo: 'https://littlesandmeknits.com/strikketorget-icon.svg',
  description: 'Norges marked for håndstrikkede plagg, brukt og nytt. Trygg betaling, fellesskap av strikkere.',
  parentOrganization: {
    '@type': 'Organization',
    name: 'Weggersen Design',
    url: 'https://littlesandmeknits.com',
  },
};
---

<Layout title="Strikketorget" description="Norges marked for håndstrikkede plagg. Kjøp og selg brukt eller nytt, bestill plagg fra strikkere, betal trygt med Trygg betaling." lang="nb">
  <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} is:inline />
  <MarketplaceShell current="home">
      <!-- Hero (desktop): two-column with larger icon + stacked title/tagline/search.
           Mobile keeps the search-first compact layout below. -->
      <div class="hidden sm:flex items-center gap-6 mb-6">
        <img src="/strikketorget-icon.svg" alt="" width="160" height="160" class="shrink-0 w-32 h-32 lg:w-40 lg:h-40" />
        <div class="flex-1 min-w-0">
          <h1 class="font-serif text-3xl lg:text-4xl leading-tight">Strikketorget</h1>
          <p class="text-sm text-charcoal/55 mt-1 mb-3">Kjøp brukt og nytt strikket fra fellesskapet, eller bestill at noen strikker for deg.</p>
          <form action="/market/used" method="get" class="relative w-full max-w-xl">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-charcoal/30 pointer-events-none" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input type="text" name="q" placeholder="Søk etter plagg, garn, størrelse..."
              class="w-full bg-white rounded-full pl-11 pr-4 py-3 text-sm border border-sage-500/15 focus:border-sage-500/30 focus:outline-none shadow-sm" />
          </form>
        </div>
      </div>

      <!-- Mobile-only search bar (the desktop one lives inside the hero) -->
      <div class="sm:hidden mb-3 flex justify-center">
        <form action="/market/used" method="get" class="relative w-full max-w-md">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-charcoal/30 pointer-events-none" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" name="q" placeholder="Søk etter plagg, garn, størrelse..."
            class="w-full bg-white rounded-full pl-10 pr-4 py-2 text-sm border border-sage-500/15 focus:border-sage-500/30 focus:outline-none shadow-sm" />
        </form>
      </div>

      <!-- Sentinel: once it scrolls out of view, the search has been passed.
           Until then we don't engage the scroll-direction hide logic. -->
      <div data-sticky-sentinel aria-hidden="true" class="h-0 w-0"></div>

      <script>
        function initStickySentinel() {
          const sentinel = document.querySelector<HTMLElement>('[data-sticky-sentinel]');
          if (!sentinel) return;
          const obs = new IntersectionObserver(
            ([entry]) => {
              if (entry.isIntersecting) {
                document.body.removeAttribute('data-past-anchor');
              } else if (entry.boundingClientRect.top < 0) {
                document.body.setAttribute('data-past-anchor', 'true');
              }
            },
            { rootMargin: '-120px 0px 0px 0px', threshold: 0 },
          );
          obs.observe(sentinel);
        }
        document.addEventListener('astro:page-load', initStickySentinel);
      </script>

      <!-- Categories: compact horizontal cards on mobile, rich cards with art on sm+ -->
      <div class="grid grid-cols-3 sm:grid-cols-3 gap-2 sm:gap-4 mb-6 sm:mb-8">
        <a href="/market/used" class="group relative block overflow-hidden rounded-2xl sm:rounded-3xl p-3 sm:p-4 border border-sage-500/10 hover:border-terracotta-500/30 transition-all hover:shadow-md bg-white sm:bg-gradient-to-br sm:from-oatmeal/60 sm:to-white">
          <svg class="hidden sm:block absolute -right-3 -bottom-3 w-28 h-28 text-terracotta-500/[0.07] transition-transform group-hover:scale-110" viewBox="0 0 80 80" fill="currentColor">
            <path d="M40 8c-4 0-8 2-10 5l-2 4c-2 3-6 5-10 5h-2c-3 0-6 3-6 6v30c0 4 3 7 7 7h46c4 0 7-3 7-7V28c0-3-3-6-6-6h-2c-4 0-8-2-10-5l-2-4c-2-3-6-5-10-5zm0 6a3 3 0 0 1 2 1l3 5c2 3 5 5 9 6v1H26c4-1 7-3 9-6l3-5a3 3 0 0 1 2-1zM27 32h26c1 0 2 1 2 2v16c0 4-3 7-7 7H32c-4 0-7-3-7-7V34c0-1 1-2 2-2zm2 4v14c0 2 1 3 3 3h16c2 0 3-1 3-3V36H29z"/>
          </svg>
          <p class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500 mb-0.5 sm:mb-2">Brukt</p>
          <h2 class="font-serif text-base sm:text-xl mb-0 sm:mb-1 leading-tight">Pre-loved</h2>
          <p class="hidden sm:block text-sm text-charcoal/55">Plagg ungene har vokst fra. Som regel under 500&nbsp;kr.</p>
        </a>
        <a href="/market/new" class="group relative block overflow-hidden rounded-2xl sm:rounded-3xl p-3 sm:p-4 border border-sage-500/10 hover:border-sage-500/30 transition-all hover:shadow-md bg-white sm:bg-gradient-to-br sm:from-sage-100/40 sm:to-white">
          <svg class="hidden sm:block absolute -right-2 -bottom-2 w-28 h-28 text-sage-500/[0.08] transition-transform group-hover:scale-110" viewBox="0 0 80 80" fill="currentColor">
            <circle cx="40" cy="42" r="22"/>
            <path d="M40 20c-12 0-22 10-22 22s10 22 22 22 22-10 22-22-10-22-22-22zm0 6c9 0 16 7 16 16s-7 16-16 16-16-7-16-16 7-16 16-16z"/>
            <path d="M36 28c-3 2-6 6-6 14 0 6 4 12 10 12s10-6 10-12c0-8-3-12-6-14" fill="none" stroke="currentColor" stroke-width="2.5"/>
            <path d="M40 20V8M44 10l-4-4-4 4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M50 24l8-6M54 14l6 6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <p class="text-[10px] font-bold uppercase tracking-widest text-sage-900 mb-0.5 sm:mb-2">Nytt</p>
          <h2 class="font-serif text-base sm:text-xl mb-0 sm:mb-1 leading-tight">Ferdigstrikket</h2>
          <p class="hidden sm:block text-sm text-charcoal/55">Strikkere selger plagg de har strikket på spec.</p>
        </a>
        <a href="/market/commissions" class="group relative block overflow-hidden rounded-2xl sm:rounded-3xl p-3 sm:p-4 border border-sage-500/10 hover:border-terracotta-500/30 transition-all hover:shadow-md bg-white sm:bg-gradient-to-br sm:from-terracotta-500/[0.06] sm:to-white">
          <svg class="hidden sm:block absolute -right-2 -bottom-4 w-28 h-28 text-terracotta-500/[0.07] transition-transform group-hover:scale-110" viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 58l10-40c1-3 4-5 7-4l6 2c3 1 5 4 4 7l-8 32"/>
            <path d="M46 58l-10-40c-1-3 1-6 4-7l6-2c3-1 6 1 7 4l8 32"/>
            <path d="M24 40c4 6 12 10 16 10s12-4 16-10"/>
            <circle cx="40" cy="56" r="6" fill="currentColor" opacity="0.3"/>
          </svg>
          <p class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500 mb-0.5 sm:mb-2">Strikk for meg</p>
          <h2 class="font-serif text-base sm:text-xl mb-0 sm:mb-1 leading-tight">Oppdrag</h2>
          <p class="hidden sm:block text-sm text-charcoal/55">Bestill et plagg fra en strikker i fellesskapet.</p>
        </a>
      </div>

      {followedListings.length > 0 && (
        <>
          <h2 class="font-serif text-xl sm:text-2xl mb-3 sm:mb-4">Nye fra sellere du følger</h2>
          <ul class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 mb-10">
            {followedListings.map((l) => (
              <ListingCard
                id={l.id}
                title={l.title}
                price={l.price_nok}
                imgUrl={projectPhotoUrl(l.hero_photo_path)}
                meta={`${KIND_LABEL[l.kind] ?? l.kind} · str. ${l.size_label}`}
                showFav={!!user}
                isFav={favIds.includes(l.id)}
                promoted={!!(l.promoted_until && new Date(l.promoted_until) > new Date())}
                promotionTier={l.promotion_tier ?? null}
              />
            ))}
          </ul>
        </>
      )}

      <h2 class="font-serif text-xl sm:text-2xl mb-3 sm:mb-4">{featuredTitle}</h2>
      {featured.length === 0 ? (
        <EmptyState message="Ingen annonser ennå. Kom tilbake snart." />
      ) : (
        <ul class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
          {featured.map((l) => (
            <ListingCard
              id={l.id}
              title={l.title}
              price={l.price_nok}
              imgUrl={projectPhotoUrl(l.hero_photo_path)}
              meta={`${KIND_LABEL[l.kind] ?? l.kind} · str. ${l.size_label}`}
              showFav={!!user}
              isFav={favIds.includes(l.id)}
              promoted={!!(l.promoted_until && new Date(l.promoted_until) > new Date())}
              promotionTier={l.promotion_tier ?? null}
            />
          ))}
        </ul>
      )}
      {(latestRequests ?? []).length > 0 && (
        <>
          <h2 class="font-serif text-2xl mb-4 mt-12">Nyeste forespørsler</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
            {(latestRequests ?? []).map((r) => (
              <CommissionCard
                id={r.id}
                title={r.title}
                category={r.category}
                sizeLabel={r.size_label}
                budgetMin={r.budget_nok_min}
                budgetMax={r.budget_nok_max}
                offerCount={r.offer_count}
              />
            ))}
          </ul>
          <a href="/market/commissions" class="inline-block mt-4 text-sm font-medium text-charcoal/55 hover:text-terracotta-500 transition-colors">
            Se alle forespørsler →
          </a>
        </>
      )}
  </MarketplaceShell>
  <FavScript />
  <ImpressionTracker source="home" />
</Layout>
