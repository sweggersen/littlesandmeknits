---
import Layout from '../../layouts/Layout.astro';
import { env } from 'cloudflare:workers';

if (import.meta.env.PROD) return Astro.redirect('/marked');

const host = Astro.url.hostname;
if (host !== 'localhost' && host !== '127.0.0.1' && !host.endsWith('.workers.dev')) {
  return Astro.redirect('/marked');
}

const encoder = new TextEncoder();
const keyData = encoder.encode(env.SUPABASE_SERVICE_ROLE_KEY ?? '');
const key = await crypto.subtle.importKey('raw', keyData, { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']);
const today = new Date().toISOString().slice(0, 10);
const sig = await crypto.subtle.sign('HMAC', key, encoder.encode(`admin-tower-${today}`));
const adminToken = btoa(String.fromCharCode(...new Uint8Array(sig))).slice(0, 43);
---

<Layout title="Test Control Tower" lang="nb">
  <div id="tower" class="min-h-[calc(100vh-64px)] bg-charcoal/[0.03]" data-admin-token={adminToken}>
    <!-- Desktop only -->
    <div class="hidden lg:block">
      <!-- Sticky control bar -->
      <div class="bg-white border-b border-sage-500/10 sticky top-[64px] z-20">
        <div class="max-w-[1400px] mx-auto px-6 py-3 flex items-center justify-between gap-4">
          <div class="flex items-center gap-6">
            <div>
              <p class="text-[9px] font-bold uppercase tracking-widest text-terracotta-500 mb-0.5">Dev Tool</p>
              <h1 class="font-mono text-base font-bold leading-tight">Test Control Tower</h1>
            </div>
            <div id="scenario-tabs" class="flex gap-1"></div>
          </div>
          <div class="flex items-center gap-2">
            <button id="btn-cleanup" class="px-3 py-1.5 text-xs font-medium text-red-600/70 hover:text-red-700 border border-red-300/30 rounded-lg hover:bg-red-50 transition-colors">Slett testdata</button>
            <button id="btn-reset" class="px-3 py-1.5 text-xs font-medium text-charcoal/60 hover:text-charcoal border border-sage-500/15 rounded-lg hover:bg-sage-100/50 transition-colors">Reset</button>
            <button id="btn-step" class="px-3 py-1.5 text-xs font-medium text-charcoal bg-sage-100 hover:bg-sage-200 rounded-lg transition-colors">Step &#9654;</button>
            <button id="btn-run" class="px-3 py-1.5 text-xs font-medium text-linen bg-charcoal hover:bg-terracotta-500 rounded-lg transition-colors">Run All &#9654;&#9654;</button>
          </div>
        </div>
      </div>

      <!-- Main content -->
      <div class="max-w-[1400px] mx-auto px-6 py-6 flex gap-6 items-start">
        <div id="steps-panel" class="flex-1 min-w-0"></div>
        <div id="state-panel" class="w-[340px] shrink-0 sticky top-[130px]"></div>
      </div>
    </div>

    <!-- Mobile fallback -->
    <div class="lg:hidden flex items-center justify-center min-h-[60vh] p-8">
      <p class="text-charcoal/55 text-center">Test Control Tower krever en bred skjerm (1024px+).</p>
    </div>
  </div>

  <style>
    .step-connector { position: relative; }
    .step-connector::before {
      content: '';
      position: absolute;
      left: 19px;
      top: 40px;
      bottom: 0;
      width: 2px;
      background: #e5e7eb;
    }
    .step-connector.done::before { background: #86B681; }

    .step-dot {
      width: 14px; height: 14px;
      border-radius: 50%;
      border: 2.5px solid #d1d5db;
      background: white;
      position: absolute;
      left: 13px;
      top: 16px;
      z-index: 1;
    }
    .step-dot.done { border-color: #86B681; background: #86B681; }
    .step-dot.ready { border-color: #374151; }
    .step-dot.running { border-color: #C75B39; animation: dot-pulse 1.2s infinite; }
    .step-dot.failed { border-color: #ef4444; background: #ef4444; }

    @keyframes dot-pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(199, 91, 57, 0.4); }
      50% { box-shadow: 0 0 0 6px rgba(199, 91, 57, 0); }
    }

    .bp-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: transparent;
      border: 1.5px solid #d1d5db;
      cursor: pointer;
      transition: all 0.15s;
      position: absolute;
      left: 0;
      top: 19px;
    }
    .bp-dot:hover { border-color: #ef4444; background: #fecaca; }
    .bp-dot.active { border-color: #ef4444; background: #ef4444; }

    .role-buyer { background: #DBEAFE; color: #1E40AF; }
    .role-knitter { background: #FDE8E0; color: #9A3412; }
    .role-seller { background: #DCFCE7; color: #166534; }
    .role-moderator { background: #FEF3C7; color: #92400E; }
    .role-admin { background: #E0E7FF; color: #3730A3; }

    .state-badge {
      display: inline-block;
      padding: 1px 6px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .state-badge.open { background: #DCFCE7; color: #166534; }
    .state-badge.awaiting_payment { background: #FEF3C7; color: #92400E; }
    .state-badge.awaiting_yarn { background: #FEF3C7; color: #92400E; }
    .state-badge.awarded { background: #DBEAFE; color: #1E40AF; }
    .state-badge.completed { background: #E0E7FF; color: #3730A3; }
    .state-badge.delivered { background: #D1FAE5; color: #065F46; }
    .state-badge.pending { background: #F3F4F6; color: #4B5563; }
    .state-badge.accepted { background: #DCFCE7; color: #166534; }
    .state-badge.declined { background: #FEE2E2; color: #991B1B; }
    .state-badge.active { background: #DBEAFE; color: #1E40AF; }
    .state-badge.planning { background: #F3F4F6; color: #4B5563; }
    .state-badge.draft { background: #F3F4F6; color: #4B5563; }
    .state-badge.pending_review { background: #FEF3C7; color: #92400E; }
    .state-badge.rejected { background: #FEE2E2; color: #991B1B; }
    .state-badge.approved { background: #D1FAE5; color: #065F46; }
    .state-badge.escalated { background: #E0E7FF; color: #3730A3; }
    .state-badge.assigned { background: #DBEAFE; color: #1E40AF; }
    .state-badge.resolved { background: #D1FAE5; color: #065F46; }
    .state-badge.dismissed { background: #F3F4F6; color: #4B5563; }
    .state-badge.paid { background: #D1FAE5; color: #065F46; }

    #state-panel details summary { cursor: pointer; user-select: none; }
    #state-panel details summary::-webkit-details-marker { display: none; }
  </style>

