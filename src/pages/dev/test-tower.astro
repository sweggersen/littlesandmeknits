      eline:  { email: 'eline@test.strikketorget.no',  name: 'Eline',  role: 'knitter',   roleLabel: 'Strikker' },
      maja:   { email: 'maja@test.strikketorget.no',    name: 'Maja',   role: 'knitter',   roleLabel: 'Strikker' },
      ingrid: { email: 'ingrid@test.strikketorget.no',  name: 'Ingrid', role: 'knitter',   roleLabel: 'Strikker' },
      kari:   { email: 'kari@test.strikketorget.no',   name: 'Kari',   role: 'moderator', roleLabel: 'Moderator' },
