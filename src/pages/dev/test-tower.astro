    // ═══════════════════════════════════════════════
    // STATE
    // ═══════════════════════════════════════════════

    let activeScenario = 'commission';
    let results = {};      // stepId → { ok, data, error }
    let breakpoints = {};  // stepId → true
    let running = false;
    let stateData = null;

    function resolve(stepId, field) {
      const r = results[stepId];
      if (!r?.data) return undefined;
      return r.data[field];
    }

    function resolveParams(params) {
      const out = {};
      for (const [k, v] of Object.entries(params)) {
        if (typeof v === 'string' && v.startsWith('$')) {
          const [sid, f] = v.slice(1).split('.');
          out[k] = resolve(sid, f);
        } else {
          out[k] = v;
        }
      }
      return out;
    }

    function getScenario() { return SCENARIOS[activeScenario]; }

    function isStepDone(stepId) {
      const s = getScenario();
      const step = s.steps.find(st => st.id === stepId);
      const r = results[stepId];
      if (!r) return false;
      if (step?.expectFail) return r.ok === false;
      return r.ok === true;
    }

    function isPrevDone(idx) {
      if (idx === 0) return true;
      return isStepDone(getScenario().steps[idx - 1].id);
    }

    function nextStepIndex() {
      const steps = getScenario().steps;
      for (let i = 0; i < steps.length; i++) {
        if (!isStepDone(steps[i].id)) return i;
      }
      return -1;
    }

    // ═══════════════════════════════════════════════
    // API
    // ═══════════════════════════════════════════════

    const ADMIN_TOKEN = document.getElementById('tower').dataset.adminToken;

    async function api(body) {
      const res = await fetch('/api/dev/test-exec', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Admin-Token': ADMIN_TOKEN },
        body: JSON.stringify(body),
      });
      return res.json();
    }

    async function execStep(step) {
      const persona = P[step.actor];
      const editedParams = getEditedParams(step.id, step.params);
      const params = resolveParams(editedParams);
      return api({ action: step.action, actor: persona.email, params });
    }

    async function fetchState() {
      const s = getScenario();
      const params = { user_emails: s.personas.map(k => P[k].email) };

      const reqActions = ['create-request', 'create-request-moderated'];
      const listActions = ['create-listing', 'create-listing-moderated'];

      if (s.track === 'request') {
        for (const step of s.steps) {
          const r = results[step.id];
          if (r?.ok && r.data?.id && reqActions.includes(step.action)) {
            params.request_id = r.data.id;
          }
        }
      }
      if (s.track === 'listing') {
        for (const step of s.steps) {
          const r = results[step.id];
          if (r?.ok && r.data?.id && listActions.includes(step.action)) {
            params.listing_id = r.data.id;
          }
        }
      }

      for (const step of s.steps) {
        const r = results[step.id];
        if (r?.ok && r.data?.queue_item_id) {
          params.queue_item_id = r.data.queue_item_id;
        }
      }

      const modScenarios = ['mod-approve', 'mod-reject', 'shadow-review', 'shadow-override', 'reports', 'reviews-trust', 'mod-compensation', 'self-review-block'];
      if (modScenarios.includes(activeScenario)) {
        params.include_mod_stats = true;
        params.include_profiles = true;
      }
      if (activeScenario === 'reports') params.include_reports = true;
      if (activeScenario === 'reviews-trust') params.include_tx_reviews = true;
      if (activeScenario === 'mod-compensation') params.include_payouts = true;

      const res = await api({ action: 'get-state', params });
      if (res.ok) stateData = res.data;
      return res;
    }

    async function cleanup() {
      const params = { clean_notifications: true };
      const reqId = resolve('create-request', 'id');
      const listId = resolve('create-listing', 'id');
      if (reqId) params.request_ids = [reqId];
      if (listId) params.listing_ids = [listId];
      return api({ action: 'cleanup', params });
    }

    // ═══════════════════════════════════════════════
    // EDITABLE PARAMS
    // ═══════════════════════════════════════════════

    let editedValues = {};

    function getEditedParams(stepId, defaults) {
      const edits = editedValues[stepId] || {};
      return { ...defaults, ...edits };
    }

    function setEditedParam(stepId, key, value) {
      if (!editedValues[stepId]) editedValues[stepId] = {};
      editedValues[stepId][key] = isNaN(Number(value)) ? value : Number(value);
    }

    // ═══════════════════════════════════════════════
    // RENDERING
    // ═══════════════════════════════════════════════

    function renderTabs() {
      const el = document.getElementById('scenario-tabs');
      el.innerHTML = Object.entries(SCENARIOS).map(([key, s]) =>
        `<button data-scenario="${key}" class="px-3 py-1.5 text-xs font-medium rounded-lg transition-colors ${
          key === activeScenario
            ? 'bg-charcoal text-linen'
            : 'text-charcoal/60 hover:bg-sage-100/50'
        }">${s.title}</button>`
      ).join('');
    }

    function renderSteps() {
      const s = getScenario();
      const el = document.getElementById('steps-panel');

      el.innerHTML = `
        <p class="text-sm text-charcoal/55 mb-6">${s.desc}</p>
        ${s.steps.map((step, i) => renderStep(step, i, s.steps.length)).join('')}
      `;
    }

    function renderStep(step, idx, total) {
      const r = results[step.id];
      const done = isStepDone(step.id);
      const failed = r && !done;
      const ready = !done && !failed && isPrevDone(idx);
      const isRunning = running === step.id;
      const persona = P[step.actor];
      const hasBP = breakpoints[step.id];
      const isLast = idx === total - 1;

      const dotClass = done ? 'done' : failed ? 'failed' : isRunning ? 'running' : ready ? 'ready' : '';
      const lineClass = done ? 'done' : '';

      let editableHtml = '';
      if ((ready || done) && step.editable?.length) {
        const params = getEditedParams(step.id, step.params);
        editableHtml = `<div class="flex flex-wrap gap-2 mt-3 ml-8">
          ${step.editable.map(key => {
            const val = params[key] ?? '';
            const label = key.replace(/_/g, ' ');
            return `<label class="text-[10px] text-charcoal/50">
              <span class="uppercase tracking-wider">${label}</span>
              <input type="text" value="${val}" data-edit-step="${step.id}" data-edit-key="${key}"
                class="block mt-0.5 w-28 bg-linen border border-sage-500/15 rounded px-2 py-1 text-xs font-mono focus:outline-none focus:border-charcoal/30"
                ${done ? 'disabled' : ''} />
            </label>`;
          }).join('')}
        </div>`;
      }

      let resultHtml = '';
      if (done && step.expectFail) {
        resultHtml = `<p class="mt-2 ml-8 text-xs text-green-700">&#10003; Feilet som forventet: ${escHtml(r.error || '')}</p>`;
      } else if (done && r.data) {
        const preview = JSON.stringify(r.data, null, 2);
        resultHtml = `<details class="mt-3 ml-8">
          <summary class="text-[10px] text-green-700 font-medium cursor-pointer select-none">&#10003; Utført — vis resultat</summary>
          <pre class="mt-1 text-[10px] text-charcoal/60 bg-sage-100/30 rounded p-2 overflow-x-auto max-h-32 font-mono">${escHtml(preview)}</pre>
        </details>`;
      }
      if (failed) {
        resultHtml = `<p class="mt-2 ml-8 text-xs text-red-600">&#10007; ${escHtml(r.error || 'Ukjent feil')}</p>`;
      }

      let assertHtml = '';
      const checks = assertions[step.id];
      if (checks) {
        const pass = checks.filter(c => c.pass).length;
        const fail = checks.filter(c => !c.pass).length;
        const allPass = fail === 0;
        assertHtml = `<details class="mt-2 ml-8">
          <summary class="text-[10px] font-bold ${allPass ? 'text-green-700' : 'text-red-600'} cursor-pointer select-none">
            ${allPass ? '&#10003;' : '&#10007;'} ${pass}/${checks.length} sjekker bestått
          </summary>
          <div class="mt-1 space-y-0.5">
            ${checks.map(c => c.pass
              ? `<p class="text-[10px] text-green-700 font-mono">&#10003; ${escHtml(c.label)} = ${escHtml(c.actual)}</p>`
              : `<p class="text-[10px] text-red-600 font-mono">&#10007; ${escHtml(c.label)}: fikk <b>${escHtml(c.actual)}</b>, forventet <b>${escHtml(c.expected)}</b></p>`
            ).join('')}
          </div>
        </details>`;
      }

      const viewUrl = step.viewUrl && done ? step.viewUrl(r.data) : null;
      const canRunTo = !done && idx > 0;
      let actionsHtml = '';
      if (ready && !isRunning) {
        actionsHtml = `<div class="flex items-center gap-2 mt-3 ml-8">
          <button data-exec="${step.id}" class="px-3 py-1.5 text-[11px] font-medium text-linen bg-charcoal hover:bg-terracotta-500 rounded-lg transition-colors">&#9654; Kjør</button>
          ${step.branch ? `<button data-exec="${step.id}" data-branch="true" class="px-3 py-1.5 text-[11px] font-medium text-charcoal/70 border border-sage-500/15 hover:bg-sage-100/50 rounded-lg transition-colors">${step.branch.label}</button>` : ''}
          ${canRunTo ? `<button data-run-to="${step.id}" class="px-3 py-1.5 text-[11px] font-medium text-charcoal/50 hover:text-charcoal border border-sage-500/15 hover:bg-sage-100/50 rounded-lg transition-colors">&#9654;&#9654; Kjør hit</button>` : ''}
        </div>`;
      } else if (!done && !isRunning && !ready) {
        actionsHtml = `<div class="flex items-center gap-2 mt-3 ml-8">
          ${canRunTo ? `<button data-run-to="${step.id}" class="px-3 py-1.5 text-[11px] font-medium text-charcoal/50 hover:text-charcoal border border-sage-500/15 hover:bg-sage-100/50 rounded-lg transition-colors">&#9654;&#9654; Kjør hit</button>` : ''}
        </div>`;
      }
      if (isRunning) {
        actionsHtml = `<p class="mt-3 ml-8 text-xs text-terracotta-500 animate-pulse">Kjører...</p>`;
      }

      let viewHtml = '';
      if (viewUrl) {
        const viewPersona = step.viewAs ? P[step.viewAs] : persona;
        const formId = `view-${step.id}`;
        viewHtml = `<form id="${formId}" method="post" action="/api/dev/impersonate" target="_blank" class="inline mt-2 ml-8">
          <input type="hidden" name="email" value="${viewPersona.email}">
          <input type="hidden" name="next" value="${viewUrl}">
          <button type="submit" class="text-[10px] text-charcoal/40 hover:text-terracotta-500 transition-colors cursor-pointer">Se som ${viewPersona.name} &rarr; ${viewUrl}</button>
        </form>`;
      }

      return `
        <div class="relative pl-11 pb-1 ${!isLast ? 'step-connector ' + lineClass : ''}" data-step-row="${step.id}">
          <div class="bp-dot ${hasBP ? 'active' : ''}" data-bp="${step.id}" title="Breakpoint"></div>
          <div class="step-dot ${dotClass}"></div>

          <div class="bg-white rounded-xl border ${ready ? 'border-charcoal/15 shadow-sm' : done ? 'border-sage-500/10' : 'border-sage-500/10 opacity-60'} p-4 mb-4">
            <div class="flex items-center gap-2.5">
              <span class="font-mono text-[11px] text-charcoal/30 w-5 text-right shrink-0">${idx + 1}</span>
              <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-full role-${persona.role}">${persona.name} &middot; ${persona.roleLabel}</span>
              <span class="text-sm font-medium flex-1">${step.label}</span>
            </div>
            <p class="text-xs text-charcoal/50 mt-1.5 ml-8">${step.desc}</p>
            ${editableHtml}
            ${actionsHtml}
            ${resultHtml}
            ${assertHtml}
            ${viewHtml}
          </div>
        </div>`;
    }

