                ${name} <span class="text-charcoal/30 font-mono">${notifs.length}</span>
              </summary>
              <div class="mt-1 space-y-1 pl-2 border-l-2 border-sage-500/10">
                ${notifs.map(n => `<p class="text-[10px] text-charcoal/55">${escHtml(n.title)}</p>`).join('')}
              </div>
            </details>`;
          }).join('')}
        </div>`;
      }

      html += `</div>`;
      el.innerHTML = html;
    }

    function escHtml(s) {
      if (!s) return '';
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ═══════════════════════════════════════════════
    // ACTIONS
    // ═══════════════════════════════════════════════

    let assertions = {};

    function runAssertions(step) {
      if (!step.expect || !stateData) return null;
      const checks = step.expect(stateData);
      return checks.map(([label, actual, expected]) => ({
        label,
        pass: actual === expected,
        actual: String(actual ?? 'undefined'),
        expected: String(expected),
      }));
    }

    async function doExecuteStep(stepId, useBranch) {
      const s = getScenario();
      const step = s.steps.find(st => st.id === stepId);
      if (!step) return;

      let actualStep = step;
      if (useBranch && step.branch?.swapRef) {
        actualStep = { ...step, params: { ...step.params, offer_id: `$${step.branch.swapRef}.id` } };
      }

      running = stepId;
      renderSteps();

      const res = await execStep(actualStep);
      results[stepId] = res;
      running = false;

      await fetchState();
      if (isStepDone(stepId) && step.expect) {
        assertions[stepId] = runAssertions(step);
      }
      renderSteps();
      renderState();
    }

    async function doStepNext() {
      const idx = nextStepIndex();
      if (idx < 0) return;
      await doExecuteStep(getScenario().steps[idx].id);
    }

    async function doRunAll() {
      const steps = getScenario().steps;
      for (let i = 0; i < steps.length; i++) {
        if (isStepDone(steps[i].id)) continue;
        if (breakpoints[steps[i].id] && i > 0) break;
        await doExecuteStep(steps[i].id);
        if (!isStepDone(steps[i].id)) break;
      }
    }

    async function doRunTo(targetId) {
      const steps = getScenario().steps;
      const targetIdx = steps.findIndex(s => s.id === targetId);
      if (targetIdx < 0) return;
      for (let i = 0; i <= targetIdx; i++) {
        if (isStepDone(steps[i].id)) continue;
        await doExecuteStep(steps[i].id);
        if (!isStepDone(steps[i].id)) break;
      }
    }

    async function doReset() {
      if (!confirm('Reset scenario? Sletter testdata fra databasen.')) return;
      await cleanup();
      results = {};
      editedValues = {};
      assertions = {};
      stateData = null;
      renderSteps();
      renderState();
    }

    function switchScenario(key) {
      activeScenario = key;
      results = {};
      editedValues = {};
      assertions = {};
      stateData = null;
      renderTabs();
      renderSteps();
      renderState();
    }

    // ═══════════════════════════════════════════════
    // EVENTS
    // ═══════════════════════════════════════════════

    document.addEventListener('click', (e) => {
      const target = e.target.closest('[data-scenario]');
      if (target) {
        switchScenario(target.dataset.scenario);
        return;
      }

      const runTo = e.target.closest('[data-run-to]');
      if (runTo && !running) {
        doRunTo(runTo.dataset.runTo);
        return;
      }

      const exec = e.target.closest('[data-exec]');
      if (exec && !running) {
        doExecuteStep(exec.dataset.exec, exec.dataset.branch === 'true');
        return;
      }

      const bp = e.target.closest('[data-bp]');
      if (bp) {
        const id = bp.dataset.bp;
        breakpoints[id] = !breakpoints[id];
        bp.classList.toggle('active', breakpoints[id]);
        return;
      }
    });

    document.addEventListener('input', (e) => {
      const input = e.target.closest('[data-edit-step]');
      if (input) {
        setEditedParam(input.dataset.editStep, input.dataset.editKey, input.value);
      }
    });

    document.getElementById('btn-reset')?.addEventListener('click', doReset);
    document.getElementById('btn-step')?.addEventListener('click', doStepNext);
    document.getElementById('btn-run')?.addEventListener('click', doRunAll);
    document.getElementById('btn-cleanup')?.addEventListener('click', async () => {
      if (!confirm('Slett ALL testdata (opprettet av @test.strikketorget.no-kontoer)?\n\nDette sletter forespørsler, tilbud, prosjekter, annonser, samtaler, meldinger og varsler.')) return;
      const btn = document.getElementById('btn-cleanup');
      btn.textContent = 'Sletter…';
      btn.disabled = true;
      const r = await api({ action: 'cleanup', actor: P.liv.email, params: {} });
      btn.textContent = r.ok ? 'Slettet!' : 'Feil!';
      btn.disabled = false;
      setTimeout(() => { btn.textContent = 'Slett testdata'; }, 2000);
      if (r.ok) { doReset(); }
    });

    // ═══════════════════════════════════════════════
    // INIT
    // ═══════════════════════════════════════════════

    renderTabs();
    renderSteps();
    renderState();

  })();
  </script>
</Layout>
