---
import Layout from '../layouts/Layout.astro';
import ResetPasswordForm from '../components/ResetPasswordForm';
import { getCurrentUser } from '../lib/auth';

const user = await getCurrentUser({ request: Astro.request, cookies: Astro.cookies });
if (!user) return Astro.redirect('/login');
---

<Layout title="Sett nytt passord — Littles and Me" lang="nb">
  <section class="max-w-md mx-auto px-6 py-16 sm:py-24">
    <div class="text-center mb-10">
      <h1 class="font-serif text-4xl sm:text-5xl mb-3">Sett nytt passord</h1>
      <p class="text-charcoal/55">Velg et nytt passord for kontoen din.</p>
    </div>
    <div class="bg-white rounded-3xl p-8 shadow-sm border border-sage-500/10">
      <ResetPasswordForm client:only="react" />
    </div>
  </section>
</Layout>
