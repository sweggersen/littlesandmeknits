---
import AdminLayout from '../../layouts/AdminLayout.astro';
import EmptyState from '../../components/EmptyState.astro';
import { createServerSupabase } from '../../lib/supabase';

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });

const showResolved = Astro.url.searchParams.get('show') === 'resolved';
const { data: events } = await supabase
  .from('dead_letter_events')
  .select('id, occurred_at, service, user_id, context, error, resolved_at, resolution_note')
  .filter('resolved_at', showResolved ? 'not.is' : 'is', null)
  .order('occurred_at', { ascending: false })
  .limit(200);

const rows = events ?? [];

// Group unresolved by service for at-a-glance triage.
const byService = new Map<string, number>();
for (const r of rows) {
  if (!r.resolved_at) byService.set(r.service, (byService.get(r.service) ?? 0) + 1);
}
---

<AdminLayout title="Dead-letters">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <header class="flex items-baseline justify-between gap-4 mb-6">
      <div>
        <h1 class="font-serif text-3xl mb-1">Dead-letter events</h1>
        <p class="text-sm text-charcoal/55">
          Commerce-path failures that need a human. Resolved entries auto-hide.
        </p>
      </div>
      <a
        href={showResolved ? '/admin/dead-letters' : '/admin/dead-letters?show=resolved'}
        class="text-xs text-charcoal/55 hover:text-charcoal underline"
      >
        {showResolved ? 'Vis uløste' : 'Vis løste'} →
      </a>
    </header>

    {!showResolved && byService.size > 0 && (
      <div class="bg-amber-50 border border-amber-300/50 rounded-2xl p-4 mb-6">
        <p class="text-xs font-bold uppercase tracking-widest text-amber-700 mb-2">Uløste · gruppert</p>
        <ul class="text-sm text-charcoal/80 space-y-1">
          {[...byService.entries()]
            .sort((a, b) => b[1] - a[1])
            .map(([svc, n]) => (
              <li><span class="font-mono">{svc}</span> — {n}</li>
            ))}
        </ul>
      </div>
    )}

    {rows.length === 0 ? (
      <EmptyState message={showResolved ? 'Ingen løste hendelser ennå.' : 'Alt rent. Ingen dead-letter-hendelser å sjekke.'} />
    ) : (
      <ul class="space-y-3">
        {rows.map((r) => (
          <li class="bg-white rounded-2xl border border-sage-500/15 p-5">
            <div class="flex items-baseline justify-between gap-3 mb-2">
              <p class="font-mono text-sm font-medium text-charcoal/90">{r.service}</p>
              <time class="text-xs text-charcoal/45 font-mono shrink-0">
                {new Date(r.occurred_at).toLocaleString('nb-NO')}
              </time>
            </div>
            <p class="text-sm text-charcoal/70 whitespace-pre-line mb-3">{r.error}</p>
            {Object.keys(r.context ?? {}).length > 0 && (
              <details class="text-xs">
                <summary class="cursor-pointer text-charcoal/55 hover:text-charcoal">Kontekst</summary>
                <pre class="bg-charcoal/[0.04] rounded-lg p-3 mt-2 overflow-x-auto font-mono text-[11px]">{JSON.stringify(r.context, null, 2)}</pre>
              </details>
            )}

            {r.resolved_at ? (
              <p class="text-xs text-sage-700 mt-3">
                Løst {new Date(r.resolved_at).toLocaleString('nb-NO')}
                {r.resolution_note && <> · <span class="italic">{r.resolution_note}</span></>}
              </p>
            ) : (
              <form method="post" action={`/api/admin/dead-letters/${r.id}/resolve`} class="mt-3 flex gap-2">
                <input
                  name="note"
                  type="text"
                  maxlength="200"
                  placeholder="Hva ble gjort? (valgfritt)"
                  class="flex-1 text-xs rounded-full border border-sage-500/20 bg-linen/50 px-3 py-1.5 focus:outline-none focus:border-terracotta-500"
                />
                <button
                  type="submit"
                  class="text-xs bg-primary text-primary-fg rounded-full px-3 py-1.5 font-medium hover:bg-primary-hover transition-colors"
                >
                  Marker løst
                </button>
              </form>
            )}
          </li>
        ))}
      </ul>
    )}
  </div>
</AdminLayout>
