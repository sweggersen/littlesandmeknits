---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireModerator } from '../../../lib/admin-auth';
import { createServerSupabase, createAdminSupabase } from '../../../lib/supabase';
import { anonymizeUser } from '../../../lib/anonymize';
import { REPORT_STATUS } from '../../../lib/labels';
import { env } from 'cloudflare:workers';

const auth = await requireModerator(Astro.request, Astro.cookies);
if (!auth) return Astro.redirect('/market');

const id = Astro.params.id;
if (!id) return Astro.redirect('/admin/reports');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const admin = createAdminSupabase(env.SUPABASE_SERVICE_ROLE_KEY);

const { data: report } = await supabase
  .from('reports').select('*').eq('id', id).maybeSingle();
if (!report) return Astro.redirect('/admin/reports');

// Resolve the linked item URL so we can embed it in an iframe.
// Also figure out who the moderator might want to contact (the seller/
// owner) — their display name, account email, and existing message
// conversation with the reporter (if any).
let itemUrl: string | null = null;
let itemTitle: string | null = null;
let subjectName: string | null = null;
let subjectEmail: string | null = null;
let subjectKind: 'selger' | 'kjøper' | 'butikk' | 'innmelder' = 'selger';
let existingConversationId: string | null = null;

if (report.target_type === 'listing') {
  const { data: l } = await admin.from('listings')
    .select('id, title, status, seller_id, store_id').eq('id', report.target_id).maybeSingle();
  if (l) {
    itemUrl = `/market/listing/${l.id}`;
    itemTitle = l.title;
    if (l.store_id) {
      const { data: s } = await admin.from('stores').select('name, contact_email').eq('id', l.store_id).maybeSingle();
      if (s) { subjectKind = 'butikk'; subjectName = s.name; subjectEmail = s.contact_email; }
    } else {
      const { data: p } = await admin.from('profiles').select('display_name').eq('id', l.seller_id).maybeSingle();
      const { data: u } = await admin.auth.admin.getUserById(l.seller_id);
      subjectName = p?.display_name ?? null;
      subjectEmail = u?.user?.email ?? null;
    }
    // Conversation between reporter and seller for this listing
    const { data: conv } = await admin.from('marketplace_conversations')
      .select('id').eq('listing_id', l.id).eq('buyer_id', report.reporter_id).maybeSingle();
    existingConversationId = conv?.id ?? null;
  }
} else if (report.target_type === 'commission_request') {
  const { data: r } = await admin.from('commission_requests').select('id, title, buyer_id').eq('id', report.target_id).maybeSingle();
  if (r) {
    itemUrl = `/market/commissions/${r.id}`;
    itemTitle = r.title;
    subjectKind = 'kjøper';
    const { data: p } = await admin.from('profiles').select('display_name').eq('id', r.buyer_id).maybeSingle();
    const { data: u } = await admin.auth.admin.getUserById(r.buyer_id);
    subjectName = p?.display_name ?? null;
    subjectEmail = u?.user?.email ?? null;
  }
} else if (report.target_type === 'store') {
  const { data: s } = await admin.from('stores')
    .select('id, slug, name, contact_email, created_by').eq('id', report.target_id).maybeSingle();
  if (s) {
    itemUrl = `/market/store/${s.slug}`;
    itemTitle = s.name;
    subjectKind = 'butikk';
    subjectName = s.name;
    subjectEmail = s.contact_email;
  }
}

// Reporter contact info. If the report is anonymous, we deliberately
// don't fetch the email — moderator can't contact the reporter and the
// UI says so.
const isAnonymous = !!report.anonymous;
let reporterDisplayName: string | null = null;
let reporterEmail: string | null = null;
if (!isAnonymous) {
  const { data: reporterProfile } = await admin.from('profiles').select('display_name').eq('id', report.reporter_id).maybeSingle();
  const { data: reporterUser } = await admin.auth.admin.getUserById(report.reporter_id);
  reporterDisplayName = reporterProfile?.display_name ?? null;
  reporterEmail = reporterUser?.user?.email ?? null;
}

// Pre-composed email subject + body for outreach to the subject
const reasonLabel: Record<string, string> = {
  scam: 'svindel', inappropriate: 'upassende innhold',
  wrong_category: 'feil kategori', spam: 'spam', other: 'annet',
};
const targetLabel = report.target_type === 'listing' ? 'annonsen'
  : report.target_type === 'store' ? 'butikken' : 'oppdraget';
const subjectMailto = subjectEmail
  ? `mailto:${subjectEmail}?subject=${encodeURIComponent(`Strikketorget — vi har mottatt en rapport på ${targetLabel}`)}&body=${encodeURIComponent(`Hei${subjectName ? ' ' + subjectName : ''},\n\nVi har mottatt en rapport om ${targetLabel} «${itemTitle ?? ''}». Innmelderen oppga grunnen «${reasonLabel[report.reason] ?? report.reason}»${report.description ? `, med beskrivelse: «${report.description}»` : ''}.\n\nKan du gi oss din side av saken så vi kan vurdere videre?\n\nVennlig hilsen\nModeratorteamet i Strikketorget`)}`
  : null;
const reporterMailto = reporterEmail
  ? `mailto:${reporterEmail}?subject=${encodeURIComponent('Strikketorget — oppfølging av rapporten din')}&body=${encodeURIComponent(`Hei${reporterDisplayName ? ' ' + reporterDisplayName : ''},\n\nTakk for at du varslet oss om ${targetLabel} «${itemTitle ?? ''}». Vi har noen tilleggsspørsmål:\n\n[skriv her]\n\nVennlig hilsen\nModeratorteamet i Strikketorget`)}`
  : null;

const REASON_LABEL: Record<string, string> = {
  scam: 'Svindel',
  inappropriate: 'Upassende innhold',
  wrong_category: 'Feil kategori',
  spam: 'Spam',
  other: 'Annet',
};
const TARGET_LABEL: Record<string, string> = {
  listing: 'Annonse',
  commission_request: 'Oppdrag',
  store: 'Butikk',
};

const reporterName = isAnonymous
  ? 'Anonym'
  : (reporterDisplayName ?? anonymizeUser(report.reporter_id));
const isOpen = report.status === 'open';

const itemLabel = report.target_type === 'listing' ? 'annonsen'
  : report.target_type === 'store' ? 'butikken'
  : 'oppdraget';
const itemArchiveTitle = report.target_type === 'store'
  ? `Lukk og suspender ${itemLabel}`
  : `Lukk og arkiver ${itemLabel}`;
const itemArchiveDesc = report.target_type === 'store'
  ? 'Suspenderer butikken og arkiverer alle aktive annonser tilknyttet.'
  : `Fjerner ${itemLabel} fra Strikketorget.`;
const dismissNote = `«Avvis» ignorerer valget over og lukker rapporten uten å påvirke ${itemLabel}.`;
---

<AdminLayout title="Rapport" current="rapporter">
  <a href="/admin/reports" class="text-xs text-charcoal/40 hover:text-terracotta-500 transition-colors mb-3 inline-block">&larr; Tilbake til rapporter</a>

  <div class="grid lg:grid-cols-[420px_1fr] gap-4 items-start">
    <!-- Left: report details + decision -->
    <div class="bg-white rounded-xl border border-sage-500/10 p-5 space-y-4 lg:sticky lg:top-[80px]">
      <div>
        <div class="flex items-center gap-2 mb-2 flex-wrap">
          <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">{TARGET_LABEL[report.target_type] ?? report.target_type}</span>
          <span class:list={[
            'text-[10px] font-bold uppercase tracking-widest rounded-full px-2 py-0.5',
            report.reason === 'scam' ? 'text-red-600 bg-red-50' : 'text-amber-600 bg-amber-50',
          ]}>{REASON_LABEL[report.reason] ?? report.reason}</span>
          <span class:list={[
            'text-[10px] font-bold uppercase tracking-widest rounded-full px-2 py-0.5',
            report.status === 'open' ? 'text-terracotta-500 bg-terracotta-500/10'
              : report.status === 'resolved' ? 'text-sage-700 bg-sage-100'
              : 'text-charcoal/40 bg-oatmeal/60',
          ]}>{REPORT_STATUS[report.status]}</span>
        </div>
        <h1 class="font-serif text-xl">{itemTitle ?? 'Rapportert element'}</h1>
        {itemUrl && (
          <a href={itemUrl} target="_blank" rel="noopener" class="text-xs text-terracotta-500 hover:underline mt-1 inline-block">Åpne i ny fane &nearr;</a>
        )}
      </div>

      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-1">Innmelder</p>
        <p class="text-sm">{reporterName}</p>
        <p class="text-[11px] text-charcoal/40">{new Date(report.created_at).toLocaleDateString('nb-NO', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</p>
      </div>

      {report.description && (
        <div>
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-1">Beskrivelse</p>
          <p class="text-sm text-charcoal/75 whitespace-pre-wrap bg-linen rounded-lg p-3">{report.description}</p>
        </div>
      )}

      <!-- Contact / resolution-process shortcuts -->
      {isOpen && (subjectEmail || reporterEmail || existingConversationId) && (
        <div class="border-t border-sage-500/10 pt-4">
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">Kontakt for utredning</p>
          <div class="space-y-1.5">
            {subjectMailto && (
              <a href={subjectMailto} class="flex items-start gap-2 text-xs bg-linen hover:bg-sage-100/60 rounded-lg px-3 py-2 transition-colors">
                <span class="text-base leading-none mt-0.5">✉️</span>
                <span>
                  <strong class="block">Send e-post til {subjectKind}</strong>
                  <span class="text-charcoal/55 font-mono break-all">{subjectEmail}</span>
                </span>
              </a>
            )}
            {existingConversationId && (
              <a href={`/market/messages/${existingConversationId}`} target="_blank" rel="noopener" class="flex items-start gap-2 text-xs bg-linen hover:bg-sage-100/60 rounded-lg px-3 py-2 transition-colors">
                <span class="text-base leading-none mt-0.5">💬</span>
                <span>
                  <strong class="block">Se eksisterende samtale</strong>
                  <span class="text-charcoal/55">Mellom innmelder og {subjectKind}</span>
                </span>
              </a>
            )}
            {reporterMailto && (
              <a href={reporterMailto} class="flex items-start gap-2 text-xs bg-linen hover:bg-sage-100/60 rounded-lg px-3 py-2 transition-colors">
                <span class="text-base leading-none mt-0.5">✉️</span>
                <span>
                  <strong class="block">Spør innmelderen om mer info</strong>
                  <span class="text-charcoal/55 font-mono break-all">{reporterEmail}</span>
                </span>
              </a>
            )}
            {isAnonymous && (
              <div class="flex items-start gap-2 text-xs bg-linen rounded-lg px-3 py-2 opacity-60 cursor-not-allowed">
                <span class="text-base leading-none mt-0.5 grayscale">✉️</span>
                <span>
                  <strong class="block">Kan ikke kontakte innmelder</strong>
                  <span class="text-charcoal/55">Rapporten er anonym — moderator kan ikke be om oppfølging.</span>
                </span>
              </div>
            )}
          </div>
        </div>
      )}

      {report.status !== 'open' && (
        <div class="bg-sage-100/40 rounded-lg p-3 text-xs">
          <p class="font-medium mb-0.5">Behandlet {report.resolved_at && new Date(report.resolved_at).toLocaleDateString('nb-NO', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })}</p>
          {report.resolution_notes && <p class="text-charcoal/65 whitespace-pre-wrap mt-1">{report.resolution_notes}</p>}
        </div>
      )}

      {isOpen && (
        <form method="post" action="/api/admin/reports/resolve" class="space-y-3">
          <input type="hidden" name="report_id" value={report.id} />
          <label class="block">
            <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55">Interne notater (valgfritt)</span>
            <textarea name="notes" rows="3" maxlength="1000" placeholder="Hva ble gjort? F.eks. 'Kontaktet selger, fjernet villedende bilde.'"
              class="w-full mt-1 bg-linen rounded-lg px-3 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 resize-none"></textarea>
          </label>

          <fieldset class="space-y-1.5">
            <legend class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-1.5">
              Hvis rapporten er gyldig, hva skal gjøres med {itemLabel}?
            </legend>
            <label class="flex items-start gap-2 text-xs cursor-pointer bg-linen rounded-lg px-3 py-2 border border-sage-500/15">
              <input type="radio" name="affect_item" value="none" checked class="mt-0.5" />
              <span>
                <strong class="block">Bare lukk rapporten</strong>
                <span class="text-charcoal/55">Allerede håndtert utenfor systemet (DM, samtale med selger, e.l.).</span>
              </span>
            </label>
            <label class="flex items-start gap-2 text-xs cursor-pointer bg-linen rounded-lg px-3 py-2 border border-sage-500/15">
              <input type="radio" name="affect_item" value="archive" class="mt-0.5" />
              <span>
                <strong class="block">{itemArchiveTitle}</strong>
                <span class="text-charcoal/55">{itemArchiveDesc}</span>
              </span>
            </label>
          </fieldset>

          <div class="flex gap-2 pt-1">
            <button type="submit" name="action" value="resolve" class="flex-1 bg-sage-500 text-white px-3 py-2.5 rounded-lg text-xs font-medium hover:bg-sage-600">Løs (gyldig rapport)</button>
            <button type="submit" name="action" value="dismiss" class="flex-1 border border-sage-500/30 text-charcoal/65 px-3 py-2.5 rounded-lg text-xs font-medium hover:bg-sage-100/50">Avvis (ikke gyldig)</button>
          </div>
          <p class="text-[10px] text-charcoal/40 leading-tight">{dismissNote}</p>
        </form>
      )}
    </div>

    <!-- Right: live preview of the reported item -->
    <div class="bg-white rounded-xl border border-sage-500/10 p-2 lg:p-3">
      <div class="flex items-center justify-between mb-2 px-2 pt-1">
        <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">Forhåndsvisning</p>
        {itemUrl && (
          <a href={itemUrl} target="_blank" rel="noopener" class="text-[10px] text-charcoal/45 hover:text-terracotta-500">Åpne i ny fane &nearr;</a>
        )}
      </div>
      {itemUrl ? (
        <iframe src={`${itemUrl}?embed=1`} class="w-full rounded-lg border border-sage-500/10" style="height: calc(100vh - 200px); min-height: 600px;" title="Rapportert element"></iframe>
      ) : (
        <p class="p-5 text-sm text-charcoal/55">Elementet finnes ikke lenger eller er ikke tilgjengelig.</p>
      )}
    </div>
  </div>
</AdminLayout>
