---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireModerator } from '../../../lib/admin-auth';
import { createServerSupabase, createAdminSupabase } from '../../../lib/supabase';
import { REPORT_STATUS } from '../../../lib/labels';
import { env } from '../../../lib/env';

const auth = await requireModerator(Astro.request, Astro.cookies);
if (!auth) return Astro.redirect('/market');

const id = Astro.params.id;
if (!id) return Astro.redirect('/admin/reports');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const admin = createAdminSupabase(env.SUPABASE_SERVICE_ROLE_KEY);

const { data: report } = await supabase
  .from('reports').select('*').eq('id', id).maybeSingle();
if (!report) return Astro.redirect('/admin/reports');

// Sibling reports: every report (open OR closed) targeting the same item.
const { data: siblingsData } = await admin
  .from('reports')
  .select('id, reporter_id, reason, description, status, anonymous, created_at')
  .eq('target_type', report.target_type)
  .eq('target_id', report.target_id)
  .order('created_at', { ascending: true });
const siblings: any[] = siblingsData ?? [];
const openSiblings = siblings.filter(s => s.status === 'open');

// Look up the item title + URL for the iframe preview.
let itemUrl: string | null = null;
let itemTitle: string | null = null;

if (report.target_type === 'listing') {
  const { data: l } = await admin.from('listings')
    .select('id, title').eq('id', report.target_id).maybeSingle();
  if (l) { itemUrl = `/market/listing/${l.id}`; itemTitle = l.title; }
} else if (report.target_type === 'commission_request') {
  const { data: r } = await admin.from('commission_requests').select('id, title').eq('id', report.target_id).maybeSingle();
  if (r) { itemUrl = `/market/commissions/${r.id}`; itemTitle = r.title; }
} else if (report.target_type === 'store') {
  const { data: s } = await admin.from('stores').select('id, slug, name').eq('id', report.target_id).maybeSingle();
  if (s) { itemUrl = `/market/store/${s.slug}`; itemTitle = s.name; }
}

// If an OPEN thread already exists for this target, jump straight to it —
// that's where the active work continues.
const { data: openThread } = await admin.from('moderation_threads')
  .select('id').eq('target_type', report.target_type).eq('target_id', report.target_id)
  .eq('status', 'open').order('created_at', { ascending: false }).limit(1).maybeSingle();
if (openThread) return Astro.redirect(`/admin/moderation-threads/${openThread.id}`);

// Otherwise show closed/historical thread link if any.
const { data: existingThread } = await admin.from('moderation_threads')
  .select('id, status').eq('target_type', report.target_type).eq('target_id', report.target_id)
  .order('created_at', { ascending: false }).limit(1).maybeSingle();

const REASON_LABEL: Record<string, string> = {
  scam: 'Svindel', inappropriate: 'Upassende innhold',
  wrong_category: 'Feil kategori', spam: 'Spam', other: 'Annet',
};
const TARGET_LABEL: Record<string, string> = {
  listing: 'Annonse', commission_request: 'Oppdrag', store: 'Butikk',
};
function reasonLbl(reason: string): string { return REASON_LABEL[reason] ?? reason; }

const draftSiblings = siblings.filter(s => s.status !== 'dismissed');
const draftReasonLines = draftSiblings.map((s) =>
  `- «${reasonLbl(s.reason)}»${s.description ? `: ${s.description}` : ''}`
).join('\n');
const draftIntro = draftSiblings.length > 1
  ? `Vi har mottatt ${draftSiblings.length} rapporter om ${'__ITEM__'} med følgende grunner:\n${draftReasonLines}`
  : `Vi har mottatt en rapport om ${'__ITEM__'}. Innmelder oppga grunnen «${reasonLbl(draftSiblings[0]?.reason ?? report.reason)}»${draftSiblings[0]?.description ? `, beskrevet som «${draftSiblings[0].description}»` : ''}.`;

const isOpen = report.status === 'open';
const itemLabel = report.target_type === 'listing' ? 'annonsen'
  : report.target_type === 'store' ? 'butikken'
  : 'oppdraget';
---

<AdminLayout title="Rapport" current="rapporter">
  <a href="/admin/reports" class="text-xs text-charcoal/40 hover:text-terracotta-500 transition-colors mb-3 inline-block">&larr; Tilbake til rapporter</a>

  <div class="grid lg:grid-cols-[420px_1fr] gap-4 items-start">
    <div class="bg-white rounded-xl border border-sage-500/10 p-5 space-y-4 lg:sticky lg:top-[80px]">
      <div>
        <div class="flex items-center gap-2 mb-2 flex-wrap">
          <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">{TARGET_LABEL[report.target_type] ?? report.target_type}</span>
          <span class:list={[
            'text-[10px] font-bold uppercase tracking-widest rounded-full px-2 py-0.5',
            report.status === 'open' ? 'text-terracotta-500 bg-terracotta-500/10'
              : report.status === 'resolved' ? 'text-sage-700 bg-sage-100'
              : 'text-charcoal/40 bg-oatmeal/60',
          ]}>{REPORT_STATUS[report.status]}</span>
        </div>
        <h1 class="font-serif text-xl">{itemTitle ?? 'Rapportert element'}</h1>
        {itemUrl && (
          <a href={itemUrl} target="_blank" rel="noopener" class="text-xs text-terracotta-500 hover:underline mt-1 inline-block">Åpne i ny fane &nearr;</a>
        )}
      </div>

      <div>
        <div class="flex items-center justify-between mb-2">
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55">
            {siblings.length === 1 ? '1 rapport' : `${siblings.length} rapporter`}
          </p>
          {openSiblings.length > 1 && (
            <p class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500">{openSiblings.length} åpne</p>
          )}
        </div>
        <ul class="space-y-2">
          {siblings.map((s) => (
            <li class="bg-linen rounded-lg p-3 text-xs">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <span class:list={[
                  'text-[10px] font-bold uppercase tracking-widest rounded-full px-2 py-0.5',
                  s.reason === 'scam' ? 'text-red-600 bg-red-50' : 'text-amber-600 bg-amber-50',
                ]}>{reasonLbl(s.reason)}</span>
                <span class="text-charcoal/40 text-[10px] ml-auto">{new Date(s.created_at).toLocaleDateString('nb-NO', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })}</span>
              </div>
              {s.description && (
                <p class="text-charcoal/75 whitespace-pre-wrap mt-1">{s.description}</p>
              )}
            </li>
          ))}
        </ul>
      </div>

      {existingThread && (
        <a href={`/admin/moderation-threads/${existingThread.id}`} class="block bg-amber-50 border border-amber-300 text-amber-900 rounded-lg p-3 text-xs hover:bg-amber-100 transition-colors">
          <strong class="block">{existingThread.status === 'open' ? 'Aktiv tråd' : 'Tidligere tråd'} for dette elementet</strong>
          <span class="text-amber-800/80">Gå til samtalen med eieren &rarr;</span>
        </a>
      )}

      {report.status !== 'open' && (
        <div class="bg-sage-100/40 rounded-lg p-3 text-xs">
          <p class="font-medium mb-0.5">Behandlet {report.resolved_at && new Date(report.resolved_at).toLocaleDateString('nb-NO', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })}</p>
          {report.resolution_notes && <p class="text-charcoal/65 whitespace-pre-wrap mt-1">{report.resolution_notes}</p>}
        </div>
      )}

      {isOpen && (
        <div class="border-t border-sage-500/10 pt-4 space-y-4">
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55">Steg 1 — er rapporten gyldig?</p>

          <!-- VALID: freeze + open thread -->
          <form method="post" action="/api/admin/reports/resolve" class="space-y-3 bg-amber-50/60 border border-amber-300/40 rounded-xl p-3">
            <input type="hidden" name="report_id" value={report.id} />
            <input type="hidden" name="action" value="freeze" />
            <p class="text-xs font-medium text-amber-900">Ja, gyldig → frys og kontakt eier</p>
            <label class="block">
              <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55">Melding til eieren *</span>
              <textarea name="first_message" rows="12" required maxlength="2000"
                class="w-full mt-1 bg-white rounded-lg px-3 py-2 text-sm border border-sage-500/20 focus:outline-none focus:border-sage-500 resize-none">{`Hei,\n\n${draftIntro.replace('__ITEM__', itemLabel)}\n\nMens vi behandler saken er ${itemLabel} midlertidig frosset og skjult fra Strikketorget. Den blir gjenåpnet så snart vi er enige om en løsning.\n\nKan du svare oss her med din side av saken? Hvis vi ikke hører fra deg innen 48 timer, lukker vi saken med utgangspunkt i informasjonen vi har.\n\nVennlig hilsen\nModeratorteamet`}</textarea>
            </label>
            <label class="block">
              <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55">Interne notater (valgfritt)</span>
              <textarea name="notes" rows="2" maxlength="1000"
                class="w-full mt-1 bg-white rounded-lg px-3 py-2 text-sm border border-sage-500/20 focus:outline-none focus:border-sage-500 resize-none"></textarea>
            </label>
            <button type="submit" class="w-full bg-amber-500 text-white px-3 py-2.5 rounded-lg text-xs font-medium hover:bg-amber-600">
              {openSiblings.length > 1 ? `Frys ${itemLabel} og løs alle ${openSiblings.length}` : `Frys ${itemLabel} og åpne samtale`}
            </button>
            <p class="text-[10px] text-charcoal/55 leading-tight">
              {itemLabel.charAt(0).toUpperCase() + itemLabel.slice(1)} blir skjult fra Strikketorget inntil saken er løst. Eieren får en viktig-merket melding i innboksen sin og må svare deg her.
            </p>
          </form>

          <!-- INVALID: dismiss -->
          <form method="post" action="/api/admin/reports/resolve" class="space-y-2 bg-linen rounded-xl p-3 border border-sage-500/10">
            <input type="hidden" name="report_id" value={report.id} />
            <input type="hidden" name="action" value="dismiss" />
            <p class="text-xs font-medium text-charcoal/75">Nei, ikke gyldig → avvis rapporten</p>
            <label class="block">
              <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55">Interne notater (valgfritt)</span>
              <textarea name="notes" rows="2" maxlength="1000"
                class="w-full mt-1 bg-white rounded-lg px-3 py-2 text-xs border border-sage-500/20 focus:outline-none focus:border-sage-500 resize-none"></textarea>
            </label>
            <button type="submit" class="w-full border border-sage-500/30 text-charcoal/65 px-3 py-2 rounded-lg text-xs font-medium hover:bg-sage-100/50">
              {openSiblings.length > 1 ? `Avvis alle ${openSiblings.length}` : 'Avvis rapporten'}
            </button>
          </form>
        </div>
      )}
    </div>

    <div class="bg-white rounded-xl border border-sage-500/10 p-2 lg:p-3">
      <div class="flex items-center justify-between mb-2 px-2 pt-1">
        <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">Forhåndsvisning</p>
        {itemUrl && (
          <a href={itemUrl} target="_blank" rel="noopener" class="text-[10px] text-charcoal/45 hover:text-terracotta-500">Åpne i ny fane &nearr;</a>
        )}
      </div>
      {itemUrl ? (
        <iframe src={`${itemUrl}?embed=1`} class="w-full rounded-lg border border-sage-500/10" style="height: calc(100vh - 200px); min-height: 600px;" title="Rapportert element"></iframe>
      ) : (
        <p class="p-5 text-sm text-charcoal/55">Elementet finnes ikke lenger eller er ikke tilgjengelig.</p>
      )}
    </div>
  </div>
</AdminLayout>
