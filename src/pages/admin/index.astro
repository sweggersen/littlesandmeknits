---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireModerator } from '../../lib/admin-auth';
import { createServerSupabase } from '../../lib/supabase';
import { buildServiceContext } from '../../lib/services/context';
import { getDashboardTrends } from '../../lib/services/admin-stats';
import { evaluateCronHealth } from '../../lib/cron-health';
import { timeAgo } from '../../lib/time';

const auth = await requireModerator(Astro.request, Astro.cookies);
if (!auth) return Astro.redirect('/market');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });

// Business-health trends (GMV / revenue / signups + 7-day sparkline). Spans all
// users, so it runs through a service on the admin client behind a role check.
const ctx = await buildServiceContext(Astro.request, Astro.cookies);
const trendsRes = ctx ? await getDashboardTrends(ctx) : null;
const trends = trendsRes?.ok ? trendsRes.data : null;
const kr = (n: number) => n.toLocaleString('nb-NO');
const sparkMax = trends ? Math.max(1, ...trends.dailySold) : 1;

const { count: pendingCount } = await supabase
  .from('moderation_queue')
  .select('id', { count: 'exact', head: true })
  .eq('status', 'pending');

const { count: shadowCount } = await supabase
  .from('moderation_queue')
  .select('id', { count: 'exact', head: true })
  .eq('shadow_review', true)
  .is('shadow_confirmed_at', null)
  .in('status', ['approved', 'rejected']);

const { count: spotCheckCount } = await supabase
  .from('moderation_queue')
  .select('id', { count: 'exact', head: true })
  .eq('spot_check', true)
  .is('spot_check_at', null);

const { count: openReports } = await supabase
  .from('reports')
  .select('id', { count: 'exact', head: true })
  .eq('status', 'open');

// Cron liveness: a STALE heartbeat means the scheduled job has stopped running
// (escrow auto-release etc. silently halted) — the original incident. Staff
// read cron_heartbeats via RLS (0093).
const { data: cronRow } = await supabase
  .from('cron_heartbeats')
  .select('last_run_at, ok')
  .eq('name', 'main')
  .maybeSingle();
const cronHealth = evaluateCronHealth(cronRow ?? null, Date.now());

const stats = [
  { label: 'Ventende i kø', value: pendingCount ?? 0, href: '/admin/moderation', color: 'terracotta' },
  { label: 'Skyggevurdering', value: shadowCount ?? 0, href: '/admin/moderation?tab=shadow', color: 'amber' },
  { label: 'Stikkprøver', value: spotCheckCount ?? 0, href: '/admin/moderation?tab=spot', color: 'blue' },
  { label: 'Åpne rapporter', value: openReports ?? 0, href: '/admin/reports', color: 'red' },
];

const welcomeEmailStatus = Astro.url.searchParams.get('welcome_email');
const emailTestStatus = Astro.url.searchParams.get('email_test');
const emailTestTemplate = Astro.url.searchParams.get('template');

const TEMPLATES = [
  { key: 'welcome', label: 'Velkomst', desc: 'Sendes på første innlogging.' },
  { key: 'draft_nudge', label: 'Påminn om utkast', desc: 'Sendes 24t etter et bildeløst utkast.' },
  { key: 'new_message', label: 'Ny melding', desc: 'Innkommende meldinger.' },
  { key: 'new_offer', label: 'Nytt tilbud', desc: 'Tilbud på oppdrag.' },
  { key: 'listing_purchased', label: 'Varen er solgt', desc: 'Selger mottar etter kjøp.' },
  { key: 'listing_shipped', label: 'Varen er sendt', desc: 'Kjøper mottar sporingsinfo.' },
  { key: 'seller_new_listing', label: 'Ny fra selger du følger', desc: 'Følgere når en selger publiserer.' },
  { key: 'review_received', label: 'Omtale mottatt', desc: 'Etter at kjøper har skrevet omtale.' },
];
---

<AdminLayout title="Admin — Oversikt" current="dashboard">
  <h1 class="font-serif text-2xl mb-6">Oversikt</h1>

  {trends && (
    <section class="mb-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
        <div class="bg-white rounded-xl border border-sage-500/10 p-4">
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40 mb-1">Omsetning · 7d</p>
          <p class="font-mono text-2xl tabular-nums">{kr(trends.gmv7)} <span class="text-sm text-charcoal/45">kr</span></p>
          <p class="text-[11px] text-charcoal/40 mt-1">30d: {kr(trends.gmv30)} kr</p>
        </div>
        <div class="bg-white rounded-xl border border-sage-500/10 p-4">
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40 mb-1">Inntekt · 7d</p>
          <p class="font-mono text-2xl tabular-nums">{kr(trends.revenue7)} <span class="text-sm text-charcoal/45">kr</span></p>
          <p class="text-[11px] text-charcoal/40 mt-1">30d: {kr(trends.revenue30)} kr</p>
        </div>
        <div class="bg-white rounded-xl border border-sage-500/10 p-4">
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40 mb-1">Solgt · 7d</p>
          <p class="font-mono text-2xl tabular-nums">{trends.sold7}</p>
          <p class="text-[11px] text-charcoal/40 mt-1">30d: {trends.sold30}</p>
        </div>
        <div class="bg-white rounded-xl border border-sage-500/10 p-4">
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40 mb-1">Nye brukere · 7d</p>
          <p class="font-mono text-2xl tabular-nums">{trends.signups7}</p>
          <p class="text-[11px] text-charcoal/40 mt-1">30d: {trends.signups30}</p>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-sage-500/10 p-4 flex items-center gap-5">
        <div class="shrink-0">
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40 mb-2">Salg siste 7 dager</p>
          <div class="flex items-end gap-1.5 h-12" role="img" aria-label={`Salg per dag siste uke: ${trends.dailySold.join(', ')}`}>
            {trends.dailySold.map((v) => (
              <div class="w-5 rounded-t bg-sage-500/70" style={`height:${Math.round((v / sparkMax) * 100)}%;min-height:2px`} title={`${v}`}></div>
            ))}
          </div>
        </div>
        <div class="flex flex-wrap gap-4 text-sm border-l border-sage-500/10 pl-5">
          <a href="/market" class="hover:text-terracotta-500 transition-colors"><span class="font-mono tabular-nums text-lg">{trends.activeListings}</span> <span class="text-charcoal/55">aktive annonser</span></a>
          <a href="/admin/disputes" class:list={['hover:text-terracotta-500 transition-colors', trends.openDisputes > 0 && 'text-terracotta-600']}><span class="font-mono tabular-nums text-lg">{trends.openDisputes}</span> <span class="text-charcoal/55">åpne tvister</span></a>
          <a href="/admin/support" class:list={['hover:text-terracotta-500 transition-colors', trends.openSupport > 0 && 'text-terracotta-600']}><span class="font-mono tabular-nums text-lg">{trends.openSupport}</span> <span class="text-charcoal/55">åpne henvendelser</span></a>
          <span class:list={[trends.openDeadLetters > 0 ? 'text-red-600 font-medium' : 'text-charcoal/55']} title="Uløste feil i betalingsflyten (dead_letter_events)"><span class="font-mono tabular-nums text-lg">{trends.openDeadLetters}</span> uløste feil</span>
          <span
            class:list={[cronHealth.stale ? 'text-red-600 font-medium' : (cronHealth.ok ? 'text-charcoal/55' : 'text-terracotta-600')]}
            title={cronHealth.stale
              ? 'Cron-jobben ser ut til å ha stoppet — automatiske oppgaver (escrow-frigjøring m.m.) kjører ikke. Sjekk cron-job.org.'
              : 'Siste vellykkede kjøring av den planlagte jobben'}>
            <span class="text-charcoal/40">Cron:</span>{' '}
            {cronHealth.lastRunAt
              ? (cronHealth.stale ? `stoppet? (${timeAgo(cronHealth.lastRunAt)})` : `ok · ${timeAgo(cronHealth.lastRunAt)}`)
              : 'aldri kjørt'}
          </span>
        </div>
      </div>
    </section>
  )}

  <h2 class="font-serif text-lg mb-3">Moderering</h2>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    {stats.map(s => (
      <a href={s.href} class="bg-white rounded-xl border border-sage-500/10 p-4 hover:border-sage-500/30 transition-colors">
        <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40 mb-1">{s.label}</p>
        <p class="font-mono text-3xl tabular-nums">{s.value}</p>
      </a>
    ))}
  </div>

  {(pendingCount ?? 0) > 0 && (
    <a href="/admin/moderation" class="inline-block bg-primary text-primary-fg px-5 py-2.5 rounded-full text-xs font-medium hover:bg-primary-hover transition-colors">
      Start moderering &rarr;
    </a>
  )}

  <section class="mt-10 pt-6 border-t border-sage-500/10">
    <h2 class="font-serif text-lg mb-2">E-postmaler</h2>
    <p class="text-sm text-charcoal/55 mb-4">
      Send en kopi av en mal til <strong>{auth.user.email}</strong> for å sjekke hvordan den ser ut.
    </p>
    {(welcomeEmailStatus === 'sent' || emailTestStatus === 'sent') && (
      <p class="text-sm text-sage-700 mb-3">✓ Sendt{emailTestTemplate ? ` (${emailTestTemplate})` : ''}. Sjekk innboksen.</p>
    )}
    {(welcomeEmailStatus === 'failed' || emailTestStatus === 'failed') && (
      <p class="text-sm text-terracotta-700 mb-3">Klarte ikke å sende. Sjekk Resend-loggen.</p>
    )}
    {(welcomeEmailStatus === 'no_api_key' || emailTestStatus === 'no_api_key') && (
      <p class="text-sm text-terracotta-700 mb-3">RESEND_API_KEY mangler i miljøet.</p>
    )}
    {emailTestStatus === 'unknown' && (
      <p class="text-sm text-terracotta-700 mb-3">Ukjent mal.</p>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {TEMPLATES.map((t) => (
        <form method="post" action="/api/admin/test-email" class="bg-white rounded-2xl p-4 border border-sage-500/10 flex items-start justify-between gap-3">
          <input type="hidden" name="template" value={t.key} />
          <div class="min-w-0">
            <p class="text-sm font-medium">{t.label}</p>
            <p class="text-xs text-charcoal/55 mt-0.5">{t.desc}</p>
          </div>
          <button type="submit" class="shrink-0 bg-primary text-primary-fg px-3 py-1.5 rounded-full text-xs font-medium hover:bg-primary-hover transition-colors">
            Send →
          </button>
        </form>
      ))}
    </div>
  </section>
</AdminLayout>
