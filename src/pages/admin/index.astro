---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireModerator } from '../../lib/admin-auth';
import { createServerSupabase } from '../../lib/supabase';

const auth = await requireModerator(Astro.request, Astro.cookies);
if (!auth) return Astro.redirect('/market');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });

const { count: pendingCount } = await supabase
  .from('moderation_queue')
  .select('id', { count: 'exact', head: true })
  .eq('status', 'pending');

const { count: shadowCount } = await supabase
  .from('moderation_queue')
  .select('id', { count: 'exact', head: true })
  .eq('shadow_review', true)
  .is('shadow_confirmed_at', null)
  .in('status', ['approved', 'rejected']);

const { count: spotCheckCount } = await supabase
  .from('moderation_queue')
  .select('id', { count: 'exact', head: true })
  .eq('spot_check', true)
  .is('spot_check_at', null);

const { count: openReports } = await supabase
  .from('reports')
  .select('id', { count: 'exact', head: true })
  .eq('status', 'open');

const stats = [
  { label: 'Ventende i kø', value: pendingCount ?? 0, href: '/admin/moderation', color: 'terracotta' },
  { label: 'Skyggevurdering', value: shadowCount ?? 0, href: '/admin/moderation?tab=shadow', color: 'amber' },
  { label: 'Stikkprøver', value: spotCheckCount ?? 0, href: '/admin/moderation?tab=spot', color: 'blue' },
  { label: 'Åpne rapporter', value: openReports ?? 0, href: '/admin/reports', color: 'red' },
];

const welcomeEmailStatus = Astro.url.searchParams.get('welcome_email');
---

<AdminLayout title="Admin — Oversikt" current="dashboard">
  <h1 class="font-serif text-2xl mb-6">Oversikt</h1>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    {stats.map(s => (
      <a href={s.href} class="bg-white rounded-xl border border-sage-500/10 p-4 hover:border-sage-500/30 transition-colors">
        <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40 mb-1">{s.label}</p>
        <p class="font-mono text-3xl tabular-nums">{s.value}</p>
      </a>
    ))}
  </div>

  {(pendingCount ?? 0) > 0 && (
    <a href="/admin/moderation" class="inline-block bg-charcoal text-linen px-5 py-2.5 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors">
      Start moderering &rarr;
    </a>
  )}

  <section class="mt-10 pt-6 border-t border-sage-500/10">
    <h2 class="font-serif text-lg mb-2">E-postmaler</h2>
    <p class="text-sm text-charcoal/55 mb-4">
      Send en kopi av en mal til din egen adresse for å sjekke hvordan den ser ut.
    </p>
    {welcomeEmailStatus === 'sent' && (
      <p class="text-sm text-sage-700 mb-3">✓ Velkomst-e-post sendt til {auth.user.email}.</p>
    )}
    {welcomeEmailStatus === 'failed' && (
      <p class="text-sm text-terracotta-700 mb-3">Klarte ikke å sende. Sjekk Resend-loggen.</p>
    )}
    {welcomeEmailStatus === 'no_api_key' && (
      <p class="text-sm text-terracotta-700 mb-3">RESEND_API_KEY mangler i miljøet.</p>
    )}
    <form method="post" action="/api/admin/test-welcome-email" class="inline">
      <button type="submit" class="bg-white border border-sage-500/20 px-4 py-2 rounded-full text-xs font-medium hover:border-charcoal/40 transition-colors">
        ✉️ Send test-velkomst til {auth.user.email}
      </button>
    </form>
  </section>
</AdminLayout>
