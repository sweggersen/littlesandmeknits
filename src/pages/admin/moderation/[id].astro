---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireModerator } from '../../../lib/admin-auth';
import { createServerSupabase, createAdminSupabase } from '../../../lib/supabase';
import { computeConfidenceScore, computeStoreConfidenceScore, getReviewStats } from '../../../lib/moderation';
import { anonymizeUser } from '../../../lib/anonymize';
import { projectPhotoUrl } from '../../../lib/storage';
import { CATEGORY_LABEL } from '../../../lib/labels';
import { lookupOrgnrRoles, type OrgRole } from '../../../lib/brreg';
import { env } from 'cloudflare:workers';

const auth = await requireModerator(Astro.request, Astro.cookies);
if (!auth) return Astro.redirect('/market');

const id = Astro.params.id;
if (!id) return Astro.redirect('/admin/moderation');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const admin = createAdminSupabase(env.SUPABASE_SERVICE_ROLE_KEY);

const { data: queueItem } = await supabase
  .from('moderation_queue')
  .select('*')
  .eq('id', id)
  .maybeSingle();

if (!queueItem) return Astro.redirect('/admin/moderation');

// Fetch submitter profile
const { data: submitter } = await admin
  .from('profiles')
  .select('id, display_name, stripe_onboarded, created_at, trust_score, trust_tier, total_completed_transactions, total_rejections')
  .eq('id', queueItem.submitter_id)
  .single();

// Fetch the actual item
let itemData: any = null;
if (queueItem.item_type === 'listing') {
  const { data } = await admin.from('listings').select('*').eq('id', queueItem.item_id).maybeSingle();
  itemData = data;
} else if (queueItem.item_type === 'store') {
  const { data } = await admin.from('stores').select('*').eq('id', queueItem.item_id).maybeSingle();
  itemData = data;
} else {
  const { data } = await admin.from('commission_requests').select('*').eq('id', queueItem.item_id).maybeSingle();
  itemData = data;
}

// For store items: fetch the registered roles from Brønnøysund and the
// submitter's auth email (so the moderator can compare names + reach out
// to verify identity if needed).
let storeRoles: OrgRole[] = [];
let rolesError: string | null = null;
let submitterEmail: string | null = null;
let matchedRoleNames: Set<string> = new Set();

if (queueItem.item_type === 'store' && itemData?.orgnr) {
  const rolesRes = await lookupOrgnrRoles(itemData.orgnr);
  if (rolesRes.ok && rolesRes.roles) {
    storeRoles = rolesRes.roles.filter(r => !r.resignedFlag);
  } else {
    rolesError = rolesRes.error ?? 'unknown';
  }

  const { data: authUser } = await admin.auth.admin.getUserById(queueItem.submitter_id);
  submitterEmail = authUser?.user?.email ?? null;

  // Fuzzy name-match: case-insensitive, normalised, check if submitter's
  // display_name appears in any role person's name (or vice versa). Lets
  // "Ola N." or "Ola Hansen Nordmann" match "Ola Nordmann".
  const normalize = (s: string) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z\s]/g, '').trim();
  const submitterName = submitter?.display_name ? normalize(submitter.display_name) : '';
  if (submitterName) {
    for (const role of storeRoles) {
      if (!role.personName) continue;
      const rn = normalize(role.personName);
      const tokens = rn.split(/\s+/).filter(t => t.length > 1);
      const submitterTokens = submitterName.split(/\s+/).filter(t => t.length > 1);
      // Match if at least 2 name tokens overlap (or both are short names)
      const shared = tokens.filter(t => submitterTokens.includes(t));
      if (shared.length >= 2 || (tokens.length === 1 && submitterTokens.includes(tokens[0]))) {
        matchedRoleNames.add(role.personName);
      }
    }
  }

  // Compute store confidence now that we have all signals
  if (submitter && itemData) {
    const matchedNames = [...matchedRoleNames];
    const KEY_ROLE_CODES = new Set([
      'INNH',  // proprietor (ENK)
      'DAGL',  // CEO
      'LEDE',  // chair of the board
      'KONT',  // contact person
      'KOMP',  // partner with personal liability (ANS/DA)
      'BEST',  // managing partner
      'SIGN',  // signing rights
    ]);
    const matchedKey = storeRoles.some(r =>
      r.personName && matchedRoleNames.has(r.personName) && KEY_ROLE_CODES.has(r.roleCode),
    );
    confidence = computeStoreConfidenceScore({
      profileCreatedAt: submitter.created_at,
      profileTotalRejections: submitter.total_rejections ?? 0,
      stripeOnboarded: !!itemData.stripe_onboarded,
      submitterDisplayName: submitter.display_name ?? null,
      submitterEmail: submitterEmail,
      storeContactEmail: itemData.contact_email,
      storeWebsiteUrl: itemData.website_url,
      storeDescription: itemData.description,
      legalFoundedDate: itemData.legal_founded_date,
      legalBusinessType: itemData.legal_business_type,
      registeredRoleNames: storeRoles.map(r => r.personName).filter((n): n is string => !!n),
      matchedRoleNames: matchedNames,
      matchedKeyRole: matchedKey,
    });
  }
}

// Fetch listing photos
let photoUrls: string[] = [];
if (queueItem.item_type === 'listing') {
  const { data: photoRows } = await admin
    .from('listing_photos')
    .select('path, position')
    .eq('listing_id', queueItem.item_id)
    .order('position');
  const photos = (photoRows ?? []).length > 0
    ? photoRows!
    : itemData?.hero_photo_path
      ? [{ path: itemData.hero_photo_path, position: 0 }]
      : [];
  photoUrls = photos.map(p => projectPhotoUrl(p.path)).filter(Boolean) as string[];
}

// Compute confidence score.
const reviewStats = submitter ? await getReviewStats(admin, submitter.id) : { avg_rating: 0, review_count: 0 };
let confidence: { total: number; breakdown: { label: string; points: number; max: number }[] };
if (submitter && itemData && queueItem.item_type === 'store') {
  // For stores, score is built later (after roles + email are fetched).
  // Initialise empty and compute below.
  confidence = { total: 0, breakdown: [] };
} else if (submitter && itemData) {
  confidence = computeConfidenceScore(submitter, {
    title: itemData.title,
    description: itemData.description,
    price_nok: itemData.price_nok,
    budget_nok_min: itemData.budget_nok_min,
    budget_nok_max: itemData.budget_nok_max,
    category: itemData.category,
  }, reviewStats);
} else {
  confidence = { total: 0, breakdown: [] };
}

// Previous moderation history for submitter
const { data: prevQueue } = await supabase
  .from('moderation_queue')
  .select('id, item_type, status, decision_at')
  .eq('submitter_id', queueItem.submitter_id)
  .neq('id', id)
  .in('status', ['approved', 'rejected'])
  .order('decision_at', { ascending: false })
  .limit(10);

const isAdmin = auth.role === 'admin';
const isShadowPending = queueItem.shadow_review && !queueItem.shadow_confirmed_at && ['approved', 'rejected'].includes(queueItem.status);
const isSpotCheckPending = queueItem.spot_check && !queueItem.spot_check_at && ['approved', 'rejected'].includes(queueItem.status);
const canDecide = ['pending', 'assigned', 'escalated'].includes(queueItem.status) && queueItem.submitter_id !== auth.user.id;

function scoreColor(s: number) {
  if (s >= 60) return 'text-sage-700 bg-sage-100';
  if (s >= 30) return 'text-amber-700 bg-amber-50';
  return 'text-red-700 bg-red-50';
}
---

<AdminLayout title="Vurder element" current="moderering">
  <a href="/admin/moderation" class="text-xs text-charcoal/40 hover:text-terracotta-500 transition-colors mb-4 inline-block">&larr; Tilbake til kø</a>

  <div class="grid lg:grid-cols-[1fr_340px] gap-6">
    <!-- Left: Item details -->
    <div class="space-y-4">
      <div class="bg-white rounded-xl border border-sage-500/10 p-5">
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-2">
            <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">{
              queueItem.item_type === 'listing' ? 'Annonse'
                : queueItem.item_type === 'store' ? 'Butikk'
                : 'Oppdrag'
            }</span>
            {queueItem.submitter_id === auth.user.id && (
              <span class="text-[10px] font-bold uppercase tracking-widest text-red-600 bg-red-50 rounded-full px-2 py-0.5">Ditt eget — kan ikke vurdere</span>
            )}
          </div>
          <a
            href={
              queueItem.item_type === 'listing' ? `/market/listing/${queueItem.item_id}`
                : queueItem.item_type === 'store' ? `/market/store/${itemData?.slug ?? ''}`
                : `/market/commissions/${queueItem.item_id}`
            }
            target="_blank"
            class="text-[10px] font-medium text-charcoal/50 hover:text-terracotta-500 transition-colors border border-sage-500/15 rounded-lg px-2.5 py-1">
            Se offentlig visning &nearr;
          </a>
        </div>

        {!itemData ? (
          <p class="text-sm text-charcoal/45">Element ikke funnet.</p>
        ) : queueItem.item_type === 'store' ? (
          <div>
            <h2 class="font-serif text-xl mb-1">{itemData.name}</h2>
            <p class="text-xs text-charcoal/55 mb-3">/market/store/{itemData.slug}</p>

            <div class="bg-sage-100/50 rounded-lg p-3 mb-3">
              <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-1">Brønnøysund-registrert</p>
              <p class="text-sm font-medium">{itemData.legal_name}</p>
              <p class="text-xs text-charcoal/65 font-mono">{itemData.orgnr} {itemData.legal_business_type && `· ${itemData.legal_business_type}`}</p>
              {itemData.legal_address && <p class="text-xs text-charcoal/55 mt-1">{itemData.legal_address}</p>}
            </div>

            {itemData.tagline && (
              <p class="text-sm text-charcoal/75 italic mb-2">"{itemData.tagline}"</p>
            )}
            {itemData.description && (
              <div class="bg-linen rounded-lg p-3 mb-3">
                <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">Beskrivelse</span>
                <p class="text-sm text-charcoal/75 whitespace-pre-line mt-1">{itemData.description}</p>
              </div>
            )}

            <div class="grid grid-cols-2 gap-2 text-sm mb-3">
              {itemData.contact_email && (
                <div><span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">E-post</span><p class="truncate">{itemData.contact_email}</p></div>
              )}
              {itemData.contact_phone && (
                <div><span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">Telefon</span><p>{itemData.contact_phone}</p></div>
              )}
              {itemData.location_city && (
                <div><span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">By</span><p>{itemData.location_city}</p></div>
              )}
              {itemData.website_url && (
                <div class="col-span-2"><span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">Nettside</span><p class="truncate"><a href={itemData.website_url} target="_blank" rel="noopener" class="text-terracotta-500 hover:underline">{itemData.website_url}</a></p></div>
              )}
            </div>

            {(itemData.instagram_url || itemData.etsy_url || itemData.pinterest_url || itemData.tiktok_url) && (
              <div class="flex flex-wrap gap-2 text-xs">
                {itemData.instagram_url && <a href={itemData.instagram_url} target="_blank" rel="noopener" class="text-charcoal/55 hover:text-charcoal underline">Instagram</a>}
                {itemData.etsy_url && <a href={itemData.etsy_url} target="_blank" rel="noopener" class="text-charcoal/55 hover:text-charcoal underline">Etsy</a>}
                {itemData.pinterest_url && <a href={itemData.pinterest_url} target="_blank" rel="noopener" class="text-charcoal/55 hover:text-charcoal underline">Pinterest</a>}
                {itemData.tiktok_url && <a href={itemData.tiktok_url} target="_blank" rel="noopener" class="text-charcoal/55 hover:text-charcoal underline">TikTok</a>}
              </div>
            )}

            {/* === Verification: registered representatives === */}
            <div class="mt-5 pt-5 border-t border-sage-500/15">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-sm font-medium">Registrerte representanter</h3>
                <a href={`https://virksomhet.brreg.no/nb/oppslag/enheter/${itemData.orgnr}/roller`} target="_blank" rel="noopener"
                  class="text-[10px] text-charcoal/45 hover:text-terracotta-500 underline">
                  Se på brreg.no &nearr;
                </a>
              </div>
              {rolesError ? (
                <p class="text-xs text-charcoal/55 bg-amber-50 rounded-lg p-2">
                  Kunne ikke hente roller fra Brønnøysund ({rolesError}).
                </p>
              ) : storeRoles.length === 0 ? (
                <p class="text-xs text-charcoal/55">Ingen aktive registrerte roller funnet.</p>
              ) : (
                <ul class="space-y-1.5">
                  {storeRoles.map(role => {
                    const isMatch = role.personName ? matchedRoleNames.has(role.personName) : false;
                    return (
                      <li class:list={[
                        'text-xs flex items-center justify-between gap-2 rounded px-2 py-1',
                        isMatch && 'bg-sage-100/60',
                      ]}>
                        <div>
                          <span class={isMatch ? 'font-bold' : 'font-medium'}>
                            {role.isOrganisation ? role.organisationName : role.personName}
                          </span>
                          {role.isOrganisation && <span class="text-charcoal/45 ml-1">(org)</span>}
                          <span class="text-charcoal/55"> · {role.roleDescription}</span>
                        </div>
                        {isMatch && <span class="text-[10px] font-bold uppercase tracking-widest text-sage-700">samsvarer</span>}
                      </li>
                    );
                  })}
                </ul>
              )}
            </div>

            {/* === Submitter contact + email-query buttons === */}
            <div class="mt-5 pt-5 border-t border-sage-500/15">
              <h3 class="text-sm font-medium mb-2">Verifisering</h3>
              <div class="space-y-1.5 text-xs">
                <div class="flex justify-between"><span class="text-charcoal/55">Innmelders navn:</span><span class:list={['font-medium', matchedRoleNames.size > 0 && 'text-sage-700']}>{submitter?.display_name ?? '—'} {matchedRoleNames.size > 0 && '✓'}</span></div>
                <div class="flex justify-between"><span class="text-charcoal/55">Innmelders konto-e-post:</span><span class="font-mono">{submitterEmail ?? '—'}</span></div>
                <div class="flex justify-between"><span class="text-charcoal/55">Oppgitt kontakt-e-post:</span><span class="font-mono">{itemData.contact_email ?? '—'}</span></div>
              </div>

              <p class="text-xs text-charcoal/55 mt-3 mb-2">
                Hvis usikker på eierskap: send forespørsel om bekreftelse til kontakt-e-posten.
              </p>
              <div class="flex flex-wrap gap-2">
                {itemData.contact_email && (
                  <a
                    href={`mailto:${itemData.contact_email}?subject=${encodeURIComponent('Verifisering av butikkregistrering på Strikketorget')}&body=${encodeURIComponent(`Hei,\n\nVi har mottatt en søknad om å opprette butikk på Strikketorget med organisasjonsnummer ${itemData.orgnr} (${itemData.legal_name}).\n\nFor å bekrefte at registreringen er gjort av en autorisert representant for virksomheten, kan du svare på denne e-posten og bekrefte:\n\n• Ditt navn og stilling i ${itemData.legal_name}\n• At du ønsker å være representert på Strikketorget\n\nDenne e-posten er sendt til den oppgitte kontakt-adressen.\n\nVennlig hilsen\nModeratorteamet i Strikketorget`)}`}
                    class="text-xs bg-charcoal text-linen px-3 py-1.5 rounded-full font-medium hover:bg-terracotta-500 transition-colors">
                    Send til kontakt-e-post
                  </a>
                )}
                {submitterEmail && submitterEmail !== itemData.contact_email && (
                  <a
                    href={`mailto:${submitterEmail}?subject=${encodeURIComponent('Verifisering av butikkregistrering på Strikketorget')}&body=${encodeURIComponent(`Hei,\n\nVi behandler søknaden din om butikk for organisasjonsnummer ${itemData.orgnr} (${itemData.legal_name}).\n\nKan du bekrefte din rolle i virksomheten?\n\nVennlig hilsen\nModeratorteamet i Strikketorget`)}`}
                    class="text-xs border border-sage-500/30 text-charcoal/70 px-3 py-1.5 rounded-full font-medium hover:bg-sage-100/50 transition-colors">
                    Send til innmelder
                  </a>
                )}
              </div>
            </div>
          </div>
        ) : (
          <div>
            <h2 class="font-serif text-xl mb-2">{itemData.title}</h2>
            {photoUrls.length > 0 && (
              <div class="flex gap-2 mb-3 overflow-x-auto pb-1">
                {photoUrls.map((url, i) => (
                  <a href={url} target="_blank" rel="noopener" class="shrink-0">
                    <img src={url} alt={`Bilde ${i + 1}`} class="w-24 h-24 object-cover rounded-lg border border-sage-500/10" loading="lazy" />
                  </a>
                ))}
              </div>
            )}
            <div class="grid grid-cols-2 gap-2 text-sm mb-3">
              <div>
                <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">Kategori</span>
                <p>{CATEGORY_LABEL[itemData.category] ?? itemData.category}</p>
              </div>
              <div>
                <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">Størrelse</span>
                <p>{itemData.size_label}</p>
              </div>
              {itemData.price_nok != null && (
                <div>
                  <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">Pris</span>
                  <p class="font-mono">{itemData.price_nok} NOK</p>
                </div>
              )}
              {itemData.budget_nok_min != null && (
                <div>
                  <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">Budsjett</span>
                  <p class="font-mono">{itemData.budget_nok_min}–{itemData.budget_nok_max} NOK</p>
                </div>
              )}
            </div>
            {itemData.description && (
              <div class="bg-linen rounded-lg p-3">
                <p class="text-sm text-charcoal/75 whitespace-pre-line">{itemData.description}</p>
              </div>
            )}
          </div>
        )}
      </div>

      <!-- Decision form -->
      {canDecide && (
        <div class="bg-white rounded-xl border border-sage-500/10 p-5">
          <h3 class="font-medium text-sm mb-3">Vurdering</h3>
          <form method="post" action="/api/admin/moderation/review" data-astro-reload class="space-y-3">
            <input type="hidden" name="queue_id" value={queueItem.id} />
            <div class="flex gap-2">
              <button type="submit" name="decision" value="approve" class="flex-1 bg-sage-500 text-white px-4 py-2.5 rounded-lg text-xs font-medium hover:bg-sage-600 transition-colors">Godkjenn</button>
              <button type="submit" name="decision" value="reject" class="flex-1 bg-red-500 text-white px-4 py-2.5 rounded-lg text-xs font-medium hover:bg-red-600 transition-colors">Avvis</button>
              <button type="submit" name="decision" value="escalate" class="px-4 py-2.5 border border-sage-500/15 rounded-lg text-xs font-medium text-charcoal/60 hover:bg-sage-100/50 transition-colors">Eskaler</button>
            </div>
            <label class="block">
              <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">Avvisningsgrunn (valgfritt)</span>
              <input name="rejection_reason" type="text" maxlength="500" placeholder={
                queueItem.item_type === 'store' ? 'F.eks. eier ikke virksomheten, mistanke om impersonasjon'
                  : queueItem.item_type === 'commission_request' ? 'F.eks. urealistisk budsjett'
                  : 'F.eks. ikke et strikkeprodukt'
              } class="w-full mt-1 bg-linen rounded-lg px-3 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500" />
            </label>
            <label class="block">
              <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40">Interne notater</span>
              <textarea name="internal_notes" rows="2" maxlength="1000" class="w-full mt-1 bg-linen rounded-lg px-3 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 resize-none"></textarea>
            </label>
          </form>
        </div>
      )}

      <!-- Shadow confirm (admin only) -->
      {isAdmin && isShadowPending && (
        <div class="bg-amber-50 rounded-xl border border-amber-200 p-5">
          <h3 class="font-medium text-sm mb-1">Skyggevurdering — bekreft moderatorens avgjørelse</h3>
          <p class="text-xs text-charcoal/55 mb-3">Moderator valgte: <strong>{queueItem.status === 'approved' ? 'Godkjent' : 'Avvist'}</strong></p>
          <form method="post" action="/api/admin/moderation/shadow-confirm" data-astro-reload class="flex gap-2">
            <input type="hidden" name="queue_id" value={queueItem.id} />
            <button type="submit" name="action" value="confirm" class="px-4 py-2 bg-sage-500 text-white rounded-lg text-xs font-medium">Bekreft</button>
            <button type="submit" name="action" value="override" class="px-4 py-2 bg-red-500 text-white rounded-lg text-xs font-medium">Overstyr</button>
          </form>
        </div>
      )}

      <!-- Spot check (admin only) -->
      {isAdmin && isSpotCheckPending && (
        <div class="bg-blue-50 rounded-xl border border-blue-200 p-5">
          <h3 class="font-medium text-sm mb-1">Stikkprøve</h3>
          <p class="text-xs text-charcoal/55 mb-3">Moderator valgte: <strong>{queueItem.status === 'approved' ? 'Godkjent' : 'Avvist'}</strong></p>
          <form method="post" action="/api/admin/moderation/spot-check" data-astro-reload class="flex gap-2">
            <input type="hidden" name="queue_id" value={queueItem.id} />
            <button type="submit" name="action" value="agree" class="px-4 py-2 bg-sage-500 text-white rounded-lg text-xs font-medium">Enig</button>
            <button type="submit" name="action" value="disagree" class="px-4 py-2 bg-red-500 text-white rounded-lg text-xs font-medium">Uenig</button>
          </form>
        </div>
      )}
    </div>

    <!-- Right: Score + Submitter -->
    <div class="space-y-4">
      <!-- Confidence score -->
      <div class="bg-white rounded-xl border border-sage-500/10 p-4">
        <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40 mb-2">Tillitsscore</p>
        <div class="flex items-center gap-3 mb-3">
          <span class:list={['font-mono text-3xl font-bold tabular-nums rounded-lg px-3 py-1', scoreColor(confidence.total)]}>
            {confidence.total}
          </span>
          <span class="text-xs text-charcoal/40">/ 100</span>
        </div>
        <div class="space-y-1">
          {confidence.breakdown.map(b => (
            <div class="flex items-center justify-between text-[11px]">
              <span class="text-charcoal/55">{b.label}</span>
              <span class:list={['font-mono tabular-nums', b.points < 0 ? 'text-red-600' : b.points > 0 ? 'text-sage-700' : 'text-charcoal/30']}>
                {b.points > 0 ? '+' : ''}{b.points}
              </span>
            </div>
          ))}
        </div>
      </div>

      <!-- Submitter profile.
           For store moderation we show the real name + email so the
           moderator can verify identity against Brønnøysund roles. For
           listings/commissions, identity stays anonymised. -->
      {submitter && (
        <div class="bg-white rounded-xl border border-sage-500/10 p-4">
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40 mb-2">Innmelder</p>
          <div class="flex items-center gap-3 mb-3">
            <div class:list={['w-8 h-8 rounded-full flex items-center justify-center shrink-0', matchedRoleNames.size > 0 ? 'bg-sage-100' : 'bg-sage-100']}>
              <span class="font-serif text-sm text-sage-700">{
                queueItem.item_type === 'store' && submitter.display_name
                  ? submitter.display_name[0]?.toUpperCase() ?? '#'
                  : '#'
              }</span>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-medium truncate">{
                queueItem.item_type === 'store'
                  ? (submitter.display_name || anonymizeUser(submitter.id))
                  : anonymizeUser(submitter.id)
              }{
                queueItem.item_type === 'store' && matchedRoleNames.size > 0 ? ' ✓' : ''
              }</p>
              {queueItem.item_type === 'store' && submitterEmail && (
                <p class="text-[10px] text-charcoal/55 font-mono truncate">{submitterEmail}</p>
              )}
              <p class="text-[10px] text-charcoal/40">
                {submitter.trust_tier} · score {submitter.trust_score} · {submitter.total_completed_transactions} fullførte
              </p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-1 text-[11px]">
            <span class="text-charcoal/40">Registrert</span>
            <span>{new Date(submitter.created_at).toLocaleDateString('nb-NO')}</span>
            <span class="text-charcoal/40">Stripe</span>
            <span>{submitter.stripe_onboarded ? 'Verifisert' : 'Nei'}</span>
            <span class="text-charcoal/40">Avvisninger</span>
            <span class:list={[submitter.total_rejections > 0 ? 'text-red-600 font-medium' : '']}>{submitter.total_rejections}</span>
          </div>
        </div>
      )}

      <!-- Previous history -->
      {prevQueue && prevQueue.length > 0 && (
        <div class="bg-white rounded-xl border border-sage-500/10 p-4">
          <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40 mb-2">Tidligere vurderinger</p>
          <div class="space-y-1">
            {prevQueue.map(pq => (
              <div class="flex items-center justify-between text-[11px]">
                <span class="text-charcoal/55">{pq.item_type === 'listing' ? 'Annonse' : 'Oppdrag'}</span>
                <span class:list={[pq.status === 'approved' ? 'text-sage-700' : 'text-red-600']}>
                  {pq.status === 'approved' ? 'Godkjent' : 'Avvist'}
                </span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</AdminLayout>
