---
import StudioLayout from '../../layouts/StudioLayout.astro';
import StudioSubNav from '../../components/StudioSubNav.astro';
import { useTranslations } from '../../lib/i18n';
import { createServerSupabase } from '../../lib/supabase';
import { getEntry } from 'astro:content';
import { formatNok } from '../../lib/format';

const meTabs = [
  { key: 'profil', label: 'Profil', href: '/studio/profil' },
  { key: 'bibliotek', label: 'Bibliotek', href: '/studio/mine-oppskrifter' },
  { key: 'kjop', label: 'Kjøp', href: '/studio/kjop' },
];

const t = useTranslations('nb');
const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });

type PurchaseRow = {
  id: string;
  pattern_slug: string;
  amount_nok: number;
  status: string;
  created_at: string;
};

const { data } = await supabase
  .from('purchases')
  .select('id, pattern_slug, amount_nok, status, created_at')
  .order('created_at', { ascending: false });

const purchases = (data ?? []) as PurchaseRow[];

const enriched = await Promise.all(
  purchases.map(async (p) => {
    const entry = await getEntry('patterns', p.pattern_slug);
    return {
      ...p,
      title: entry?.data.title.nb ?? p.pattern_slug,
    };
  })
);
---

<StudioLayout title="Kjøp — Littles and Me" lang="nb">
  <StudioSubNav items={meTabs} active="kjop" />

  <h1 class="font-serif text-3xl sm:text-4xl mb-8">{t('studio.nav.purchases')}</h1>

  {enriched.length === 0 ? (
    <div class="bg-white rounded-3xl p-12 text-center border border-sage-500/10">
      <p class="text-charcoal/55 mb-6">{t('studio.empty.purchases')}</p>
      <a
        href="/oppskrifter"
        class="inline-block bg-charcoal text-linen px-6 py-3 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors"
      >
        {t('studio.cta.browsePatterns')}
      </a>
    </div>
  ) : (
    <ul class="space-y-3">
      {enriched.map((p) => (
        <li class="bg-white rounded-2xl p-5 border border-sage-500/10 flex items-center justify-between gap-4">
          <div>
            <h3 class="font-serif text-lg leading-tight">{p.title}</h3>
            <p class="text-xs text-charcoal/50 mt-1">
              {formatNok(p.amount_nok, 'nb')} · {new Date(p.created_at).toLocaleDateString('nb-NO')}
            </p>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <a
              href={`/studio/prosjekter/ny?from=${encodeURIComponent(p.pattern_slug)}`}
              class="hidden sm:inline-block text-xs font-medium text-charcoal/70 hover:text-terracotta-500 px-3 py-2.5 rounded-full transition-colors whitespace-nowrap"
            >
              Start prosjekt
            </a>
            <a
              href={`/api/download/${p.id}`}
              target="_blank"
              rel="noopener"
              class="bg-charcoal text-linen px-5 py-2.5 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors whitespace-nowrap"
            >
              Last ned PDF
            </a>
          </div>
        </li>
      ))}
    </ul>
  )}
</StudioLayout>
