---
import StudioLayout from '../../layouts/StudioLayout.astro';
import InstallAppButton from '../../components/InstallAppButton.astro';
import DashboardEngine from '../../components/dashboard/DashboardEngine.astro';
import DashboardEditChrome from '../../components/dashboard/DashboardEditChrome.astro';
import DashboardPalette from '../../components/dashboard/DashboardPalette.astro';
import { createServerSupabase } from '../../lib/supabase';
import { useTranslations } from '../../lib/i18n';
import { parseStored } from '../../lib/services/dashboard-layout';

const t = useTranslations('nb');

const user = Astro.locals.user!;  // middleware-gated route
const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });

// Saved studio dashboard arrangement (shares the engine with /profile, but a
// separate 'studio' context row).
const { data: layoutRow } = await supabase
  .from('dashboard_layouts')
  .select('layout')
  .eq('user_id', user.id)
  .eq('context', 'studio')
  .maybeSingle();
const { mode: savedMode, items: savedLayout } = parseStored(layoutRow?.layout);

const now = new Date();
const startOfYear = new Date(now.getFullYear(), 0, 1).toISOString().slice(0, 10);

const [projectsRes, yarnsRes, needlesRes, externalRes, deductionsRes] = await Promise.all([
  supabase.from('projects').select('id, status, started_at, finished_at, created_at').eq('user_id', user!.id),
  supabase.from('yarns').select('id, total_grams'),
  supabase.from('needles').select('id'),
  supabase.from('external_patterns').select('id'),
  supabase.from('project_yarns').select('grams_used, deducted_at'),
]);

type ProjectStatRow = {
  id: string;
  status: 'planning' | 'active' | 'finished' | 'frogged';
  started_at: string | null;
  finished_at: string | null;
  created_at: string;
};

const projects = (projectsRes.data ?? []) as ProjectStatRow[];
const yarns = (yarnsRes.data ?? []) as Array<{ id: string; total_grams: number | null }>;
const needles = (needlesRes.data ?? []) as Array<{ id: string }>;
const externals = (externalRes.data ?? []) as Array<{ id: string }>;
const deductions = (deductionsRes.data ?? []) as Array<{ grams_used: number; deducted_at: string | null }>;

const finishedAll = projects.filter((p) => p.status === 'finished');
const finishedThisYear = finishedAll.filter((p) => p.finished_at && p.finished_at >= startOfYear);
const active = projects.filter((p) => p.status === 'active');
const planning = projects.filter((p) => p.status === 'planning');

const stashTotalGrams = yarns.reduce((s, y) => s + (y.total_grams ?? 0), 0);
const totalGramsKnit = deductions
  .filter((d) => d.deducted_at)
  .reduce((s, d) => s + (d.grams_used ?? 0), 0);

let longestDays = 0;
for (const p of finishedAll) {
  if (!p.started_at || !p.finished_at) continue;
  const days = Math.round(
    (new Date(p.finished_at).getTime() - new Date(p.started_at).getTime()) / 86_400_000,
  );
  if (days > longestDays) longestDays = days;
}

type Badge = { id: string; label: string; emoji: string; description: string; earned: boolean };
const badges: Badge[] = [
  {
    id: 'first-finished',
    label: 'Første plagg',
    emoji: '🎉',
    description: 'Strikket ferdig ditt første prosjekt.',
    earned: finishedAll.length >= 1,
  },
  {
    id: 'five-finished',
    label: '5 plagg',
    emoji: '🧶',
    description: 'Fem ferdige prosjekter.',
    earned: finishedAll.length >= 5,
  },
  {
    id: 'ten-finished',
    label: '10 plagg',
    emoji: '🏅',
    description: 'Ti ferdige prosjekter — du er på rull.',
    earned: finishedAll.length >= 10,
  },
  {
    id: 'kilo-knit',
    label: '1 kg strikket',
    emoji: '⚖️',
    description: 'Totalt 1 kg garn brukt på ferdige prosjekter.',
    earned: totalGramsKnit >= 1000,
  },
  {
    id: 'stash-builder',
    label: 'Garnsamler',
    emoji: '🪡',
    description: '10 garn i lageret.',
    earned: yarns.length >= 10,
  },
  {
    id: 'librarian',
    label: 'Bibliotekar',
    emoji: '📚',
    description: '10 oppskrifter i biblioteket.',
    earned: externals.length >= 10,
  },
];

const earnedBadges = badges.filter((b) => b.earned);

// Prefer the user-set display name; fall back to a best-effort first name
// derived from the email local part (sam.mathias.weggersen → Sam) and
// finally to an empty string so the layout shows a neutral greeting.
function firstNameFromEmail(email: string | undefined): string {
  if (!email) return '';
  const local = email.split('@')[0] ?? '';
  const first = local.split(/[._-]/)[0] ?? '';
  if (!first) return '';
  return first.charAt(0).toUpperCase() + first.slice(1).toLowerCase();
}
const meta = (user?.user_metadata ?? {}) as { display_name?: string };
const hasDisplayName = !!(meta.display_name && meta.display_name.trim());
const greeting = hasDisplayName ? meta.display_name!.trim() : firstNameFromEmail(user?.email);
const fmtKg = (g: number) => (g >= 1000 ? `${(g / 1000).toFixed(1)} kg` : `${g} g`);

const studioStats: Array<{ label: string; value: string; href: string }> = [
  { label: 'I gang', value: String(active.length), href: '/studio/projects' },
  { label: 'Planlegges', value: String(planning.length), href: '/studio/projects' },
  { label: `Ferdig ${now.getFullYear()}`, value: String(finishedThisYear.length), href: '/studio/projects' },
  { label: 'Strikket totalt', value: fmtKg(totalGramsKnit), href: '/studio/projects' },
  { label: 'I lager', value: fmtKg(stashTotalGrams), href: '/studio/yarn' },
  { label: 'Pinner', value: String(needles.length), href: '/studio/needles' },
];
---

<StudioLayout title="Strikkestua — Littles and Me Knits" lang="nb">
  <!-- Header: greeting + Rediger (same editable-dashboard chrome as /profile) -->
  <div class="flex items-start gap-4 mb-6">
    <div class="min-w-0 flex-1">
      <h1 class="font-serif text-3xl sm:text-4xl mb-1 leading-tight">
        {greeting ? `Hei, ${greeting}` : 'Velkommen tilbake'}
      </h1>
      <p class="text-charcoal/60 text-sm sm:text-base max-w-prose">
        Oversikt over alt du driver med — prosjekter, garnlager, oppskriftene dine, og verktøyene som hjelper deg fra plan til ferdig plagg.
      </p>
    </div>
    <DashboardEditChrome />
  </div>

  {!hasDisplayName && (
    <form
      method="post"
      action="/api/profile/update"
      class="mb-6 bg-sage-100 rounded-2xl p-4 sm:p-5 flex flex-col sm:flex-row sm:items-end gap-3 max-w-xl"
    >
      <input type="hidden" name="next" value="/studio" />
      <div class="flex-1">
        <label class="block text-[10px] font-bold uppercase tracking-widest text-sage-900/80 mb-1">Hva skal jeg kalle deg?</label>
        <input
          type="text"
          name="display_name"
          maxlength="60"
          required
          placeholder="Sam"
          class="w-full bg-white rounded-xl px-3 py-2 text-base border border-sage-500/20 focus:outline-none focus:border-sage-500"
        />
      </div>
      <button
        type="submit"
        class="bg-primary text-primary-fg px-4 py-2 rounded-full text-xs font-medium hover:bg-primary-hover transition-colors whitespace-nowrap"
      >
        Lagre
      </button>
    </form>
  )}

  <div data-edit-hint class="hidden mb-4 rounded-2xl bg-terracotta-500/8 border border-terracotta-500/20 px-4 py-3 text-sm text-terracotta-500">
    Dra kortene for å flytte dem, og bruk størrelse&shy;knappen (S · M · L) for å endre bredde. Trykk «Lagre» når du er fornøyd.
  </div>

  <div id="dashgrid" class="grid grid-cols-1 md:grid-cols-6 gap-4 md:gap-5 items-start" data-context="studio" data-user={user.id} data-saved-layout={JSON.stringify(savedLayout)} data-saved-mode={savedMode}>
    <!-- Nøkkeltall (låst: alltid synlig) -->
    <div class="dash-widget md:col-span-6" data-widget="stats" data-size="l" data-default="1" data-lock="1" data-label="Nøkkeltall">
      <section class="dash-group rounded-2xl border border-sage-500/20 overflow-hidden">
        <div class="dash-group-head px-5 py-3.5 border-b border-sage-500/15">
          <h2 class="font-serif text-lg">Nøkkeltall</h2>
        </div>
        <div class="p-4">
          <div class="dash-tiles">
            {studioStats.map((s) => (
              <a href={s.href} data-tile class="bg-white rounded-2xl border border-sage-500/20 p-4 hover:border-sage-500/30 transition-colors">
                <p class="font-serif text-3xl leading-none tabular-nums">{s.value}</p>
                <p class="text-[11px] text-charcoal/55 mt-1.5 leading-tight">{s.label}</p>
              </a>
            ))}
          </div>
          {longestDays > 0 && (
            <p class="mt-3 text-xs text-charcoal/55 italic">Lengste prosjekt: {longestDays} dager fra start til ferdig.</p>
          )}
        </div>
      </section>
    </div>

    <!-- Lær å strikke -->
    <div class="dash-widget md:col-span-4" data-widget="learn" data-size="m" data-default="1" data-label="Lær å strikke">
      <a href="/studio/learn" class="group flex items-center gap-4 bg-white rounded-2xl p-5 border border-sage-500/20 hover:border-sage-500/30 hover:shadow-sm transition-all h-full">
        <div class="shrink-0 w-12 h-12 rounded-full bg-sage-100 flex items-center justify-center text-sage-900">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="6 4 20 12 6 20 6 4" fill="currentColor" stroke="none" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-[10px] font-bold uppercase tracking-widest text-sage-900 mb-0.5">Lær å strikke</p>
          <h3 class="font-serif text-lg leading-tight">Begynnerkurs i video</h3>
          <p class="text-xs text-charcoal/55 mt-0.5">17 leksjoner fra NimbleNeedles, fra første maske til ferdig plagg.</p>
        </div>
        <span class="hidden sm:flex items-center text-charcoal/30 group-hover:text-charcoal/60 transition-colors pr-1">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </span>
      </a>
    </div>

    <!-- Snarveier -->
    <div class="dash-widget md:col-span-2" data-widget="snarveier" data-size="s" data-default="1" data-label="Snarveier">
      <section class="bg-white rounded-2xl border border-sage-500/20 p-5 h-full">
        <h2 class="font-serif text-lg px-5 -mx-5 pb-3.5 mb-4 border-b border-sage-500/15">Snarveier</h2>
        <div class="flex flex-col gap-2 text-sm">
          <a href="/studio/projects/new" class="text-charcoal/60 hover:text-terracotta-500 transition-colors">Nytt prosjekt →</a>
          <a href="/studio/yarn/new" class="text-charcoal/60 hover:text-terracotta-500 transition-colors">Nytt garn →</a>
          <a href="/studio/needles/new" class="text-charcoal/60 hover:text-terracotta-500 transition-colors">Ny pinne →</a>
          <a href="/profile/library/new" class="text-charcoal/60 hover:text-terracotta-500 transition-colors">Last opp oppskrift →</a>
        </div>
      </section>
    </div>

    <!-- Merker -->
    <div class="dash-widget md:col-span-6" data-widget="badges" data-size="l" data-default="1" data-label="Merker">
      <section class="bg-white rounded-2xl border border-sage-500/20 overflow-hidden">
        <div class="flex items-center justify-between px-5 py-3.5 border-b border-sage-500/15">
          <h2 class="font-serif text-lg">Merker</h2>
          <span class="text-xs text-charcoal/45">
            {earnedBadges.length === 0 ? 'Ingen ennå' : `${earnedBadges.length} av ${badges.length}`}
          </span>
        </div>
        <div class="p-4">
          <div class="dash-tiles">
            {badges.map((b) => (
              <div
                data-tile
                class:list={[
                  'bg-white rounded-2xl p-4 border text-center transition-all',
                  b.earned ? 'border-sage-500/30 shadow-sm' : 'border-sage-500/10 opacity-50',
                ]}
              >
                <div class={`text-3xl mb-1 ${b.earned ? '' : 'grayscale'}`}>{b.emoji}</div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal mb-1">{b.label}</p>
                <p class="text-[10px] text-charcoal/55 leading-tight dash-sub">{b.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    </div>
  </div>

  <DashboardPalette />

  <div class="mt-6">
    <InstallAppButton />
  </div>

  {projects.length === 0 && (
    <div class="mt-10 bg-sage-100 rounded-3xl p-8 text-center">
      <p class="font-serif text-2xl text-sage-900 mb-3">Ny her?</p>
      <p class="text-sage-900/80 max-w-md mx-auto mb-5">{t('studio.empty.projects')}</p>
      <a href="/studio/projects/new" class="inline-block bg-primary text-primary-fg px-6 py-3 rounded-full text-sm font-medium hover:bg-primary-hover transition-colors">
        Start et prosjekt
      </a>
    </div>
  )}

  <DashboardEngine />
</StudioLayout>
