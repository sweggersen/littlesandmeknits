---
import StudioLayout from '../../../layouts/StudioLayout.astro';
import { createServerSupabase } from '../../../lib/supabase';
import { getEntry } from 'astro:content';
import { projectPhotoUrl } from '../../../lib/storage';

const { id } = Astro.params;
if (!id) return Astro.redirect('/studio/prosjekter');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });

type ProjectRow = {
  id: string;
  title: string;
  summary: string | null;
  status: 'planning' | 'active' | 'finished' | 'frogged';
  recipient: string | null;
  target_size: string | null;
  yarn: string | null;
  needles: string | null;
  pattern_slug: string | null;
  pattern_external: string | null;
  hero_photo_path: string | null;
  started_at: string | null;
  finished_at: string | null;
  created_at: string;
  updated_at: string;
  public_slug: string | null;
};

const { data: project, error } = await supabase
  .from('projects')
  .select('id, title, summary, status, recipient, target_size, yarn, needles, pattern_slug, pattern_external, hero_photo_path, started_at, finished_at, created_at, updated_at, public_slug')
  .eq('id', id)
  .maybeSingle();

if (error || !project) {
  return Astro.redirect('/studio/prosjekter');
}

const p = project as ProjectRow;

type LogRow = {
  id: string;
  body: string;
  log_date: string;
  photos: string[];
  created_at: string;
};

const { data: logsData } = await supabase
  .from('project_logs')
  .select('id, body, log_date, photos, created_at')
  .eq('project_id', id)
  .order('log_date', { ascending: false })
  .order('created_at', { ascending: false });

const logs = (logsData ?? []) as LogRow[];

const patternEntry = p.pattern_slug ? await getEntry('patterns', p.pattern_slug) : null;
const heroUrl = projectPhotoUrl(p.hero_photo_path);

const statusLabels = {
  planning: 'Planlegges',
  active: 'I gang',
  finished: 'Ferdig',
  frogged: 'Røket opp',
} as const;

const statusClass = {
  planning: 'bg-oatmeal text-charcoal/70',
  active: 'bg-sage-100 text-sage-900',
  finished: 'bg-terracotta-500/10 text-terracotta-500',
  frogged: 'bg-charcoal/10 text-charcoal/60',
} as const;

const today = new Date().toISOString().slice(0, 10);

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://www.littlesandmeknits.com';
const shareUrl = p.public_slug ? `${siteUrl}/p/${p.public_slug}` : null;
---

<StudioLayout title={`${p.title} — Littles and Me`} lang="nb">
  <nav class="text-xs text-charcoal/50 mb-4">
    <a href="/studio/prosjekter" class="hover:text-charcoal transition-colors">Prosjekter</a>
    <span class="mx-2">/</span>
    <span>{p.title}</span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main column -->
    <div class="lg:col-span-2">
      {heroUrl && (
        <div class="aspect-[16/10] rounded-3xl overflow-hidden bg-oatmeal mb-6 border border-sage-500/10">
          <img src={heroUrl} alt={p.title} class="w-full h-full object-cover" loading="lazy" />
        </div>
      )}

      <header class="flex items-start justify-between gap-4 mb-6">
        <div class="flex-1 min-w-0">
          <span class={`text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full ${statusClass[p.status]}`}>
            {statusLabels[p.status]}
          </span>
          <h1 class="font-serif text-4xl mt-3 leading-tight">{p.title}</h1>
          {p.summary && (
            <p class="text-charcoal/65 mt-3 leading-relaxed">{p.summary}</p>
          )}
        </div>
      </header>

      <!-- Add a log -->
      <section class="bg-white rounded-3xl p-6 border border-sage-500/10 mb-8">
        <h2 class="font-serif text-lg mb-4">Ny logg</h2>
        <form method="post" action={`/api/projects/${p.id}/log`} enctype="multipart/form-data" class="space-y-3">
          <textarea
            name="body"
            required
            rows="4"
            maxlength="4000"
            placeholder="Hva skjedde i dag? Antall masker, endringer i mønsteret, hvordan det ser ut…"
            class="w-full bg-linen rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors resize-none"
          ></textarea>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">Bilder (valgfritt, opptil 6)</label>
            <input
              type="file"
              name="photos"
              accept="image/*"
              multiple
              class="block w-full text-sm text-charcoal/70 file:mr-3 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-medium file:bg-sage-100 file:text-sage-900 hover:file:bg-sage-500 hover:file:text-linen file:cursor-pointer file:transition-colors"
            />
          </div>
          <div class="flex items-center justify-between gap-3 pt-2">
            <input
              type="date"
              name="log_date"
              value={today}
              class="bg-linen rounded-xl px-3 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors"
            />
            <button
              type="submit"
              class="bg-charcoal text-linen px-5 py-2.5 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors"
            >
              Legg til logg
            </button>
          </div>
        </form>
      </section>

      <!-- Logs timeline -->
      <section>
        <h2 class="font-serif text-lg mb-4">Tidslinje</h2>
        {logs.length === 0 ? (
          <p class="text-sm text-charcoal/50 italic">Ingen loggføringer ennå. Legg til en over for å begynne.</p>
        ) : (
          <ol class="space-y-4">
            {logs.map((log) => (
              <li class="bg-white rounded-2xl p-5 border border-sage-500/10">
                <div class="flex items-baseline justify-between mb-2">
                  <time class="text-xs font-bold uppercase tracking-wider text-sage-900">
                    {new Date(log.log_date).toLocaleDateString('nb-NO', { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric' })}
                  </time>
                  <form method="post" action={`/api/projects/${p.id}/log/${log.id}/delete`} class="inline">
                    <button
                      type="submit"
                      class="text-[11px] text-charcoal/40 hover:text-terracotta-500 transition-colors"
                      onclick="return confirm('Slette denne loggen?')"
                    >
                      Slett
                    </button>
                  </form>
                </div>
                <p class="text-sm text-charcoal/80 leading-relaxed whitespace-pre-wrap">{log.body}</p>
                {log.photos && log.photos.length > 0 && (
                  <div class={`mt-4 grid gap-2 ${log.photos.length === 1 ? 'grid-cols-1' : log.photos.length === 2 ? 'grid-cols-2' : 'grid-cols-3'}`}>
                    {log.photos.map((path) => (
                      <a href={projectPhotoUrl(path)} target="_blank" rel="noopener" class="aspect-square rounded-xl overflow-hidden bg-oatmeal hover:opacity-90 transition-opacity">
                        <img src={projectPhotoUrl(path)} alt="" class="w-full h-full object-cover" loading="lazy" />
                      </a>
                    ))}
                  </div>
                )}
              </li>
            ))}
          </ol>
        )}
      </section>
    </div>

    <!-- Sidebar -->
    <aside class="lg:col-span-1 space-y-5">
      <!-- Details -->
      <div class="bg-white rounded-3xl p-6 border border-sage-500/10">
        <h2 class="font-serif text-lg mb-4">Detaljer</h2>
        <dl class="space-y-3 text-sm">
          {p.recipient && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">For</dt>
              <dd>{p.recipient}</dd>
            </div>
          )}
          {patternEntry && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Oppskrift</dt>
              <dd>
                <a href={`/oppskrifter/${p.pattern_slug}`} class="text-terracotta-500 hover:underline" target="_blank" rel="noopener">
                  {patternEntry.data.title.nb}
                </a>
              </dd>
            </div>
          )}
          {!patternEntry && p.pattern_external && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Oppskrift</dt>
              <dd>{p.pattern_external}</dd>
            </div>
          )}
          {p.target_size && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Størrelse</dt>
              <dd>{p.target_size}</dd>
            </div>
          )}
          {p.yarn && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Garn</dt>
              <dd>{p.yarn}</dd>
            </div>
          )}
          {p.needles && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Pinner</dt>
              <dd>{p.needles}</dd>
            </div>
          )}
          <div>
            <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Opprettet</dt>
            <dd class="text-charcoal/60">{new Date(p.created_at).toLocaleDateString('nb-NO')}</dd>
          </div>
        </dl>

        <div class="mt-6 pt-6 border-t border-sage-500/10">
          <form method="post" action={`/api/projects/${p.id}/status`}>
            <label class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 block mb-2">
              Status
            </label>
            <div class="flex gap-2">
              <select
                name="status"
                class="flex-1 bg-linen rounded-xl px-3 py-2 text-sm border border-sage-500/15"
              >
                <option value="planning" selected={p.status === 'planning'}>Planlegges</option>
                <option value="active" selected={p.status === 'active'}>I gang</option>
                <option value="finished" selected={p.status === 'finished'}>Ferdig</option>
                <option value="frogged" selected={p.status === 'frogged'}>Røket opp</option>
              </select>
              <button
                type="submit"
                class="bg-charcoal text-linen px-3 rounded-xl text-xs font-medium hover:bg-terracotta-500 transition-colors"
              >
                Lagre
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Hero photo -->
      <div class="bg-white rounded-3xl p-6 border border-sage-500/10">
        <h2 class="font-serif text-lg mb-3">Hovedbilde</h2>
        {heroUrl ? (
          <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-oatmeal mb-3">
            <img src={heroUrl} alt="" class="w-full h-full object-cover" />
          </div>
        ) : (
          <p class="text-xs text-charcoal/50 italic mb-3">Ingen hovedbilde ennå.</p>
        )}
        <form method="post" action={`/api/projects/${p.id}/photo`} enctype="multipart/form-data" class="space-y-2">
          <input
            type="file"
            name="hero_photo"
            accept="image/*"
            class="block w-full text-xs text-charcoal/70 file:mr-3 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-medium file:bg-sage-100 file:text-sage-900 hover:file:bg-sage-500 hover:file:text-linen file:cursor-pointer file:transition-colors"
          />
          <div class="flex gap-2">
            <button
              type="submit"
              class="flex-1 bg-charcoal text-linen px-3 py-2 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors"
            >
              {heroUrl ? 'Bytt bilde' : 'Last opp'}
            </button>
            {heroUrl && (
              <button
                type="submit"
                formnovalidate
                onclick={`event.preventDefault(); if(confirm('Fjern hovedbilde?')) { this.form.querySelector('input[type=file]').value=''; this.form.submit(); }`}
                class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors px-3"
              >
                Fjern
              </button>
            )}
          </div>
        </form>
      </div>

      <!-- Share -->
      <div class="bg-white rounded-3xl p-6 border border-sage-500/10">
        <h2 class="font-serif text-lg mb-3">Deling</h2>
        {shareUrl ? (
          <>
            <p class="text-xs text-charcoal/55 mb-2">Prosjektet er offentlig på:</p>
            <div class="flex gap-2 items-center bg-linen rounded-xl px-3 py-2 mb-3">
              <input
                type="text"
                value={shareUrl}
                readonly
                class="flex-1 bg-transparent text-xs text-charcoal/80 focus:outline-none truncate"
                data-share-url
              />
              <button
                type="button"
                class="text-[10px] font-bold uppercase tracking-wider text-sage-900 hover:text-terracotta-500 transition-colors whitespace-nowrap"
                data-copy-share
              >
                Kopier
              </button>
            </div>
            <a
              href={shareUrl}
              target="_blank"
              rel="noopener"
              class="text-xs text-terracotta-500 hover:underline block mb-4"
            >
              Åpne delt side ↗
            </a>

            <div class="border-t border-sage-500/10 pt-4 mb-3">
              <h3 class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">For Instagram</h3>
              {heroUrl ? (
                <a
                  href={heroUrl}
                  download
                  class="block text-center text-xs font-medium text-charcoal/80 hover:text-terracotta-500 transition-colors py-2 border border-sage-500/15 rounded-full"
                >
                  Last ned hovedbilde
                </a>
              ) : (
                <p class="text-[11px] text-charcoal/50 italic">Last opp et hovedbilde for å laste det ned for Instagram.</p>
              )}
              <p class="text-[10px] text-charcoal/40 mt-2 leading-relaxed">
                Branded delingskort med tittel og merkevare kommer snart — for nå deler du selve bildet, med lenke til siden i caption: <code class="text-[10px] text-charcoal/60">{shareUrl}</code>
              </p>
            </div>

            <form method="post" action={`/api/projects/${p.id}/share`}>
              <input type="hidden" name="share" value="false" />
              <button
                type="submit"
                class="w-full text-xs text-charcoal/55 hover:text-terracotta-500 transition-colors py-2"
                onclick="return confirm('Slutte å dele dette prosjektet?')"
              >
                Slutt å dele
              </button>
            </form>
          </>
        ) : (
          <>
            <p class="text-xs text-charcoal/55 mb-3">Lag en offentlig lenke som hvem som helst kan se. Hovedbilde, detaljer og logger blir delt.</p>
            <form method="post" action={`/api/projects/${p.id}/share`}>
              <input type="hidden" name="share" value="true" />
              <button
                type="submit"
                class="w-full bg-charcoal text-linen px-3 py-2.5 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors"
              >
                Del prosjekt
              </button>
            </form>
          </>
        )}
      </div>

      <form method="post" action={`/api/projects/${p.id}/delete`}>
        <button
          type="submit"
          class="w-full text-xs text-charcoal/40 hover:text-terracotta-500 transition-colors py-2"
          onclick="return confirm('Slett dette prosjektet permanent? Alle logger forsvinner.')"
        >
          Slett prosjekt
        </button>
      </form>
    </aside>
  </div>
</StudioLayout>

<script>
  document.querySelector('[data-copy-share]')?.addEventListener('click', () => {
    const input = document.querySelector<HTMLInputElement>('[data-share-url]');
    if (!input) return;
    navigator.clipboard.writeText(input.value).then(() => {
      const btn = document.querySelector<HTMLButtonElement>('[data-copy-share]');
      if (!btn) return;
      const original = btn.textContent;
      btn.textContent = 'Kopiert ✓';
      setTimeout(() => { btn.textContent = original; }, 1600);
    });
  });
</script>
