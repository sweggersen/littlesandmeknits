---
import StudioLayout from '../../../layouts/StudioLayout.astro';
import StudioBackLink from '../../../components/StudioBackLink.astro';
import { createServerSupabase } from '../../../lib/supabase';
import { getEntry } from 'astro:content';
import { projectPhotoUrl } from '../../../lib/storage';
import { getCurrentUser } from '../../../lib/auth';

const { id } = Astro.params;
if (!id) return Astro.redirect('/studio/prosjekter');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });

type ProjectRow = {
  id: string;
  title: string;
  summary: string | null;
  status: 'planning' | 'active' | 'finished' | 'frogged';
  recipient: string | null;
  target_size: string | null;
  yarn: string | null;
  needles: string | null;
  pattern_slug: string | null;
  pattern_external: string | null;
  hero_photo_path: string | null;
  started_at: string | null;
  finished_at: string | null;
  created_at: string;
  updated_at: string;
  public_slug: string | null;
  target_rows: number | null;
  current_rows: number | null;
};

const { data: project, error } = await supabase
  .from('projects')
  .select('id, title, summary, status, recipient, target_size, yarn, needles, pattern_slug, pattern_external, hero_photo_path, started_at, finished_at, created_at, updated_at, public_slug, target_rows, current_rows')
  .eq('id', id)
  .maybeSingle();

if (error || !project) {
  return Astro.redirect('/studio/prosjekter');
}

const p = project as ProjectRow;

type LogRow = {
  id: string;
  body: string;
  log_date: string;
  photos: string[];
  rows_at: number | null;
  created_at: string;
};

const { data: logsData } = await supabase
  .from('project_logs')
  .select('id, body, log_date, photos, rows_at, created_at')
  .eq('project_id', id)
  .order('log_date', { ascending: false })
  .order('created_at', { ascending: false });

const logs = (logsData ?? []) as LogRow[];

const targetRows = p.target_rows ?? null;
const currentRows = p.current_rows ?? null;
const progressPct = targetRows && targetRows > 0 && currentRows !== null
  ? Math.min(100, Math.round((currentRows / targetRows) * 100))
  : null;

// Linked yarns from the stash (with grams used + deduction state).
type ProjectYarnLink = {
  id: string;
  yarn_id: string;
  grams_used: number;
  deducted_at: string | null;
  yarns: {
    brand: string;
    name: string;
    color: string | null;
    total_grams: number | null;
  } | null;
};
const { data: yarnLinksData } = await supabase
  .from('project_yarns')
  .select('id, yarn_id, grams_used, deducted_at, yarns(brand, name, color, total_grams)')
  .eq('project_id', id)
  .order('created_at', { ascending: true });
const yarnLinks = (yarnLinksData ?? []) as ProjectYarnLink[];

// All yarns in the user's stash for the picker.
type StashYarnRow = {
  id: string;
  brand: string;
  name: string;
  color: string | null;
  total_grams: number | null;
};
const { data: stashData } = await supabase
  .from('yarns')
  .select('id, brand, name, color, total_grams')
  .order('brand', { ascending: true })
  .order('name', { ascending: true });
const stash = (stashData ?? []) as StashYarnRow[];
const linkedYarnIds = new Set(yarnLinks.map((l) => l.yarn_id));
const availableStash = stash.filter((y) => !linkedYarnIds.has(y.id));

const patternEntry = p.pattern_slug ? await getEntry('patterns', p.pattern_slug) : null;
const heroUrl = projectPhotoUrl(p.hero_photo_path);

const statusLabels = {
  planning: 'Planlegges',
  active: 'I gang',
  finished: 'Ferdig',
  frogged: 'Røket opp',
} as const;

const statusClass = {
  planning: 'bg-oatmeal text-charcoal/70',
  active: 'bg-sage-100 text-sage-900',
  finished: 'bg-terracotta-500/10 text-terracotta-500',
  frogged: 'bg-charcoal/10 text-charcoal/60',
} as const;

// Inline-style palette for the offscreen share-card scaffold (Tailwind classes
// can't be relied on for the 1080×1350 / 1080×1920 dimensions, so we hardcode
// the brand tones the satori version used to produce).
const statusPillBg = {
  planning: '#E8DFD0',
  active: '#E8EFE3',
  finished: '#FBEAE3',
  frogged: '#E5E3DD',
} as const;
const statusPillFg = {
  planning: '#5B544A',
  active: '#4A5A3F',
  finished: '#C76D4E',
  frogged: '#6F6A60',
} as const;

const today = new Date().toISOString().slice(0, 10);

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://www.littlesandmeknits.com';
const shareUrl = p.public_slug ? `${siteUrl}/p/${p.public_slug}` : null;
const cardSummary = p.summary ?? null;
const cardMeta = [p.recipient && `For ${p.recipient}`, p.yarn].filter(Boolean).join(' · ');

// User profile bits used by the share card + caption builder.
const profileUser = await getCurrentUser({ request: Astro.request, cookies: Astro.cookies });
const profileMeta = (profileUser?.user_metadata ?? {}) as {
  display_name?: string;
  instagram_handle?: string;
};
const igHandle = profileMeta.instagram_handle?.replace(/^@+/, '').trim() || null;
const designerLine = igHandle ? `@${igHandle}` : 'Littles and Me';
---

<StudioLayout title={`${p.title} — Littles and Me`} lang="nb">
  <StudioBackLink href="/studio/prosjekter">Prosjekter</StudioBackLink>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main column -->
    <div class="lg:col-span-2">
      {heroUrl && (
        <div class="aspect-[16/10] rounded-3xl overflow-hidden bg-oatmeal mb-6 border border-sage-500/10">
          <img src={heroUrl} alt={p.title} class="w-full h-full object-cover" loading="lazy" />
        </div>
      )}

      <header class="flex items-start justify-between gap-4 mb-6">
        <div class="flex-1 min-w-0">
          <span class={`text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full ${statusClass[p.status]}`}>
            {statusLabels[p.status]}
          </span>
          <h1 class="font-serif text-3xl sm:text-4xl mt-3 leading-tight">{p.title}</h1>
          {p.summary && (
            <p class="text-charcoal/65 mt-3 leading-relaxed">{p.summary}</p>
          )}
        </div>
      </header>

      <!-- Fremdrift / progress -->
      <section class="bg-white rounded-3xl p-6 border border-sage-500/10 mb-8">
        <details class="group">
          <summary class="flex items-baseline justify-between gap-3 cursor-pointer list-none">
            <h2 class="font-serif text-lg">Fremdrift</h2>
            {progressPct !== null ? (
              <span class="text-sm text-charcoal/65 font-medium">
                {currentRows} / {targetRows} rader · {progressPct}%
              </span>
            ) : currentRows !== null ? (
              <span class="text-sm text-charcoal/65 font-medium">{currentRows} rader</span>
            ) : (
              <span class="text-xs text-charcoal/45">Sett mål for å vise fremdrift</span>
            )}
          </summary>

          {progressPct !== null && (
            <div class="mt-4 h-2 bg-sage-500/10 rounded-full overflow-hidden">
              <div
                class="h-full bg-sage-500 transition-all"
                style={`width: ${progressPct}%`}
              ></div>
            </div>
          )}

          <form method="post" action={`/api/projects/${p.id}/progress`} class="mt-5 grid grid-cols-1 sm:grid-cols-3 gap-3 items-end">
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">Rader strikket</label>
              <input
                type="number"
                name="current_rows"
                min="0"
                step="1"
                value={currentRows ?? ''}
                placeholder="0"
                class="w-full bg-linen rounded-xl px-3 py-2 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500"
              />
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">Mål (totalt)</label>
              <input
                type="number"
                name="target_rows"
                min="0"
                step="1"
                value={targetRows ?? ''}
                placeholder="—"
                class="w-full bg-linen rounded-xl px-3 py-2 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500"
              />
            </div>
            <button
              type="submit"
              class="bg-charcoal text-linen px-4 py-2 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors"
            >
              Lagre
            </button>
          </form>
        </details>
      </section>

      <!-- Garn brukt / yarns from stash -->
      <section class="bg-white rounded-3xl p-6 border border-sage-500/10 mb-8">
        <details class="group" open={yarnLinks.length > 0}>
          <summary class="flex items-baseline justify-between gap-3 cursor-pointer list-none">
            <h2 class="font-serif text-lg">Garn brukt</h2>
            {yarnLinks.length > 0 ? (
              <span class="text-sm text-charcoal/65 font-medium">
                {yarnLinks.length} {yarnLinks.length === 1 ? 'nøste' : 'nøster'} ·
                {' '}{yarnLinks.reduce((s, l) => s + (l.grams_used ?? 0), 0)} g
              </span>
            ) : (
              <span class="text-xs text-charcoal/45">Knytt garn fra lageret for å trekke fra automatisk når prosjektet er ferdig.</span>
            )}
          </summary>

          {yarnLinks.length > 0 && (
            <ul class="mt-4 space-y-2">
              {yarnLinks.map((link) => (
                <li class="flex items-center justify-between gap-3 bg-linen rounded-xl px-4 py-2.5">
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium truncate">
                      {link.yarns?.brand} {link.yarns?.name}
                      {link.yarns?.color && <span class="text-charcoal/55"> · {link.yarns.color}</span>}
                    </p>
                    <p class="text-xs text-charcoal/55">
                      {link.grams_used} g
                      {link.deducted_at ? (
                        <span class="text-sage-900 font-medium ml-2">✓ trukket fra lager</span>
                      ) : (
                        link.yarns?.total_grams !== null && link.yarns?.total_grams !== undefined && (
                          <span class="ml-2">av {link.yarns.total_grams} g i lager</span>
                        )
                      )}
                    </p>
                  </div>
                  <form method="post" action={`/api/projects/${p.id}/yarn/${link.id}/delete`} class="inline">
                    <button
                      type="submit"
                      class="text-[11px] text-charcoal/40 hover:text-terracotta-500 transition-colors"
                      onclick="return confirm('Fjerne denne garnkoblingen? Hvis prosjektet er ferdig, legges grammene tilbake i lageret.')"
                    >
                      Fjern
                    </button>
                  </form>
                </li>
              ))}
            </ul>
          )}

          {availableStash.length > 0 ? (
            <form method="post" action={`/api/projects/${p.id}/yarn`} class="mt-4 grid grid-cols-1 sm:grid-cols-[1fr_120px_auto] gap-3 items-end">
              <div>
                <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">Garn fra lager</label>
                <select name="yarn_id" required class="w-full bg-linen rounded-xl px-3 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500">
                  {availableStash.map((y) => (
                    <option value={y.id}>
                      {y.brand} {y.name}{y.color ? ` · ${y.color}` : ''}{y.total_grams ? ` (${y.total_grams} g)` : ''}
                    </option>
                  ))}
                </select>
              </div>
              <div>
                <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">Brukt (g)</label>
                <input type="number" name="grams_used" required min="0" step="10" placeholder="100" class="w-full bg-linen rounded-xl px-3 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500" />
              </div>
              <button type="submit" class="bg-charcoal text-linen px-4 py-2 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors">
                Knytt garn
              </button>
            </form>
          ) : stash.length === 0 ? (
            <p class="mt-4 text-xs text-charcoal/45">
              Ingen garn i lageret ennå. <a href="/studio/garn/ny" class="text-terracotta-500 hover:underline">Legg til et garn</a> for å kunne knytte det til prosjekter.
            </p>
          ) : (
            <p class="mt-4 text-xs text-charcoal/45">Alle garnene fra lageret er allerede knyttet til dette prosjektet.</p>
          )}

          {p.status === 'finished' && yarnLinks.length > 0 && yarnLinks.every((l) => l.deducted_at) && (
            <p class="mt-4 text-xs text-sage-900">Garnene er trukket fra lageret. De legges automatisk tilbake hvis du endrer status.</p>
          )}
        </details>
      </section>

      <!-- Add a log -->
      <section class="bg-white rounded-3xl p-6 border border-sage-500/10 mb-8">
        <h2 class="font-serif text-lg mb-4">Ny logg</h2>
        <form method="post" action={`/api/projects/${p.id}/log`} enctype="multipart/form-data" class="space-y-3">
          <textarea
            name="body"
            required
            rows="4"
            maxlength="4000"
            placeholder="Hva skjedde i dag? Antall masker, endringer i mønsteret, hvordan det ser ut…"
            class="w-full bg-linen rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors resize-none"
          ></textarea>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">Bilder (valgfritt, opptil 6)</label>
            <input
              type="file"
              name="photos"
              accept="image/*"
              multiple
              class="block w-full text-sm text-charcoal/70 file:mr-3 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-medium file:bg-sage-100 file:text-sage-900 hover:file:bg-sage-500 hover:file:text-linen file:cursor-pointer file:transition-colors"
            />
          </div>
          <div class="flex items-center justify-between gap-3 pt-2 flex-wrap">
            <div class="flex items-center gap-2">
              <input
                type="date"
                name="log_date"
                value={today}
                class="bg-linen rounded-xl px-3 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors"
              />
              <input
                type="number"
                name="rows_at"
                min="0"
                step="1"
                placeholder="rad nr."
                title="Hvilken rad er du på? (valgfritt)"
                class="w-24 bg-linen rounded-xl px-3 py-2 text-sm border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors"
              />
            </div>
            <button
              type="submit"
              class="bg-charcoal text-linen px-5 py-2.5 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors"
            >
              Legg til logg
            </button>
          </div>
        </form>
      </section>

      <!-- Logs timeline -->
      <section>
        <h2 class="font-serif text-lg mb-4">Tidslinje</h2>
        {logs.length === 0 ? (
          <p class="text-sm text-charcoal/50 italic">Ingen loggføringer ennå. Legg til en over for å begynne.</p>
        ) : (
          <ol class="space-y-4">
            {logs.map((log) => (
              <li class="bg-white rounded-2xl p-5 border border-sage-500/10">
                <div class="flex items-baseline justify-between mb-2">
                  <div class="flex items-baseline gap-3 flex-wrap">
                    <time class="text-xs font-bold uppercase tracking-wider text-sage-900">
                      {new Date(log.log_date).toLocaleDateString('nb-NO', { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric' })}
                    </time>
                    {log.rows_at !== null && log.rows_at !== undefined && (
                      <span class="text-[10px] font-medium uppercase tracking-wider text-charcoal/45">
                        Rad {log.rows_at}
                      </span>
                    )}
                  </div>
                  <form method="post" action={`/api/projects/${p.id}/log/${log.id}/delete`} class="inline">
                    <button
                      type="submit"
                      class="text-[11px] text-charcoal/40 hover:text-terracotta-500 transition-colors"
                      onclick="return confirm('Slette denne loggen?')"
                    >
                      Slett
                    </button>
                  </form>
                </div>
                <p class="text-sm text-charcoal/80 leading-relaxed whitespace-pre-wrap">{log.body}</p>
                {log.photos && log.photos.length > 0 && (
                  <div class={`mt-4 grid gap-2 ${log.photos.length === 1 ? 'grid-cols-1' : log.photos.length === 2 ? 'grid-cols-2' : 'grid-cols-3'}`}>
                    {log.photos.map((path) => (
                      <a href={projectPhotoUrl(path)} target="_blank" rel="noopener" class="aspect-square rounded-xl overflow-hidden bg-oatmeal hover:opacity-90 transition-opacity">
                        <img src={projectPhotoUrl(path)} alt="" class="w-full h-full object-cover" loading="lazy" />
                      </a>
                    ))}
                  </div>
                )}
              </li>
            ))}
          </ol>
        )}
      </section>
    </div>

    <!-- Sidebar -->
    <aside class="lg:col-span-1 space-y-5">
      <!-- Details -->
      <div class="bg-white rounded-3xl p-6 border border-sage-500/10">
        <h2 class="font-serif text-lg mb-4">Detaljer</h2>
        <dl class="space-y-3 text-sm">
          {p.recipient && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">For</dt>
              <dd>{p.recipient}</dd>
            </div>
          )}
          {patternEntry && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Oppskrift</dt>
              <dd>
                <a href={`/oppskrifter/${p.pattern_slug}`} class="text-terracotta-500 hover:underline" target="_blank" rel="noopener">
                  {patternEntry.data.title.nb}
                </a>
              </dd>
            </div>
          )}
          {!patternEntry && p.pattern_external && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Oppskrift</dt>
              <dd>{p.pattern_external}</dd>
            </div>
          )}
          {p.target_size && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Størrelse</dt>
              <dd>{p.target_size}</dd>
            </div>
          )}
          {p.yarn && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Garn</dt>
              <dd>{p.yarn}</dd>
            </div>
          )}
          {p.needles && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Pinner</dt>
              <dd>{p.needles}</dd>
            </div>
          )}
          <div>
            <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Opprettet</dt>
            <dd class="text-charcoal/60">{new Date(p.created_at).toLocaleDateString('nb-NO')}</dd>
          </div>
        </dl>

        <div class="mt-6 pt-6 border-t border-sage-500/10">
          <form method="post" action={`/api/projects/${p.id}/status`}>
            <label class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 block mb-2">
              Status
            </label>
            <div class="flex gap-2">
              <select
                name="status"
                class="flex-1 bg-linen rounded-xl px-3 py-2 text-sm border border-sage-500/15"
              >
                <option value="planning" selected={p.status === 'planning'}>Planlegges</option>
                <option value="active" selected={p.status === 'active'}>I gang</option>
                <option value="finished" selected={p.status === 'finished'}>Ferdig</option>
                <option value="frogged" selected={p.status === 'frogged'}>Røket opp</option>
              </select>
              <button
                type="submit"
                class="bg-charcoal text-linen px-3 rounded-xl text-xs font-medium hover:bg-terracotta-500 transition-colors"
              >
                Lagre
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Hero photo -->
      <div class="bg-white rounded-3xl p-6 border border-sage-500/10">
        <h2 class="font-serif text-lg mb-3">Hovedbilde</h2>
        {heroUrl ? (
          <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-oatmeal mb-3">
            <img src={heroUrl} alt="" class="w-full h-full object-cover" />
          </div>
        ) : (
          <p class="text-xs text-charcoal/50 italic mb-3">Ingen hovedbilde ennå.</p>
        )}
        <form method="post" action={`/api/projects/${p.id}/photo`} enctype="multipart/form-data" class="space-y-2">
          <input
            type="file"
            name="hero_photo"
            accept="image/*"
            class="block w-full text-xs text-charcoal/70 file:mr-3 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-medium file:bg-sage-100 file:text-sage-900 hover:file:bg-sage-500 hover:file:text-linen file:cursor-pointer file:transition-colors"
          />
          <div class="flex gap-2">
            <button
              type="submit"
              class="flex-1 bg-charcoal text-linen px-3 py-2 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors"
            >
              {heroUrl ? 'Bytt bilde' : 'Last opp'}
            </button>
            {heroUrl && (
              <button
                type="submit"
                formnovalidate
                onclick={`event.preventDefault(); if(confirm('Fjern hovedbilde?')) { this.form.querySelector('input[type=file]').value=''; this.form.submit(); }`}
                class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors px-3"
              >
                Fjern
              </button>
            )}
          </div>
        </form>
      </div>

      <!-- Share -->
      <div class="bg-white rounded-3xl p-6 border border-sage-500/10">
        <h2 class="font-serif text-lg mb-3">Deling</h2>
        {shareUrl ? (
          <>
            <p class="text-xs text-charcoal/55 mb-2">Prosjektet er offentlig på:</p>
            <div class="flex gap-2 items-center bg-linen rounded-xl px-3 py-2 mb-3">
              <input
                type="text"
                value={shareUrl}
                readonly
                class="flex-1 bg-transparent text-xs text-charcoal/80 focus:outline-none truncate"
                data-share-url
              />
              <button
                type="button"
                class="text-[10px] font-bold uppercase tracking-wider text-sage-900 hover:text-terracotta-500 transition-colors whitespace-nowrap"
                data-copy-share
              >
                Kopier
              </button>
            </div>
            <a
              href={shareUrl}
              target="_blank"
              rel="noopener"
              class="text-xs text-terracotta-500 hover:underline block mb-4"
            >
              Åpne delt side ↗
            </a>

            <div class="border-t border-sage-500/10 pt-4 mb-3">
              <h3 class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">For Instagram</h3>
              <div class="grid grid-cols-2 gap-2 mb-2">
                <button
                  type="button"
                  data-share-card="feed"
                  class="block text-center text-xs font-medium text-charcoal/80 hover:text-terracotta-500 transition-colors py-2 border border-sage-500/15 rounded-full disabled:opacity-50 disabled:cursor-wait"
                >
                  Feed (4:5)
                </button>
                <button
                  type="button"
                  data-share-card="story"
                  class="block text-center text-xs font-medium text-charcoal/80 hover:text-terracotta-500 transition-colors py-2 border border-sage-500/15 rounded-full disabled:opacity-50 disabled:cursor-wait"
                >
                  Story (9:16)
                </button>
              </div>
              <button
                type="button"
                data-share-caption
                class="w-full mt-2 text-center text-xs font-medium text-charcoal/80 hover:text-terracotta-500 transition-colors py-2 border border-sage-500/15 rounded-full"
              >
                Kopier caption
              </button>
              <p class="text-[10px] text-charcoal/45 leading-relaxed mt-3" data-share-status>
                Brandede delingskort. Trykk for å laste ned. Bruk «Kopier caption» og lim inn i Instagram-posten.
              </p>
              {!igHandle && (
                <p class="text-[10px] text-charcoal/55 mt-2">
                  Tips: Legg til Instagram-handle på <a href="/studio/profil" class="text-terracotta-500 hover:underline">profilen din</a> så blir den med på kortet og i caption.
                </p>
              )}
            </div>

            <form method="post" action={`/api/projects/${p.id}/share`}>
              <input type="hidden" name="share" value="false" />
              <button
                type="submit"
                class="w-full text-xs text-charcoal/55 hover:text-terracotta-500 transition-colors py-2"
                onclick="return confirm('Slutte å dele dette prosjektet?')"
              >
                Slutt å dele
              </button>
            </form>
          </>
        ) : (
          <>
            <p class="text-xs text-charcoal/55 mb-3">Lag en offentlig lenke som hvem som helst kan se. Hovedbilde, detaljer og logger blir delt.</p>
            <form method="post" action={`/api/projects/${p.id}/share`}>
              <input type="hidden" name="share" value="true" />
              <button
                type="submit"
                class="w-full bg-charcoal text-linen px-3 py-2.5 rounded-full text-xs font-medium hover:bg-terracotta-500 transition-colors"
              >
                Del prosjekt
              </button>
            </form>
          </>
        )}
      </div>

      <form method="post" action={`/api/projects/${p.id}/delete`}>
        <button
          type="submit"
          class="w-full text-xs text-charcoal/40 hover:text-terracotta-500 transition-colors py-2"
          onclick="return confirm('Slett dette prosjektet permanent? Alle logger forsvinner.')"
        >
          Slett prosjekt
        </button>
      </form>
    </aside>
  </div>

  {p.public_slug && (
    <div
      aria-hidden="true"
      data-share-root
      data-share-slug={p.public_slug}
      data-share-title={p.title}
      data-share-summary={p.summary ?? ''}
      data-share-url={shareUrl ?? ''}
      data-share-handle={igHandle ?? ''}
      style="position:fixed; left:-99999px; top:0; pointer-events:none; opacity:1;"
    >
      {/* Feed card 1080×1350 */}
      <div
        data-share-scaffold="feed"
        style={`width:1080px; height:1350px; background:#FAF6F0; font-family:'Inter','Inter Variable',system-ui,sans-serif; display:flex; flex-direction:column;`}
      >
        <div
          style={`width:100%; height:780px; background-color:#E8DFD0; ${heroUrl ? `background-image:url('${heroUrl}'); background-size:cover; background-position:center;` : ''}`}
        ></div>
        <div style="flex:1; padding:60px 80px; display:flex; flex-direction:column; justify-content:space-between;">
          <div style="display:flex; flex-direction:column; gap:20px;">
            <span style={`align-self:flex-start; font-size:20px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; padding:10px 22px; border-radius:999px; background:${statusPillBg[p.status]}; color:${statusPillFg[p.status]};`}>
              {statusLabels[p.status]}
            </span>
            <div style="font-family:'Fraunces','Fraunces Variable',serif; font-size:76px; font-weight:500; line-height:1.05; color:#2C2A26; letter-spacing:-0.01em;">{p.title}</div>
            {cardSummary && (
              <div style="font-size:24px; color:rgba(44,42,38,0.7); line-height:1.4;">
                {cardSummary.length > 110 ? cardSummary.slice(0, 107) + '…' : cardSummary}
              </div>
            )}
            {cardMeta && (
              <div style="font-size:22px; color:rgba(44,42,38,0.55);">{cardMeta}</div>
            )}
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center; padding-top:24px; border-top:1px solid rgba(0,0,0,0.08);">
            <div style="font-family:'Fraunces','Fraunces Variable',serif; font-size:28px; color:#2C2A26; font-weight:500;">Littles and Me</div>
            <div style="font-size:18px; color:#C76D4E; font-weight:600; letter-spacing:0.14em;">
              {igHandle ? `@${igHandle}` : `littlesandmeknits.com/p/${p.public_slug}`}
            </div>
          </div>
        </div>
      </div>

      {/* Story card 1080×1920 */}
      <div
        data-share-scaffold="story"
        style={`width:1080px; height:1920px; background-color:#2C2A26; ${heroUrl ? `background-image:url('${heroUrl}'); background-size:cover; background-position:center;` : ''} font-family:'Inter','Inter Variable',system-ui,sans-serif; color:#FAF6F0; position:relative;`}
      >
        <div style="position:absolute; inset:0; background:linear-gradient(180deg, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0) 22%, rgba(0,0,0,0) 55%, rgba(0,0,0,0.78) 100%); padding:120px 90px; display:flex; flex-direction:column; justify-content:space-between;">
          <div style="text-align:center; font-family:'Fraunces','Fraunces Variable',serif; font-style:italic; font-size:28px; letter-spacing:0.22em; text-transform:uppercase; opacity:0.92;">Littles and Me</div>
          <div style="display:flex; flex-direction:column; gap:28px; align-items:center; text-align:center;">
            <span style="background:#C76D4E; color:#FAF6F0; font-size:22px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; padding:12px 26px; border-radius:999px;">
              {statusLabels[p.status]}
            </span>
            <div style="font-family:'Fraunces','Fraunces Variable',serif; font-size:108px; font-weight:500; line-height:1.04; letter-spacing:-0.01em; max-width:900px;">{p.title}</div>
            {cardSummary && (
              <div style="font-family:'Fraunces','Fraunces Variable',serif; font-style:italic; font-size:32px; line-height:1.4; opacity:0.9; max-width:780px;">
                {cardSummary.length > 130 ? cardSummary.slice(0, 127) + '…' : cardSummary}
              </div>
            )}
            <div style="margin-top:20px; padding-top:24px; border-top:1px solid rgba(255,255,255,0.3); font-size:22px; letter-spacing:0.18em; opacity:0.85;">
              {igHandle ? `@${igHandle}` : `littlesandmeknits.com/p/${p.public_slug}`}
            </div>
          </div>
        </div>
      </div>
    </div>
  )}
</StudioLayout>

<script>
  document.querySelector<HTMLElement>('[data-copy-share]')?.addEventListener('click', () => {
    const input = document.querySelector<HTMLInputElement>('[data-share-url]');
    if (!input) return;
    navigator.clipboard.writeText(input.value).then(() => {
      const btn = document.querySelector<HTMLButtonElement>('[data-copy-share]');
      if (!btn) return;
      const original = btn.textContent;
      btn.textContent = 'Kopiert ✓';
      setTimeout(() => { btn.textContent = original; }, 1600);
    });
  });

  const shareRoot = document.querySelector<HTMLElement>('[data-share-root]');
  const slug = shareRoot?.dataset.shareSlug ?? null;
  const shareTitle = shareRoot?.dataset.shareTitle ?? '';
  const shareSummary = shareRoot?.dataset.shareSummary ?? '';
  const shareUrlValue = shareRoot?.dataset.shareUrl ?? '';
  const shareHandle = shareRoot?.dataset.shareHandle ?? '';

  function buildCaption(): string {
    const lines: string[] = [];
    if (shareTitle) lines.push(shareTitle);
    if (shareSummary) lines.push('', shareSummary);
    lines.push('');
    if (shareHandle) {
      lines.push(`Strikket av @${shareHandle}`);
    }
    if (shareUrlValue) lines.push(`Hele prosjektet: ${shareUrlValue}`);
    lines.push('', '#strikking #strikkemamma #littlesandme');
    return lines.join('\n');
  }

  const captionBtn = document.querySelector<HTMLButtonElement>('[data-share-caption]');
  captionBtn?.addEventListener('click', async () => {
    const caption = buildCaption();
    const status = document.querySelector<HTMLElement>('[data-share-status]');
    const setStatus = (msg: string) => { if (status) status.textContent = msg; };
    try {
      await navigator.clipboard.writeText(caption);
      const original = captionBtn.textContent;
      captionBtn.textContent = 'Kopiert ✓';
      setStatus('Caption kopiert til utklippstavla. Lim inn på Instagram.');
      setTimeout(() => { if (captionBtn) captionBtn.textContent = original; }, 2000);
    } catch {
      setStatus('Klarte ikke å kopiere — marker tekst manuelt og prøv igjen.');
    }
  });

  if (slug) {
    const status = document.querySelector<HTMLElement>('[data-share-status]');
    const setStatus = (msg: string) => { if (status) status.textContent = msg; };

    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-share-card]');
    buttons.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const format = btn.getAttribute('data-share-card');
        if (!format) return;
        const scaffold = document.querySelector<HTMLElement>(`[data-share-scaffold="${format}"]`);
        if (!scaffold) return;

        buttons.forEach((b) => { b.disabled = true; });
        const originalLabel = btn.textContent;
        btn.textContent = 'Genererer…';

        try {
          if (document.fonts && document.fonts.ready) await document.fonts.ready;
          const { toPng } = await import('html-to-image');
          const dataUrl = await toPng(scaffold, {
            pixelRatio: 1,
            cacheBust: true,
            // Avoid CORS taint on Supabase-hosted hero photos.
            fetchRequestInit: { mode: 'cors', credentials: 'omit' },
          });
          const a = document.createElement('a');
          a.href = dataUrl;
          a.download = `${slug}-${format}.png`;
          document.body.appendChild(a);
          a.click();
          a.remove();
          setStatus('Lastet ned. Last opp på Instagram, og lim inn lenken i caption.');
        } catch (err) {
          console.error('share card render failed', err);
          setStatus('Kunne ikke lage delingskort. Prøv igjen, eller bruk hovedbildet manuelt.');
        } finally {
          buttons.forEach((b) => { b.disabled = false; });
          btn.textContent = originalLabel;
        }
      });
    });
  }
</script>
