---
import StudioLayout from '../../../layouts/StudioLayout.astro';
import StudioSubNav from '../../../components/StudioSubNav.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import EmptyState from '../../../components/EmptyState.astro';
import { createServerSupabase } from '../../../lib/supabase';
import { getCurrentUser } from '../../../lib/auth';

type ProjectRow = {
  id: string;
  title: string;
  summary: string | null;
  status: 'planning' | 'active' | 'finished' | 'frogged';
  recipient: string | null;
  pattern_slug: string | null;
  pattern_external: string | null;
  hero_photo_path: string | null;
  started_at: string | null;
  finished_at: string | null;
  created_at: string;
  public_slug: string | null;
};

const user = await getCurrentUser({ request: Astro.request, cookies: Astro.cookies });
if (!user) return Astro.redirect('/logg-inn?next=/studio/prosjekter');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const { data } = await supabase
  .from('projects')
  .select('id, title, summary, status, recipient, pattern_slug, pattern_external, hero_photo_path, started_at, finished_at, created_at, public_slug')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false });

const allProjects = (data ?? []) as ProjectRow[];

const VALID_FILTERS = ['alle', 'active', 'planning', 'finished', 'frogged'] as const;
type Filter = (typeof VALID_FILTERS)[number];
const filterParam = Astro.url.searchParams.get('status');
const filter: Filter = (VALID_FILTERS as readonly string[]).includes(filterParam ?? '')
  ? (filterParam as Filter)
  : 'alle';

const projects = filter === 'alle' ? allProjects : allProjects.filter((p) => p.status === filter);

const counts = {
  alle: allProjects.length,
  active: allProjects.filter((p) => p.status === 'active').length,
  planning: allProjects.filter((p) => p.status === 'planning').length,
  finished: allProjects.filter((p) => p.status === 'finished').length,
  frogged: allProjects.filter((p) => p.status === 'frogged').length,
} as const;

const filterTabs: Array<{ key: Filter; label: string; count: number }> = [
  { key: 'alle', label: 'Alle', count: counts.alle },
  { key: 'active', label: 'Pågående', count: counts.active },
  { key: 'planning', label: 'Planlagte', count: counts.planning },
  { key: 'finished', label: 'Ferdige', count: counts.finished },
  { key: 'frogged', label: 'Røket opp', count: counts.frogged },
];

---

<StudioLayout title="Prosjekter — Littles and Me" lang="nb">
  {allProjects.length > 0 && (
    <StudioSubNav
      items={filterTabs.map((tab) => ({
        key: tab.key,
        label: tab.label,
        href: tab.key === 'alle' ? '/studio/prosjekter' : `/studio/prosjekter?status=${tab.key}`,
        count: tab.count,
      }))}
      active={filter}
    />
  )}

  <div class="flex items-center justify-between mb-6 gap-4 flex-wrap">
    <h1 class="font-serif text-3xl sm:text-4xl">Prosjekter</h1>
    <a
      href="/studio/prosjekter/ny"
      class="bg-charcoal text-linen px-5 py-2.5 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors"
    >
      + Nytt prosjekt
    </a>
  </div>

  {allProjects.length === 0 ? (
    <EmptyState message="Ingen prosjekter ennå. Start ditt første for å samle bilder, fremgang og notater på ett sted." ctaText="Start et prosjekt" ctaHref="/studio/prosjekter/ny" />
  ) : projects.length === 0 ? (
    <EmptyState message="Ingen prosjekter med denne statusen." compact />
  ) : (
    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map((p) => (
        <ProjectCard
          id={p.id}
          title={p.title}
          status={p.status}
          heroPhotoPath={p.hero_photo_path}
          summary={p.summary}
          recipient={p.recipient}
          patternLabel={p.pattern_slug ?? p.pattern_external}
          createdAt={p.created_at}
          publicSlug={p.public_slug}
        />
      ))}
    </ul>
  )}
</StudioLayout>
