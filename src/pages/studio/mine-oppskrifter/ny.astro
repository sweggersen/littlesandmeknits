---
import StudioLayout from '../../../layouts/StudioLayout.astro';
import StudioBackLink from '../../../components/StudioBackLink.astro';
---

<StudioLayout title="Last opp oppskrift — Littles and Me" lang="nb">
  <div class="max-w-2xl">
    <StudioBackLink href="/studio/mine-oppskrifter">Mine oppskrifter</StudioBackLink>
    <h1 class="font-serif text-3xl sm:text-4xl mb-8">Ny oppskrift</h1>

    <form method="post" action="/api/external-patterns/create" enctype="multipart/form-data" class="bg-white rounded-3xl p-6 sm:p-8 border border-sage-500/10 space-y-6">
      <div>
        <label for="title" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">
          Tittel *
        </label>
        <input
          id="title"
          name="title"
          type="text"
          required
          maxlength="120"
          placeholder="Mariusgenser, Strikkemagasinet 03/24…"
          class="w-full bg-linen rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors"
        />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="designer" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">
            Designer
          </label>
          <input
            id="designer"
            name="designer"
            type="text"
            maxlength="120"
            placeholder="Unni Strand"
            class="w-full bg-linen rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors"
          />
        </div>
        <div>
          <label for="source_url" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">
            Lenke til kilde
          </label>
          <input
            id="source_url"
            name="source_url"
            type="url"
            maxlength="400"
            placeholder="https://…"
            class="w-full bg-linen rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors"
          />
        </div>
      </div>

      <div>
        <label for="file" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">
          Selve oppskriften (PDF eller bilde)
        </label>
        <input
          id="file"
          name="file"
          type="file"
          accept="application/pdf,image/*"
          class="block w-full text-sm text-charcoal/70 file:mr-4 file:py-2.5 file:px-5 file:rounded-full file:border-0 file:text-sm file:font-medium file:bg-sage-100 file:text-sage-900 hover:file:bg-sage-500 hover:file:text-linen file:cursor-pointer file:transition-colors"
        />
        <p class="text-[11px] text-charcoal/45 mt-2">PDF, JPG eller PNG. Maks 25 MB.</p>
      </div>

      <div>
        <label for="cover" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">
          Forside (valgfritt)
        </label>
        <input
          id="cover"
          name="cover"
          type="file"
          accept="image/*"
          class="block w-full text-sm text-charcoal/70 file:mr-4 file:py-2.5 file:px-5 file:rounded-full file:border-0 file:text-sm file:font-medium file:bg-sage-100 file:text-sage-900 hover:file:bg-sage-500 hover:file:text-linen file:cursor-pointer file:transition-colors"
        />
        <p class="text-[11px] text-charcoal/45 mt-2">Brukes som thumbnail i biblioteket. Hvis du laster opp et bilde over, brukes det som forside automatisk.</p>
      </div>

      <div>
        <label for="notes" class="block text-xs font-bold uppercase tracking-widest text-charcoal/55 mb-2">
          Notater
        </label>
        <textarea
          id="notes"
          name="notes"
          rows="3"
          maxlength="1000"
          placeholder="Hvor er den fra, hvem lånte du den fra, alternative pinnestørrelser…"
          class="w-full bg-linen rounded-xl px-4 py-3 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500 transition-colors resize-none"
        ></textarea>
      </div>

      <div class="flex items-center justify-end gap-3 pt-2">
        <a
          href="/studio/mine-oppskrifter"
          class="text-sm font-medium text-charcoal/60 hover:text-charcoal transition-colors px-4 py-2"
        >
          Avbryt
        </a>
        <button
          type="submit"
          class="bg-charcoal text-linen px-6 py-3 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors"
        >
          Last opp
        </button>
      </div>
    </form>
  </div>
</StudioLayout>
