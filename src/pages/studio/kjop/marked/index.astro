---
import StudioLayout from '../../../../layouts/StudioLayout.astro';
import { getCurrentUser } from '../../../../lib/auth';
import { createServerSupabase } from '../../../../lib/supabase';

const user = await getCurrentUser({ request: Astro.request, cookies: Astro.cookies });
if (!user) return Astro.redirect('/logg-inn?next=/studio/kjop/marked');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const { data: orders } = await supabase
  .from('marketplace_orders')
  .select('id, status, gross_nok, created_at, listing_id')
  .eq('buyer_id', user.id)
  .order('created_at', { ascending: false });

const STATUS_LABEL: Record<string, string> = {
  pending_payment: 'Venter på betaling',
  paid: 'Betalt — venter på utsendelse',
  shipped: 'Sendt',
  delivered: 'Levert',
  released: 'Bekreftet',
  disputed: 'I tvist',
  refunded: 'Refundert',
  cancelled: 'Avbrutt',
};
---

<StudioLayout title="Mine kjøp — Marked" lang="nb">
  <h1 class="font-serif text-3xl sm:text-4xl mb-8">Kjøp fra markedet</h1>

  {(orders ?? []).length === 0 ? (
    <div class="bg-white rounded-3xl p-12 text-center border border-sage-500/10">
      <p class="text-charcoal/55 mb-4">Ingen kjøp ennå.</p>
      <a href="/marked" class="inline-block bg-charcoal text-linen px-5 py-2.5 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors">
        Til markedet
      </a>
    </div>
  ) : (
    <ul class="space-y-2">
      {(orders ?? []).map((o) => (
        <li>
          <a
            href={`/studio/kjop/marked/${o.id}`}
            class="block bg-white rounded-2xl p-4 border border-sage-500/10 hover:border-sage-500/30 transition-colors"
          >
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">
                  {STATUS_LABEL[o.status] ?? o.status}
                </p>
                <p class="text-sm text-charcoal/70">Ordre {o.id.slice(0, 8)}</p>
              </div>
              <p class="font-mono tabular-nums text-sm">{o.gross_nok} NOK</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}
</StudioLayout>
