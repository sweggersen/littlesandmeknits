---
import StudioLayout from '../../layouts/StudioLayout.astro';
import StudioSubNav from '../../components/StudioSubNav.astro';

const needles = [
  { metric: '2.0', us: '0', uk: '14' },
  { metric: '2.25', us: '1', uk: '13' },
  { metric: '2.5', us: '1.5', uk: '—' },
  { metric: '2.75', us: '2', uk: '12' },
  { metric: '3.0', us: '—', uk: '11' },
  { metric: '3.25', us: '3', uk: '10' },
  { metric: '3.5', us: '4', uk: '—' },
  { metric: '3.75', us: '5', uk: '9' },
  { metric: '4.0', us: '6', uk: '8' },
  { metric: '4.5', us: '7', uk: '7' },
  { metric: '5.0', us: '8', uk: '6' },
  { metric: '5.5', us: '9', uk: '5' },
  { metric: '6.0', us: '10', uk: '4' },
  { metric: '6.5', us: '10.5', uk: '3' },
  { metric: '7.0', us: '—', uk: '2' },
  { metric: '7.5', us: '—', uk: '1' },
  { metric: '8.0', us: '11', uk: '0' },
  { metric: '9.0', us: '13', uk: '00' },
  { metric: '10.0', us: '15', uk: '000' },
];

const VALID_TOOLS = ['gauge', 'yardage', 'evenly', 'ruler', 'needles'] as const;
type Tool = (typeof VALID_TOOLS)[number];
const toolParam = Astro.url.searchParams.get('tool');
const tool: Tool = (VALID_TOOLS as readonly string[]).includes(toolParam ?? '')
  ? (toolParam as Tool)
  : 'gauge';

const toolTabs = [
  { key: 'gauge', label: 'Strikkfasthet', href: '/studio/tools?tool=gauge' },
  { key: 'yardage', label: 'Garnforbruk', href: '/studio/tools?tool=yardage' },
  { key: 'evenly', label: 'Felling/økning', href: '/studio/tools?tool=evenly' },
  { key: 'ruler', label: 'Linjal', href: '/studio/tools?tool=ruler' },
  { key: 'needles', label: 'Pinner', href: '/studio/tools?tool=needles' },
];
---

<StudioLayout title="Verktøy — Littles and Me" lang="nb">
  <h1 class="font-serif text-3xl sm:text-4xl mb-3">Verktøy</h1>
  <p class="text-charcoal/60 mb-6 max-w-2xl">
    Praktiske kalkulatorer for å hjelpe deg fra plan til ferdig plagg. Alt regner lokalt i nettleseren — ingenting lagres eller sendes.
  </p>

  <StudioSubNav items={toolTabs} active={tool} variant="inline" />

  <div>

    <!-- Strikkfasthet -->
    <section data-verktoy-tool="gauge" hidden={tool !== 'gauge'} class="bg-white rounded-3xl p-6 sm:p-8 border border-sage-500/10">
      <h2 class="font-serif text-2xl mb-2">Strikkfasthet</h2>
      <p class="text-sm text-charcoal/55 mb-6">Regn ut hvor mange masker du trenger for å få riktig bredde.</p>
      <form class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end" data-gauge>
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">
            Masker pr 10 cm
          </label>
          <input
            type="number"
            name="stitches"
            min="1"
            step="0.5"
            value="22"
            class="w-full bg-linen rounded-xl px-3 py-2.5 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500"
          />
        </div>
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">
            Ønsket bredde (cm)
          </label>
          <input
            type="number"
            name="width"
            min="1"
            step="0.5"
            value="50"
            class="w-full bg-linen rounded-xl px-3 py-2.5 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500"
          />
        </div>
        <div class="bg-sage-100 rounded-xl px-4 py-3">
          <p class="text-[10px] font-bold uppercase tracking-widest text-sage-900 mb-1">Du trenger</p>
          <p class="font-serif text-3xl text-sage-900" data-gauge-result>110</p>
          <p class="text-xs text-sage-900/70">masker</p>
        </div>
      </form>
      <p class="text-xs text-charcoal/45 mt-4">Tips: Strikk alltid en prøvelapp først. Strikkfastheten endrer seg med garn, pinner og hvor stramt du strikker.</p>
    </section>

    <!-- Garnforbruk -->
    <section data-verktoy-tool="yardage" hidden={tool !== 'yardage'} class="bg-white rounded-3xl p-6 sm:p-8 border border-sage-500/10">
      <h2 class="font-serif text-2xl mb-2">Garnforbruk</h2>
      <p class="text-sm text-charcoal/55 mb-6">Anslag basert på plaggtype og str. Kan variere med ±20 %.</p>

      <form class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end" data-yardage>
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">
            Plagg
          </label>
          <select name="garment" class="w-full bg-linen rounded-xl px-3 py-2.5 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500">
            <option value="hat">Lue</option>
            <option value="mittens">Votter (par)</option>
            <option value="socks">Sokker (par)</option>
            <option value="scarf">Skjerf</option>
            <option value="cardigan_kid" selected>Genser/cardigan, barn</option>
            <option value="cardigan_adult">Genser/cardigan, voksen</option>
            <option value="blanket">Babyteppe</option>
          </select>
        </div>
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">
            Størrelse / alder
          </label>
          <select name="size" class="w-full bg-linen rounded-xl px-3 py-2.5 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500">
            <option value="0">0–6 mnd</option>
            <option value="1">1 år</option>
            <option value="2" selected>2 år</option>
            <option value="4">4 år</option>
            <option value="6">6 år</option>
            <option value="8">8 år</option>
            <option value="adult_s">Voksen S</option>
            <option value="adult_m">Voksen M</option>
            <option value="adult_l">Voksen L</option>
          </select>
        </div>
        <div class="bg-sage-100 rounded-xl px-4 py-3">
          <p class="text-[10px] font-bold uppercase tracking-widest text-sage-900 mb-1">Forbruk ca.</p>
          <p class="font-serif text-3xl text-sage-900" data-yardage-grams>250 g</p>
          <p class="text-xs text-sage-900/70" data-yardage-meters>· 580 m</p>
        </div>
      </form>
    </section>

    <!-- Felling og økning -->
    <section data-verktoy-tool="evenly" hidden={tool !== 'evenly'} class="bg-white rounded-3xl p-6 sm:p-8 border border-sage-500/10">
      <h2 class="font-serif text-2xl mb-2">Felling og økning</h2>
      <p class="text-sm text-charcoal/55 mb-6">Fordel fellingene eller økningene jevnt over et antall rader.</p>
      <form class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end mb-6" data-evenly>
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">Maskeantall nå</label>
          <input
            type="number"
            name="current"
            min="1"
            step="1"
            value="120"
            class="w-full bg-linen rounded-xl px-3 py-2.5 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500"
          />
        </div>
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">Ønsket antall</label>
          <input
            type="number"
            name="target"
            min="1"
            step="1"
            value="80"
            class="w-full bg-linen rounded-xl px-3 py-2.5 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500"
          />
        </div>
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-2">Rader til disp.</label>
          <input
            type="number"
            name="rows"
            min="1"
            step="1"
            value="40"
            class="w-full bg-linen rounded-xl px-3 py-2.5 text-base border border-sage-500/15 focus:outline-none focus:border-sage-500"
          />
        </div>
      </form>
      <div class="bg-sage-100 rounded-xl p-4">
        <p class="font-serif text-lg text-sage-900 mb-1" data-evenly-summary>—</p>
        <p class="text-xs text-sage-900/70" data-evenly-detail></p>
        <p class="text-xs text-sage-900/70 mt-2 break-words" data-evenly-rows></p>
      </div>
      <p class="text-xs text-charcoal/45 mt-4">Tips: Plasser felling/økning symmetrisk på begge sider for raglan eller A‑form. Skriv ut rad‑listen og kryss av etter hvert.</p>
    </section>

    <!-- Linjal -->
    <section data-verktoy-tool="ruler" hidden={tool !== 'ruler'} class="bg-white rounded-3xl p-6 sm:p-8 border border-sage-500/10">
      <h2 class="font-serif text-2xl mb-2">Linjal</h2>
      <p class="text-sm text-charcoal/55 mb-6">
        Mål prøvelappen rett på skjermen. Kalibrer én gang ved å holde et bankkort mot skjermen og justere bredden under.
      </p>

      <div class="bg-linen rounded-2xl p-6 mb-6">
        <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55 mb-3">Kalibrering — bankkort (85,6 mm)</p>
        <div class="mb-4 flex justify-center">
          <div data-ruler-card class="bg-sage-500/15 border border-sage-500/40 rounded-md flex items-center justify-center text-xs text-charcoal/60" style="height: 54px;">
            Hold kortet ditt her
          </div>
        </div>
        <div class="flex items-center gap-3">
          <button type="button" data-ruler-narrow class="text-xs font-medium text-charcoal/70 hover:text-terracotta-500 px-2 py-1">−</button>
          <input
            type="range"
            data-ruler-slider
            min="2.5"
            max="6"
            step="0.01"
            value="3.78"
            class="flex-1 accent-sage-900"
            aria-label="Juster kalibrering"
          />
          <button type="button" data-ruler-wide class="text-xs font-medium text-charcoal/70 hover:text-terracotta-500 px-2 py-1">+</button>
        </div>
        <div class="flex items-center justify-between mt-3">
          <p class="text-xs text-charcoal/55"><span data-ruler-pxpmm>3,78</span> px / mm</p>
          <button type="button" data-ruler-save class="text-[10px] font-bold uppercase tracking-wider text-sage-900 hover:text-terracotta-500">Lagre kalibrering</button>
        </div>
        <p class="text-[10px] text-charcoal/45 mt-2" data-ruler-savemsg></p>
      </div>

      <div class="overflow-x-auto -mx-2 px-2 pb-2">
        <div data-ruler class="relative bg-linen rounded-md" style="height: 70px; width: 100%;"></div>
      </div>
      <p class="text-xs text-charcoal/45 mt-4">
        Linjalen tegnes i centimeter og millimeter etter kalibreringen din. Tips: Strikk en lapp på minst 12 × 12 cm og bløtlegg den før du måler.
      </p>
    </section>

    <!-- Pinnestørrelse -->
    <section data-verktoy-tool="needles" hidden={tool !== 'needles'} class="bg-white rounded-3xl p-6 sm:p-8 border border-sage-500/10">
      <h2 class="font-serif text-2xl mb-2">Pinnestørrelser</h2>
      <p class="text-sm text-charcoal/55 mb-6">Konverteringstabell mellom metrisk, US og UK.</p>
      <div class="overflow-x-auto -mx-2">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-[10px] font-bold uppercase tracking-widest text-charcoal/55 border-b border-sage-500/15">
              <th class="text-left py-3 px-2">Metrisk (mm)</th>
              <th class="text-left py-3 px-2">US</th>
              <th class="text-left py-3 px-2">UK</th>
            </tr>
          </thead>
          <tbody>
            {needles.map((n) => (
              <tr class="border-b border-sage-500/10">
                <td class="py-2 px-2 font-medium">{n.metric}</td>
                <td class="py-2 px-2 text-charcoal/70">{n.us}</td>
                <td class="py-2 px-2 text-charcoal/70">{n.uk}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</StudioLayout>

<script>
  import { init } from "../../lib/client/controllers/studio-tools";
  import { registerController } from "../../lib/client/dom";
  registerController(init);
</script>
