---
import StudioLayout from '../../../../layouts/StudioLayout.astro';
import { getCurrentUser } from '../../../../lib/auth';
import { createServerSupabase } from '../../../../lib/supabase';

const user = await getCurrentUser({ request: Astro.request, cookies: Astro.cookies });
if (!user) return Astro.redirect('/logg-inn?next=/studio/marked/meldinger');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });

const { data: conversations } = await supabase
  .from('marketplace_conversations')
  .select(`
    id, updated_at, listing_id, buyer_id, seller_id,
    listings!inner(title, hero_photo_path),
    marketplace_messages(body, sender_id, created_at)
  `)
  .or(`buyer_id.eq.${user.id},seller_id.eq.${user.id}`)
  .order('updated_at', { ascending: false })
  .limit(50);

const profileIds = new Set<string>();
for (const c of conversations ?? []) {
  profileIds.add(c.buyer_id);
  profileIds.add(c.seller_id);
}
const { data: profiles } = profileIds.size > 0
  ? await supabase
      .from('profiles')
      .select('id, display_name')
      .in('id', [...profileIds])
  : { data: [] };
const profileMap = new Map((profiles ?? []).map((p) => [p.id, p.display_name]));

function otherName(conv: { buyer_id: string; seller_id: string }) {
  const otherId = conv.buyer_id === user!.id ? conv.seller_id : conv.buyer_id;
  return profileMap.get(otherId) ?? 'Anonym';
}

function lastMessage(conv: { marketplace_messages: { body: string; created_at: string }[] }) {
  const msgs = conv.marketplace_messages ?? [];
  if (msgs.length === 0) return '';
  const sorted = msgs.sort((a, b) => b.created_at.localeCompare(a.created_at));
  const text = sorted[0].body;
  return text.length > 80 ? text.slice(0, 80) + '…' : text;
}
---

<StudioLayout title="Meldinger — Marked" lang="nb">
  <div class="max-w-2xl">
    <nav class="text-xs text-charcoal/50 mb-4">
      <a href="/studio/marked" class="hover:text-charcoal transition-colors">Marked</a>
      <span class="mx-2">/</span>
      <span>Meldinger</span>
    </nav>
    <h1 class="font-serif text-3xl sm:text-4xl mb-8">Meldinger</h1>

    {(!conversations || conversations.length === 0) ? (
      <div class="bg-white rounded-3xl p-10 text-center border border-sage-500/10">
        <p class="text-charcoal/55 text-sm">Ingen meldinger ennå.</p>
      </div>
    ) : (
      <ul class="space-y-2">
        {conversations.map((c) => (
          <li>
            <a
              href={`/studio/marked/meldinger/${c.id}`}
              class="block bg-white rounded-2xl p-4 border border-sage-500/10 hover:border-sage-500/30 transition-colors"
            >
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-1">
                    {(c.listings as any)?.title}
                  </p>
                  <p class="font-medium">{otherName(c)}</p>
                  <p class="text-sm text-charcoal/55 truncate mt-1">{lastMessage(c)}</p>
                </div>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-charcoal/40 shrink-0 mt-2">
                  <path d="m9 18 6-6-6-6" />
                </svg>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</StudioLayout>
