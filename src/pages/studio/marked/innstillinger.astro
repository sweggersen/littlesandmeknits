---
import StudioLayout from '../../../layouts/StudioLayout.astro';
import { createServerSupabase } from '../../../lib/supabase';
import { getCurrentUser } from '../../../lib/auth';

const user = await getCurrentUser({ request: Astro.request, cookies: Astro.cookies });
if (!user) return Astro.redirect('/logg-inn?next=/studio/marked/innstillinger');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });
const { data: knitter } = await supabase
  .from('knitter_profiles')
  .select('user_id, slug, availability, stripe_account_id, stripe_charges_enabled, stripe_payouts_enabled, mva_registered, org_number')
  .eq('user_id', user.id)
  .maybeSingle();

const justReturned = Astro.url.searchParams.get('return') === '1';
const needsConnect = Astro.url.searchParams.get('need_connect') === '1';
const isReady = !!knitter?.stripe_charges_enabled;
---

<StudioLayout title="Innstillinger — Marked" lang="nb">
  <div class="max-w-2xl">
    <nav class="text-xs text-charcoal/50 mb-4">
      <a href="/studio/marked" class="hover:text-charcoal transition-colors">Marked</a>
      <span class="mx-2">/</span>
      <span>Innstillinger</span>
    </nav>
    <h1 class="font-serif text-3xl sm:text-4xl mb-8">Innstillinger</h1>

    {needsConnect && (
      <div class="bg-terracotta-500/10 text-terracotta-500 rounded-2xl p-4 mb-6 text-sm">
        Du må fullføre Stripe-oppsettet før du kan publisere annonser.
      </div>
    )}
    {justReturned && isReady && (
      <div class="bg-sage-100 text-sage-900 rounded-2xl p-4 mb-6 text-sm">
        Stripe-oppsettet er fullført. Du kan publisere annonser nå.
      </div>
    )}

    <section class="bg-white rounded-3xl p-6 sm:p-8 border border-sage-500/10 mb-6">
      <h2 class="font-serif text-xl mb-2">Utbetalinger (Stripe Connect)</h2>
      <p class="text-sm text-charcoal/70 mb-5">
        Vi bruker Stripe Connect for å betale ut til kontoen din.
        Pengene holdes hos plattformen til kjøper bekrefter at de har
        mottatt varen.
      </p>

      {!knitter?.stripe_account_id ? (
        <form method="post" action="/api/stripe/connect/onboard">
          <button
            type="submit"
            class="bg-charcoal text-linen px-6 py-3 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors"
          >
            Sett opp Stripe-konto
          </button>
        </form>
      ) : (
        <div class="space-y-3">
          <ul class="space-y-2 text-sm">
            <li class="flex items-center justify-between">
              <span class="text-charcoal/65">Kan motta betalinger</span>
              <span class={knitter.stripe_charges_enabled ? 'text-sage-900' : 'text-terracotta-500'}>
                {knitter.stripe_charges_enabled ? 'Ja' : 'Nei'}
              </span>
            </li>
            <li class="flex items-center justify-between">
              <span class="text-charcoal/65">Kan motta utbetalinger</span>
              <span class={knitter.stripe_payouts_enabled ? 'text-sage-900' : 'text-terracotta-500'}>
                {knitter.stripe_payouts_enabled ? 'Ja' : 'Nei'}
              </span>
            </li>
          </ul>
          {!isReady && (
            <form method="post" action="/api/stripe/connect/onboard" class="pt-2">
              <button
                type="submit"
                class="bg-charcoal text-linen px-5 py-2.5 rounded-full text-sm font-medium hover:bg-terracotta-500 transition-colors"
              >
                Fortsett oppsettet
              </button>
            </form>
          )}
        </div>
      )}
    </section>

    <section class="bg-white rounded-3xl p-6 sm:p-8 border border-sage-500/10">
      <h2 class="font-serif text-xl mb-2">Skatt (MVA)</h2>
      <p class="text-sm text-charcoal/70 mb-3">
        Hobbysalg under 50 000 NOK i året er normalt ikke MVA-pliktig.
        Du er selv ansvarlig for å oppgi inntekten korrekt.
      </p>
      <p class="text-xs text-charcoal/55">
        Status: {knitter?.mva_registered ? `MVA-registrert${knitter.org_number ? ` (org. ${knitter.org_number})` : ''}` : 'Ikke MVA-registrert'}
      </p>
    </section>
  </div>
</StudioLayout>
