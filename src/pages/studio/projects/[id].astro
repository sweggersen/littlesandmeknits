---
import StudioLayout from '../../../layouts/StudioLayout.astro';
import StudioBackLink from '../../../components/StudioBackLink.astro';
import ProgressSection from '../../../components/project/ProgressSection.astro';
import YarnSection from '../../../components/project/YarnSection.astro';
import LogsSection from '../../../components/project/LogsSection.astro';
import ShareSection from '../../../components/project/ShareSection.astro';
import { createServerSupabase } from '../../../lib/supabase';
import { getEntry } from 'astro:content';
import { projectPhotoUrl } from '../../../lib/storage';

const { id } = Astro.params;
if (!id) return Astro.redirect('/studio/projects');

const supabase = createServerSupabase({ request: Astro.request, cookies: Astro.cookies });

type ProjectRow = {
  id: string;
  title: string;
  summary: string | null;
  status: 'planning' | 'active' | 'finished' | 'frogged';
  recipient: string | null;
  target_size: string | null;
  yarn: string | null;
  needles: string | null;
  pattern_slug: string | null;
  pattern_external: string | null;
  hero_photo_path: string | null;
  started_at: string | null;
  finished_at: string | null;
  created_at: string;
  updated_at: string;
  public_slug: string | null;
  target_rows: number | null;
  current_rows: number | null;
  commission_offer_id: string | null;
};

const { data: project, error } = await supabase
  .from('projects')
  .select('id, title, summary, status, recipient, target_size, yarn, needles, pattern_slug, pattern_external, hero_photo_path, started_at, finished_at, created_at, updated_at, public_slug, target_rows, current_rows, commission_offer_id')
  .eq('id', id)
  .maybeSingle();

if (error || !project) {
  return Astro.redirect('/studio/projects');
}

const p = project as ProjectRow;

let commissionInfo: { requestId: string; requestTitle: string; buyerName: string; priceNok: number } | null = null;
if (p.commission_offer_id) {
  const { data: offerData } = await supabase
    .from('commission_offers')
    .select('price_nok, commission_requests!commission_offers_request_id_fkey(id, title, profiles!commission_requests_buyer_id_fkey(display_name))')
    .eq('id', p.commission_offer_id)
    .maybeSingle();
  if (offerData) {
    const req = (offerData as any).commission_requests;
    commissionInfo = {
      requestId: req?.id,
      requestTitle: req?.title ?? '',
      buyerName: req?.profiles?.display_name ?? 'Bestiller',
      priceNok: offerData.price_nok,
    };
  }
}

type LogRow = {
  id: string;
  body: string;
  log_date: string;
  photos: string[];
  rows_at: number | null;
  created_at: string;
};

const { data: logsData } = await supabase
  .from('project_logs')
  .select('id, body, log_date, photos, rows_at, created_at')
  .eq('project_id', id)
  .order('log_date', { ascending: false })
  .order('created_at', { ascending: false });

const logs = (logsData ?? []) as LogRow[];

const targetRows = p.target_rows ?? null;
const currentRows = p.current_rows ?? null;
const progressPct = targetRows && targetRows > 0 && currentRows !== null
  ? Math.min(100, Math.round((currentRows / targetRows) * 100))
  : null;

// Linked yarns from the stash (with grams used + deduction state).
type ProjectYarnLink = {
  id: string;
  yarn_id: string;
  grams_used: number;
  deducted_at: string | null;
  yarns: {
    brand: string;
    name: string;
    color: string | null;
    total_grams: number | null;
  } | null;
};
const { data: yarnLinksData } = await supabase
  .from('project_yarns')
  .select('id, yarn_id, grams_used, deducted_at, yarns(brand, name, color, total_grams)')
  .eq('project_id', id)
  .order('created_at', { ascending: true });
const yarnLinks = (yarnLinksData ?? []) as ProjectYarnLink[];

// All yarns in the user's stash for the picker.
type StashYarnRow = {
  id: string;
  brand: string;
  name: string;
  color: string | null;
  total_grams: number | null;
};
const { data: stashData } = await supabase
  .from('yarns')
  .select('id, brand, name, color, total_grams')
  .order('brand', { ascending: true })
  .order('name', { ascending: true });
const stash = (stashData ?? []) as StashYarnRow[];
const linkedYarnIds = new Set(yarnLinks.map((l) => l.yarn_id));
const availableStash = stash.filter((y) => !linkedYarnIds.has(y.id));

const patternEntry = p.pattern_slug ? await getEntry('patterns', p.pattern_slug) : null;
const heroUrl = projectPhotoUrl(p.hero_photo_path);

const statusLabels = {
  planning: 'Planlegges',
  active: 'I gang',
  finished: 'Ferdig',
  frogged: 'Røket opp',
} as const;

const statusClass = {
  planning: 'bg-oatmeal text-charcoal/70',
  active: 'bg-sage-100 text-sage-900',
  finished: 'bg-terracotta-500/10 text-terracotta-500',
  frogged: 'bg-charcoal/10 text-charcoal/60',
} as const;

// Inline-style palette for the offscreen share-card scaffold (Tailwind classes
// can't be relied on for the 1080×1350 / 1080×1920 dimensions, so we hardcode
// the brand tones the satori version used to produce).
const statusPillBg = {
  planning: '#E8DFD0',
  active: '#E8EFE3',
  finished: '#FBEAE3',
  frogged: '#E5E3DD',
} as const;
const statusPillFg = {
  planning: '#5B544A',
  active: '#4A5A3F',
  finished: '#C76D4E',
  frogged: '#6F6A60',
} as const;

const today = new Date().toISOString().slice(0, 10);

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://www.littlesandmeknits.com';
const shareUrl = p.public_slug ? `${siteUrl}/p/${p.public_slug}` : null;
const cardSummary = p.summary ?? null;
const cardMeta = [p.recipient && `For ${p.recipient}`, p.yarn].filter(Boolean).join(' · ');

// User profile bits used by the share card + caption builder.
const profileUser = Astro.locals.user;  // middleware-gated route, but typed as nullable
const profileMeta = (profileUser?.user_metadata ?? {}) as {
  display_name?: string;
  instagram_handle?: string;
};
const igHandle = profileMeta.instagram_handle?.replace(/^@+/, '').trim() || null;
const designerLine = igHandle ? `@${igHandle}` : 'Littles and Me';
---

<StudioLayout title={`${p.title} — Littles and Me`} lang="nb">
  <StudioBackLink href="/studio/projects">Prosjekter</StudioBackLink>

  {commissionInfo && (
    <div class="bg-terracotta-500/5 border border-terracotta-500/20 rounded-2xl p-4 mb-6 flex items-center justify-between gap-4 flex-wrap">
      <div class="min-w-0">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-[10px] font-bold uppercase tracking-widest text-terracotta-500">Oppdrag</span>
          <span class="text-[10px] text-charcoal/40">·</span>
          <span class="font-mono tabular-nums text-xs text-charcoal/70">{commissionInfo.priceNok} NOK</span>
        </div>
        <p class="text-sm text-charcoal/70">
          Strikkes for <span class="font-medium text-charcoal">{commissionInfo.buyerName}</span> — bilder og logger her vises også til kjøperen.
        </p>
      </div>
      <div class="flex items-center gap-3 shrink-0">
        <a href={`/market/commissions/${commissionInfo.requestId}/prosjekt?preview=1`} target="_blank" rel="noopener" class="text-xs font-medium text-terracotta-500 hover:text-terracotta-600 transition-colors">
          Forhåndsvis som {commissionInfo.buyerName} ↗
        </a>
        <a href={`/market/commissions/${commissionInfo.requestId}`} class="text-xs text-charcoal/45 hover:text-charcoal/70 transition-colors">
          Se forespørsel →
        </a>
      </div>
    </div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main column -->
    <div class="lg:col-span-2">
      {heroUrl && (
        <div class="aspect-[16/10] rounded-3xl overflow-hidden bg-oatmeal mb-6 border border-sage-500/10">
          <img src={heroUrl} alt={p.title} class="w-full h-full object-cover" loading="lazy" />
        </div>
      )}

      <header class="flex items-start justify-between gap-4 mb-6">
        <div class="flex-1 min-w-0">
          <span class={`text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full ${statusClass[p.status]}`}>
            {statusLabels[p.status]}
          </span>
          <h1 class="font-serif text-3xl sm:text-4xl mt-3 leading-tight">{p.title}</h1>
          {p.summary && (
            <p class="text-charcoal/65 mt-3 leading-relaxed">{p.summary}</p>
          )}
        </div>
      </header>

      <ProgressSection projectId={p.id} currentRows={currentRows} targetRows={targetRows} progressPct={progressPct} />

      <YarnSection projectId={p.id} status={p.status} yarnLinks={yarnLinks} availableStash={availableStash} stash={stash} />

      <LogsSection projectId={p.id} today={today} logs={logs} />
    </div>

    <!-- Sidebar -->
    <aside class="lg:col-span-1 space-y-5">
      <!-- Details -->
      <div class="bg-white rounded-3xl p-6 border border-sage-500/10">
        <h2 class="font-serif text-lg mb-4">Detaljer</h2>
        <dl class="space-y-3 text-sm">
          {p.recipient && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">For</dt>
              <dd>{p.recipient}</dd>
            </div>
          )}
          {patternEntry && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Oppskrift</dt>
              <dd>
                <a href={`/patterns/${p.pattern_slug}`} class="text-terracotta-500 hover:underline" target="_blank" rel="noopener">
                  {patternEntry.data.title.nb}
                </a>
              </dd>
            </div>
          )}
          {!patternEntry && p.pattern_external && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Oppskrift</dt>
              <dd>{p.pattern_external}</dd>
            </div>
          )}
          {p.target_size && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Størrelse</dt>
              <dd>{p.target_size}</dd>
            </div>
          )}
          {p.yarn && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Garn</dt>
              <dd>{p.yarn}</dd>
            </div>
          )}
          {p.needles && (
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Pinner</dt>
              <dd>{p.needles}</dd>
            </div>
          )}
          <div>
            <dt class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 mb-0.5">Opprettet</dt>
            <dd class="text-charcoal/60">{new Date(p.created_at).toLocaleDateString('nb-NO')}</dd>
          </div>
        </dl>

        <div class="mt-6 pt-6 border-t border-sage-500/10">
          <form method="post" action={`/api/projects/${p.id}/status`}>
            <label class="text-[10px] font-bold uppercase tracking-widest text-charcoal/45 block mb-2">
              Status
            </label>
            <div class="flex gap-2">
              <select
                name="status"
                class="flex-1 bg-linen rounded-xl px-3 py-2 text-sm border border-sage-500/15"
              >
                <option value="planning" selected={p.status === 'planning'}>Planlegges</option>
                <option value="active" selected={p.status === 'active'}>I gang</option>
                <option value="finished" selected={p.status === 'finished'}>Ferdig</option>
                <option value="frogged" selected={p.status === 'frogged'}>Røket opp</option>
              </select>
              <button
                type="submit"
                class="bg-primary text-primary-fg px-3 rounded-xl text-xs font-medium hover:bg-primary-hover transition-colors"
              >
                Lagre
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Hero photo -->
      <div class="bg-white rounded-3xl p-6 border border-sage-500/10">
        <h2 class="font-serif text-lg mb-3">Hovedbilde</h2>
        {heroUrl ? (
          <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-oatmeal mb-3">
            <img src={heroUrl} alt="" class="w-full h-full object-cover" />
          </div>
        ) : (
          <p class="text-xs text-charcoal/50 italic mb-3">Ingen hovedbilde ennå.</p>
        )}
        <form method="post" action={`/api/projects/${p.id}/photo`} enctype="multipart/form-data" class="space-y-2">
          <input
            type="file"
            name="hero_photo"
            accept="image/*"
            class="block w-full text-xs text-charcoal/70 file:mr-3 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-medium file:bg-sage-100 file:text-sage-900 hover:file:bg-sage-500 hover:file:text-linen file:cursor-pointer file:transition-colors"
          />
          <div class="flex gap-2">
            <button
              type="submit"
              class="flex-1 bg-primary text-primary-fg px-3 py-2 rounded-full text-xs font-medium hover:bg-primary-hover transition-colors"
            >
              {heroUrl ? 'Bytt bilde' : 'Last opp'}
            </button>
            {heroUrl && (
              <button
                type="submit"
                formnovalidate
                onclick={`event.preventDefault(); if(confirm('Fjern hovedbilde?')) { this.form.querySelector('input[type=file]').value=''; this.form.submit(); }`}
                class="text-xs text-charcoal/45 hover:text-terracotta-500 transition-colors px-3"
              >
                Fjern
              </button>
            )}
          </div>
        </form>
      </div>

      <ShareSection projectId={p.id} shareUrl={shareUrl} igHandle={igHandle} />

      <form method="post" action={`/api/projects/${p.id}/delete`}>
        <button
          type="submit"
          class="w-full text-xs text-charcoal/40 hover:text-terracotta-500 transition-colors py-2"
          onclick="return confirm('Slett dette prosjektet permanent? Alle logger forsvinner.')"
        >
          Slett prosjekt
        </button>
      </form>
    </aside>
  </div>

  {p.public_slug && (
    <div
      aria-hidden="true"
      data-share-root
      data-share-slug={p.public_slug}
      data-share-title={p.title}
      data-share-summary={p.summary ?? ''}
      data-share-url={shareUrl ?? ''}
      data-share-handle={igHandle ?? ''}
      style="position:fixed; left:-99999px; top:0; pointer-events:none; opacity:1;"
    >
      {/* Feed card 1080×1350 */}
      <div
        data-share-scaffold="feed"
        style={`width:1080px; height:1350px; background:#FAF6F0; font-family:'Inter','Inter Variable',system-ui,sans-serif; display:flex; flex-direction:column;`}
      >
        <div
          style={`width:100%; height:780px; background-color:#E8DFD0; ${heroUrl ? `background-image:url('${heroUrl}'); background-size:cover; background-position:center;` : ''}`}
        ></div>
        <div style="flex:1; padding:60px 80px; display:flex; flex-direction:column; justify-content:space-between;">
          <div style="display:flex; flex-direction:column; gap:20px;">
            <span style={`align-self:flex-start; font-size:20px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; padding:10px 22px; border-radius:999px; background:${statusPillBg[p.status]}; color:${statusPillFg[p.status]};`}>
              {statusLabels[p.status]}
            </span>
            <div style="font-family:'Fraunces','Fraunces Variable',serif; font-size:76px; font-weight:500; line-height:1.05; color:#2C2A26; letter-spacing:-0.01em;">{p.title}</div>
            {cardSummary && (
              <div style="font-size:24px; color:rgba(44,42,38,0.7); line-height:1.4;">
                {cardSummary.length > 110 ? cardSummary.slice(0, 107) + '…' : cardSummary}
              </div>
            )}
            {cardMeta && (
              <div style="font-size:22px; color:rgba(44,42,38,0.55);">{cardMeta}</div>
            )}
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center; padding-top:24px; border-top:1px solid rgba(0,0,0,0.08);">
            <div style="font-family:'Fraunces','Fraunces Variable',serif; font-size:28px; color:#2C2A26; font-weight:500;">Littles and Me</div>
            <div style="font-size:18px; color:#C76D4E; font-weight:600; letter-spacing:0.14em;">
              {igHandle ? `@${igHandle}` : `littlesandmeknits.com/p/${p.public_slug}`}
            </div>
          </div>
        </div>
      </div>

      {/* Story card 1080×1920 */}
      <div
        data-share-scaffold="story"
        style={`width:1080px; height:1920px; background-color:#2C2A26; ${heroUrl ? `background-image:url('${heroUrl}'); background-size:cover; background-position:center;` : ''} font-family:'Inter','Inter Variable',system-ui,sans-serif; color:#FAF6F0; position:relative;`}
      >
        <div style="position:absolute; inset:0; background:linear-gradient(180deg, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0) 22%, rgba(0,0,0,0) 55%, rgba(0,0,0,0.78) 100%); padding:120px 90px; display:flex; flex-direction:column; justify-content:space-between;">
          <div style="text-align:center; font-family:'Fraunces','Fraunces Variable',serif; font-style:italic; font-size:28px; letter-spacing:0.22em; text-transform:uppercase; opacity:0.92;">Littles and Me</div>
          <div style="display:flex; flex-direction:column; gap:28px; align-items:center; text-align:center;">
            <span style="background:#C76D4E; color:#FAF6F0; font-size:22px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; padding:12px 26px; border-radius:999px;">
              {statusLabels[p.status]}
            </span>
            <div style="font-family:'Fraunces','Fraunces Variable',serif; font-size:108px; font-weight:500; line-height:1.04; letter-spacing:-0.01em; max-width:900px;">{p.title}</div>
            {cardSummary && (
              <div style="font-family:'Fraunces','Fraunces Variable',serif; font-style:italic; font-size:32px; line-height:1.4; opacity:0.9; max-width:780px;">
                {cardSummary.length > 130 ? cardSummary.slice(0, 127) + '…' : cardSummary}
              </div>
            )}
            <div style="margin-top:20px; padding-top:24px; border-top:1px solid rgba(255,255,255,0.3); font-size:22px; letter-spacing:0.18em; opacity:0.85;">
              {igHandle ? `@${igHandle}` : `littlesandmeknits.com/p/${p.public_slug}`}
            </div>
          </div>
        </div>
      </div>
    </div>
  )}
</StudioLayout>

<script>
  import { init } from "../../../lib/client/controllers/project-share";
  import { registerController } from "../../../lib/client/dom";
  registerController(init);
</script>
