---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, type Lang } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const { title, description, lang: langProp } = Astro.props;
const lang = langProp ?? getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang === 'nb' ? 'nb-NO' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description ?? ''} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-linen text-charcoal flex flex-col">
    <Navbar lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
