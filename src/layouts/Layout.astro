---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import StrikketorgetNav from '../components/StrikketorgetNav.astro';
import Footer from '../components/Footer.astro';
import StrikketorgetFooter from '../components/StrikketorgetFooter.astro';
import CookieBanner from '../components/CookieBanner.astro';
import InterestForm from '../components/InterestForm.astro';
import { getLangFromUrl, type Lang } from '../lib/i18n';

const isStrikketorget = Astro.locals.isStrikketorget ?? false;

// Pre-launch lock: on strikketorget.no, render every page but blur the
// content and overlay the interest form so the public can SEE what's
// coming without being able to interact yet. Bypass when the visitor
// has the login_invite cookie (set by /login?invite=<LOGIN_INVITE_KEY>).
const hasInvite = Astro.cookies.get('login_invite')?.value === '1';
// Localhost / 127.0.0.1 always skip the prelaunch lock so dev isn't gated.
const isLocalhostHost =
  Astro.url.hostname === 'localhost' || Astro.url.hostname === '127.0.0.1';
const showLockOverlay =
  isStrikketorget
  && !hasInvite
  && !isLocalhostHost
  && !Astro.url.pathname.startsWith('/login')
  && !Astro.url.pathname.startsWith('/auth/');

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  /** Absolute or root-relative image URL for OG / Twitter previews. */
  ogImage?: string;
  /** Mark admin/dev surfaces noindex so they don't end up in search. */
  noindex?: boolean;
}

const { title, description, lang: langProp, ogImage, noindex } = Astro.props;
const lang = langProp ?? getLangFromUrl(Astro.url);

// Compose a search-friendly title: append the brand if the page didn't
// already include it. Mirrors what Google shows in result snippets.
const titleSeparator = ' · ';
const hasBrand = /Strikketorget|Littles and Me/i.test(title);
const fullTitle = hasBrand ? title : `${title}${titleSeparator}Strikketorget`;

// Default description nudges Norwegian queries about handknit children's
// clothing (the platform's core).
const metaDescription = description
  ?? 'Strikketorget er Norges marked for håndstrikkede plagg, brukt og nytt. Kjøp og selg trygt med Trygg betaling, eller bestill et plagg fra en strikker.';

const SITE = 'https://littlesandmeknits.com';
const canonical = new URL(Astro.url.pathname, SITE).toString();
const ogImageUrl = ogImage
  ? new URL(ogImage, SITE).toString()
  : `${SITE}/strikketorget-icon.svg`;

const inMarketSession = Astro.locals.inMarketSession ?? false;
// Branding follows the *section* the user is in, not the domain. After
// consolidating all auth routes onto strikketorget.no, host alone can't
// distinguish Strikkestua (/studio) from Strikketorget (/market).
const path = Astro.url.pathname;
const isStudioPath = path.startsWith('/studio');
const isMarket = !isStudioPath && (
  path.startsWith('/market')
  || path.startsWith('/inbox')
  || inMarketSession
  // On strikketorget.no, the bare domain and other unscoped routes default
  // to marketplace branding. /studio above takes priority.
  || (isStrikketorget && path === '/')
);
const faviconHref = isMarket ? '/strikketorget-favicon.svg' : '/favicon.svg';
// ?embed=1 renders the page without nav/footer/tab-bar — used by moderator
// iframes (reports/disputes detail) that want a clean content preview.
const isEmbed = Astro.url.searchParams.get('embed') === '1';
---

<!doctype html>
<html lang={lang === 'nb' ? 'nb-NO' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={metaDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="apple-touch-icon" href={faviconHref} />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#FAF6F0" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Littles" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>

    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {/* Open Graph — for Facebook, Slack, Discord, iMessage previews */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Strikketorget" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={lang === 'nb' ? 'nb_NO' : 'en_US'} />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <ClientRouter />
    <style is:inline>
      ::view-transition-group(*) { animation-duration: 150ms; }

      /* Mobile reveal-on-scroll-up:
         - In the hero (no data-past-anchor): sticky bars visible naturally.
         - Past the search anchor: bars are HIDDEN by default. Only visible
           while the user is actively scrolling up (data-scroll-state="up"). */
      @media (max-width: 639px) {
        [data-hide-on-scroll] {
          will-change: transform;
        }
        body[data-past-anchor="true"] [data-hide-on-scroll] {
          transform: translateY(-240px);
        }
        body[data-past-anchor="true"][data-scroll-state="up"] [data-hide-on-scroll] {
          transform: translateY(0);
        }
      }
    </style>
    <script is:inline>
      // Scroll-direction hide on mobile. Attached once on window so it
      // persists across Astro view transitions (which only swap body).
      (function () {
        if (window.__scrollDirAttached) return;
        window.__scrollDirAttached = true;
        var lastY = 0;
        var ticking = false;
        function update() {
          var b = document.body;
          if (!b) { ticking = false; return; }
          var y = window.scrollY || 0;
          var delta = y - lastY;
          if (y < 120) {
            b.removeAttribute('data-scroll-state');
          } else if (delta > 4) {
            b.setAttribute('data-scroll-state', 'down');
          } else if (delta < -4) {
            b.setAttribute('data-scroll-state', 'up');
          }
          lastY = y;
          ticking = false;
        }
        window.addEventListener('scroll', function () {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(update);
        }, { passive: true });
      })();
    </script>
    <script is:inline>
      // PWA preview mode: visiting any URL with ?pwa=1 (or returning from a
      // page that set it) makes the browser render as if it were in
      // standalone display-mode. Useful for showing the bottom tab bar +
      // collapsed chrome to anyone before they install the app. ?pwa=0
      // clears the flag.
      (function () {
        try {
          var url = new URL(window.location.href);
          var pwa = url.searchParams.get('pwa');
          if (pwa === '1') sessionStorage.setItem('lm-pwa-preview', '1');
          else if (pwa === '0') sessionStorage.removeItem('lm-pwa-preview');
          if (sessionStorage.getItem('lm-pwa-preview') === '1') {
            document.documentElement.classList.add('pwa-preview');
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="min-h-screen bg-linen text-charcoal flex flex-col" data-embed={isEmbed ? '1' : undefined}>
    {!isEmbed && (() => {
      // Variant picks the nav's brand + items + accent.
      //   1. Path identifies a section explicitly -> use it
      //   2. LMK home / about / patterns / projects -> 'home' variant
      //      (these are their own section; prev_section cookie shouldn't
      //      override them, otherwise navigating market -> / keeps the
      //      Strikketorget brand on what is clearly the LMK home).
      //   3. Host is strikketorget.no -> default to Strikketorget
      //   4. Otherwise fall back to prev_section for shared routes
      //      like /login or /profile that lack section identity.
      const path = Astro.url.pathname;
      const isHomeContent =
        path === '/'
        || path.startsWith('/oppskrifter')
        || path.startsWith('/prosjekter')
        || path.startsWith('/p/')
        || path === '/om' || path.startsWith('/om/')
        || path === '/about' || path.startsWith('/about/')
        || path === '/en' || path.startsWith('/en/');
      const prev = Astro.locals.prevSection ?? null;
      let navVariant: 'strikketorget' | 'strikkestua' | 'home';
      if (isStudioPath) navVariant = 'strikkestua';
      else if (isMarket) navVariant = 'strikketorget';
      else if (isHomeContent) navVariant = 'home';
      else if (isStrikketorget) navVariant = 'strikketorget';
      else if (prev === 'studio') navVariant = 'strikkestua';
      else if (prev === 'market') navVariant = 'strikketorget';
      else navVariant = 'home';
      return <StrikketorgetNav variant={navVariant} lang={lang} />;
    })()}
    <main class="flex-1" inert={showLockOverlay ? '' : undefined}>
      <slot />
    </main>
    {!isEmbed && (isMarket ? <StrikketorgetFooter /> : <Footer lang={lang} />)}
    {!isEmbed && <CookieBanner />}

    {showLockOverlay && (
      <div
        class="fixed inset-0 z-[100] bg-linen/30 backdrop-blur-sm flex items-start sm:items-center justify-center overflow-y-auto py-10 px-4"
        aria-modal="true"
        role="dialog"
        data-prelaunch-lock
      >
        <InterestForm />
      </div>
    )}

    <a
      data-pwa-preview-exit
      href="?pwa=0"
      class="fixed left-3 z-[65] hidden bg-primary text-primary-fg px-3 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest shadow-lg hover:bg-primary-hover transition-colors"
      style="bottom: calc(64px + env(safe-area-inset-bottom) + 12px);"
    >
      PWA preview · avslutt
    </a>

    <script>
      // Register the PWA service worker on supported browsers.
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
      // Surface the "exit preview" pill only when the preview class is set.
      if (document.documentElement.classList.contains('pwa-preview')) {
        document.querySelector('[data-pwa-preview-exit]')?.classList.remove('hidden');
      }
    </script>
  </body>
</html>
