---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, type Lang } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const { title, description, lang: langProp } = Astro.props;
const lang = langProp ?? getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang === 'nb' ? 'nb-NO' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description ?? ''} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#FAF6F0" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Littles" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
    <style is:inline>
      ::view-transition-group(*) { animation-duration: 150ms; }
    </style>
    <script is:inline>
      // PWA preview mode: visiting any URL with ?pwa=1 (or returning from a
      // page that set it) makes the browser render as if it were in
      // standalone display-mode. Useful for showing the bottom tab bar +
      // collapsed chrome to anyone before they install the app. ?pwa=0
      // clears the flag.
      (function () {
        try {
          var url = new URL(window.location.href);
          var pwa = url.searchParams.get('pwa');
          if (pwa === '1') sessionStorage.setItem('lm-pwa-preview', '1');
          else if (pwa === '0') sessionStorage.removeItem('lm-pwa-preview');
          if (sessionStorage.getItem('lm-pwa-preview') === '1') {
            document.documentElement.classList.add('pwa-preview');
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="min-h-screen bg-linen text-charcoal flex flex-col">
    <Navbar lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />

    <a
      data-pwa-preview-exit
      href="?pwa=0"
      class="fixed left-3 z-[65] hidden bg-charcoal text-linen px-3 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest shadow-lg hover:bg-terracotta-500 transition-colors"
      style="bottom: calc(64px + env(safe-area-inset-bottom) + 12px);"
    >
      PWA preview · avslutt
    </a>

    <script>
      // Register the PWA service worker on supported browsers.
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
      // Surface the "exit preview" pill only when the preview class is set.
      if (document.documentElement.classList.contains('pwa-preview')) {
        document.querySelector('[data-pwa-preview-exit]')?.classList.remove('hidden');
      }
    </script>
  </body>
</html>
