# Public env vars (build-time, baked into client bundle).
# Copy to `.env.local` for local dev. In CI/CD set as build env vars
# in Cloudflare Workers Builds → Settings → Variables and Secrets → Build env.
#
# These are NOT secrets. The anon key + publishable key are designed to be public.

PUBLIC_SITE_URL="https://www.littlesandmeknits.com"
PUBLIC_SUPABASE_URL=""
PUBLIC_SUPABASE_ANON_KEY=""
PUBLIC_STRIPE_PUBLISHABLE_KEY=""
