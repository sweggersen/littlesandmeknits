{
  "name": "littlesandme",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "supabase start",
    "predev:fresh": "supabase start",
    "dev": "astro dev",
    "dev:fresh": "rm -rf node_modules/.vite && astro dev",
    "db:up": "supabase start",
    "db:down": "supabase stop",
    "build": "astro build && find dist -name '._*' -delete",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy --config dist/server/wrangler.json",
    "deploy:preview": "wrangler versions upload --config dist/server/wrangler.json",
    "test": "vitest run",
    "typecheck": "astro check",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:rls": "PUBLIC_SUPABASE_URL=http://127.0.0.1:54321 PUBLIC_SUPABASE_ANON_KEY=$(supabase status -o env | grep ANON_KEY | cut -d= -f2 | tr -d '\"') SUPABASE_SERVICE_ROLE_KEY=$(supabase status -o env | grep SERVICE_ROLE_KEY | cut -d= -f2 | tr -d '\"') vitest run rls",
    "astro": "astro",
    "db:types": "supabase gen types typescript --linked 2>/dev/null > src/lib/database.types.ts",
    "test:mutation": "stryker run"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.1",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.10",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "stripe": "^22.1.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20260601.1",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
